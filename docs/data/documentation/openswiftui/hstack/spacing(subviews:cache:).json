{"abstract":[{"text":"Returns the preferred spacing values of the composite view.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"spacing"},{"kind":"text","text":"("},{"kind":"externalParam","text":"subviews"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","kind":"typeIdentifier","text":"Subviews","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cache"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa","kind":"typeIdentifier","text":"Cache","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV","kind":"typeIdentifier","text":"ViewSpacing","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"subviews","content":[{"inlineContent":[{"type":"text","text":"A collection of proxy instances that represent the"},{"type":"text","text":" "},{"type":"text","text":"views that the container arranges. You can use the proxies in the"},{"type":"text","text":" "},{"type":"text","text":"collection to get information about the subviews as you determine"},{"type":"text","text":" "},{"type":"text","text":"how much spacing the container prefers around it."}],"type":"paragraph"}]},{"name":"cache","content":[{"inlineContent":[{"type":"text","text":"Optional storage for calculated data that you can share among"},{"type":"text","text":" "},{"type":"text","text":"the methods of your custom layout container. See"},{"type":"text","text":" "},{"type":"codeVoice","code":"makeCache(subviews:)"},{"type":"text","text":" for details."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"anchor":"return-value","text":"Return Value","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"A "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing"},{"type":"text","text":" instance that describes the preferred"},{"type":"text","text":" "},{"type":"text","text":"spacing around the container view."}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement this method to provide custom spacing preferences"},{"type":"text","text":" "},{"type":"text","text":"for a layout container. The value you return affects"},{"type":"text","text":" "},{"type":"text","text":"the spacing around the container, but it doesn’t affect how the"},{"type":"text","text":" "},{"type":"text","text":"container arranges subviews relative to one another inside the"},{"type":"text","text":" "},{"type":"text","text":"container."}]},{"type":"paragraph","inlineContent":[{"text":"Create a custom ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","isActive":true,"type":"reference"},{"text":" instance for your container by","type":"text"},{"text":" ","type":"text"},{"text":"initializing one with default values, and then merging that with","type":"text"},{"text":" ","type":"text"},{"text":"spacing instances of certain subviews. For example, if you define","type":"text"},{"text":" ","type":"text"},{"text":"a basic vertical stack that places subviews in a column, you could","type":"text"},{"text":" ","type":"text"},{"text":"use the spacing preferences of the subview edges that make","type":"text"},{"text":" ","type":"text"},{"text":"contact with the container’s edges:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["extension BasicVStack {","    func spacing(subviews: Subviews, cache: inout ()) -> ViewSpacing {","        var spacing = ViewSpacing()","","        for index in subviews.indices {","            var edges: Edge.Set = [.leading, .trailing]","            if index == 0 { edges.formUnion(.top) }","            if index == subviews.count - 1 { edges.formUnion(.bottom) }","            spacing.formUnion(subviews[index].spacing, edges: edges)","        }","","        return spacing","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the above example, the first and last subviews contribute to the"},{"type":"text","text":" "},{"type":"text","text":"spacing above and below the container, respectively, while all subviews"},{"type":"text","text":" "},{"type":"text","text":"affect the spacing on the leading and trailing edges."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you don’t implement this method, the protocol provides a default"},{"type":"text","text":" "},{"type":"text","text":"implementation that merges the spacing preferences across all subviews on all edges."}]}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/hstack\/spacing(subviews:cache:)"]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"]]},"metadata":{"role":"symbol","remoteSource":{"fileName":"Layout.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Layout.swift#L747"},"title":"spacing(subviews:cache:)","externalID":"s:15OpenSwiftUICore6LayoutPAAE7spacing8subviews5cacheAA11ViewSpacingVAA0D8SubviewsV_5CacheQzztF::SYNTHESIZED::s:15OpenSwiftUICore6HStackV","symbolKind":"method","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUI