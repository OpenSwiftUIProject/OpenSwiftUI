{"kind":"symbol","metadata":{"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Layout.swift#L747","fileName":"Layout.swift"},"symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"spacing"},{"kind":"text","text":"("},{"kind":"externalParam","text":"subviews"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","text":"Subviews"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cache"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa","text":"Cache"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV","text":"ViewSpacing"}],"role":"symbol","extendedModule":"OpenSwiftUICore","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"roleHeading":"Instance Method","title":"spacing(subviews:cache:)","externalID":"s:15OpenSwiftUICore6LayoutPAAE7spacing8subviews5cacheAA11ViewSpacingVAA0D8SubviewsV_5CacheQzztF::SYNTHESIZED::s:15OpenSwiftUICore6HStackV"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spacing","kind":"identifier"},{"text":"(","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews","text":"Subviews","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa"},{"text":", ","kind":"text"},{"text":"cache","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache","text":"Cache","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa"},{"text":") -> ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","text":"ViewSpacing","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV"}]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A collection of proxy instances that represent the"},{"type":"text","text":" "},{"type":"text","text":"views that the container arranges. You can use the proxies in the"},{"type":"text","text":" "},{"type":"text","text":"collection to get information about the subviews as you determine"},{"type":"text","text":" "},{"type":"text","text":"how much spacing the container prefers around it."}]}],"name":"subviews"},{"content":[{"inlineContent":[{"type":"text","text":"Optional storage for calculated data that you can share among"},{"type":"text","text":" "},{"type":"text","text":"the methods of your custom layout container. See"},{"type":"text","text":" "},{"type":"codeVoice","code":"makeCache(subviews:)"},{"type":"text","text":" for details."}],"type":"paragraph"}],"name":"cache"}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","type":"reference"},{"text":" instance that describes the preferred","type":"text"},{"text":" ","type":"text"},{"text":"spacing around the container view.","type":"text"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Implement this method to provide custom spacing preferences"},{"type":"text","text":" "},{"type":"text","text":"for a layout container. The value you return affects"},{"type":"text","text":" "},{"type":"text","text":"the spacing around the container, but it doesn’t affect how the"},{"type":"text","text":" "},{"type":"text","text":"container arranges subviews relative to one another inside the"},{"type":"text","text":" "},{"type":"text","text":"container."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Create a custom "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","isActive":true},{"type":"text","text":" instance for your container by"},{"type":"text","text":" "},{"type":"text","text":"initializing one with default values, and then merging that with"},{"type":"text","text":" "},{"type":"text","text":"spacing instances of certain subviews. For example, if you define"},{"type":"text","text":" "},{"type":"text","text":"a basic vertical stack that places subviews in a column, you could"},{"type":"text","text":" "},{"type":"text","text":"use the spacing preferences of the subview edges that make"},{"type":"text","text":" "},{"type":"text","text":"contact with the container’s edges:"}],"type":"paragraph"},{"syntax":"swift","code":["extension BasicVStack {","    func spacing(subviews: Subviews, cache: inout ()) -> ViewSpacing {","        var spacing = ViewSpacing()","","        for index in subviews.indices {","            var edges: Edge.Set = [.leading, .trailing]","            if index == 0 { edges.formUnion(.top) }","            if index == subviews.count - 1 { edges.formUnion(.bottom) }","            spacing.formUnion(subviews[index].spacing, edges: edges)","        }","","        return spacing","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"In the above example, the first and last subviews contribute to the","type":"text"},{"text":" ","type":"text"},{"text":"spacing above and below the container, respectively, while all subviews","type":"text"},{"text":" ","type":"text"},{"text":"affect the spacing on the leading and trailing edges.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you don’t implement this method, the protocol provides a default","type":"text"},{"text":" ","type":"text"},{"text":"implementation that merges the spacing preferences across all subviews on all edges.","type":"text"}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/openswiftui\/hstack\/spacing(subviews:cache:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Returns the preferred spacing values of the composite view."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"]]},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack\/spacing(subviews:cache:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ViewSpacing":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewSpacing","kind":"identifier"}],"title":"ViewSpacing","url":"\/documentation\/openswiftui\/viewspacing","kind":"symbol","type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","abstract":[{"text":"A collection of the geometric spacing preferences of a view.","type":"text"}],"role":"symbol","navigatorTitle":[{"text":"ViewSpacing","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwif