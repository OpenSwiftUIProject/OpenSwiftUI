":[{"text":"Depending on the current value of the ","type":"text"},{"code":"isHidden","type":"codeVoice"},{"text":" state variable in the","type":"text"},{"text":" ","type":"text"},{"text":"example above, controlled by the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference","isActive":true},{"text":" instance, OpenSwiftUI draws","type":"text"},{"text":" ","type":"text"},{"text":"the circle or completely omits it from the layout.","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack\/hidden()"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"]]},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/HStack/hidden()":{"type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"hidden"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"role":"symbol","abstract":[{"type":"text","text":"Hides this view unconditionally."}],"url":"\/documentation\/openswiftui\/hstack\/hidden()","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack\/hidden()","title":"hidden()"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/HStack":{"type":"topic","navigatorTitle":[{"text":"HStack","kind":"identifier"}],"title":"HStack","url":"\/documentation\/openswiftui\/hstack","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","abstract":[{"text":"A view that arranges its subviews in a horizontal line.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"HStack","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/Open