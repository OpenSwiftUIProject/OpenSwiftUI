{"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fixedSize"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}]}]},{"content":[{"anchor":"return-value","type":"heading","level":2,"text":"Return Value"},{"inlineContent":[{"type":"text","text":"A view that fixes this view at its ideal size."}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"During the layout of the view hierarchy, each view proposes a size to","type":"text"},{"text":" ","type":"text"},{"text":"each child view it contains. If the child view doesn’t need a fixed size","type":"text"},{"text":" ","type":"text"},{"text":"it can accept and conform to the size offered by the parent.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"type":"text","text":" view placed in an explicitly sized frame wraps"},{"type":"text","text":" "},{"type":"text","text":"and truncates its string to remain within its parent’s bounds:"}],"type":"paragraph"},{"code":["Text(\"A single line of text, too long to fit in a box.\")","    .frame(width: 200, height: 200)","    .border(Color.gray)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" modifier can be used to create a view that maintains"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ideal size"}]},{"type":"text","text":" of its children both dimensions:"}],"type":"paragraph"},{"code":["Text(\"A single line of text, too long to fit in a box.\")","    .fixedSize()","    .frame(width: 200, height: 200)","    .border(Color.gray)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"This can result in the view exceeding the parent’s bounds, which may or"},{"type":"text","text":" "},{"type":"text","text":"may not be the effect you want."}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"You can think of ","type":"text"},{"code":"fixedSize()","type":"codeVoice"},{"text":" as the creation of a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"counter proposal","type":"text"}]},{"text":" ","type":"text"},{"text":"to the view size proposed to a view by its parent. The ideal size of a","type":"text"},{"text":" ","type":"text"},{"text":"view, and the specific effects of ","type":"text"},{"code":"fixedSize()","type":"codeVoice"},{"text":" depends on the","type":"text"},{"text":" ","type":"text"},{"text":"particular view and how you have configured it.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"To create a view that fixes the view’s size in either the horizontal or","type":"text"},{"text":" ","type":"text"},{"text":"vertical dimensions, see ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/hstack\/fixedsize()"]}],"sections":[],"metadata":{"role":"symbol","extendedModule":"OpenSwiftUICore","title":"fixedSize()","roleHeading":"Instance Method","symbolKind":"method","platforms":[{"unav