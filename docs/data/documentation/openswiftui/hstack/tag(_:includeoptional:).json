maryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"tag","kind":"identifier"},{"text":"<","kind":"text"},{"text":"V","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"tag","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"V","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"includeOptional","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","preciseIdentifier":"s:Sb","kind":"typeIdentifier"},{"text":" = true) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"V","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"Hashable","preciseIdentifier":"s:SH","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"languages":["swift"]}]},{"parameters":[{"name":"tag","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/hashable","isActive":true},{"type":"text","text":" "},{"type":"text","text":"value to use as the view’s tag."}]}]},{"name":"includeOptional","content":[{"inlineContent":[{"text":"If the tag value for ","type":"text"},{"type":"codeVoice","code":"Optional<V>"},{"text":" should","type":"text"},{"text":" ","type":"text"},{"text":"also be set.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view with the specified tag set."}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier to differentiate among certain selectable views,","type":"text"},{"text":" ","type":"text"},{"text":"like the possible values of a ","type":"text"},{"type":"codeVoice","code":"Picker"},{"text":" or the tabs of a ","type":"text"},{"type":"codeVoice","code":"TabView"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Tag values can be of any type that conforms to the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/hashable"},{"text":" protocol.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This modifier will write the tag value for the type ","type":"text"},{"type":"codeVoice","code":"V"},{"text":", as well as","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Optional<V>"},{"text":" if ","type":"text"},{"type":"codeVoice","code":"includeOptional"},{"text":" is enabled. Containers checking for","type":"text"},{"text":" ","type":"text"},{"text":"tags of either type will see the value as set.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"In the example below, the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach","type":"reference"},{"text":" loop in the ","type":"text"},{"type":"codeVoice","code":"Picker"},{"text":" view","type":"text"},{"text":" ","type":"text"},{"text":"builder iterates over the ","type":"text"},{"type":"codeVoice","code":"Flavor"},{"text":" enumeration. It extracts the string","type":"text"},{"text":" ","type":"text"},{"text":"value of each enumeration element for use in constructing the row","type":"text"},{"text":" ","type":"text"},{"text":"label, and uses the enumeration value as input to the ","type":"text"},{"type":"codeVoice","code":"tag(_:)"},{"text":" ","type":"text"},{"text":"modifier.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct FlavorPicker: View {","    enum Flavor: String, CaseIterable, Identifiable {","        case chocolate, vanilla, strawberry","        var id: Self { self }","    }","","    @State private var selectedFlavor: Flavor? = nil","","    var body: some View {","        Picker(\"Flavor\", selection: $selectedFlavor) {","            ForEach(Flavor.allCases) { flavor in","                Text(flavor.rawValue)","                    .tag(flavor)","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The selection type of the "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":" is an "},{"type":"codeVoice","code":"Optional<Flavor>"},{"type":"text","text":" and so it"},{"type":"text","text":" "},{"type":"text","text":"will look for tags on its contents of "},{"type":"codeVoice","code":"Optional<Flavor>"},{"type":"text","text":"type. Since the"},{"type":"text","text":" "},{"type":"text","text":"tag modifier defaults to having "},{"type":"codeVoice","code":"includeOptional"},{"type":"text","text":" enabled, even though"},{"type":"text","text":" "},{"type":"text","text":"the tag for each option is a non-optional "},{"type":"codeVoice","code":"Flavor"},{"type":"text","text":", the tag modifier"},{"type":"text","text":" "},{"type":"text","text":"writes values for both the non-optional, and optional versions of the"},{"type":"text","text":" "},{"type":"text","text":"value, allowing the contents to be selectable by the "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach","type":"reference","isActive":true},{"type":"text","text":" automatically applies a default tag to each enumerated"},{"type":"text","text":" "},{"type":"text","text":"view using the "},{"type":"codeVoice","code":"id"},{"type":"text","text":" parameter of the corresponding element. If"},{"type":"text","text":" "},{"type":"text","text":"the element’s "},{"type":"codeVoice","code":"id"},{"type":"text","text":" parameter and the picker’s "},{"type":"codeVoice","code":"selection"},{"type":"text","text":" input"},{"type":"text","text":" "},{"type":"text","text":"have exactly the same type, or the same type but optional, you can omit"},{"type":"text","text":" "},{"type":"text","text":"the explicit tag modifier."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To see examples that don’t require an explicit tag, see "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":"."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/hstack\/tag(_:includeoptional:)"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"url":"\/documentation\/openswiftui\/view","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/HStack":{"type":"topic","navigatorTitle":[{"text":"HStack","kind":"identifier"}],"title":"HStack","url":"\/documentation\/openswiftui\/hstack","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","abstract":[{"text":"A view that arranges its subviews in a horizontal line.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"HStack","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/OpenSwift