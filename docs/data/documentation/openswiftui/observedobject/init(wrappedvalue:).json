{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Don’t call this initializer directly. Instead, declare"},{"type":"text","text":" "},{"type":"text","text":"an input to a view with the "},{"code":"@ObservedObject","type":"codeVoice"},{"type":"text","text":" attribute, and pass a"},{"type":"text","text":" "},{"type":"text","text":"value to this input when you instantiate the view. Unlike a"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StateObject"},{"type":"text","text":" which manages data storage, you use an observed"},{"type":"text","text":" "},{"type":"text","text":"object to refer to storage that you manage elsewhere, as in the"},{"type":"text","text":" "},{"type":"text","text":"following example:"}],"type":"paragraph"},{"type":"codeListing","code":["class DataModel: ObservableObject {","    @Published var name = \"Some Name\"","    @Published var isEnabled = false","}","","struct MyView: View {","    @StateObject private var model = DataModel()","","    var body: some View {","        Text(model.name)","        MySubView(model: model)","    }","}","","struct MySubView: View {","    @ObservedObject var model: DataModel","","    var body: some View {","        Toggle(\"Enabled\", isOn: $model.isEnabled)","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Explicitly calling the observed object initializer in "},{"type":"codeVoice","code":"MySubView"},{"type":"text","text":" would"},{"type":"text","text":" "},{"type":"text","text":"behave correctly, but would needlessly recreate the same observed object"},{"type":"text","text":" "},{"type":"text","text":"instance every time OpenSwiftUI calls the view’s initializer to redraw the"},{"type":"text","text":" "},{"type":"text","text":"view."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\