{"abstract":[{"text":"Fixes this view at its ideal size.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TupleView"]]},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fixedSize"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","text":"View"},{"kind":"text","text":"\n"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Return Value","type":"heading","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that fixes this view at its ideal size."}]}],"kind":"content"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"During the layout of the view hierarchy, each view proposes a size to"},{"type":"text","text":" "},{"type":"text","text":"each child view it contains. If the child view doesn’t need a fixed size"},{"type":"text","text":" "},{"type":"text","text":"it can accept and conform to the size offered by the parent."}]},{"type":"paragraph","inlineContent":[{"text":"For example, a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view placed in an explicitly sized frame wraps","type":"text"},{"text":" ","type":"text"},{"text":"and truncates its string to remain within its parent’s bounds:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Text(\"A single line of text, too long to fit in a box.\")","    .frame(width: 200, height: 200)","    .border(Color.gray)"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"fixedSize()","type":"codeVoice"},{"type":"text","text":" modifier can be used to create a view that maintains"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"ideal size"}]},{"type":"text","text":" of its children both dimensions:"}]},{"type":"codeListing","syntax":"swift","code":["Text(\"A single line of text, too long to fit in a box.\")","    .fixedSize()","    .frame(width: 200, height: 200)","    .border(Color.gray)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This can result in the view exceeding the parent’s bounds, which may or"},{"type":"text","text":" "},{"type":"text","text":"may not be the effect you want."}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"You can think of ","type":"text"},{"type":"codeVoice","code":"fixedSize()"},{"text":" as the creation of a ","type":"text"},{"inlineContent":[{"type":"text","text":"counter proposal"}],"type":"emphasis"},{"text":" ","type":"text"},{"text":"to the view size proposed to a view by its parent. The ideal size of a","type":"text"},{"text":" ","type":"text"},{"text":"view, and the specific effects of ","type":"text"},{"type":"codeVoice","code":"fixedSize()"},{"text":" depends on the","type":"text"},{"text":" ","type":"text"},{"text":"particular view and how you have configured it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a view that fixes the view’s size in either the horizontal or"},{"type":"text","text":" "},{"type":"text","text":"vertical dimensions, see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)"},{"type":"text","text":"."}]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","metadata":{"rem