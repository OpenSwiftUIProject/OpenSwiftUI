ype":"text","text":" "},{"type":"text","text":"a platform-specific default amount. The default value of this"},{"type":"text","text":" "},{"type":"text","text":"parameter is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"text":"Return Value","type":"heading","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"A view that’s padded by the specified amount on the","type":"text"},{"text":" ","type":"text"},{"text":"specified edges.","type":"text"}]}],"kind":"content"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"Use this modifier to add a specified amount of padding to one or more","type":"text"},{"text":" ","type":"text"},{"text":"edges of the view. Indicate the edges to pad by naming either a single","type":"text"},{"text":" ","type":"text"},{"text":"value from ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set","isActive":true,"type":"reference"},{"text":", or by specifying an","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/Swift\/OptionSet","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"that contains edge values:","type":"text"}],"type":"paragraph"},{"code":["VStack {","    Text(\"Text padded by 20 points on the bottom and trailing edges.\")","        .padding([.bottom, .trailing], 20)","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The order in which you apply modifiers matters. The example above","type":"text"},{"text":" ","type":"text"},{"text":"applies the padding before applying the border to ensure that the","type":"text"},{"text":" ","type":"text"},{"text":"border encompasses the padded region:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"You can omit either or both of the parameters. If you omit the ","type":"text"},{"type":"codeVoice","code":"length"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"OpenSwiftUI uses a default amount of padding. If you","type":"text"},{"text":" ","type":"text"},{"text":"omit the ","type":"text"},{"type":"codeVoice","code":"edges"},{"text":", OpenSwiftUI applies the padding to all edges. Omit both","type":"text"},{"text":" ","type":"text"},{"text":"to add a default padding all the way around a view. OpenSwiftUI chooses a","type":"text"},{"text":" ","type":"text"},{"text":"default amount of padding that’s appropriate for the platform and","type":"text"},{"text":" ","type":"text"},{"text":"the presentation context.","type":"text"}],"type":"paragraph"},{"code":["VStack {","    Text(\"Text with default padding.\")","        .padding()","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The example above looks like this in iOS under typical conditions:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"To control the amount of padding independently for each edge, use","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"View\/padding(_:)-6pgqq"},{"text":". To pad all outside edges of a view by a","type":"text"},{"text":" ","type":"text"},{"text":"specified amount, use ","type":"text"},{"type":"codeVoice","code":"View\/padding(_:)-68shk"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","metadata":{"platforms":[{"introducedAt":"13.0","beta":false,"name":"iOS","unavailable":false,"deprecated":false},{"introducedAt":"10.15","beta":false,"name":"macOS","unavailable":false,"deprecated":false},{"introducedAt":"13.0","beta":false,"name":"tvOS","unavailable