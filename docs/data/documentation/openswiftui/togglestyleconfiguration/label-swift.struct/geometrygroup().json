{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/togglestyleconfiguration\/label-swift.struct\/geometrygroup()"]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct"]]},"metadata":{"platforms":[{"introducedAt":"13.0","unavailable":false,"deprecated":false,"beta":false,"name":"iOS"},{"introducedAt":"10.15","unavailable":false,"deprecated":false,"beta":false,"name":"macOS"},{"introducedAt":"13.0","unavailable":false,"deprecated":false,"beta":false,"name":"tvOS"},{"introducedAt":"1.0","unavailable":false,"deprecated":false,"beta":false,"name":"visionOS"},{"introducedAt":"6.0","unavailable":false,"deprecated":false,"beta":false,"name":"watchOS"}],"remoteSource":{"fileName":"RendererEffect.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Render\/RendererEffect\/RendererEffect.swift#L294"},"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}],"extendedModule":"OpenSwiftUICore","role":"symbol","roleHeading":"Instance Method","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"externalID":"s:15OpenSwiftUICore4ViewPAAE13geometryGroupQryF::SYNTHESIZED::s:11OpenSwiftUI24ToggleStyleConfigurationV5LabelV","symbolKind":"method","title":"geometryGroup()"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Isolates the geometry (e.g. position and size) of the view","type":"text"},{"text":" ","type":"text"},{"text":"from its parent view.","type":"text"}],"kind":"symbol","sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct\/geometryGroup()"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"By default OpenSwiftUI views push position and size changes down","type":"text"},{"text":" ","type":"text"},{"text":"through the view hierarchy, so that only views that draw","type":"text"},{"text":" ","type":"text"},{"text":"something (known as leaf views) apply the current animation to","type":"text"},{"text":" ","type":"text"},{"text":"their frame rectangle. However in some cases this coalescing","type":"text"},{"text":" ","type":"text"},{"text":"behavior can give undesirable results; inserting a geometry","type":"text"},{"text":" ","type":"text"},{"text":"group can correct that. A group acts as a barrier between the","type":"text"},{"text":" ","type":"text"},{"text":"parent view and its subviews, forcing the position and size","type":"text"},{"text":" ","type":"text"},{"text":"values to be resolved and animated by the parent, before being","type":"text"},{"text":" ","type":"text"},{"text":"passed down to each subview.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The example below shows one use of this function: ensuring that"},{"type":"text","text":" "},{"type":"text","text":"the member views of each row in the stack apply (and animate"},{"type":"text","text":" "},{"type":"text","text":"as) a single geometric transform from their ancestor view,"},{"type":"text","text":" "},{"type":"text","text":"rather than letting the effects of the ancestor views be"},{"type":"text","text":" "},{"type":"text","text":"applied separately to each leaf view. If the members of"},{"type":"text","text":" "},{"type":"codeVoice","code":"ItemView"},{"type":"text","text":" may be added and removed at different times the"},{"type":"text","text":" "},{"type":"text","text":"group ensures that they stay locked together as animations are"},{"type":"text","text":" "},{"type":"text","text":"applied."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["VStack {","    ForEach(items) { item in","        ItemView(item: item)","            .geometryGroup()","    }","}"]},{"inlineContent":[{"text":"Returns: a new view whose geometry is isolated from that of its","type":"text"},{"text":" ","type":"text"},{"text":"parent view.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ToggleStyleConfiguration/Label-swift.struct/geometryGroup()":{"title":"geometryGroup()","abstract":[{"text":"Isolates the geometry (e.g. position and size) of the view","type":"text"},{"text":" ","type":"text"},{"text":"from its parent view.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct\/geometryGroup()","type":"topic","url":"\/documentation\/openswiftui\/togglestyleconfiguration\/label-swift.struct\/geometrygroup()"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"f