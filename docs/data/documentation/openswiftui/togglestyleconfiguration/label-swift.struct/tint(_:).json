{"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct"]]},"metadata":{"extendedModule":"OpenSwiftUICore","externalID":"s:15OpenSwiftUICore4ViewPAAE4tintyQrAA5ColorVSgF::SYNTHESIZED::s:11OpenSwiftUI24ToggleStyleConfigurationV5LabelV","title":"tint(_:)","roleHeading":"Instance Method","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"symbolKind":"method","platforms":[{"introducedAt":"13.0","deprecated":false,"beta":false,"name":"iOS","unavailable":false},{"introducedAt":"10.15","deprecated":false,"beta":false,"name":"macOS","unavailable":false},{"introducedAt":"13.0","deprecated":false,"beta":false,"name":"tvOS","unavailable":false},{"introducedAt":"1.0","deprecated":false,"beta":false,"name":"visionOS","unavailable":false},{"introducedAt":"6.0","deprecated":false,"beta":false,"name":"watchOS","unavailable":false}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"tint","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Color","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore5ColorV"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"role":"symbol","remoteSource":{"fileName":"Tint.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Shape\/Tint.swift#L134"}},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct\/tint(_:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text"