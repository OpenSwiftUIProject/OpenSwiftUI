"text"}],"type":"paragraph"},{"code":["struct ControlTint: View {","    var body: some View {","        HStack {","            Button {","                \/\/ Answer the call","            } label: {","                Label(\"Answer\", systemImage: \"phone\")","            }","            .tint(.green)","            Button {","                \/\/ Decline the call","            } label: {","                Label(\"Decline\", systemImage: \"phone.down\")","            }","            .tint(.red)","        }","        .buttonStyle(.borderedProminent)","        .padding()","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Some controls adapt to the tint color differently based on their style,"},{"type":"text","text":" "},{"type":"text","text":"the current platform, and the surrounding context. For example, in"},{"type":"text","text":" "},{"type":"text","text":"macOS, a button with the "},{"type":"codeVoice","code":"PrimitiveButtonStyle\/bordered"},{"type":"text","text":" style doesn’t"},{"type":"text","text":" "},{"type":"text","text":"tint its background, but one with the"},{"type":"text","text":" "},{"type":"codeVoice","code":"PrimitiveButtonStyle\/borderedProminent"},{"type":"text","text":" style does. In macOS, neither"},{"type":"text","text":" "},{"type":"text","text":"of these button styles tint their label, but they do in other platforms."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/openswiftui\/togglestyleconfiguration\/label-swift.struct\/tint(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","abstract":[{"type":"text","text":"Sets the tint color within this view."}],"sections":[],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Color":{"abstract":[{"type":"text","text":"A representation of a color that adapts to a given context."}],"url":"\/documentation\/openswiftui\/color","title":"Color","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Color"}],"type":"to