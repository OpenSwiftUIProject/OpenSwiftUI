text":" "},{"type":"text","text":"and its child views."}]}],"kind":"content"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"Use this modifier on a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference"},{"text":" instance to set a style that defines","type":"text"},{"text":" ","type":"text"},{"text":"the control’s appearance and behavior. For example, you can choose","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","type":"reference"},{"text":" style:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["Toggle(\"Vibrate on Ring\", isOn: $vibrateOnRing)","    .toggleStyle(.switch)"]},{"inlineContent":[{"type":"text","text":"Built-in styles typically have a similar appearance across platforms,"},{"type":"text","text":" "},{"type":"text","text":"tailored to the platform’s overall style:"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Appearance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"iOS, iPadOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]],"type":"table","header":"row"},{"anchor":"Styling-toggles-in-a-hierarchy","level":3,"type":"heading","text":"Styling toggles in a hierarchy"},{"inlineContent":[{"text":"You can set a style for all toggle instances within a view hierarchy","type":"text"},{"text":" ","type":"text"},{"text":"by applying the style modifier to a container view. For example, you","type":"text"},{"text":" ","type":"text"},{"text":"can apply the ","type":"text"},{"code":"ToggleStyle\/button","type":"codeVoice"},{"text":" style to an ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","type":"reference","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["HStack {","    Toggle(isOn: $isFlagged) {","        Label(\"Flag\", systemImage: \"flag.fill\")","    }","    Toggle(isOn: $isMuted) {","        Label(\"Mute\", systemImage: \"speaker.slash.fill\")","    }","}",".toggleStyle(.button)"]},{"inlineContent":[{"text":"The example above has the following appearance when ","type":"text"},{"code":"isFlagged","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"isMuted","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"false","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Appearance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS, iPadOS"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]],"type":"table","header":"row"},{"anchor":"Automatic-styling","level":3,"type":"heading","text":"Automatic styling"},{"inlineContent":[{"text":"If you don’t set a style, OpenSwiftUI assumes a value of","type":"text"},{"text":" ","type":"text"},{"code":"ToggleStyle\/automatic","type":"codeVoice"},{"text":", which corresponds to a context-specific","type":"text"},{"text":" ","type":"text"},{"text":"default. Specify the automatic style explicitly to override a","type":"text"},{"text":" ","type":"text"},{"text":"container’s style and revert to the default:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["HStack {","    Toggle(isOn: $isShuffling) {","        Label(\"Shuffle\", systemImage: \"shuffle\")","    }","    Toggle(isOn: $isRepeating) {","        Label(\"Repeat\", systemImage: \"repeat\")","    }","","    Divider()","","    Toggle(\"Enhance Sound\", isOn: $isEnhanced)","        .toggleStyle(.automatic) \/\/ Revert to the default style.","}",".toggleStyle(.button) \/\/ Use button style for toggles in the stack.",".labelStyle(.iconOnly) \/\/ Omit the title from any labels."]},{"inlineContent":[{"type":"text","text":"The style that OpenSwiftUI uses as the default depends on both the platform"},{"type":"text","text":" "},{"type":"text","text":"and the context. In macOS, the default in most contexts is a"},{"type":"text","text":" "},{"type":"codeVoice","code":"ToggleStyle\/checkbox"},{"type":"text","text":", while in iOS, the default toggle style is a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Platform"}]}],[{"type":"paragraph","inlineContent":[{"text":"Appearance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"iOS, iPadOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS"}]}],[{"type":"paragraph","inlineContent":[]}]]],"type":"table","header":"row"},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Like toggle style does for toggles, the ","type":"text"},{"code":"View\/labelStyle(_:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"modifier sets the style for ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct","type":"reference","isActive":true},{"text":" instances in the hierarchy. The","type":"text"},{"text":" ","type":"text"},{"text":"example above demostrates the compact ","type":"text"},{"code":"LabelStyle\/iconOnly","type":"codeVoice"},{"text":" style,","type":"text"},{"text":" ","type":"text"},{"text":"which is useful for button toggles in space-constrained contexts.","type":"text"},{"text":" ","type":"text"},{"text":"Always include a descriptive title for better accessibility.","type":"text"}]}],"name":"Note"},{"inlineContent":[{"text":"For more information about how OpenSwiftUI chooses a default toggle style,","type":"text"},{"text":" ","type":"text"},{"text":"see the ","type":"text"},{"code":"ToggleStyle\/automatic","type":"codeVoice"},{"text":" style.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","abstract":[{"type":"text","text":"Sets the style for toggles in a view hierarchy."}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ToggleStyleConfiguration/Label-swift.struct/toggleStyle(_:)":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"toggleStyle"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lFQO1Sqd__mfp","text":"S"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"}],"url":"\/documentation\/openswiftui\/togglestyleconfiguration\/label-swift.struct\/togglestyle(_:)","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct\/toggleStyle(_:)","type":"topic","abstract":[{"type":"text","text":"Sets the style for toggles in a view hierarchy."}],"kind":"symbol","role":"symbol","title":"toggleStyle(_:)"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ToggleStyleConfiguration":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"ToggleStyleConfiguration"}],"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/do