"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the example above, the first "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" element has the default"},{"type":"text","text":" "},{"type":"text","text":"priority "},{"type":"codeVoice","code":"0"},{"type":"text","text":" which causes its view to shrink dramatically due to the"},{"type":"text","text":" "},{"type":"text","text":"higher priority of the second "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" element, even though all of their"},{"type":"text","text":" "},{"type":"text","text":"other attributes (font, font size and character count) are the same."}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"A parent layout offers the child views with the highest layout priority","type":"text"},{"text":" ","type":"text"},{"text":"all the space offered to the parent minus the minimum space required for","type":"text"},{"text":" ","type":"text"},{"text":"all its lower-priority children.","type":"text"}]}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/togglestyleconfiguration\/label-swift.struct\/layoutpriority(_:)"]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct\/layoutPriority(_:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct"]]},"metadata":{"role":"symbol","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"platforms":[{"unavailable