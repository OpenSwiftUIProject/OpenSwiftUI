s a moderately long string.\")","        .font(.largeTitle)","        .border(Color.gray)","","    Spacer()","","    Text(\"This is a higher priority string.\")","        .font(.largeTitle)","        .layoutPriority(1)","        .border(Color.gray)","}"]},{"inlineContent":[{"type":"text","text":"In the example above, the first "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" element has the default"},{"type":"text","text":" "},{"type":"text","text":"priority "},{"code":"0","type":"codeVoice"},{"type":"text","text":" which causes its view to shrink dramatically due to the"},{"type":"text","text":" "},{"type":"text","text":"higher priority of the second "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" element, even though all of their"},{"type":"text","text":" "},{"type":"text","text":"other attributes (font, font size and character count) are the same."}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"A parent layout offers the child views with the highest layout priority","type":"text"},{"text":" ","type":"text"},{"text":"all the space offered to the parent minus the minimum space required for","type":"text"},{"text":" ","type":"text"},{"text":"all its lower-priority children.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ToggleStyleConfiguration/Label-swift.struct":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Label"}],"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Label"}],"abstract":[{"type":"text","text":"A type-erased label of a toggle."}],"url":"\/documentation\/openswiftui\/togglestyleconfiguration\/label-s