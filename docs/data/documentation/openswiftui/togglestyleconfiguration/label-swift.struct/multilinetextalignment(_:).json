{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct"]]},"abstract":[{"text":"Sets the alignment of a text view that contains multiple lines of text.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct\/multilineTextAlignment(_:)"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"multilineTextAlignment","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"alignment","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"TextAlignment","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TextAlignment","preciseIdentifier":"s:15OpenSwiftUICore13TextAlignmentO"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":"\n","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"A value that you use to align multiple lines of"},{"type":"text","text":" "},{"type":"text","text":"text within a view."}],"type":"paragraph"}],"name":"alignment"}],"kind":"parameters"},{"content":[{"level":2,"anchor":"return-value","type":"heading","text":"Return Value"},{"inlineContent":[{"type":"text","text":"A view that aligns the lines of multiline "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" instances"},{"type":"text","text":" "},{"type":"text","text":"it contains."}],"type":"paragraph"}],"kind":"content"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier to set an alignment for a multiline block of text.","type":"text"},{"text":" ","type":"text"},{"text":"For example, the modifier centers the contents of the following","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"text":" view:","type":"text"}]},{"type":"codeListing","code":["Text(\"This is a block of text that shows up in a text element as multiple lines.\\(\"\\n\") Here we have chosen to center this text.\")","    .frame(width: 200)","    .multilineTextAlignment(.center)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The text in the above example spans more than one line because:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"The newline character introduces a line break.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The frame modifier limits the space available to the text view, and","type":"text"},{"text":" ","type":"text"},{"text":"by default a text view wraps lines that don’t fit in the available","type":"text"},{"text":" ","type":"text"},{"text":"width. As a result, the text before the explicit line break wraps to","type":"text"},{"text":" ","type":"text"},{"text":"three lines, and the text after uses two lines.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier applies the alignment to the all the lines of text in"},{"type":"text","text":" "},{"type":"text","text":"the view, regardless of why wrapping occurs:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier has no effect on a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" view that contains only one"},{"type":"text","text":" "},{"type":"text","text":"line of text, because a text view has a width that exactly matches the"},{"type":"text","text":" "},{"type":"text","text":"width of its widest line. If you want to align an entire text view"},{"type":"text","text":" "},{"type":"text","text":"rather than its contents, set the aligment of its container, like a"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":" or a frame that you create with the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/frame(minWidth:idealWidth:maxWidth:minHeight:idealHeight:maxHeight:alignment:)"},{"type":"text","text":" "},{"type":"text","text":"modifier."}]},{"type":"aside","content":[{"inlineContent":[{"text":"You can use this modifier to control the alignment of a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"view that you create with the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/init(_:style:)","type":"reference","isActive":true},{"text":" initializer","type":"text"},{"text":" ","type":"text"},{"text":"to display localized dates and times, including when the view uses","type":"text"},{"text":" ","type":"text"},{"text":"only a single line, but only when that view appears in a widget.","type":"text"}],"type":"paragraph"}],"name":"Note","style":"note"},{"type":"paragraph","inlineContent":[{"text":"The modifier also affects the content alignment of other text container","type":"text"},{"text":" ","type":"text"},{"text":"types, like ","type":"text"},{"code":"TextEditor","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"TextField","type":"codeVoice"},{"text":". In those cases, the","type":"text"},{"text":" ","type":"text"},{"text":"modifier sets the alignment even when the view contains only a single","type":"text"},{"text":" ","type":"text"},{"text":"line because view’s width isn’t dictated by the width of the text it","type":"text"},{"text":" ","type":"text"},{"text":"contains.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The modifier operates by setting the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/multilineTextAlignment","isActive":true,"type":"reference"},{"text":" value in the environment,","type":"text"},{"text":" ","type":"text"},{"text":"so it affects all the text containers in the modified view hierarchy.","type":"text"},{"text":" ","type":"text"},{"text":"For example, you can apply the modifier to a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true,"type":"reference"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"configure all the text views inside the stack.","type":"text"}]}],"kind":"content"}],"metadata":{"symbolKind":"method","remoteSource":{"fileName":"EnvironmentParagraphStyle.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/View\/Text\/Util\/EnvironmentParagraphStyle.swift#L383"},"platforms":[{"unavailable":false,"beta":false,"name":"iOS","deprecated":false,"introducedAt":"13.0"},{"unavailable":false,"beta":false,"name":"macOS","deprecated":false,"introducedAt":"10.15"},{"unavailable":false,"beta":false,"name":"tvOS","deprecated":false,"introducedAt":"13.0"},{"unavailable":false,"beta":false,"name":"visionOS","deprecated":false,"introducedAt":"1.0"},{"unavailable":false,"beta":false,"name":"watch