" "},{"type":"text","text":"instance of "},{"code":"MyView","type":"codeVoice"},{"type":"text","text":". On the other hand, each instance of "},{"code":"MyView","type":"codeVoice"},{"text":" ","type":"text"},{"text":"creates a distinct instance of the data model. For example, each of","type":"text"},{"text":" ","type":"text"},{"text":"the views in the following ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"text":" has its own model storage:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var body: some View {","    VStack {","        MyView()","        MyView()","    }","}"],"type":"codeListing"},{"anchor":"Initialize-using-external-data","type":"heading","level":3,"text":"Initialize using external data"},{"inlineContent":[{"type":"text","text":"If the initial state of a state object depends on external data, you can"},{"type":"text","text":" "},{"type":"text","text":"call this initializer directly. However, use caution when doing this,"},{"type":"text","text":" "},{"type":"text","text":"because OpenSwiftUI only initializes the object once during the lifetime of"},{"type":"text","text":" "},{"type":"text","text":"the view — even if you call the state object initializer more than"},{"type":"text","text":" "},{"type":"text","text":"once — which might result in unexpected behavior. For more information"},{"type":"text","text":" "},{"type":"text","text":"and an example, see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StateObject"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/VStack":{"title":"VStack","navigatorTitle":[{"kind":"identifier","text":"VStack"}],"abstract":[{"type":"text","text":"A view that arranges its subviews in a vertical line."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifi