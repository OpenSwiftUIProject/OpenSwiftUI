{"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"abstract":[{"type":"text","text":"A view that updates according to a schedule that you provide."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"topicSections":[{"title":"Structures","generated":true,"anchor":"Structures","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView\/Context"]},{"title":"Initializers","generated":true,"anchor":"Initializers","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView\/init(_:content:)-8eoar","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView\/init(_:content:)-8r9m2"]},{"title":"Default Implementations","generated":true,"anchor":"Default-Implementations","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView\/View-Implementations"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TimelineView","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Schedule","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Schedule","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"TimelineSchedule","preciseIdentifier":"s:15OpenSwiftUICore16TimelineScheduleP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineSchedule","kind":"typeIdentifier"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"A timeline view acts as a container with no appearance of its own. Instead,","type":"text"},{"text":" ","type":"text"},{"text":"it redraws the content it contains at scheduled points in time.","type":"text"},{"text":" ","type":"text"},{"text":"For example, you can update the face of an analog timer once per second:","type":"text"}]},{"type":"codeListing","code":["TimelineView(.periodic(from: startDate, by: 1)) { context in","    AnalogTimerView(date: context.date)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The closure that creates the content receives an input of type ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView\/Context","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"that you can use to customize the content’s appearance. The context includes","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView\/Context\/date","isActive":true,"type":"reference"},{"text":" that triggered the update. In the example above,","type":"text"},{"text":" ","type":"text"},{"text":"the timeline view sends that date to an analog timer that you create so the","type":"text"},{"text":" ","type":"text"},{"text":"timer view knows how to draw the hands on its face.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The context also includes a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView\/Context\/cadence-swift.property","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"property that you can use to hide unnecessary detail. For example, you","type":"text"},{"text":" ","type":"text"},{"text":"can use the cadence to decide when it’s appropriate to display the","type":"text"},{"text":" ","type":"text"},{"text":"timer’s second hand:","type":"text"}]},{"type":"codeListing","code":["TimelineView(.periodic(from: startDate, by: 1.0)) { context in","    AnalogTimerView(","        date: context.date,","        showSeconds: context.cadence <= .seconds)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The system might use a cadence that’s slower than the schedule’s","type":"text"},{"text":" ","type":"text"},{"text":"update rate. For example, a view on watchOS might remain visible when the","type":"text"},{"text":" ","type":"text"},{"text":"user lowers their wrist, but update less frequently, and thus require","type":"text"},{"text":" ","type":"text"},{"text":"less detail.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can define a custom schedule by creating a type that conforms to the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineSchedule","type":"reference"},{"text":" protocol, or use one of the built-in schedule types:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use an "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineSchedule\/everyMinute","isActive":true},{"type":"text","text":" schedule to update at the"},{"type":"text","text":" "},{"type":"text","text":"beginning of each minute."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Use a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineSchedule\/periodic(from:by:)","type":"reference"},{"text":" schedule to update","type":"text"},{"text":" ","type":"text"},{"text":"periodically with a custom start time and interval between updates.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use an "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineSchedule\/explicit(_:)","isActive":true,"type":"reference"},{"type":"text","text":" schedule when you need a finite number, or"},{"type":"text","text":" "},{"type":"text","text":"irregular set of updates."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For a schedule containing only dates in the past,"},{"type":"text","text":" "},{"type":"text","text":"the timeline view shows the last date in the schedule."},{"type":"text","text":" "},{"type":"text","text":"For a schedule containing only dates in the future,"},{"type":"text","text":" "},{"type":"text","text":"the timeline draws its content using the current date"},{"type":"text","text":" "},{"type":"text","text":"until the first scheduled date arrives."}]}],"kind":"content"}],"kind":"symbol","variants":[{"paths":["\/documentation\/openswiftui\/timelineview"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"navigatorTitle":[{"text":"TimelineView","kind":"identifier"}],"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/Animation\/Timeline\/TimelineView.swift#L67","fileName":"TimelineView.swift"},"roleHeading":"Structure","title":"TimelineView","platforms":[{"unavailable":false,"beta":false,"name":"iOS","deprecated":false,"introducedAt":"13.0"},{"unavailable":false,"beta":false,"name":"macOS","deprecated":false,"introducedAt":"10.15"},{"unavailable":false,"beta":false,"name":"tvOS","deprecated":false,"introducedAt":"13.0"},{"unavailable":false,"beta":false,"name":"visionOS","deprecated":false,"introducedAt":"1.0"},{"unavailable":false,"beta":false,"name":"watchOS","deprecated":false,"introducedAt":"6.0"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TimelineView","kind":"identifier"}],"role":"symbol","modules":[{"name":"OpenSwiftUI"}],"symbolKind":"struct","externalID":"s:11OpenSwiftUI12TimelineViewV"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView"},"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OpenSwiftUI\/s8CopyableP","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/TimelineView":{"url":"\/documentation\/openswiftui\/timelineview","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineVi