{"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/PlaceholderContentView"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"tint","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"tint","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore5ColorV","text":"Color","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":"\n","kind":"text"}]}]},{"parameters":[{"name":"tint","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The tint "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color"},{"type":"text","text":" to apply."}]}]}],"kind":"parameters"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to override the default accent color for this view."},{"type":"text","text":" "},{"type":"text","text":"Unlike an app’s accent color, which can be overridden by user"},{"type":"text","text":" "},{"type":"text","text":"preference, the tint color is always respected and should be used as a"},{"type":"text","text":" "},{"type":"text","text":"way to provide additional meaning to the control."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example shows Answer and Decline buttons with "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/green","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/red","isActive":true},{"type":"text","text":" tint colors, respectively."}]},{"type":"codeListing","syntax":"swift","code":["struct ControlTint: View {","    var body: some View {","        HStack {","            Button {","                \/\/ Answer the call","            } label: {","                Label(\"Answer\", systemImage: \"phone\")","            }","            .tint(.green)","            Button {","                \/\/ Decline the call","            } label: {","                Label(\"Decline\", systemImage: \"phone.down\")","            }","            .tint(.red)","        }","        .buttonStyle(.borderedProminent)","        .padding()","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some controls adapt to the tint color differently based on their style,"},{"type":"text","text":" "},{"type":"text","text":"the current platform, and the surrounding context. For example, in"},{"type":"text","text":" "},{"type":"text","text":"macOS, a button with the "},{"code":"PrimitiveButtonStyle\/bordered","type":"codeVoice"},{"type":"text","text":" style doesn’t"},{"type":"text","text":" "},{"type":"text","text":"tint its background, but one with the"},{"type":"text","text":" "},{"code":"PrimitiveButtonStyle\/borderedProminent","type":"codeVoice"},{"type":"text","text":" style does. In macOS, neither"},{"type":"text","text":" "},{"type":"text","text":"of these button styles tint their label, but they do in other platforms."}]}],"kind":"content"}],"kind":"symbol","abstract":[{"type":"text","text":"Sets the tint color within this view."}],"metadata":{"externalID":"s:15OpenSwiftUICore4ViewPAAE4tintyQrAA5ColorVSgF::SYNTHESIZED::s:15OpenSwiftUICo