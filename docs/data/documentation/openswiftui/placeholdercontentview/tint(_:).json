d","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"tint"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"tint"},{"kind":"text","text":": "},{"preciseIdentifier":"s:15OpenSwiftUICore5ColorV","kind":"typeIdentifier","text":"Color","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier"},{"text":"\n","kind":"text"}]}]},{"kind":"parameters","parameters":[{"name":"tint","content":[{"inlineContent":[{"type":"text","text":"The tint "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color"},{"type":"text","text":" to apply."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Use this method to override the default accent color for this view.","type":"text"},{"text":" ","type":"text"},{"text":"Unlike an app’s accent color, which can be overridden by user","type":"text"},{"text":" ","type":"text"},{"text":"preference, the tint color is always respected and should be used as a","type":"text"},{"text":" ","type":"text"},{"text":"way to provide additional meaning to the control.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This example shows Answer and Decline buttons with "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/green","isActive":true},{"type":"text","text":" "},{"type":"text","text":"and "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/red","isActive":true},{"type":"text","text":" tint colors, respectively."}],"type":"paragraph"},{"code":["struct ControlTint: View {","    var body: some View {","        HStack {","            Button {","                \/\/ Answer the call","            } label: {","                Label(\"Answer\", systemImage: \"phone\")","            }","            .tint(.green)","            Button {","                \/\/ Decline the call","            } label: {","                Label(\"Decline\", systemImage: \"phone.down\")","            }","            .tint(.red)","        }","        .buttonStyle(.borderedProminent)","        .padding()","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Some controls adapt to the tint color differently based on their style,","type":"text"},{"text":" ","type":"text"},{"text":"the current platform, and the surrounding context. For example, in","type":"text"},{"text":" ","type":"text"},{"text":"macOS, a button with the ","type":"text"},{"code":"PrimitiveButtonStyle\/bordered","type":"codeVoice"},{"text":" style doesn’t","type":"text"},{"text":" ","type":"text"},{"text":"tint its background, but one with the","type":"text"},{"text":" ","type":"text"},{"code":"PrimitiveButtonStyle\/borderedProminent","type":"codeVoice"},{"text":" style does. In macOS, neither","type":"text"},{"text":" ","type":"text"},{"text":"of these button styles tint their label, but they do in other platforms.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/placeholdercontentview\/tint(_:)"]}],"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ShapeStyle/green":{"url":"\/documentation\/openswiftui\/shapestyle\/green","kind":"symbol","type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/green","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"green"},{"kind":"text","text