nt value of the "},{"type":"codeVoice","code":"isHidden"},{"type":"text","text":" state variable in the"},{"type":"text","text":" "},{"type":"text","text":"example above, controlled by the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference","isActive":true},{"type":"text","text":" instance, OpenSwiftUI draws"},{"type":"text","text":" "},{"type":"text","text":"the circle or completely omits it from the layout."}]},{"type":"paragraph","inlineContent":[]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/openswiftui\/placeholdercontentview\/hidden()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/PlaceholderContentView\/hidden()","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Hides this view unconditionally."}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Toggle":{"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Toggle"}],"role":"symbol","url":"\/documentation\/openswiftui\/toggle","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Toggle"}],"title":"Toggle","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","abstract":[]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/PlaceholderContentView/hidden()":{"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"hidden"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"}],"kind":"symbol","url":"\/documentation\/openswiftui\/placeholdercontentview\/hidden()","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/PlaceholderContentView\/hidden()","abstract":[{"type":"text","text":"Hides this view unconditionally."}],"title":"hidden()","role":"symbol"},"doc