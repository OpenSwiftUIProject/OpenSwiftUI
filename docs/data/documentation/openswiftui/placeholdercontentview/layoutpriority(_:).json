{"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Sets the priority by which a parent layout should apportion space to"},{"type":"text","text":" "},{"type":"text","text":"this child."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"layoutPriority"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"value"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"},{"kind":"text","text":"\n"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The priority by which a parent layout apportions"},{"type":"text","text":" "},{"type":"text","text":"space to the child."}]}],"name":"value"}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Views typically have a default priority of "},{"code":"0","type":"codeVoice"},{"type":"text","text":" which causes space to be"},{"type":"text","text":" "},{"type":"text","text":"apportioned evenly to all sibling views. Raising a view’s layout"},{"type":"text","text":" "},{"type":"text","text":"priority encourages the higher priority view to shrink later when the"},{"type":"text","text":" "},{"type":"text","text":"group is shrunk and stretch sooner when the group is stretched."}]},{"code":["HStack {","    Text(\"This is a moderately long string.