ext"}]}],"kind":"content"},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"Use this modifier to change or replace the animation used in a view.","type":"text"},{"text":" ","type":"text"},{"text":"Consider three identical views controlled by a","type":"text"},{"text":" ","type":"text"},{"text":"button that changes all three simultaneously:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"The first view animates rotating the “Rotation” ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view by 360","type":"text"},{"text":" ","type":"text"},{"text":"degrees.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The second uses the ","type":"text"},{"type":"codeVoice","code":"transaction(_:)"},{"text":" modifier to change the","type":"text"},{"text":" ","type":"text"},{"text":"animation by adding a delay to the start of the animation","type":"text"},{"text":" ","type":"text"},{"text":"by two seconds and then increases the rotational speed of the","type":"text"},{"text":" ","type":"text"},{"text":"“Rotation\\nModified” ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference"},{"text":" view animation by a factor of 2.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The third uses the "},{"type":"codeVoice","code":"transaction(_:)"},{"type":"text","text":" modifier to disable animations"},{"type":"text","text":" "},{"type":"text","text":"affecting the “Animation\\nReplaced” "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" view."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The following code implements these animations:","type":"text"}],"type":"paragr