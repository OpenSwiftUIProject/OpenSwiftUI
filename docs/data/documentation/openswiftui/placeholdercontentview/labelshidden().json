"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"This modifier doesn’t work for all labels. It applies to","type":"text"},{"text":" ","type":"text"},{"text":"labels that are separate from the rest of the control’s interface,","type":"text"},{"text":" ","type":"text"},{"text":"like they are for ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference","isActive":true},{"text":", but not to controls like a bordered","type":"text"},{"text":" ","type":"text"},{"text":"button where the label is inside the button’s border.","type":"text"}],"type":"paragraph"}],"name":"Note","style":"note","type":"aside"}],"kind":"content"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Toggle":{"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Toggle"}],"role":"symbol","url":"\/documentation\/openswiftui\/toggle","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Toggle"}],"title":"Toggle","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","abstract":[]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/PlaceholderContentView":{"kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"PlaceholderContentView","kind":"identifier"}],"navigatorTitle":[{"text":"PlaceholderContentView","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/PlaceholderContentView","url":"\/documentation\/openswiftui\/placeholdercontentview","title":"PlaceholderContentView","abstract":[{"type":"text","text":"A placeholder used to construct an inline modifier, transition, or other"},{"type":"text","text":" "},{"type":"text","text":"helper type."}],"type":"topic"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/PlaceholderContentView/labelsHidden()":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"labelsHidden","kind":"iden