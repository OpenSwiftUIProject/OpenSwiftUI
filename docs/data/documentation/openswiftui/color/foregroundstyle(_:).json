{"abstract":[{"type":"text","text":"Sets a view’s foreground elements to use a given style."}],"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"foregroundStyle","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"style","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","text":"ShapeStyle","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore10ShapeStyleP"},{"text":"\n","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The color or pattern to use when filling in the","type":"text"},{"text":" ","type":"text"},{"text":"foreground elements. To indicate a specific value, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","isActive":true},{"text":" or","type":"text"},{"text":" ","type":"text"},{"code":"ShapeStyle\/image(_:sourceRect:scale:)","type":"codeVoice"},{"text":", or one of the gradient","type":"text"},{"text":" ","type":"text"},{"text":"types, like","type":"text"},{"text":" ","type":"text"},{"code":"ShapeStyle\/linearGradient(colors:startPoint:endPoint:)","type":"codeVoice"},{"text":". To set a","type":"text"},{"text":" ","type":"text"},{"text":"style that’s relative to the containing view’s style, use one of the","type":"text"},{"text":" ","type":"text"},{"text":"semantic styles, like ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/primary","isActive":true},{"text":".","type":"text"}]}],"name":"style"}],"kind":"parameters"},{"content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"text":"A view that uses the given foreground style.","type":"text"}]}],"kind":"content"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to style"},{"type":"text","text":" "},{"type":"text","text":"foreground content like text, shapes, and template images"},{"type":"text","text":" "},{"type":"text","text":"(including symbols):"}]},{"type":"codeListing","syntax":"swift","code":["HStack {","    Image(systemName: \"triangle.fill\")","    Text(\"Hello, world!\")","    RoundedRectangle(cornerRadius: 5)","        .frame(width: 40, height: 20)","}",".foregroundStyle(.teal)"]},{"type":"paragraph","inlineContent":[{"text":"The example above creates a row of ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/teal","isActive":true},{"text":" foreground","type":"text"},{"text":" ","type":"text"},{"text":"elements:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use any style that conforms to the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle"},{"type":"text","text":" protocol,"},{"type":"text","text":" "},{"type":"text","text":"like the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/teal"},{"type":"text","text":" color in the example above, or the"},{"type":"text","text":" "},{"type":"codeVoice","code":"ShapeStyle\/linearGradient(colors:startPoint:endPoint:)"},{"type":"text","text":" gradient"},{"type":"text","text":" "},{"type":"text","text":"shown below:"}]},{"type":"codeListing","syntax":"swift","code":["Text(\"Gradient Text\")","    .font(.largeTitle)","    .foregroundStyle(","        .linearGradient(","            colors: [.yellow, .blue],","            startPoint: .top,","            endPoint: .bottom","        )","    )"]},{"type":"paragraph","inlineContent":[]},{"type":"aside","name":"Tip","style":"tip","content":[{"inlineContent":[{"type":"text","text":"If you want to fill a single "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape"},{"type":"text","text":" instance with a style,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape\/fill(style:)"},{"type":"text","text":" shape modifier instead because it’s more"},{"type":"text","text":" "},{"type":"text","text":"efficient."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenSwiftUI creates a context-dependent render for a given style."},{"type":"text","text":" "},{"type":"text","text":"For example, a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","isActive":true},{"type":"text","text":" that you load from an asset catalog"},{"type":"text","text":" "},{"type":"text","text":"can have different light and dark appearances, while some styles"},{"type":"text","text":" "},{"type":"text","text":"also vary by platform."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Hierarchical foreground styles like "},{"type":"codeVoice","code":"ShapeStyle\/secondary"},{"type":"text","text":" "},{"type":"text","text":"don’t impose a style of their own, but instead modify other styles."},{"type":"text","text":" "},{"type":"text","text":"In particular, they modify the primary"},{"type":"text","text":" "},{"type":"text","text":"level of the current foreground style to the degree given by"},{"type":"text","text":" "},{"type":"text","text":"the hierarchical style’s name."},{"type":"text","text":" "},{"type":"text","text":"To find the current foreground style to modify, OpenSwiftUI looks for"},{"type":"text","text":" "},{"type":"text","text":"the innermost containing style that you apply with the"},{"type":"text","text":" "},{"type":"codeVoice","code":"foregroundStyle(_:)"},{"type":"text","text":" or the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/foregroundColor(_:)","isActive":true,"type":"reference"},{"type":"text","text":" modifier."},{"type":"text","text":" "},{"type":"text","text":"If you haven’t specified a style, OpenSwiftUI uses the default foreground"},{"type":"text","text":" "},{"type":"text","text":"style, as in the following example:"}]},{"type":"codeListing","syntax":"swift","code":["VStack(alignment: .leading) {","    Label(\"Primary\", systemImage: \"1.square.fill\")","    Label(\"Secondary\", systemImage: \"2.square.fill\")","        .foregroundStyle(.secondary)","}"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"If you add a foreground style on the enclosing","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true,"type":"reference"},{"text":", the hierarchical styling responds accordingly:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["VStack(alignment: .leading) {","    Label(\"Primary\", systemImage: \"1.square.fill\")","    Label(\"Secondary\", systemImage: \"2.square.fill\")","        .foregroundStyle(.secondary)","}",".foregroundStyle(.blue)"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"When you apply a custom style to a view, the view disables the vibrancy","type":"text"},{"text":" ","type":"text"},{"text":"effect for foreground elements in that view, or in any of its child","type":"text"},{"text":" ","type":"text"},{"text":"views, that it would otherwise gain from adding a background material","type":"text"},{"text":" ","type":"text"},{"text":"— for example, using the ","type":"text"},{"code":"View\/background(_:ignoresSafeAreaEdges:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"modifier. However, hierarchical styles applied to the default foreground","type":"text"},{"text":" ","type":"text"},{"text":"don’t disable vibrancy.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"role":"symbol","remoteSource":{"fileName":"ForegroundStyleModifier.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Shape\/ShapeStyle\/ForegroundStyleModifier.swift#L112"},"extendedModule":"OpenSwiftUICore","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"title":"foregroundStyle(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"foregroundStyle","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}],"symbolKind":"method","roleHeading":"Instance Method","externalID":"s:15OpenSwiftUICore4ViewPAAE15foregroundStyleyQrqd__AA05ShapeF0Rd__lF::SYNTHESIZED::s:15OpenSwiftUICore5ColorV","platforms":[{"name":"iOS","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"name":"macOS","introducedAt":"10.15","deprecated":false,"unavailable":false,"beta":false},{"name":"tvOS","introducedAt":"13.0","deprecated":false,"un