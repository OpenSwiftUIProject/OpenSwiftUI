xt":" "},{"type":"text","text":"higher priority of the second "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"type":"text","text":" element, even though all of their"},{"type":"text","text":" "},{"type":"text","text":"other attributes (font, font size and character count) are the same."}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A parent layout offers the child views with the highest layout priority"},{"type":"text","text":" "},{"type":"text","text":"all the space offered to the parent minus the minimum space required for"},{"type":"text","text":" "},{"type":"text","text":"all its lower-priority children."}]}]}],"abstract":[{"text":"Sets the priority by which a parent layout should apportion space to","type":"text"},{"text":" ","type":"text"},{"text":"this child.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/color\/layoutpriority(_:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color\/layoutPriority(_:)"},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftui\/view","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"type":"topic","title":"View","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Text":{"url":"\/documentation\/openswiftui\/text","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Te