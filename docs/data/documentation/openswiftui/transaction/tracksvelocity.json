{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/transaction\/tracksvelocity"]}],"metadata":{"platforms":[{"name":"iOS","introducedAt":"13.0","deprecated":false,"beta":false,"unavailable":false},{"name":"macOS","introducedAt":"10.15","deprecated":false,"beta":false,"unavailable":false},{"name":"tvOS","introducedAt":"13.0","deprecated":false,"beta":false,"unavailable":false},{"name":"visionOS","introducedAt":"1.0","deprecated":false,"beta":false,"unavailable":false},{"name":"watchOS","introducedAt":"6.0","deprecated":false,"beta":false,"unavailable":false}],"role":"symbol","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"remoteSource":{"fileName":"VelocityTrackingAnimation.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Animation\/Animation\/VelocityTrackingAnimation.swift#L49"},"title":"tracksVelocity","symbolKind":"property","extendedModule":"OpenSwiftUICore","externalID":"s:15OpenSwiftUICore11TransactionV14tracksVelocitySbvp","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"tracksVelocity"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"roleHeading":"Instance Property"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Transaction"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Transaction\/tracksVelocity"},"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"Whether this transaction will track the velocity of any animatable"},{"type":"text","text":" "},{"type":"text","text":"properties that change."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"tracksVelocity","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"keyword"},{"text":" }","kind":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"This property can be enabled in an interactive context to track velocity","type":"text"},{"text":" ","type":"text"},{"text":"during a user interaction so that when the interaction ends, an","type":"text"},{"text":" ","type":"text"},{"text":"animation can use the accumulated velocities to create animations that","type":"text"},{"text":" ","type":"text"},{"text":"preserve them. This tracking is mutually exclusive with an animation","type":"text"},{"text":" ","type":"text"},{"text":"being used during a view change, since if there is an animation, it is","type":"text"},{"text":" ","type":"text"},{"text":"responsible for managing its own velocity.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Gesture onChanged and updating callbacks automatically set this property"},{"type":"text","text":" "},{"type":"text","text":"to true."}],"type":"paragraph"},{"inlineContent":[{"text":"This example shows an interaction which applies changes, tracking","type":"text"},{"text":" ","type":"text"},{"text":"velocity until the final change, which applies an animation (which will","type":"text"},{"text":" ","type":"text"},{"text":"start with the velocity that was tracked during the previous changes).","type":"text"},{"text":" ","type":"text"},{"text":"These changes could come from a server or from an interactive control","type":"text"},{"text":" ","type":"text"},{"text":"like a slider.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["func receiveChange(change: ChangeInfo) {","    var transaction = Transaction()","    if change.isFinal {","        transaction.animation = .spring","    } else {","        transaction.tracksVelocity = true","    }","    withTransaction(transaction) {","        state.applyChange(change)","    }","}"],"type":"codeListing"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Transaction/tracksVelocity":{"role":"symbol","type":"topic","title":"tracksVelocity","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"tracksVelocity"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Transaction\/tracksVelocity","url":"\/documentation\/openswiftui\/transaction\/tracksvelocity","abstract":[{"type":"text","text":"Whether this transaction will track the velocity of any animatable"},{"type":"text","text":" "},{"type":"text","text":"properties that change."}],"kind":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Transaction":{"type":"topic","navigatorTitle":[{"text":"Transaction","kind":"identifier"}],"title":"Transaction","url":"\/documentation\/openswiftui\/transaction","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Transaction","abstract":[{"text":"The context of the current state-processing update.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Transaction","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]}}}