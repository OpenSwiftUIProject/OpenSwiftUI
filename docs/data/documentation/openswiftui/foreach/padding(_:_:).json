ied edges. If you set the value to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", OpenSwiftUI uses","type":"text"},{"text":" ","type":"text"},{"text":"a platform-specific default amount. The default value of this","type":"text"},{"text":" ","type":"text"},{"text":"parameter is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Return Value","level":2,"type":"heading","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that’s padded by the specified amount on the"},{"type":"text","text":" "},{"type":"text","text":"specified edges."}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to add a specified amount of padding to one or more"},{"type":"text","text":" "},{"type":"text","text":"edges of the view. Indicate the edges to pad by naming either a single"},{"type":"text","text":" "},{"type":"text","text":"value from "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set","isActive":true},{"type":"text","text":", or by specifying an"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/Swift\/OptionSet","isActive":true},{"type":"text","text":" "},{"type":"text","text":"that contains edge values:"}]},{"code":["VStack {","    Text(\"Text padded by 20 points on the bottom and trailing edges.\")","        .padding([.bottom, .trailing], 20)","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The order in which you apply modifiers matters. The example above","type":"text"},{"text":" ","type":"text"},{"text":"applies the padding before applying the border to ensure that the",