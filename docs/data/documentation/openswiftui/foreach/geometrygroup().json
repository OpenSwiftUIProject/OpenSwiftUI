{"abstract":[{"type":"text","text":"Isolates the geometry (e.g. position and size) of the view"},{"type":"text","text":" "},{"type":"text","text":"from its parent view."}],"metadata":{"symbolKind":"method","role":"symbol","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"platforms":[{"name":"iOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"13.0"},{"name":"macOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"10.15"},{"name":"tvOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"13.0"},{"name":"visionOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"1.0"},{"name":"watchOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"6.0"}],"extendedModule":"OpenSwiftUICore","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}],"roleHeading":"Instance Method","externalID":"s:15OpenSwiftUICore4ViewPAAE13geometryGroupQryF::SYNTHESIZED::s:15OpenSwiftUICore7ForEachV","title":"geometryGroup()","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Render\/RendererEffect\/RendererEffect.swift#L294","fileName":"RendererEffect.swift"}},"variants":[{"paths":["\/documentation\/openswiftui\/foreach\/geometrygroup()"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach\/geometryGroup()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"geometryGroup"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"By default OpenSwiftUI views push position and size changes down","type":"text"},{"text":" ","type":"text"},{"text":"through the view hierarchy, so that only views that draw","type":"text"},{"text":" ","type":"text"},{"text":"something (known as leaf views) apply the current animation to","type":"text"},{"text":" ","type":"text"},{"text":"their frame rectangle. However in some cases this coalescing","type":"text"},{"text":" ","type":"text"},{"text":"behavior can give undesirable results; inserting a geometry","type":"text"},{"text":" ","type":"text"},{"text":"group can correct that. A group acts as a barrier between the","type":"text"},{"text":" ","type":"text"},{"text":"parent view and its subviews, forcing the position and size","type":"text"},{"text":" ","type":"text"},{"text":"values to be resolved and animated by the parent, before being","type":"text"},{"text":" ","type":"text"},{"text":"passed down to each subview.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The example below shows one use of this function: ensuring that"},{"type":"text","text":" "},{"type":"text","text":"the member views of each row in the stack apply (and animate"},{"type":"text","text":" "},{"type":"text","text":"as) a single geometric transform from their ancestor view,"},{"type":"text","text":" "},{"type":"text","text":"rather than letting the effects of the ancestor views be"},{"type":"text","text":" "},{"type":"text","text":"applied separately to each leaf view. If the members of"},{"type":"text","text":" "},{"type":"codeVoice","code":"ItemView"},{"type":"text","text":" may be added and removed at different times the"},{"type":"text","text":" "},{"type":"text","text":"group ensures that they stay locked together as animations are"},{"type":"text","text":" "},{"type":"text","text":"applied."}],"type":"paragraph"},{"code":["VStack {","    ForEach(items) { item in","        ItemView(item: item)","            .geometryGroup()","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Returns: a new view whose geometry is isolated from that of its"},{"type":"text","text":" "},{"type":"text","text":"parent view."}],"type":"paragraph"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ForEach/geometryGroup()":{"abstract":[{"type":"text","text":"Isolates the geometry (e.g. position and size) of the view"},{"type":"text","text":" "},{"type":"text","text":"from its parent view."}],"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"geometryGroup"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"}],"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach\/geometryGroup()","title":"geometryGroup()","type":"topic","url":"\/documentation\/openswiftui\/foreach\/geometrygroup()"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"url":"\/documentation\/openswiftui\/view","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ForEach":{"abstract":[{"text":"A structure that computes views on demand from an underlying collection of","type":"text"},{"text":" ","type":"text"},{"text":"identified data.","type":"text"}],"type":"topic","role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ForEach","kind":"identifier"}],"navigatorTitle":[{"text":"ForEach","kind":"identifier"}],"title":"ForEach","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach","url":"\/documentation\/openswiftui\/foreach"}}}