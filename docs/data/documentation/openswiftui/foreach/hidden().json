        .hidden()","    Image(systemName: \"d.circle.fill\")","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The third circle takes up space, because it’s still present, but","type":"text"},{"text":" ","type":"text"},{"text":"OpenSwiftUI doesn’t draw it onscreen.","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to conditionally include a view in the view hierarchy, use"},{"type":"text","text":" "},{"type":"text","text":"an "},{"code":"if","type":"codeVoice"},{"type":"text","text":" statement instead:"}]},{"type":"codeListing","code":["VStack {","    HStack {","        Image(systemName: \"a.circle.fill\")","        Image(systemName: \"b.circle.fill\")","        if !isHidden {","            Image(systemName: \"c.circle.fill\")","        }","        Image(systemName: \"d.circle.fill\")","    }","    Toggle(\"Hide\", isOn: $isHidden)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Depending on the current value of the "},{"code":"isHidden","type":"codeVoice"},{"type":"text","text":" state variable in the"},{"type":"text","text":" "},{"type":"text","text":"example above, controlled by the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference","isActive":true},{"type":"text","text":" instance, OpenSwiftUI draws"},{"type":"text","text":" "},{"type":"text","text":"the circle or completely omits it from the layout."}]},{"type":"paragraph","inlineContent":[]}]}],"metadata":{"roleHeading":"Instance Method","platforms":[{"unavailable":false,"introducedAt":"13.0","beta":false,"deprecated":false,"name":"iOS"},{"unavailable":false,"introducedAt":"10.15","beta":false,"deprecated":false,"name":"macOS"},{"unavailable":false,"introducedAt":"13.0","beta":false,"deprecated":false,"name":"tvOS"},{"unavailable":false,"introducedAt":"1.0","beta":false,"deprecated":false,"name":"visionOS"},{"unavailable":false,"intr