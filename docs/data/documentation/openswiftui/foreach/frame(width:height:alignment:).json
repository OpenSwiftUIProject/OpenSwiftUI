xt"},{"text":"that height, and whatever width the layout system offers to its parent.","type":"text"}],"type":"paragraph"},{"code":["VStack {","    Ellipse()","        .fill(Color.purple)","        .frame(width: 200, height: 100)","    Ellipse()","        .fill(Color.blue)","        .frame(height: 100)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"The alignment"},{"type":"text","text":" parameter specifies this view’s alignment within the"},{"type":"text","text":" "},{"type":"text","text":"frame."}],"type":"paragraph"},{"code":["Text(\"Hello world!\")","    .frame(width: 200, height: 30, alignment: .topLeading)","    .border(Color.gray)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"In the example above, the text is positioned at the top, leading corner","type":"text"},{"text":" ","type":"text"},{"text":"of the frame. If the text is taller than the frame, its bounds may","type":"text"},{"text":" ","type":"text"},{"text":"extend beyond the bottom of the frame’s bounds.","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach"]]},"sections":[],"metadata":{"remoteSource":{"fileName":"FrameLayout.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Modifier\/FrameLayout.swift#L167"},"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"extendedModule":"OpenSwiftUICore","platforms":[{"name":"iOS","introducedAt":"13.0","beta":false,"unavailable":false,"deprecated":false},{"name":"macOS","introducedAt":"10.15","beta":false,"unavailable":false,"deprecated":false},{"beta":false,"unavailable":false,"name":"tvOS","deprecated":false,"introducedAt":"13.0"},{"beta":false,"unavailable":false,"name":"visionOS","deprecated":false,"introducedAt":"1.