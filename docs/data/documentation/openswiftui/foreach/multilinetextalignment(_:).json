kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to set an alignment for a multiline block of text."},{"type":"text","text":" "},{"type":"text","text":"For example, the modifier centers the contents of the following"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference"},{"type":"text","text":" view:"}]},{"type":"codeListing","syntax":"swift","code":["Text(\"This is a block of text that shows up in a text element as multiple lines.\\(\"\\n\") Here we have chosen to center this text.\")","    .frame(width: 200)","    .multilineTextAlignment(.center)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The text in the above example spans more than one line because:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The newline character introduces a line break."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The frame modifier limits the space available to the text view, and"},{"type":"text","text":" "},{"type":"text","text":"by default a text view wraps lines that don’t fit in the available"},{"type":"text","text":" "},{"type":"text","text":"width. As a result, the text before the explicit line break wraps to"},{"type":"text","text":" "},{"type":"text","text":"three lines, and the text after uses two lines."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"The modifier applies the alignment to the all the lines of text in","type":"text"},{"text":" ","type":"text"},{"text":"the view, regardless of why wrapping occurs:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"The modifier has no effect on a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"text":" view that contains only one","type":"text"},{"text":" ","type":"text"},{"text":"line of text, because a text view has a width that exactly matches the","type":"text"},{"text":" ","type":"text"},{"text":"width of its widest line. If you want to align an entire text view","type":"text"},{"text":" ","type":"text"},{"text":"rather than its contents, set the aligment of its container, like a","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"text":" or a frame that you create with the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/frame(minWidth:idealWidth:maxWidth:minHeight:idealHeight:maxHeight:alignment:)"},{"text":" ","type":"text"},{"text":"modifier.","type":"text"}]},{"style":"note","content":[{"inlineContent":[{"type":"text","text":"You can use this modifier to control the alignment of a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" "},{"type":"text","text":"view that you create with the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/init(_:style:)"},{"type":"text","text":" initializer"},{"type":"text","text":" "},{"type":"text","text":"to display localized dates and times, including when the view uses"},{"type":"text","text":" "},{"type":"text","text":"only a single line, but only when that view appears in a widget."}],"type":"paragraph"}],"type":"aside","name":"Note"},{"type":"paragraph","inlineContent":[{"text":"The modifier also affects the content alignment of other text container","type":"text"},{"text":" ","type":"text"},{"text":"types, like ","type":"text"},{"type":"codeVoice","code":"TextEditor"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"TextField"},{"text":". In those cases, the","type":"text"},{"text":" ","type":"text"},{"text":"modifier sets the alignment even when the view contains only a single","type":"text"},{"text":" ","type":"text"},{"text":"line because view’s width isn’t dictated by the width of the text it","type":"text"},{"text":" ","type":"text"},{"text":"contains.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier operates by setting the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/multilineTextAlignment"},{"type":"text","text":" value in the environment,"},{"type":"text","text":" "},{"type":"text","text":"so it affects all the text containers in the modified view hierarchy."},{"type":"text","text":" "},{"type":"text","text":"For example, you can apply the modifier to a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"configure all the text views inside the stack."}]}]}],"metadata":{"externalID":"s:15OpenSwiftUICore4ViewPAAE22multilineTextAlignmentyQrAA0fG0OF::SYNTHESIZED::s:15OpenSwiftUICore7ForEachV","title":"multilineTextAlignment(_:)","role":"symbol","symbolKind":"method","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"platforms":[{"beta":false,"name":"iOS","introducedAt":"13.0","unavailable":false,"deprecated":false},{"beta":false,"name":"macOS","introducedAt":"10.15","unavailable":false,"deprecated":false},{"beta":false,"name":"tvOS","introducedAt":"13.0","unavailable":false,"deprecated":false},{"beta":false,"name":"visionOS","introducedAt":"1.0","unavailable":false,"deprecated":false},{"beta":false,"name":"watchOS","introducedAt":"6.0","unavailable":false,"deprecated":false}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"multilineTextAlignment","kind":"identifier"},{"text":"(","k