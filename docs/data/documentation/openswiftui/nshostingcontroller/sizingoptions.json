{"sections":[],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingController"]]},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingController\/sizingOptions","interfaceLanguage":"swift"},"abstract":[{"text":"The options for how the hosting controller’s view creates and updates","type":"text"},{"text":" ","type":"text"},{"text":"constraints based on the size of its SwiftUI content.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sizingOptions"},{"kind":"text","text":": "},{"preciseIdentifier":"s:11OpenSwiftUI22NSHostingSizingOptionsV","kind":"typeIdentifier","text":"NSHostingSizingOptions","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingSizingOptions"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" "},{"kind":"keyword","text":"set"},{"kind":"text","text":" }"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"text":"NSHostingController can create minimum, maximum, and ideal (content","type":"text"},{"text":" ","type":"text"},{"text":"size) constraints that are derived from its SwiftUI view content. These","type":"text"},{"text":" ","type":"text"},{"text":"constraints are only created when Auto Layout constraints are otherwise","type":"text"},{"text":" ","type":"text"},{"text":"being used in the containing window.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the NSHostingController is set as the "},{"type":"codeVoice","code":"contentViewController"},{"type":"text","text":" of an"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSWindow"},{"type":"text","text":", it will also update the window’s "},{"type":"codeVoice","code":"contentMinSize"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"codeVoice","code":"contentMaxSize"},{"type":"text","text":" based on the minimum and maximum size of its SwiftUI"},{"type":"text","text":" "},{"type":"text","text":"content."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"sizingOptions"},{"type":"text","text":" defaults to "},{"type":"codeVoice","code":".standardBounds"},{"type":"text","text":" (which includes"},{"type":"text","text":" "},{"type":"codeVoice","code":"minSize"},{"type":"text","text":", "},{"type":"codeVoice","code":"intrinsicContentSize"},{"type":"text","text":", and "},{"type":"codeVoice","code":"maxSize"},{"type":"text","text":"), but can be set to an"},{"type":"text","text":" "},{"type":"text","text":"explicit value to control this behavior. For instance, setting a value"},{"type":"text","text":" "},{"type":"text","text":"of "},{"type":"codeVoice","code":".minSize"},{"type":"text","text":" will only create the constraints necessary to maintain the"},{"type":"text","text":" "},{"type":"text","text":"minimum size of the SwiftUI content, or setting a value of "},{"type":"codeVoice","code":"[]"},{"type":"text","text":" will"},{"type":"text","text":" "},{"type":"text","text":"create no constraints at all."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a use case can make assumptions about the size of the"},{"type":"text","text":" "},{"type":"codeVoice","code":"NSHostingController"},{"type":"text","text":" relative to its displayed content, such as the"},{"type":"text","text":" "},{"type":"text","text":"always being displayed in a fixed frame, setting this to a value with"},{"type":"text","text":" "},{"type":"text","text":"fewer options can improve performance as it reduces the amount of layout"},{"type":"text","text":" "},{"type":"text","text":"measurements that need to be performed. If an "},{"type":"codeVoice","code":"NSHostingController"},{"type":"text","text":" has"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":"frame"},{"type":"text","text":" that is smaller or larger than that required to display its"},{"type":"text","text":" "},{"type":"text","text":"SwiftUI content, the content will be centered within that frame."}],"type":"paragraph"}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/openswiftui\/nshostingcontroller\/sizingoptions"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"externalID":"s:11OpenSwiftUI19NSHostingControllerC13sizingOptionsAA0d6SizingG0Vvp","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizingOptions","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:11OpenSwiftUI22NSHostingSizingOptionsV","text":"NSHostingSizingOptions","kind":"typeIdentifier"}],"modules":[{"name":"OpenSwiftUI"}],"roleHeading":"Instance Property","role":"symbol","title":"sizingOptions","platforms":[],"symbolKind":"property","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/Integration\/Hosting\/AppKit\/Controller\/NSHostingController.swift#L117","fileName":"NSHostingController.swift"}},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/NSHostingSizingOptions":{"url":"\/documentation\/openswiftui\/nshostingsizingoptions","kind":"symbol","title":"NSHostingSizingOptions","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"NSHostingSizingOptions"}],"abstract":[{"type":"text","text":"Options for how hosting views and controllers reflect their"},{"type":"text","text":" "},{"type":"text","text":"content’s size into Auto Layout constraints."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingSizingOptions","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"NSHostingSizingOptions"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/NSHostingController":{"type":"topic","role":"symbol","url":"\/documentation\/openswiftui\/nshostingcontroller","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"NSHostingController"}],"navigatorTitle":[{"kind":"identifier","text":"NSHostingController"}],"title":"NSHostingController","kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingController","abstract":[{"type":"text","text":"An AppKit view controller that hosts SwiftUI view hierarchy."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/NSHostingController/sizingOptions":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingController\/sizingOptions","abstract":[{"type":"text","text":"The options for how the hosting controller’s view creates and updates"},{"type":"text","text":" "},{"type":"text","text":"constraints based on the size of its SwiftUI content."}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizingOptions","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:11OpenSwiftUI22NSHostingSizingOptionsV","text":"NSHostingSizingOptions","kind":"typeIdentifier"}],"kind":"symbol","role":"symbol","type":"topic","url":"\/documentation\/openswiftui\/nshostingcontroller\/sizingoptions","title":"sizingOptions"}}}