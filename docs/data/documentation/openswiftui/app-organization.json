{"metadata":{"modules":[{"name":"OpenSwiftUI"}],"role":"collectionGroup","title":"App organization","roleHeading":"API Collection"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Describe your app’s structure declaratively, much like you declare a view’s"},{"type":"text","text":" "},{"type":"text","text":"appearance. Create a type that conforms to the App protocol and use it to"},{"type":"text","text":" "},{"type":"text","text":"enumerate the Scenes that represent aspects of your app’s user interface."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenSwiftUI enables you to write code that works across all of Apple’s"},{"type":"text","text":" "},{"type":"text","text":"platforms, Linux and Windows. However, it also enables you to tailor your app to"},{"type":"text","text":" "},{"type":"text","text":"the specific capabilities of each platform. For example, if you need to respond"},{"type":"text","text":" "},{"type":"text","text":"to the callbacks that the system traditionally makes on a UIKit, AppKit, or"},{"type":"text","text":" "},{"type":"text","text":"WatchKit app’s delegate, define a delegate object and instantiate it in your app"},{"type":"text","text":" "},{"type":"text","text":"structure using an appropriate delegate adaptor property wrapper, like"},{"type":"text","text":" "},{"type":"codeVoice","code":"UIApplicationDelegateAdaptor"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"For platform-specific design guidance, see ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/platforms","type":"reference"},{"text":" ","type":"text"},{"text":"in the Human Interface Guidelines for Apple Platform and","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/learn.microsoft.com\/windows\/apps\/design","type":"reference"},{"text":" ","type":"text"},{"text":"for Windows.","type":"text"}]}]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"title":"Creating an app","anchor":"Creating-an-app","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/App"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/app-organization"]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/App-Organization","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"kind":"article","abstract":[{"text":"Define the entry point and top-level structure of your app.","type":"text"}],"sections":[],"references":{"https://learn.microsoft.com/windows/apps/design":{"title":"Windows Design Documentation","identifier":"https:\/\/learn.microsoft.com\/windows\/apps\/design","url":"https:\/\/learn.microsoft.com\/windows\/apps\/design","type":"link","titleInlineContent":[{"text":"Windows Design Documentation","type":"text"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/App":{"title":"App","url":"\/documentation\/openswiftui\/app","type":"topic","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/App","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"App"}],"abstract":[{"type":"text","text":"A type that represents the structure and behavior of an app."}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"App"}]},"https://developer.apple.com/design/human-interface-guidelines/platforms":{"title":"Platforms","identifier":"https:\/\/developer.apple.co