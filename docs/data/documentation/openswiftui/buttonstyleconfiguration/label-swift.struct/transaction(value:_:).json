xt":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that wraps this view and applies a transformation to"},{"type":"text","text":" "},{"type":"text","text":"all transactions used within the view whenever "},{"type":"codeVoice","code":"value"},{"type":"text","text":" changes."}]}],"kind":"content"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier to change or replace the animation used in a view.","type":"text"},{"text":" ","type":"text"},{"text":"Consider three identical views controlled by a","type":"text"},{"text":" ","type":"text"},{"text":"button that changes all three simultaneously:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The first view animates rotating the “Rotation” "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" view by 360"},{"type":"text","text":" "},{"type":"text","text":"degrees."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The second uses the "},{"code":"transaction(_:)","type":"codeVoice"},{"type":"text","text":" modifier to change the"},{"type":"text","text":" "},{"type":"text","text":"animation by adding a delay to the start of the animation"},{"type":"text","text":" "},{"type":"text","text":"by two seconds and then increases the rotational speed of the"},{"type":"text","text":" "},{"type":"text","text":"“Rotation\\nModified” "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"type":"text","text":" view animation by a factor of 2."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The third uses the ","type":"text"},{"code":"transaction(_:)","type":"codeVoice"},{"text":" modifier to disable animations","type":"text"},{"text":" ","type":"text"},{"text":"affecting the “Animation\\nReplaced” ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference"},{"text":" view.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code implements these animations:"}]},{"syntax":"swift","type":"codeListing","code":["struct TransactionExample: View {","    @State var flag = false","","    var body: some View {","        VStack(spacing: 50) {","            HStack(spacing: 30) {","                Text(\"Rotation\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","","                Text(\"Rotation\\nModified\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","                    .transaction(value: flag) { t in","                        t.animation =","                            t.animation?.delay(2.0).speed(2)","                    }","","                Text(\"Animation\\nReplaced\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","                    .transaction(value: flag) { t in","                        t.disableAnimations = true","                    }","            }","","            Button(\"Animate\") {","                withAnimation(.easeIn(duration: 2.0)) {","                    flag.toggle()","                }","            }","        }","    }","}"]}],"kind":"content"}],"abstract":[{"text":"Applies the given transaction mutation function to all animations used","type":"text"},{"text":" ","type":"text"},{"text":"within the view.","type":"text"}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ButtonStyleConfiguration\/Label-swift.struct\/transaction(value:_:)","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/openswiftui\/buttonstyleconfiguration\/label-swift.struct\/transaction(value:_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OpenSwiftUI/documentati