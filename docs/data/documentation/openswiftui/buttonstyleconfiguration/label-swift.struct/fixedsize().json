\")","    .frame(width: 200, height: 200)","    .border(Color.gray)"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"fixedSize()","type":"codeVoice"},{"type":"text","text":" modifier can be used to create a view that maintains"},{"type":"text","text":" "},{"type":"text","text":"the "},{"inlineContent":[{"type":"text","text":"ideal size"}],"type":"emphasis"},{"type":"text","text":" of its children both dimensions:"}]},{"syntax":"swift","type":"codeListing","code":["Text(\"A single line of text, too long to fit in a box.\")","    .fixedSize()","    .frame(width: 200, height: 200)","    .border(Color.gray)"]},{"type":"paragraph","inlineContent":[{"text":"This can result in the view exceeding the parent’s bounds, which may or","type":"text"},{"text":" ","type":"text"},{"text":"may not be the effect you want.","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"You can think of ","type":"text"},{"code":"fixedSize()","type":"codeVoice"},{"text":" as the creation of a ","type":"text"},{"inlineContent":[{"text":"counter proposal","type":"text"}],"type":"emphasis"},{"text":" ","type":"text"},{"text":"to the view size proposed to a view by its parent. The ideal size of a","type":"text"},{"text":" ","type":"text"},{"text":"view, and the specific effects of ","type":"text"},{"code":"fixedSize()","type":"codeVoice"},{"text":" depends on the","type":"text"},{"text":" ","type":"text"},{"text":"particular view and how you have configured it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a view that fixes the view’s size in either the horizontal or"},{"type":"text","text":" "},{"type":"text","text":"vertical dimensions, see "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)","type":"reference","isActive":true},{"type":"text","text":"."}]}]}],"kind":"symbol","schemaVersi