{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/buttonstyleconfiguration\/label-swift.struct\/padding(_:_:)"]}],"abstract":[{"type":"text","text":"Adds an equal padding amount to specific edges of this view."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"padding"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"edges"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Edge","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge","preciseIdentifier":"s:15OpenSwiftUICore4EdgeO"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Set","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set","preciseIdentifier":"s:15OpenSwiftUICore4EdgeO3SetV"},{"kind":"text","text":" = .all, "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"length"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV"},{"kind":"text","text":"? = nil) -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"name":"edges","content":[{"type":"paragraph","inlineContent":[{"text":"The set of edges to pad for this view. The default","type":"text"},{"text":" ","type":"text"},{"text":"is ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set\/all"},{"text":".","type":"text"}]}]},{"name":"length","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An amount, given in points, to pad this view on the"},{"type":"text","text":" "},{"type":"text","text":"specified edges. If you set the value to "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", OpenSwiftUI uses"},{"type":"text","text":" "},{"type":"text","text":"a platform-specific default amount. The default value of this"},{"type":"text","text":" "},{"type":"text","text":"parameter is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":"."}]}]}]},{"content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"inlineContent":[{"text":"A view that’s padded by the specified amount on the","type":"text"},{"text":" ","type":"text"},{"text":"specified edges.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to add a specified amount of padding to one or more"},{"type":"text","text":" "},{"type":"text","text":"edges of the view. Indicate the edges to pad by naming either a single"},{"type":"text","text":" "},{"type":"text","text":"value from "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set"},{"type":"text","text":", or by specifying an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/Swift\/OptionSet"},{"type":"text","text":" "},{"type":"text","text":"that contains edge values:"}]},{"syntax":"swift","type":"codeListing","code":["VStack {","    Text(\"Text padded by 20 points on the bottom and trailing edges.\")","        .padding([.bottom, .trailing], 20)","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The order in which you apply modifiers matte