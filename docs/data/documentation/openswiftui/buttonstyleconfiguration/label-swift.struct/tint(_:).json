{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","abstract":[{"text":"Sets the tint color within this view.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/buttonstyleconfiguration\/label-swift.struct\/tint(_:)"]}],"sections":[],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ButtonStyleConfiguration\/Label-swift.struct\/tint(_:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"tint","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"tint","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Color","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","preciseIdentifier":"s:15OpenSwiftUICore5ColorV","kind":"typeIdentifier"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"parameters":[{"name":"tint","content":[{"inlineContent":[{"type":"text","text":"The tint "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","type":"reference","isActive":true},{"type":"text","text":" to apply."}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Use this method to override the default accent color for this view."},{"type":"text","text":" "},{"type":"text","text":"Unlike an app’s accent color, which can be overridden by user"},{"type":"text","text":" "},{"type":"text","text":"preference, the tint color is always respected and should be used as a"},{"type":"text","text":" "},{"type":"text","text":"way to provide additional meaning to the control."}],"type":"paragraph"},{"inlineContent":[{"text":"This example shows Answer and Decline buttons with ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/green"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/red"},{"text":" tint colors, respectively.","type":"text"}],"type":"paragraph"},{"code":["struct ControlTint: View {","    var body: some View {","        HStack {","            Button {","                \/\/ Answer the call","            } label: {","                Label(\"Answer\", systemImage: \"phone\")","            }","            .tint(.green)","            Button {","                \/\/ Decline the call","            } label: {","                Label(\"Decline\", systemImage: \"phone.down\")","            }","            .tint(.red)","        }","        .buttonStyle(.borderedProminent)","        .padding()","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Some controls adapt to the tint color differently based on their style,"},{"type":"text","text":" "},{"type":"text","text":"the current platform, and the surrounding context. For example, in"},{"type":"text","text":" "},{"type":"text","text":"macOS, a button with the "},{"type":"codeVoice","code":"PrimitiveButtonStyle\/bordered"},{"type":"text","text":" style doesn’t"},{"type":"text","text":" "},{"type":"text","text":"tint its background, but one with the"},{"type":"text","text":" "},{"type":"codeVoice","code":"PrimitiveButtonStyle\/borderedProminent"},{"type":"text","text":" style does. In macOS, neither"},{"type":"text","text":" "},{"type":"text","text":"of these button styles tint their label, but they do in other platforms."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ButtonStyleConfiguration","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ButtonStyleConfiguration\/Label-swift.struct"]]},"metadata":{"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"externalID":"s:15OpenSwiftUICore4ViewPAAE4tintyQrAA5ColorVSgF::SYNTHESIZED::s:11OpenSwiftUI24ButtonStyleConfigurationV5LabelV","extendedModule":"OpenSwiftUICore","role":"symbol","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"tint","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore5ColorV","text":"Color","kind":"typeIdentifier"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}],"platforms":[{"unavailable":false,"introducedAt":"13.0","beta":false,"name":"iOS","deprecated":false},{"unavailable":false,"introducedAt":"10.15","beta":false,"name":"macOS","deprecated":false},{"unavailable":false,"introducedAt":"13.0","beta":false,"name":"tvOS","deprecated":false},{"unavailable":false,"introducedAt":"1.0","beta":false,"name":"visionOS","deprecated":false},{"unavailable":false,"introducedAt":"6.0","beta":false,"name":"watchOS","deprecated":false}],"symbolKind":"method","title":"tint(_:)","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Shape\/Tint.swift#L134","fileName":"Tint.swift"}},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text"