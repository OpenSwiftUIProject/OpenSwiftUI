,"                var receivedLines = [String]()","                for try await line in url.lines {","                    receivedLines.append(line)","                    message = \"Received \\(receivedLines.count) lines\"","                }","            } catch {","                message = \"Failed to load\"","            }","        }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example uses the"},{"type":"text","text":" "},{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url\/3767315-lines","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"method to get the content stored at the specified"},{"type":"text","text":" "},{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url","isActive":true,"type":"reference"},{"type":"text","text":" as an"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence of strings. When each new line arrives, the body"},{"type":"text","text":" "},{"type":"text","text":"of the "},{"code":"for","type":"codeVoice"},{"type":"text","text":"-"},{"code":"await","type":"codeVoice"},{"type":"text","text":"-"},{"code":"in","type":"codeVoice"},{"type":"text","text":" loop stores the line in an array of strings"},{"type":"text","text":" "},{"type":"text","text":"and updates the content of the text view to report the latest line"},{"type":"text","text":" "},{"type":"text","text":"count."}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ButtonStyleConfiguration\/Label-swift.struct\/task(priority:_:)"},"kind":"symbol","abstract":[{"type":"text","text":"Adds an asynchronous task to perform before this view appears."}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ButtonStyleConfiguration","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ButtonStyleConfiguration\/Label-swift.struct