ng string.\")","        .font(.largeTitle)","        .border(Color.gray)","","    Spacer()","","    Text(\"This is a higher priority string.\")","        .font(.largeTitle)","        .layoutPriority(1)","        .border(Color.gray)","}"]},{"type":"paragraph","inlineContent":[{"text":"In the example above, the first ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"text":" element has the default","type":"text"},{"text":" ","type":"text"},{"text":"priority ","type":"text"},{"type":"codeVoice","code":"0"},{"text":" which causes its view to shrink dramatically due to the","type":"text"},{"text":" ","type":"text"},{"text":"higher priority of the second ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"text":" element, even though all of their","type":"text"},{"text":" ","type":"text"},{"text":"other attributes (font, font size and character count) are the same.","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"A parent layout offers the child views with the highest layout priority","type":"text"},{"text":" ","type":"text"},{"text":"all the space offered to the parent minus the minimum space required for","type":"text"},{"text":" ","type":"text"},{"text":"all its lower-priority children.","type":"text"}]}],"kind":"content"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ButtonStyleConfiguration/Label-swift.struct":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ButtonStyleConfiguration\/Label-swift.struct","type":"top