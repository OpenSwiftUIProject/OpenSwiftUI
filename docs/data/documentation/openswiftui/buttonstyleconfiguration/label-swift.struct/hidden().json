{"schemaVersion":{"patch":0,"minor":3,"major":0},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ButtonStyleConfiguration","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ButtonStyleConfiguration\/Label-swift.struct"]]},"abstract":[{"type":"text","text":"Hides this view unconditionally."}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"hidden"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"A hidden view."}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Hidden views are invisible and can’t receive or respond to interactions.","type":"text"},{"text":" ","type":"text"},{"text":"However, they do remain in the view hierarchy and affect layout. Use","type":"text"},{"text":" ","type":"text"},{"text":"this modifier if you want to include a view for layout purposes, but","type":"text"},{"text":" ","type":"text"},{"text":"don’t want it to display.","type":"text"}]},{"type":"codeListing","code":["HStack {","    Image(systemName: \"a.circle.fill\")","    Image(systemName: \"b.circle.fill\")","    Image(systemName: \"c.circle.fill\")","        .hidden()","    Image(systemName: \"d.circle.fill\")","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The third circle takes up space, because it’s still present, but"},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI doesn’t draw it onscreen."}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to conditionally include a view in the view hierarchy, use"},{"type":"text","text":" "},{"type":"text","text":"an "},{"type":"codeVoice","code":"if"},{"type":"text","text":" statement instead:"}]},{"type":"codeListing","code":["VStack {","    HStack {","        Image(systemName: \"a.circle.fill\")","        Image(systemName: \"b.circle.fill\")","        if !isHidden {","            Image(systemName: \"c.circle.fill\")","        }","        Image(systemName: \"d.circle.fill\")","    }","    Toggle(\"Hide\", isOn: $isHidden)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Depending on the current value of the "},{"type":"codeVoice","code":"isHidden"},{"type":"text","text":" state variable in the"},{"type":"text","text":" "},{"type":"text","text":"example above, controlled by the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle"},{"type":"text","text":" instance, OpenSwiftUI draws"},{"type":"text","text":" "},{"type":"text","text":"the circle or completely omits it from the layout."}]},{"type":"paragraph","inlineContent":[]}]}],"variants":[{"paths":["\/documentation\/openswiftui\/buttonstyleconfiguration\/label-swift.struct\/hidden()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ButtonStyleConfiguration\/Label-swift.struct\/hidden()"},"metadata":{"externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE6hiddenQryF::SYNTHESIZED::s:11OpenSwiftUI24ButtonStyleConfigurationV5LabelV","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"hidden"},{"kind":"text"