pe":"text"},{"text":" ","type":"text"},{"text":"to the initializer. It selects the first child whose ideal size on the","type":"text"},{"text":" ","type":"text"},{"text":"constrained axes fits within the proposed size. This means that you","type":"text"},{"text":" ","type":"text"},{"text":"provide views in order of preference. Usually this order is largest to","type":"text"},{"text":" ","type":"text"},{"text":"smallest, but since a view might fit along one constrained axis but not the","type":"text"},{"text":" ","type":"text"},{"text":"other, this isn’t always the case. By default, ","type":"text"},{"code":"ViewThatFits","type":"codeVoice"},{"text":" constrains","type":"text"},{"text":" ","type":"text"},{"text":"in both the horizontal and vertical axes.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows an "},{"type":"codeVoice","code":"UploadProgressView"},{"type":"text","text":" that uses "},{"type":"codeVoice","code":"ViewThatFits"},{"type":"text","text":" "},{"type":"text","text":"to display the upload progress in one of three ways. In order, it attempts"},{"type":"text","text":" "},{"type":"text","text":"to display:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"An "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","type":"reference","isActive":true},{"type":"text","text":" that contains a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"type":"text","text":" view and a "},{"type":"codeVoice","code":"ProgressView"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Only the ","type":"text"},{"code":"ProgressView","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Only the "},{"type":"codeVoice","code":"Text"},{"type":"text","text":" view."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The progress views are fixed to a 100-point width.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct UploadProgressView: View {","    var uploadProgress: Double","","    var body: some View {","        ViewThatFits(in: .horizontal) {","            HStack {","                Text(\"\\(uploadProgress.formatted(.percent))\")","                ProgressView(value: uploadProgress)","                    .frame(width: 100)","            }","            ProgressView(value: uploadProgress)","                .frame(width: 100)","            Text(\"\\(uploadProgress.formatted(.percent))\")","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This use of "},{"type":"codeVoice","code":"ViewThatFits"},{"type":"text","text":" evaluates sizes only on the horizontal axis. The"},{"type":"text","text":" "},{"type":"text","text":"following code fits the "},{"type":"codeVoice","code":"UploadProgressView"},{"type":"text","text":" to several fixed widths:"}]},{"type":"codeListing","syntax":"swift","code":["VStack {","    UploadProgressView(uploadProgress: 0.75)","        .frame(maxWidth: 200)","    UploadProgressView(uploadProgress: 0.75)","        .frame(maxWidth: 100)","    UploadProgressView(uploadProgress: 0.75)","        .frame(maxWidth: 50)","}"]},{"type":"paragraph","inlineContent":[]}]}],"metadata":{"role":"symbol","roleHeading":"Structure","title":"ViewThatFits","modules":[{"name":"OpenSwiftUI"}],"remoteSource":{"fileName":"ViewThatFits.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/Layout\/ViewThatFits.swift#L66"},"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewThatFits","kind":"identifier"}],"externalID":"s:11OpenSwiftUI12ViewThatFitsV","navigatorTitle":[{"text":"ViewThatFits","kind":"identifier"}],"symbolKind":"struct"},"sections":[],"abstract":[{"type":"text","text":"A view that adapts to