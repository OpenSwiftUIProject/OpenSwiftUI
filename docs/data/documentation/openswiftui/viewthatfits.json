{"metadata":{"externalID":"s:11OpenSwiftUI12ViewThatFitsV","title":"ViewThatFits","modules":[{"name":"OpenSwiftUI"}],"roleHeading":"Structure","symbolKind":"struct","role":"symbol","remoteSource":{"fileName":"ViewThatFits.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/Layout\/ViewThatFits.swift#L66"},"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ViewThatFits"}],"navigatorTitle":[{"text":"ViewThatFits","kind":"identifier"}]},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"abstract":[{"text":"A view that adapts to the available space by providing the first","type":"text"},{"text":" ","type":"text"},{"text":"child view that fits.","type":"text"}],"relationshipsSections":[{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewThatFits","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"code":"ViewThatFits","type":"codeVoice"},{"text":" evaluates its child views in the order you provide them","type":"text"},{"text":" ","type":"text"},{"text":"to the initializer. It selects the first child whose ideal size on the","type":"text"},{"text":" ","type":"text"},{"text":"constrained axes fits within the proposed size. This means that you","type":"text"},{"text":" ","type":"text"},{"text":"provide views in order of preference. Usually this order is largest to","type":"text"},{"text":" ","type":"text"},{"text":"smallest, but since a view might fit along one constrained axis but not the","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"other, this isn’t always the case. By default, "},{"type":"codeVoice","code":"ViewThatFits"},{"type":"text","text":" constrains"},{"type":"text","text":" "},{"type":"text","text":"in both the horizontal and vertical axes."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows an "},{"type":"codeVoice","code":"UploadProgressView"},{"type":"text","text":" that uses "},{"type":"codeVoice","code":"ViewThatFits"},{"type":"text","text":" "},{"type":"text","text":"to display the upload progress in one of three ways. In order, it attempts"},{"type":"text","text":" "},{"type":"text","text":"to display:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"An "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","isActive":true},{"type":"text","text":" that contains a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" view and a "},{"code":"ProgressView","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Only the ","type":"text"},{"type":"codeVoice","code":"ProgressView"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Only the "},{"type":"codeVoice","code":"Text"},{"type":"text","text":" view."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The progress views are fixed to a 100-point width."}]},{"type":"codeListing","code":["struct UploadProgressView: View {","    var uploadProgress: Double","","    var body: some View {","        ViewThatFits(in: .horizontal) {","            HStack {","                Text(\"\\(uploadProgress.formatted(.percent))\")","                ProgressView(value: uploadProgress)","                    .frame(width: 100)","            }","            ProgressView(value: uploadProgress)","                .frame(width: 100)","            Text(\"\\(uploadProgress.formatted(.percent))\")","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This use of "},{"code":"ViewThatFits","type":"codeVoice"},{"type":"text","text":" evaluates sizes only on the horizontal axis. The"},{"type":"text","text":" "},{"type":"text","text":"following code fits the "},{"code":"UploadProgressView","type":"codeVoice"},{"type":"text","text":" to several fixed widths:"}]},{"type":"codeListing","code":["VStack {","    UploadProgressView(uploadProgress: 0.75)","        .frame(maxWidth: 200)","    UploadProgressView(uploadProgress: 0.75)","        .frame(maxWidth: 100)","    UploadProgressView(uploadProgress: 0.75)","        .frame(maxWidth: 50)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/viewthatfits"]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewThatFits"},"topicSections":[{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewThatFits\/init(in:content:)"],"generated":true,"anchor":"Initializers","title":"Initializers"},{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewThatFits\/Body"],"generated":true,"anch