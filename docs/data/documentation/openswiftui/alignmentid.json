{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"seeAlsoSections":[{"anchor":"Aligning-views","generated":true,"title":"Aligning views","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions"]}],"abstract":[{"type":"text","text":"A type that you use to create custom alignment guides."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AlignmentID","kind":"identifier"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every built-in alignment guide that "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","isActive":true,"type":"reference"},{"type":"text","text":" or"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","isActive":true,"type":"reference"},{"type":"text","text":" defines as a static property, like"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/top","isActive":true,"type":"reference"},{"type":"text","text":" or "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/leading","isActive":true,"type":"reference"},{"type":"text","text":", has a"},{"type":"text","text":" "},{"type":"text","text":"unique alignment identifier type that produces the default offset for"},{"type":"text","text":" "},{"type":"text","text":"that guide. To create a custom alignment guide, define your own alignment"},{"type":"text","text":" "},{"type":"text","text":"identifier as a type that conforms to the "},{"code":"AlignmentID","type":"codeVoice"},{"type":"text","text":" protocol, and"},{"type":"text","text":" "},{"type":"text","text":"implement the required "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID\/defaultValue(in:)","isActive":true,"type":"reference"},{"type":"text","text":" method:"}]},{"code":["private struct FirstThirdAlignment: AlignmentID {","    static func defaultValue(in context: ViewDimensions) -> CGFloat {","        context.height \/ 3","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"When implementing the method, calculate the guide’s default offset","type":"text"},{"text":" ","type":"text"},{"text":"from the view’s origin. If it’s helpful, you can use information from the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions","isActive":true,"type":"reference"},{"text":" input in the calculation. This parameter provides context","type":"text"},{"text":" ","type":"text"},{"text":"about the specific view that’s using the guide. The above example creates an","type":"text"},{"text":" ","type":"text"},{"text":"identifier called ","type":"text"},{"code":"FirstThirdAlignment","type":"codeVoice"},{"text":" and calculates a default value","type":"text"},{"text":" ","type":"text"},{"text":"that’s one-third of the height of the aligned view.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Use the identifier’s type to create a static property in an extension of","type":"text"},{"text":" ","type":"text"},{"text":"one of the alignment guide types, like ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment"},{"text":":","type":"text"}]},{"code":["extension VerticalAlignment {","    static let firstThird = VerticalAlignment(FirstThirdAlignment.self)","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"You can apply your custom guide like any of the built-in guides. For","type":"text"},{"text":" ","type":"text"},{"text":"example, you can use an ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","isActive":true,"type":"reference"},{"text":" to align its views at one-third","type":"text"},{"text":" ","type":"text"},{"text":"of their height using the guide defined above:","type":"text"}]},{"code":["struct StripesGroup: View {","    var body: some View {","        HStack(alignment: .firstThird, spacing: 1) {","            HorizontalStripes().frame(height: 60)","            HorizontalStripes().frame(height: 120)","            HorizontalStripes().frame(height: 90)","        }","    }","}","","struct HorizontalStripes: View {","    var body: some View {","        VStack(spacing: 1) {","            ForEach(0..<3) { _ in Color.blue }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Because each set of stripes has three equal, vertically stacked"},{"type":"text","text":" "},{"type":"text","text":"rectangles, they align at the bottom edge of the top rectangle. This"},{"type":"text","text":" "},{"type":"text","text":"corresponds in each case to a third of the overall height, as"},{"type":"text","text":" "},{"type":"text","text":"measured from the origin at the top of each set of stripes:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"You can also use the ","type":"text"},{"code":"View\/alignmentGuide(_:computeValue:)","type":"codeVoice"},{"text":" view","type":"text"},{"text":" ","type":"text"},{"text":"modifier to alter the behavior of your custom guide for a view, as you","type":"text"},{"text":" ","type":"text"},{"text":"might alter a built-in guide. For example, you can change","type":"text"},{"text":" ","type":"text"},{"text":"one of the stacks of stripes from the previous example to align its","type":"text"},{"text":" ","type":"text"},{"code":"firstThird","type":"codeVoice"},{"text":" guide at two thirds of the height instead:","type":"text"}]},{"code":["struct StripesGroupModified: View {","    var body: some View {","        HStack(alignment: .firstThird, spacing: 1) {","            HorizontalStripes().frame(height: 60)","            HorizontalStripes().frame(height: 120)","            HorizontalStripes().frame(height: 90)","                .alignmentGuide(.firstThird) { context in","                    2 * context.height \/ 3","                }","        }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modified guide calculation causes the affected view to place the"},{"type":"text","text":" "},{"type":"text","text":"bottom edge of its middle rectangle on the "},{"type":"codeVoice","code":"firstThird"},{"type":"text","text":" guide, which aligns"},{"type":"text","text":" "},{"type":"text","text":"with the bottom edge of the top rectangle in the other two groups:"}]},{"type":"paragraph","inlineContent":[]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID"},"variants":[{"paths":["\/documentation\/openswiftui\/alignmentid"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","metadata":{"externalID":"s:15OpenSwiftUICore11AlignmentIDP","roleHeading":"Protocol","navigatorTitle":[{"kind":"identifier","text":"AlignmentID"}],"remoteSource":{"fileName":"AlignmentGuide.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Alignment\/AlignmentGuide.swift#L106"},"symbolKind":"protocol","title":"AlignmentID","role":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AlignmentID","kind":"identifier"}],"modules":[{"name":"OpenSwiftUI"}]},"topicSections":[{"anchor":"Getting-the-default-value","title":"Getting the default value","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID\/defaultValue(in:)"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/VerticalAlignment":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"VerticalAlignment"}],"url":"\/documentation\/openswiftui\/verticalalignment","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VerticalAlignment"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","title":"VerticalAlignment","kind":"symbol","type":"topic","abstract":[{"type":"text","text":"An alignment position along the vertical axis."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/AlignmentID/defaultValue(in:)":{"required":true,"abstract":[{"type":"text","text":"Calculates a default value for the corresponding guide in the specified"},{"type":"text","text":" "},{"type":"text","text":"context."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID\/defaultValue(in:)","title":"defaultValue(in:)","type":"topic","url":"\/documentation\/openswiftui\/alignmentid\/defaultvalue(in:)","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"defaultValue"},{"kind":"text","text":"("},{"kind":"externalParam","text":"in"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ViewDimensions","preciseIdentifier":"s:15OpenSwiftUICore14ViewDimensionsV"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/VerticalAlignment/top":{"abstract":[{"type":"text","text":"A guide that marks the top edge of the view."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/top","title":"top","type":"topic","url":"\/documentation\/openswiftui\/verticalalignment\/top","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"top"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore17VerticalAlignmentV","text":"VerticalAlignment"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/AlignmentID":{"title":"AlignmentID","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AlignmentID"}],"type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID","abstract":[{"type":"text","text":"A type that you use to create custom alignment guides."}],"navigatorTitle":[{"kind":"identifier","text":"AlignmentID"}],"url":"\/documentation\/openswiftui\/alignmentid"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/HorizontalAlignment":{"abstract":[{"text":"An alignment position along the horizontal axis.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","role":"symbol","kind":"symbol","type":"topic","navigatorTitle":[{"text":"HorizontalAlignment","kind":"identifier"}],"title":"HorizontalAlignment","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"HorizontalAlignment","kind":"identifier"}],"url":"\/documentation\/openswiftui\/horizontalalignment"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/HorizontalAlignment/leading":{"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"leading"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"HorizontalAlignment","preciseIdentifier":"s:15OpenSwiftUICore19HorizontalAlignmentV"}],"abstract":[{"text":"A guide that marks the leading edge of the view.","type":"text"}],"type":"topic","kind":"symbol","title":"leading","url":"\/documentation\/openswiftui\/horizontalalignment\/leading","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/leading","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/HStack":{"type":"topic","navigatorTitle":[{"text":"HStack","kind":"identifier"}],"title":"HStack","url":"\/documentation\/openswiftui\/hstack","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","abstract":[{"text":"A view that arranges its subviews in a horizontal line.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"HStack","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ViewDimensions":{"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"ViewDimensions"}],"url":"\/documentation\/openswiftui\/viewdimensions","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ViewDimensions"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions","title":"ViewDimensions","kind":"symbol","type":"topic","abstract":[{"text":"A view’s size and alignment guides in its own coordinate space.","type":"text"}]}}}