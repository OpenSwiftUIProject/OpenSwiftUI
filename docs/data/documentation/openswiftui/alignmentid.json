{"sections":[],"topicSections":[{"title":"Getting the default value","anchor":"Getting-the-default-value","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID\/defaultValue(in:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AlignmentID"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"level":2,"type":"heading","anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Every built-in alignment guide that ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment"},{"text":" defines as a static property, like","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/top"},{"text":" or ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/leading"},{"text":", has a","type":"text"},{"text":" ","type":"text"},{"text":"unique alignment identifier type that produces the default offset for","type":"text"},{"text":" ","type":"text"},{"text":"that guide. To create a custom alignment guide, define your own alignment","type":"text"},{"text":" ","type":"text"},{"text":"identifier as a type that conforms to the ","type":"text"},{"code":"AlignmentID","type":"codeVoice"},{"text":" protocol, and","type":"text"},{"text":" ","type":"text"},{"text":"implement the required ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID\/defaultValue(in:)"},{"text":" method:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["private struct FirstThirdAlignment: AlignmentID {","    static func defaultValue(in context: ViewDimensions) -> CGFloat {","        context.height \/ 3","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When implementing the method, calculate the guide’s default offset"},{"type":"text","text":" "},{"type":"text","text":"from the view’s origin. If it’s helpful, you can use information from the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions"},{"type":"text","text":" input in the calculation. This parameter provides context"},{"type":"text","text":" "},{"type":"text","text":"about the specific view that’s using the guide. The above example creates an"},{"type":"text","text":" "},{"type":"text","text":"identifier called "},{"type":"codeVoice","code":"FirstThirdAlignment"},{"type":"text","text":" and calculates a default value"},{"type":"text","text":" "},{"type":"text","text":"that’s one-third of the height of the aligned view."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the identifier’s type to create a static property in an extension of"},{"type":"text","text":" "},{"type":"text","text":"one of the alignment guide types, like "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["extension VerticalAlignment {","    static let firstThird = VerticalAlignment(FirstThirdAlignment.self)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can apply your custom guide like any of the built-in guides. For"},{"type":"text","text":" "},{"type":"text","text":"example, you can use an "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","type":"reference","isActive":true},{"type":"text","text":" to align its views at one-third"},{"type":"text","text":" "},{"type":"text","text":"of their height using the guide defined above:"}]},{"type":"codeListing","syntax":"swift","code":["struct StripesGroup: View {","    var body: some View {","        HStack(alignment: .firstThird, spacing: 1) {","            HorizontalStripes().frame(height: 60)","            HorizontalStripes().frame(height: 120)","            HorizontalStripes().frame(height: 90)","        }","    }","}","","struct HorizontalStripes: View {","    var body: some View {","        VStack(spacing: 1) {","            ForEach(0..<3) { _ in Color.blue }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Because each set of stripes has three equal, vertically stacked","type":"text"},{"text":" ","type":"text"},{"text":"rectangles, they align at the bottom edge of the top rectangle. This","type":"text"},{"text":" ","type":"text"},{"text":"corresponds in each case to a third of the overall height, as","type":"text"},{"text":" ","type":"text"},{"text":"measured from the origin at the top of each set of stripes:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"You can also use the ","type":"text"},{"code":"View\/alignmentGuide(_:computeValue:)","type":"codeVoice"},{"text":" view","type":"text"},{"text":" ","type":"text"},{"text":"modifier to alter the behavior of your custom guide for a view, as you","type":"text"},{"text":" ","type":"text"},{"text":"might alter a built-in guide. For example, you can change","type":"text"},{"text":" ","type":"text"},{"text":"one of the stacks of stripes from the previous example to align its","type":"text"},{"text":" ","type":"text"},{"code":"firstThird","type":"codeVoice"},{"text":" guide at two thirds of the height instead:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct StripesGroupModified: View {","    var body: some View {","        HStack(alignment: .firstThird, spacing: 1) {","            HorizontalStripes().frame(height: 60)","            HorizontalStripes().frame(height: 120)","            HorizontalStripes().frame(height: 90)","                .alignmentGuide(.firstThird) { context in","                    2 * context.height \/ 3","                }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modified guide calculation causes the affected view to place the"},{"type":"text","text":" "},{"type":"text","text":"bottom edge of its middle rectangle on the "},{"type":"codeVoice","code":"firstThird"},{"type":"text","text":" guide, which aligns"},{"type":"text","text":" "},{"type":"text","text":"with the bottom edge of the top rectangle in the other two groups:"}]},{"type":"paragraph","inlineContent":[]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID"},"abstract":[{"text":"A type that you use to create custom alignment guides.","type":"text"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"seeAlsoSections":[{"title":"Aligning views","generated":true,"anchor":"Aligning-views","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions"]}],"metadata":{"title":"AlignmentID","modules":[{"name":"OpenSwiftUI"}],"navigatorTitle":[{"text":"AlignmentID","kind":"identifier"}],"roleHeading":"Protocol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AlignmentID"}],"externalID":"s:15OpenSwiftUICore11AlignmentIDP","symbolKind":"protocol","remoteSource":{"fileName":"AlignmentGuide.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Alignment\/AlignmentGuide.swift#L106"},"role":"symbol"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/alignmentid"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/VerticalAlignment":{"title":"VerticalAlignment","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","kind":"symbol","type":"topic","url":"\/documentation\/openswiftui\/verticalalignment","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"VerticalAlignment"}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VerticalAlignment"}],"abstract":[{"text":"An alignment position along the vertical axis.","type":"text"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/HorizontalAlignment/leading":{"type":"topic","title":"leading","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"let"},{"kind":"text","text":" "},{"kind":"identifier","text":"leading"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"HorizontalAlignment","preciseIdentifier":"s:15OpenSwiftUICore19HorizontalAlignmentV"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/leading","url":"\/documentation\/openswiftui\/horizontalalignment\/leading","abstract":[{"text":"A guide that marks the leading edge of the view.","type":"text"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/AlignmentID/defaultValue(in:)":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Calculates a default value for the corresponding guide in the specified"},{"type":"text","text":" "},{"type":"text","text":"context."}],