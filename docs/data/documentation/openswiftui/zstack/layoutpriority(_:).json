{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"]]},"abstract":[{"type":"text","text":"Sets the priority by which a parent layout should apportion space to"},{"type":"text","text":" "},{"type":"text","text":"this child."}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack\/layoutPriority(_:)","interfaceLanguage":"swift"},"metadata":{"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/LayoutPriority.swift#L49","fileName":"LayoutPriority.swift"},"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"extendedModule":"OpenSwiftUICore","roleHeading":"Instance Method","platforms":[{"beta":false,"unavailable":false,"introducedAt":"13.0","deprecated":false,"name":"iOS"},{"beta":false,"unavailable":false,"introducedAt":"10.15","deprecated":false,"name":"macOS"},{"beta":false,"unavailable":false,"introducedAt":"13.0","deprecated":false,"name":"tvOS"},{"beta":false,"unavailable":false,"introducedAt":"1.0","deprecated":false,"name":"visionOS"},{"beta":false,"unavailable":false,"introducedAt":"6.0","deprecated":false,"name":"watchOS"}],"externalID":"s:15OpenSwiftUICore4ViewPAAE14layoutPriorityyQrSdF::SYNTHESIZED::s:15OpenSwiftUICore6ZStackV","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"layoutPriority"},{"kind":"text","text":"("},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"}],"role":"symbol","title":"layoutPriority(_:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"layoutPriority"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"value"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}]}]},{"kind":"parameters","parameters":[{"name":"value","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The priority by which a parent layout apportions"},{"type":"text","text":" "},{"type":"text","text":"space to the child."}]}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Views typically have a default priority of ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" which causes space to be","type":"text"},{"text":" ","type":"text"},{"text":"apportioned evenly to all sibling views. Raising a view’s layout","type":"text"},{"text":" ","type":"text"},{"text":"priority encourages the higher priority view to shrink later when the","type":"text"},{"text":" ","type":"text"},{"text":"group is shrunk and stretch sooner when the group is stretched.","type":"text"}],"type":"paragraph"},{"code":["HStack {","    Text(\"This is a moderately long string.\")","        .font(.largeTitle)","        .border(Color.gray)","","    Spacer()","","    Text(\"This is a higher priority string.\")","        .font(.largeTitle)","        .layoutPriority(1)","        .border(Color.gray)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"In the example above, the first "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" element has the default"},{"type":"text","text":" "},{"type":"text","text":"priority "},{"code":"0","type":"codeVoice"},{"type":"text","text":" which causes its view to shrink dramatically due to the"},{"type":"text","text":" "},{"type":"text","text":"higher priority of the second "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" element, even though all of their"},{"type":"text","text":" "},{"type":"text","text":"other attributes (font, font size and character count) are the same."}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A parent layout offers the child views with the highest layout priority"},{"type":"text","text":" "},{"type":"text","text":"all the space offered to the parent minus the minimum space required for"},{"type":"text","text":" "},{"type":"text","text":"all its lower-priority children."}],"type":"paragraph"}]}],"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/zstack\/layoutpriority(_:)"]}],"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ZStack/layoutPriority(_:)":{"kind":"symbol","type":"topic","role":"symbol","abstract":[{"type":"text","text":"Sets the priority by which a parent layout should apportion space to"},{"type":"text","text":" "},{"type":"text","text":"this child."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack\/layoutPriority(_:)","url":"\/documentation\/openswiftui\/zsta