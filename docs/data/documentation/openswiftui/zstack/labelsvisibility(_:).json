"},{"text":" ","type":"text"},{"text":"combined label and control element:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"Always provide a label for controls, even when you hide the label,","type":"text"},{"text":" ","type":"text"},{"text":"because OpenSwiftUI uses labels for other purposes, including accessibility.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On iOS, a "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":" within a "},{"type":"codeVoice","code":"Menu"},{"type":"text","text":" hides its label by default. You can use"},{"type":"text","text":" "},{"type":"text","text":"this modifier to explicitly show the label in that context:"}]},{"type":"codeListing","syntax":"swift","code":["Menu {","    Picker(\"Flavor\", selection: $selectedFlavor) {","        Text(\"Chocolate\").tag(Flavor.chocolate)","        Text(\"Vanilla\").tag(Flavor.vanilla)","        Text(\"Strawberry\").tag(Flavor.strawberry)","    }","    .labelsVisibility(.visible)","}"]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"This modifier doesn’t work for all labels. It applies to","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent","isActive":true},{"text":" elements, including controls like ","type":"text"},{"type":"codeVoice","code":"Picker"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true},{"text":", but not to controls like a bordered button where the label","type":"text"},{"text":" ","type":"text"},{"text":"is inside the button’s border.","type":"text"}]}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/zstack\/labelsvisibility(_:)"]}],"references":{"doc://OpenSwiftUI