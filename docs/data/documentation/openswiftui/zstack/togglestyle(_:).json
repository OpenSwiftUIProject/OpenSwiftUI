"text":" or ","type":"text"},{"type":"codeVoice","code":"ToggleStyle\/button"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or a custom style that you define by creating a type that conforms","type":"text"},{"text":" ","type":"text"},{"text":"to the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle","type":"reference","isActive":true},{"text":" protocol.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that uses the specified toggle style for itself"},{"type":"text","text":" "},{"type":"text","text":"and its child views."}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"inlineContent":[{"text":"Use this modifier on a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true,"type":"reference"},{"text":" instance to set a style that defines","type":"text"},{"text":" ","type":"text"},{"text":"the control’s appearance and behavior. For example, you can choose","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true,"type":"reference"},{"text":" style:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["Toggle(\"Vibrate on Ring\", isOn: $vibrateOnRing)","    .toggleStyle(.switch)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Built-in styles typically have a similar appearance across platforms,"},{"type":"text","text":" "},{"type":"text","text":"tailored to the platform’s overall style:"}],"type":"paragraph"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Appearance"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"iOS, iPadOS","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]]],"type":"table"},{"level":3,"anchor":"Styling-toggles-in-a-hierarchy","type":"heading","text":"Styling toggles in a hierarchy"},{"inlineContent":[{"type":"text","text":"You can set a style for all toggle instances within a view hierarchy"},{"type":"text","text":" "},{"type":"text","text":"by applying the style modifier to a container view. For example, you"},{"type":"text","text":" "},{"type":"text","text":"can apply the "},{"type":"codeVoice","code":"ToggleStyle\/button"},{"type":"text","text":" style to an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["HStack {","    Toggle(isOn: $isFlagged) {","        Label(\"Flag\", systemImage: \"flag.fill\")","    }","    Toggle(isOn: $isMuted) {","        Label(\"Mute\", systemImage: \"speaker.slash.fill\")","    }","}",".toggleStyle(.button)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The example above has the following appearance when "},{"type":"codeVoice","code":"isFlagged"},{"type":"text","text":" is"},{"text":" ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"isMuted","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"false","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Appearance"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"iOS, iPadOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS"}]}],[{"type":"paragraph","inlineContent":[]}]]],"header":"row","type":"table"},{"text":"Automatic styling","level":3,"anchor":"Automatic-styling","type":"heading"},{"inlineContent":[{"type":"text","text":"If you don’t set a style, OpenSwiftUI assumes a value of"},{"type":"text","text":" "},{"type":"codeVoice","code":"ToggleStyle\/automatic"},{"type":"text","text":", which corresponds to a context-specific"},{"type":"text","text":" "},{"type":"text","text":"default. Specify the automatic style explicitly to override a"},{"type":"text","text":" "},{"type":"text","text":"container’s style and revert to the default:"}],"type":"paragraph"},{"code":["HStack {","    Toggle(isOn: $isShuffling) {","        Label(\"Shuffle\", systemImage: \"shuffle\")","    }","    Toggle(isOn: $isRepeating) {","        Label(\"Repeat\", systemImage: \"repeat\")","    }","","    Divider()","","    Toggle(\"Enhance Sound\", isOn: $isEnhanced)","        .toggleStyle(.automatic) \/\/ Revert to the default style.","}",".toggleStyle(.button) \/\/ Use button style for toggles in the stack.",".labelStyle(.iconOnly) \/\/ Omit the title from any labels."],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The style that OpenSwiftUI uses as the default depends on both the platform","type":"text"},{"text":" ","type":"text"},{"text":"and the context. In macOS, the default in most contexts is a","type":"text"},{"text":" ","type":"text"},{"code":"ToggleStyle\/checkbox","type":"codeVoice"},{"text":", while in iOS, the default toggle style is a","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Platform"}]}],[{"type":"paragraph","inlineContent":[{"text":"Appearance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"iOS, iPadOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS"}]}],[{"type":"paragraph","inlineContent":[]}]]],"header":"row","type":"table"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Like toggle style does for toggles, the "},{"type":"codeVoice","code":"View\/labelStyle(_:)"},{"type":"text","text":" "},{"type":"text","text":"modifier sets the style for "},{"type":"codeVoice","code":"Label"},{"type":"text","text":" instances in the hierarchy. The"},{"type":"text","text":" "},{"type":"text","text":"example above demostrates the compact "},{"type":"codeVoice","code":"LabelStyle\/iconOnly"},{"type":"text","text":" style,"},{"type":"text","text":" "},{"text":"which is useful for button toggles in space-constrained contexts.","type":"text"},{"text":" ","type":"text"},{"text":"Always include a descriptive title for better accessibility.","type":"text"}]}],"style":"note","type":"aside","name":"Note"},{"inlineContent":[{"type":"text","text":"For more information about how OpenSwiftUI chooses a default toggle style,"},{"type":"text","text":" "},{"type":"text","text":"see the "},{"code":"ToggleStyle\/automatic","type":"codeVoice"},{"type":"text","text":" style."}],"type":"paragraph"}]}],"metadata":{"extendedModule":"OpenSwiftUICore","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"toggleStyle"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lFQO1Sqd__mfp","kind":"typeIdentifier","text":"S"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"}],"title":"toggleStyle(_:)","role":"symbol","externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lF::SYNTHESIZED::s:15OpenSwiftUICore6ZStackV","remoteSource":{"fi