dSize()","    .frame(width: 200, height: 200)","    .border(Color.gray)"]},{"inlineContent":[{"type":"text","text":"This can result in the view exceeding the parent’s bounds, which may or"},{"type":"text","text":" "},{"type":"text","text":"may not be the effect you want."}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can think of "},{"code":"fixedSize()","type":"codeVoice"},{"type":"text","text":" as the creation of a "},{"type":"emphasis","inlineContent":[{"text":"counter proposal","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"to the view size proposed to a view by its parent. The ideal size of a"},{"type":"text","text":" "},{"type":"text","text":"view, and the specific effects of "},{"code":"fixedSize()","type":"codeVoice"},{"type":"text","text":" depends on the"},{"type":"text","text":" "},{"type":"text","text":"particular view and how you have configured it."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To create a view that fixes the view’s size in either the horizontal or"},{"type":"text","text":" "},{"type":"text","text":"vertical dimensions, see "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/openswiftui\/zstack\/fixedsize()"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ZStack":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ZStack","kind":"identifier"}],"abstract":[{"type":"text","text":"A view that overlays its subviews, aligning them in both axes."}],"title":"ZStack","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","url":"\/documentation\/openswiftui\/zstack","kind":"symbol","navigatorTitle":[{"text":"ZStack","kind":"identifier"