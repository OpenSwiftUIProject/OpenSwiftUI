{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint"},"sections":[],"metadata":{"title":"UnitPoint","modules":[{"name":"OpenSwiftUI"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UnitPoint","kind":"identifier"}],"remoteSource":{"fileName":"UnitPoint.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Geometry\/UnitPoint.swift#L73"},"symbolKind":"struct","navigatorTitle":[{"text":"UnitPoint","kind":"identifier"}],"roleHeading":"Structure","externalID":"s:15OpenSwiftUICore9UnitPointV","role":"symbol"},"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"kind":"symbol","abstract":[{"text":"A normalized 2D point in a view’s coordinate space.","type":"text"}],"topicSections":[{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/init()","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/init(x:y:)"],"title":"Initializers","anchor":"Initializers","generated":true},{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/x","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/y"],"title":"Instance Properties","anchor":"Instance-Properties","generated":true},{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/bottom","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/bottomLeading","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/bottomTrailing","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/center","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/leading","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/top","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/topLeading","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/topTrailing","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/trailing","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/zero"],"title":"Type Properties","anchor":"Type-Properties","generated":true},{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/Animatable-Implementations"],"title":"Default Implementations","anchor":"Default-Implementations","generated":true}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@frozen"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"UnitPoint"}],"languages":["swift"]}]},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"text":"Use a unit point to represent a location in a view without having to know","type":"text"},{"text":" ","type":"text"},{"text":"the view’s rendered size. The point stores a value in each dimension that","type":"text"},{"text":" ","type":"text"},{"text":"indicates the fraction of the view’s size in that dimension — measured","type":"text"},{"text":" ","type":"text"},{"text":"from the view’s origin — where the point appears. For example, you can","type":"text"},{"text":" ","type":"text"},{"text":"create a unit point that represents the center of any view by using the","type":"text"},{"text":" ","type":"text"},{"text":"value ","type":"text"},{"code":"0.5","type":"codeVoice"},{"text":" for each dimension:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["let unitPoint = UnitPoint(x: 0.5, y: 0.5)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"To project the unit point into the rendered view’s coordinate space,"},{"type":"text","text":" "},{"type":"text","text":"multiply each component of the unit point with the corresponding"},{"type":"text","text":" "},{"type":"text","text":"component of the view’s size:"}],"type":"paragraph"},{"syntax":"swift","code":["let projectedPoint = CGPoint(","    x: unitPoint.x * size.width,","    y: unitPoint.y * size.height",")"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can perform this calculation yourself if you happen to know a view’s"},{"type":"text","text":" "},{"type":"text","text":"size, or if you want to use the unit point for some custom purpose, but"},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI typically does this for you to carry out operations that"},{"type":"text","text":" "},{"type":"text","text":"you request, like when you:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"Transform a shape using a shape modifier. For example, to rotate a"},{"type":"text","text":" "},{"type":"text","text":"shape with "},{"type":"codeVoice","code":"Shape\/rotation(_:anchor:)"},{"type":"text","text":", you indicate an anchor point"},{"type":"text","text":" "},{"type":"text","text":"that you want to rotate the shape around."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Override the alignment of the view in a ","type":"text"},{"type":"codeVoice","code":"Grid"},{"text":" cell using the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"View\/gridCellAnchor(_:)"},{"text":" view modifier. The grid aligns the projection","type":"text"},{"text":" ","type":"text"},{"text":"of a unit point onto the view with the projection of the same unit point","type":"text"},{"text":" ","type":"text"},{"text":"onto the cell.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Create a gradient that has a center, or start and stop points, relative","type":"text"},{"text":" ","type":"text"},{"text":"to the shape that you are styling. See the gradient methods in","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","type":"reference"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"You can create custom unit points with explicit values, like the example"},{"type":"text","text":" "},{"type":"text","text":"above, or you can use one of the built-in unit points that OpenSwiftUI provides,"},{"type":"text","text":" "},{"type":"text","text":"like "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/zero"},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/center"},{"type":"text","text":", or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/topTrailing"},{"type":"text","text":". The built-in values"},{"type":"text","text":" "},{"type":"text","text":"correspond to the alignment positions of the similarly named, built-in"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment"},{"type":"text","text":" types."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A unit point with one or more components outside the range "},{"code":"[0, 1]","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"projects to a point outside of the view."}]}],"style":"note","name":"Note","type":"aside"},{"text":"Layout direction","level":3,"anchor":"Layout-direction","type":"heading"},{"inlineContent":[{"type":"text","text":"When a person configures their device to use a left-to-right language like"},{"type":"text","text":" "},{"type":"text","text":"English, the system places the view’s origin in its top-left corner,"},{"type":"text","text":" "},{"type":"text","text":"with positive x toward the right and positive y toward the bottom of the"},{"type":"text","text":" "},{"type":"text","text":"view. In a right-to-left environment, the origin moves to the upper-right"},{"type":"text","text":" "},{"type":"text","text":"corner, and the positive x direction changes to be toward the left. You"},{"type":"text","text":" "},{"type":"text","text":"don’t typically need to do anything to handle this change, because OpenSwiftUI"},{"type":"text","text":" "},{"type":"text","text":"applies the change to all aspects of the system. For example, see the"},{"type":"text","text":" "},{"type":"text","text":"discussion about layout direction in "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"It’s important to test your app for the different locales that you","type":"text"},{"text":" ","type":"text"},{"text":"distribute your app in. For more information about the localization process,","type":"text"},{"text":" ","type":"text"},{"text":"see ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/xcode\/localization","isActive":true}],"type":"paragraph"}]}],"relationshipsSections":[{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animatable","doc:\/\/OpenSwiftUI\/s15BitwiseCopyableP","doc:\/\/OpenSwiftUI\/s8CopyableP","doc:\/\/OpenSwiftUI\/SQ","doc:\/\/OpenSwiftUI\/SH","doc:\/\/OpenSwiftUI\/s8SendableP"],"type":"conformsTo"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/unitpoint"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/UnitPoint/zero":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnitPoint\/zero","title":"zero","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"zero","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UnitPoint","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore9UnitPointV"}],"role":"symbol","url":"\/documentation\/openswiftui\/unitpoin