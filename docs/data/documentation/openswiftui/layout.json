aragraph","inlineContent":[{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/placeSubviews(in:proposal:subviews:cache:)","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"assigns positions to the container’s subviews."}]}]}]},{"type":"paragraph","inlineContent":[{"text":"You can define a basic layout type with only these two methods:","type":"text"}]},{"code":["struct BasicVStack: Layout {","    func sizeThatFits(","        proposal: ProposedViewSize,","        subviews: Subviews,","        cache: inout ()","    ) -> CGSize {","        \/\/ Calculate and return the size of the layout container.","    }","","    func placeSubviews(","        in bounds: CGRect,","        proposal: ProposedViewSize,","        subviews: Subviews,","        cache: inout ()","    ) {","        \/\/ Tell each subview where to appear.","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use your layout the same way you use a built-in layout"},{"type":"text","text":" "},{"type":"text","text":"container, by providing a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder","isActive":true},{"type":"text","text":" with the list of subviews"},{"type":"text","text":" "},{"type":"text","text":"to arrange:"}]},{"code":["BasicVStack {","    Text(\"A Subview\")","    Text(\"Another Subview\")","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Support-additional-behaviors","type":"heading","level":3,"text":"Support additional behaviors"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can optionally implement other protocol methods and properties to"},{"type":"text","text":" "},{"type":"text","text":"provide more layout container features:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Define explicit horizontal and vertical layout guides for the container by"},{"type":"text","text":" "},{"type":"text","text":"implementing "},{"code":"explicitAlignment(of:in:proposal:subviews:cache:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"for each dimension."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Establish the preferred spacing around the container by implementing"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/spacing(subviews:cache:)","isActive":true},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Indicate the axis of orientation for a container that has characteristics","type":"text"},{"text":" ","type":"text"},{"text":"of a stack by implementing the ","type":"text"},{"type":"codeVoice","code":"layoutProperties-5rb5b"},{"text":" static property.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Create and manage a cache to store computed values across different"},{"type":"text","text":" "},{"type":"text","text":"layout protocol calls by implementing "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/makeCache(subviews:)"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The protocol provides default implementations for these symbols"},{"type":"text","text":" "},{"type":"text","text":"if you don’t implement them. See each method or property for details."}]},{"anchor":"Add-input-parameters","type":"heading","level":3,"text":"Add input parameters"},{"type":"paragraph","inlineContent":[{"text":"You can define parameters as inputs to the layout, like you might","type":"text"},{"text":" ","type":"text"},{"text":"for a ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","isActive":true},{"text":":","type":"text"}]},{"code":["struct BasicVStack: Layout {","    var alignment: HorizontalAlignment","","    \/\/ ...","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Set the parameters at the point where you instantiate the layout:","type":"text"}]},{"code":["BasicVStack(alignment: .leading) {","    \/\/ ...","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the layout provides default values for its parameters, you can omit the"},{"type":"text","text":" "},{"type":"text","text":"parameters at the call site, but you might need to keep the parentheses"},{"type":"text","text":" "},{"type":"text","text":"after the name of the layout, depending on how you specify the defaults."},{"type":"text","text":" "},{"type":"text","text":"For example, suppose you set a default alignment for the basic stack in"},{"type":"text","text":" "},{"type":"text","text":"the parameter declaration:"}]},{"code":["struct BasicVStack: Layout {","    var alignment: HorizontalAlignment = .center","","    \/\/ ...","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To instantiate this layout using the default center alignment, you don’t"},{"type":"text","text":" "},{"type":"text","text":"have to specify the alignment value, but you do need to add empty"},{"type":"text","text":" "},{"type":"text","text":"parentheses:"}]},{"code":["BasicVStack() {","    \/\/ ...","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Swift compiler requires the parentheses in this case because of how the"},{"type":"text","text":" "},{"type":"text","text":"layout protocol implements this call site syntax. Specifically, the layout’s"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/callAsFunction(_:)","isActive":true},{"type":"text","text":" method looks for an initializer with exactly zero"},{"type":"text","text":" "},{"type":"text","text":"input arguments when you omit the parentheses from the call site."},{"type":"text","text":" "},{"type":"text","text":"You can enable the simpler call site for a layout that doesn’t have an"},{"type":"text","text":" "},{"type":"text","text":"implicit initializer of this type by explicitly defining one:"}]},{"code":["init() {","    self.alignment = .center","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"For information about Swift initializers, see","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/docs.swift.org\/swift-book\/LanguageGuide\/Initialization.html","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"in ","type":"text"},{"inlineContent":[{"type":"text","text":"The Swift Programming Language"}],"type":"emphasis"},{"text":".","type":"text"}]},{"anchor":"Interact-with-subviews-through-their-proxies","type":"heading","level":3,"text":"Interact with subviews through their proxies"},{"type":"paragraph","inlineContent":[{"text":"To perform layout, you need information about all of its subviews, which","type":"text"},{"text":" ","type":"text"},{"text":"are the views that your container arranges. While your layout can’t","type":"text"},{"text":" ","type":"text"},{"text":"interact directly with its subviews, it can access a set of subview proxies","type":"text"},{"text":" ","type":"text"},{"text":"through the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews","type":"reference","isActive":true},{"text":" collection that each protocol method receives as","type":"text"},{"text":" ","type":"text"},{"text":"an input parameter. That type is an alias for the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutSubviews","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"collection type, which in turn contains ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutSubview","type":"reference","isActive":true},{"text":" instances","type":"text"},{"text":" ","type":"text"},{"text":"that are the subview proxies.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can get information about each subview from its proxy, like its","type":"text"},{"text":" ","type":"text"},{"text":"dimensions and spacing preferences. This enables","type":"text"},{"text":" ","type":"text"},{"text":"you to measure subviews before you commit to placing them. You also","type":"text"},{"text":" ","type":"text"},{"text":"assign a position to each subview by calling its proxy’s","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutSubview\/place(at:anchor:proposal:)","isActive":true,"type":"reference"},{"text":" method.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"Call the method on each subview from within your implementation of the"},{"type":"text","text":" "},{"type":"text","text":"layout’s "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/placeSubviews(in:proposal:subviews:cache:)","type":"reference","isActive":true},{"type":"text","text":" method."}]},{"anchor":"Access-layout-values","type":"heading","level":3,"text":"Access layout values"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Views have layout values that you set with view modifiers."},{"type":"text","text":" "},{"type":"text","text":"Layout containers can choose to condition their behavior accordingly."},{"type":"text","text":" "},{"type":"text","text":"For example, a built-in "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"},{"type":"text","text":" allocates space to its subviews based"},{"type":"text","text":" "},{"type":"text","text":"in part on the priorities that you set with the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/layoutPriority(_:)"},{"type":"text","text":" "},{"type":"text","text":"view modifier. Your layout container accesses this value for a subview by"},{"type":"text","text":" "},{"type":"text","text":"reading the proxy’s "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutSubview\/priority"},{"type":"text","text":" property."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also create custom layout values by creating a layout key."},{"type":"text","text":" "},{"type":"text","text":"Set a value on a view with the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/layoutValue(key:value:)"},{"type":"text","text":" view"},{"type":"text","text":" "},{"type":"text","text":"modifier. Read the corresponding value from the subview’s proxy using the"},{"type":"text","text":" "},{"type":"text","text":"key as an index on the subview. For more information about creating,"},{"type":"text","text":" "},{"type":"text","text":"setting, and accessing custom layout values, see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutValueKey"},{"type":"text","text":"."}]}],"kind":"content"}],"metadata":{"symbolKind":"protocol","role":"symbol","platforms":[{"name":"iOS","deprecated":false,"introducedAt":"13.0","unavailable":false,"beta":false},{"name":"macOS","deprecated":false,"introducedAt":"10.15","unavailable":false,"beta":false},{"name":"tvOS","deprecated":false,"introducedAt":"13.0","unavailable":false,"beta":false},{"name":"visionOS","deprecated":false,"introducedAt":"1.0","unavailable":false,"beta":false},{"name":"watchOS","deprecated":false,"introducedAt":"6.0","unavailable":false,"beta":false}],"roleHeading":"Protocol","title":"Layout","remoteSource":{"fileName":"Layout.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/La