{"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment"},"abstract":[{"text":"An alignment in both axes.","type":"text"}],"variants":[{"paths":["\/documentation\/openswiftui\/alignment"],"traits":[{"interfaceLanguage":"swift"}]}],"relationshipsSections":[{"title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OpenSwiftUI\/s15BitwiseCopyableP","doc:\/\/OpenSwiftUI\/SQ","doc:\/\/OpenSwiftUI\/s8SendableP"],"type":"conformsTo"}],"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"topicSections":[{"title":"Initializers","anchor":"Initializers","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/init(horizontal:vertical:)"],"generated":true},{"title":"Instance Properties","anchor":"Instance-Properties","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/horizontal","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/vertical"],"generated":true},{"title":"Type Properties","anchor":"Type-Properties","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/bottom","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/bottomLeading","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/bottomTrailing","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/centerFirstTextBaseline","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/centerLastTextBaseline","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/leading","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/leadingFirstTextBaseline","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/leadingLastTextBaseline","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/top","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/topLeading","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/topTrailing","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/trailing","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/trailingFirstTextBaseline","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/trailingLastTextBaseline"],"generated":true}],"metadata":{"role":"symbol","modules":[{"name":"OpenSwiftUI"}],"symbolKind":"struct","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Alignment"}],"navigatorTitle":[{"kind":"identifier","text":"Alignment"}],"remoteSource":{"fileName":"AlignmentGuide.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Alignment\/AlignmentGuide.swift#L643"},"roleHeading":"Structure","title":"Alignment","externalID":"s:15OpenSwiftUICore9AlignmentV"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Alignment","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"An "},{"code":"Alignment","type":"codeVoice"},{"type":"text","text":" contains a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment"},{"type":"text","text":" guide and a"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment"},{"type":"text","text":" guide. Specify an alignment to direct the behavior of"},{"type":"text","text":" "},{"type":"text","text":"certain layout containers and modifiers, like when you place views in a"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"type":"text","text":", or layer a view in front of or behind another view using"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/overlay(alignment:content:)"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/background(alignment:content:)"},{"type":"text","text":", respectively. During layout,"},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI brings the specified guides of the affected views together,"},{"type":"text","text":" "},{"type":"text","text":"aligning the views."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"OpenSwiftUI provides a set of built-in alignments that represent common"},{"type":"text","text":" "},{"type":"text","text":"combinations of the built-in horizontal and vertical alignment guides."},{"type":"text","text":" "},{"type":"text","text":"The blue boxes in the following diagram demonstrate the alignment named"},{"type":"text","text":" "},{"type":"text","text":"by each box’s label, relative to the background view:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following code generates the diagram above, where each blue box appears"},{"type":"text","text":" "},{"type":"text","text":"in an overlay that’s configured with a different alignment:"}],"type":"paragraph"},{"code":["struct AlignmentGallery: View {","    var body: some View {","        BackgroundView()","            .overlay(alignment: .topLeading) { box(\".topLeading\") }","            .overlay(alignment: .top) { box(\".top\") }","            .overlay(alignment: .topTrailing) { box(\".topTrailing\") }","            .overlay(alignment: .leading) { box(\".leading\") }","            .overlay(alignment: .center) { box(\".center\") }","            .overlay(alignment: .trailing) { box(\".trailing\") }","            .overlay(alignment: .bottomLeading) { box(\".bottomLeading\") }","            .overlay(alignment: .bottom) { box(\".bottom\") }","            .overlay(alignment: .bottomTrailing) { box(\".bottomTrailing\") }","            .overlay(alignment: .leadingLastTextBaseline) { box(\".leadingLastTextBaseline\") }","            .overlay(alignment: .trailingFirstTextBaseline) { box(\".trailingFirstTextBaseline\") }","    }","","    private func box(_ name: String) -> some View {","        Text(name)","            .font(.system(.caption, design: .monospaced))","            .padding(2)","            .foregroundColor(.white)","            .background(.blue.opacity(0.8), in: Rectangle())","    }","}","","private struct BackgroundView: View {","    var body: some View {","        Grid(horizontalSpacing: 0, verticalSpacing: 0) {","            GridRow {","                Text(\"Some text in an upper quadrant\")","                Color.gray.opacity(0.3)","            }","            GridRow {","                Color.gray.opacity(0.3)","                Text(\"More text in a lower quadrant\")","            }","        }","        .aspectRatio(1, contentMode: .fit)","        .foregroundColor(.secondary)","        .border(.gray)","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"To avoid crowding, the alignment diagram shows only two of the available"},{"type":"text","text":" "},{"type":"text","text":"text baseline alignments. The others align as their names imply. Notice that"},{"type":"text","text":" "},{"type":"text","text":"the first text baseline alignment aligns with the top-most line of text in"},{"type":"text","text":" "},{"type":"text","text":"the background view, while the last text baseline aligns with the"},{"type":"text","text":" "},{"type":"text","text":"bottom-most line. For more information about text baseline alignment, see"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In a left-to-right language like English, the leading and trailing"},{"type":"text","text":" "},{"type":"text","text":"alignments appear on the left and right edges, respectively. OpenSwiftUI"},{"type":"text","text":" "},{"type":"text","text":"reverses these in right-to-left language environments. For more"},{"type":"text","text":" "},{"type":"text","text":"information, see "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Custom alignment","level":3,"anchor":"Custom-alignment","type":"heading"},{"inlineContent":[{"text":"You can create custom alignments — which you typically do to make use","type":"text"},{"text":" ","type":"text"},{"text":"of custom horizontal or vertical guides — by using the","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/init(horizontal:vertical:)","isActive":true},{"text":" initializer. For example, you can combine","type":"text"},{"text":" ","type":"text"},{"text":"a custom vertical guide called ","type":"text"},{"type":"codeVoice","code":"firstThird"},{"text":" with the built-in horizontal","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/center","isActive":true},{"text":" guide, and use it to configure a ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"code":["ZStack(alignment: Alignment(horizontal: .center, vertical: .firstThird)) {","    \/\/ ...","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"For more information about creating custom guides, including the code","type":"text"},{"text":" ","type":"text"},{"text":"that creates the custom ","type":"text"},{"type":"codeVoice","code":"firstThird"},{"text":" alignment in the example above,","type":"text"},{"text":" ","type":"text"},{"text":"see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID"},{"text":".","type":"text"}],"type":"paragraph"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Alignment/centerLastTextBaseline":{"abstract":[{"text":"A guide that marks the bottom-most text baseline in a view.","type":"text"}],"url":"\/documentation\/openswiftui\/alignment\/centerlasttextbaseline","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/centerLastTextBaseline","title":"centerLastTextBaseline","type":"topic","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"centerLastTextBaseline"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore9AlignmentV","text":"Alignment"}],"kind":"symbol","role":"symbol"},"doc://OpenSwiftUI/s8SendableP":{"identifier":"doc:\/\/OpenSwiftUI\/s8SendableP","title":"Swift.Sendable","type":"unresolvable"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Alignment/trailingLastTextBaseline":{"type":"topic","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"trailingLastTextBaseline"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore9AlignmentV","text":"Alignment"}],"url":"\/documentation\/openswiftui\/alignment\/trailinglasttextbaseline","abstract":[{"text":"A guide that marks the trailing edge and bottom-most text baseline","type":"text"},{"text":" ","type":"text"},{"text":"in a view.","t