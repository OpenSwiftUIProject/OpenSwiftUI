{"sections":[],"variants":[{"paths":["\/documentation\/openswiftui\/alignment"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"topicSections":[{"generated":true,"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/init(horizontal:vertical:)"],"title":"Initializers","anchor":"Initializers"},{"generated":true,"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/horizontal","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/vertical"],"title":"Instance Properties","anchor":"Instance-Properties"},{"generated":true,"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/bottom","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/bottomLeading","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/bottomTrailing","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/centerFirstTextBaseline","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/centerLastTextBaseline","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/leading","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/leadingFirstTextBaseline","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/leadingLastTextBaseline","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/top","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/topLeading","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/topTrailing","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/trailing","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/trailingFirstTextBaseline","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/trailingLastTextBaseline"],"title":"Type Properties","anchor":"Type-Properties"}],"kind":"symbol","abstract":[{"text":"An alignment in both axes.","type":"text"}],"relationshipsSections":[{"type":"conformsTo","identifiers":["doc:\/\/OpenSwiftUI\/s15BitwiseCopyableP","doc:\/\/OpenSwiftUI\/SQ","doc:\/\/OpenSwiftUI\/s8SendableP"],"title":"Conforms To","kind":"relationships"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Alignment","kind":"identifier"}]}]},{"kind":"content","content":[{"text":"Overview","type":"heading","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"An ","type":"text"},{"code":"Alignment","type":"codeVoice"},{"text":" contains a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment"},{"text":" guide and a","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment"},{"text":" guide. Specify an alignment to direct the behavior of","type":"text"},{"text":" ","type":"text"},{"text":"certain layout containers and modifiers, like when you place views in a","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"text":", or layer a view in front of or behind another view using","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/overlay(alignment:content:)"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/background(alignment:content:)"},{"text":", respectively. During layout,","type":"text"},{"text":" ","type":"text"},{"text":"OpenSwiftUI brings the specified guides of the affected views together,","type":"text"},{"text":" ","type":"text"},{"text":"aligning the views.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"OpenSwiftUI provides a set of built-in alignments that represent common","type":"text"},{"text":" ","type":"text"},{"text":"combinations of the built-in horizontal and vertical alignment guides.","type":"text"},{"text":" ","type":"text"},{"text":"The blue boxes in the following diagram demonstrate the alignment named","type":"text"},{"text":" ","type":"text"},{"text":"by each box’s label, relative to the background view:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code generates the diagram above, where each blue box appears"},{"type":"text","text":" "},{"type":"text","text":"in an overlay that’s configured with a different alignment:"}]},{"syntax":"swift","type":"codeListing","code":["struct AlignmentGallery: View {","    var body: some View {","        BackgroundView()","            .overlay(alignment: .topLeading) { box(\".topLeading\") }","            .overlay(alignment: .top) { box(\".top\") }","            .overlay(alignment: .topTrailing) { box(\".topTrailing\") }","            .overlay(alignment: .leading) { box(\".leading\") }","            .overlay(alignment: .center) { box(\".center\") }","            .overlay(alignment: .trailing) { box(\".trailing\") }","            .overlay(alignment: .bottomLeading) { box(\".bottomLeading\") }","            .overlay(alignment: .bottom) { box(\".bottom\") }","            .overlay(alignment: .bottomTrailing) { box(\".bottomTrailing\") }","            .overlay(alignment: .leadingLastTextBaseline) { box(\".leadingLastTextBaseline\") }","            .overlay(alignment: .trailingFirstTextBaseline) { box(\".trailingFirstTextBaseline\") }","    }","","    private func box(_ name: String) -> some View {","        Text(name)","            .font(.system(.caption, design: .monospaced))","            .padding(2)","            .foregroundColor(.white)","            .background(.blue.opacity(0.8), in: Rectangle())","    }","}","","private struct BackgroundView: View {","    var body: some View {","        Grid(horizontalSpacing: 0, verticalSpacing: 0) {","            GridRow {","                Text(\"Some text in an upper quadrant\")","                Color.gray.opacity(0.3)","            }","            GridRow {","                Color.gray.opacity(0.3)","                Text(\"More text in a lower quadrant\")","            }","        }","        .aspectRatio(1, contentMode: .fit)","        .foregroundColor(.secondary)","        .border(.gray)","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"To avoid crowding, the alignment diagram shows only two of the available","type":"text"},{"text":" ","type":"text"},{"text":"text baseline alignments. The others align as their names imply. Notice that","type":"text"},{"text":" ","type":"text"},{"text":"the first text baseline alignment aligns with the top-most line of text in","type":"text"},{"text":" ","type":"text"},{"text":"the background view, while the last text baseline aligns with the","type":"text"},{"text":" ","type":"text"},{"text":"bottom-most line. For more information about text baseline alignment, see","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","type":"reference"},{"text":".","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In a left-to-right language like English, the leading and trailing"},{"type":"text","text":" "},{"type":"text","text":"alignments appear on the left and right edges, respectively. OpenSwiftUI"},{"type":"text","text":" "},{"type":"text","text":"reverses these in right-to-left language environments. For more"},{"type":"text","text":" "},{"type":"text","text":"information, see "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","type":"reference","isActive":true},{"type":"text","text":"."}]},{"text":"Custom alignment","type":"heading","level":3,"anchor":"Custom-alignment"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can create custom alignments — which you typically do to make use"},{"type":"text","text":" "},{"type":"text","text":"of custom horizontal or vertical guides — by using the"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/init(horizontal:vertical:)","type":"reference","isActive":true},{"type":"text","text":" initializer. For example, you can combine"},{"type":"text","text":" "},{"type":"text","text":"a custom vertical guide called "},{"type":"codeVoice","code":"firstThird"},{"type":"text","text":" with the built-in horizontal"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/center","type":"reference","isActive":true},{"type":"text","text":" guide, and use it to configure a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","type":"reference","isActive":true},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["ZStack(alignment: Alignment(horizontal: .center, vertical: .firstThird)) {","    \/\/ ...","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more information about creating custom guides, including the code"},{"type":"text","text":" "},{"type":"text","text":"that creates the custom "},{"type":"codeVoice","code":"firstThird"},{"type":"text","text":" alignment in the example above,"},{"type":"text","text":" "},{"type":"text","text":"see "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID","isActive":true},{"type":"text","text":"."}]}]}],"metadata":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Alignment"}],"symbolKind":"struct","navigatorTitle":[{"text":"Alignment","kind":"identifier"}],"externalID":"s:15OpenSwiftU