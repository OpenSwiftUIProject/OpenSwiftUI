{"abstract":[{"type":"text","text":"React to system events, like opening a URL."}],"kind":"article","metadata":{"modules":[{"name":"OpenSwiftUI"}],"role":"collectionGroup","title":"System events","roleHeading":"API Collection"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"topicSections":[{"title":"Handling URLs","anchor":"Handling-URLs","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/OpenURLAction"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"Specify view and scene modifiers to indicate how your app responds to certain"},{"type":"text","text":" "},{"type":"text","text":"system events. For example, you can use the "},{"type":"codeVoice","code":"onOpenURL(perform:)"},{"type":"text","text":" view"},{"type":"text","text":" "},{"type":"text","text":"modifier to define an action to take when your app receives a universal link,"},{"type":"text","text":" "},{"type":"text","text":"or use the "},{"type":"codeVoice","code":"backgroundTask(_:action:)"},{"type":"text","text":" scene modifier to specify an"},{"type":"text","text":" "},{"type":"text","text":"asynchronous task to carry out in response to a background task event, like the"},{"type":"text","text":" "},{"type":"text","text":"completion of a background URL session."}],"type":"paragraph"}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/System-Events"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/system-events"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/OpenURLAction":{"type":"topic","url":"\/documentation\/openswiftui\/openurlaction","navigatorTitle":[{"text":"OpenURLAction","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/OpenURLAction","abstract":[{"text":"An action that opens a URL.","type":"text"}],"title":"OpenURLAction","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"OpenURLAction","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]}}}