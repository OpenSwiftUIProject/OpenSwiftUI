"text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"layoutPriority"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"value"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"kind":"text","text":"\n"}],"languages":["swift"],"platforms":["macOS"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The priority by which a parent layout apportions"},{"type":"text","text":" "},{"type":"text","text":"space to the child."}]}],"name":"value"}],"kind":"parameters"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"text":"Views typically have a default priority of ","type":"text"},{"type":"codeVoice","code":"0"},{"text":" which causes space to be","type":"text"},{"text":" ","type":"text"},{"text":"apportioned evenly to all sibling views. Raising a view’s layout","type":"text"},{"text":" ","type":"text"},{"text":"priority encourages the higher priority view to shrink later when the","type":"text"},{"text":" ","type":"text"},{"text":"group is shrunk and stretch sooner when the group is stretched.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["HStack {","    Text(\"This is a moderately long string.\")","        .font(.largeTitle)","        .border(Color.gray)","","    Spacer()","","    Text(\"This is a higher priority string.\")","        .font(.largeTitle)","        .layoutPriority(1)","        .border(Color.gray)","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"In the example above, the first "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" element has the default"},{"type":"text","text":" "},{"type":"text","text":"priority "},{"code":"0","type":"codeVoice"},{"type":"text","text":" which causes its view to shrink dramatically due to the"},{"type":"text","text":" "},{"type":"text","text":"higher priority of the second "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" element, even though all of their"},{"type":"text","text":" "},{"type":"text","text":"other attributes (font, font size and character count) are the same."}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"A parent layout offers the child views with the highest layout priority","type":"text"},{"text":" ","type":"text"},{"text":"all the space offered to the parent minus the minimum space required for","type":"text"},{"text":" ","type":"text"},{"text":"all its lower-priority children.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration\/Content-swift.struct\/layoutPriority(_:)"},"kind":"symbol","variants":[{"paths":["\/documentation\/openswiftui\/labeledcontentstyleconfiguration\/content-swift.struct\/layoutpriority(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/LabeledContentStyleConfiguration/Content-swift.struct/layoutPriority(_:)":{"url":"\/documentation\/openswiftui\/labeledcontentstyleconfiguration\/content-swift.struct\/layoutpriority(_:)","abstract":[{"type":"text","text":"Sets the priority by which a parent layout should apportion space to"},{"type":"text","text":" "},{"type":"text","text":"this child."}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/L