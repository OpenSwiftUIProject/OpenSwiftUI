{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/labeledcontentstyleconfiguration\/content-swift.struct\/labelshidden()"]}],"sections":[],"abstract":[{"type":"text","text":"Hides the labels of any controls contained within this view."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration\/Content-swift.struct\/labelsHidden()"},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"labelsHidden","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier when you want to omit a label from one or more","type":"text"},{"text":" ","type":"text"},{"text":"controls in your user interface. For example, the first ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle"},{"text":" in","type":"text"},{"text":" ","type":"text"},{"text":"the following example hides its label:","type":"text"}]},{"type":"codeListing","code":["VStack {","    Toggle(isOn: $toggle1) {","        Text(\"Toggle 1\")","    }","    .labelsHidden()","","    Toggle(isOn: $toggle2) {","        Text(\"Toggle 2\")","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":" in the example above centers the first toggle’s control"},{"type":"text","text":" "},{"type":"text","text":"element in the available space, while it centers the second toggle’s"},{"type":"text","text":" "},{"type":"text","text":"combined label and control element:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"Always provide a label for controls, even when you hide the label,","type":"text"},{"text":" ","type":"text"},{"text":"because SwiftUI uses labels for other purposes, including accessibility.","type":"text"}]},{"type":"aside","style":"note","content":[{"inlineContent":[{"text":"This modifier doesn’t work for all labels. It applies to","type":"text"},{"text":" ","type":"text"},{"text":"labels that are separate from the rest of the control’s interface,","type":"text"},{"text":" ","type":"text"},{"text":"like they are for ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true,"type":"reference"},{"text":", but not to controls like a bordered","type":"text"},{"text":" ","type":"text"},{"text":"button where the label is inside the button’s border.","type":"text"}],"type":"paragraph"}],"name":"Note"}],"kind":"content"}],"metadata":{"remoteSource":{"fileName":"LabelsHiddenModifier.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/LabelContent\/LabelsHiddenModifier.swift#L44"},"extendedModule":"OpenSwiftUICore","title":"labelsHidden()","externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE12labelsHiddenQryF::SYNTHESIZED::s:11OpenSwiftUI32LabeledContentStyleConfigurationV0E0V","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"labelsHidden","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View