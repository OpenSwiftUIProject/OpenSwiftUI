eContent":[{"text":"The first animation rotates the “Rotation” ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view by 360","type":"text"},{"text":" ","type":"text"},{"text":"degrees.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The second uses the ","type":"text"},{"code":"transaction(_:)","type":"codeVoice"},{"text":" modifier to change the","type":"text"},{"text":" ","type":"text"},{"text":"animation by adding a delay to the start of the animation","type":"text"},{"text":" ","type":"text"},{"text":"by two seconds and then increases the rotational speed of the","type":"text"},{"text":" ","type":"text"},{"text":"“Rotation\\nModified” ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference"},{"text":" view animation by a factor of 2.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The third animation uses the "},{"type":"codeVoice","code":"transaction(_:)"},{"type":"text","text":" modifier to"},{"type":"text","text":" "},{"type":"text","text":"replace the rotation animation affecting the “Animation\\nReplaced”"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" view with a spring animation."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"The following code implements these animations:","type":"text"}]},{"syntax":"swift","code":["struct TransactionExample: View {","    @State private var flag = false","","    var body: some View {","        VStack(spacing: 50) {","            HStack(spacing: 30) {","                Text(\"Rotation\")","                    .rotationEffect(Angle(degrees:","                                            self.flag ? 360 : 0))","","                Text(\"Rotation\\nModified\")","                    .rotationEffect(Angle(degrees:","                                            self.flag ? 360 : 0))","                    .transaction { view in","                        view.animation =","                            view.animation?.delay(2.0).speed(2)","                    }","","                Text(\"Animation\\nReplaced\")","                    .rotationEffect(Angle(degrees:","                                            self.flag ? 360 : 0))","                    .transaction { view in","                        view.animation = .interactiveSpring(","                            response: 0.60,","                            dampingFraction: 0.20,","                            blendDuration: 0.25)","                    }","            }","","            Button(\"Animate\") {","                withAnimation(.easeIn(duration: 2.0)) {","                    self.flag.toggle()","                }","            }","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier on leaf views such as ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image","isActive":true},{"text":" or ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button","isActive":true},{"text":" rather","type":"text"},{"text":" ","type":"text"},{"text":"than container views such as ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true},{"text":" or ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","isActive":true},{"text":". The","type":"text"},{"text":" ","type":"text"},{"text":"transformation applies to all child views within this view; calling","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"transaction(_:)"},{"text":" on a container view can lead to unbounded scope of","type":"text"},{"text":" ","type":"text"},{"text":"execution depending on the depth of the view hierarchy.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/openswiftui\/labeledcontentstyleconfiguration\/content-swift.struct\/transaction(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration\/Content-swift.struct"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"abstract":[{"text":"Applies the given transaction mutation function to all animations used","type":"text"},{"text":" ","type":"text"},{"text":"within the view.","type":"text"}],"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/LabeledContentStyleConfiguration/Content-swift.struct":{"title":"LabeledContentStyleConfiguration.Content","type":"topic","navigatorTitle":[{"text":"Content","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Content","kind":"identifier"}],"role":"symbol","abstract":[{"type":"text","text":"A type-erased content of a labeled content instance."}],"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration\/Content-swift.struct","url":"\/documentation\/openswiftui\/labeledcontentstyleconfiguration\/content-swift.struct"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"