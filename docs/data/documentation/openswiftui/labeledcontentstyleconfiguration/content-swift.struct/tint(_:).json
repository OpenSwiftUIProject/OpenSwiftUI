{"schemaVersion":{"minor":3,"patch":0,"major":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration\/Content-swift.struct"]]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"tint","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"tint","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Color","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","preciseIdentifier":"s:15OpenSwiftUICore5ColorV"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":"\n","kind":"text"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"tint","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The tint "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","isActive":true},{"type":"text","text":" to apply."}]}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Use this method to override the default accent color for this view.","type":"text"},{"text":" ","type":"text"},{"text":"Unlike an app’s accent color, which can be overridden by user","type":"text"},{"text":" ","type":"text"},{"text":"preference, the tint color is always respected and should be used as a","type":"text"},{"text":" ","type":"text"},{"text":"way to provide additional meaning to the control.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This example shows Answer and Decline buttons with ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/green","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/red","isActive":true,"type":"reference"},{"text":" tint colors, respectively.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct ControlTint: View {","    var body: some View {","        HStack {","            Button {","                \/\/ Answer the call","            } label: {","                Label(\"Answer\", systemImage: \"phone\")","            }","            .tint(.green)","            Button {","                \/\/ Decline the call","            } label: {","                Label(\"Decline\", systemImage: \"phone.down\")","            }","            .tint(.red)","        }","        .buttonStyle(.borderedProminent)","        .padding()","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Some controls adapt to the tint color differently based on their style,","type":"text"},{"text":" ","type":"text"},{"text":"the current platform, and the surrounding context. For example, in","type":"text"},{"text":" ","type":"text"},{"text":"macOS, a button with the ","type":"text"},{"code":"PrimitiveButtonStyle\/bordered","type":"codeVoice"},{"text":" style doesn’t","type":"text"},{"text":" ","type":"text"},{"text":"tint its background, but one with the","type":"text"},{"text":" ","type":"text"},{"code":"PrimitiveButtonStyle\/borderedProminent","type":"codeVoice"},{"text":" style does. In macOS, neither","type":"text"},{"text":" ","type":"text"},{"text":"of these button styles tint their label, but they do in other platforms.","type":"text"}]}]}],"metadata":{"extendedModule":"OpenSwiftUICore","roleHeading":"Instance Method","role":"symbol","title":"tint(_:)","platforms":[{"unavailable":false,"introducedAt":"13.0","deprecated":false,"name":"iOS","beta":false},{"unavailable":false,"introducedAt":"10.15","deprecated":false,"name":"macOS","beta":false},{"unavailable":false,"introducedAt":"13.0","deprecated":false,"name":"tvOS","beta":false},{"unavailable":false,"introducedAt":"1.0","deprecated":false,"name":"visionOS","beta":false},{"unavailable":false,"introducedAt":"6.0","deprecated":false,"name":"watchOS","beta":false}],"externalID":"s:15OpenSwiftUICore4ViewPAAE4tintyQrAA5ColorVSgF::SYNTHESIZED::s:11OpenSwiftUI32LabeledContentStyleConfigurationV0E0V","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"tint"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Color","preciseIdentifier":"s:15OpenSwiftUICore5ColorV"},{"kind":"text","text":"?) -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Shape\/Tint.swift#L134","fileName":"Tint.swift"},"symbolKind":"method"},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration\/Content-swift.struct\/tint(_:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/labeledcontentstyleconfiguration\/content-swift.struct\/tint(_:)"]}],"sections":[],"abstract":[{"text":"Sets the tint color within this view.","type":"text"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ShapeStyle/green":{"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"green","kind":"identifier"},{"text":": ","k