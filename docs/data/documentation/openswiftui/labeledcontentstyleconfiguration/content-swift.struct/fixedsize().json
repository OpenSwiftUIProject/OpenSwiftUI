{"abstract":[{"type":"text","text":"Fixes this view at its ideal size."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration\/Content-swift.struct"]]},"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration\/Content-swift.struct\/fixedSize()","interfaceLanguage":"swift"},"metadata":{"symbolKind":"method","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"title":"fixedSize()","externalID":"s:15OpenSwiftUICore4ViewPAAE9fixedSizeQryF::SYNTHESIZED::s:11OpenSwiftUI32LabeledContentStyleConfigurationV0E0V","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fixedSize","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"role":"symbol","roleHeading":"Instance Method","extendedModule":"OpenSwiftUICore","platforms":[{"beta":false,"name":"iOS","introducedAt":"13.0","unavailable":false,"deprecated":false},{"beta":false,"name":"macOS","introducedAt":"10.15","unavailable":false,"deprecated":false},{"beta":false,"name":"tvOS","introducedAt":"13.0","unavailable":false,"deprecated":false},{"beta":false,"name":"visionOS","introducedAt":"1.0","unavailable":false,"deprecated":false},{"beta":false,"name":"watchOS","introducedAt":"6.0","unavailable":false,"deprecated":false}],"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/FixedSizeLayout.swift#L144","fileName":"FixedSizeLayout.swift"}},"schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fixedSize","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"type":"text","text":"A view that fixes this view at its ideal size."}],"type":"paragraph"}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"During the layout of the view hierarchy, each view proposes a size to","type":"text"},{"text":" ","type":"text"},{"text":"each child view it contains. If the child view doesn’t need a fixed size","type":"text"},{"text":" ","type":"text"},{"text":"it can accept and conform to the size offered by the parent.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For example, a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view placed in an explicitly sized frame wraps","type":"text"},{"text":" ","type":"text"},{"text":"and truncates its string to remain within its parent’s bounds:","type":"text"}],"type":"paragraph"},{"code":["Text(\"A single line of text, too long to fit in a box.\")","    .frame(width: 200, height: 200)","    .border(Color.gray)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" modifier can be used to create a view that maintains"},{"type":"text","text":" "},{"type":"text","text":"the "},{"inlineContent":[{"text":"ideal size","type":"text"}],"type":"emphasis"},{"type":"text","text":" of its children both dimensions:"}],"type":"paragraph"},{"code":["Text(\"A single line of text, too long to fit in a box.\")","    .fixedSize()","    .frame(width: 200, height: 200)","    .border(Color.gray)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"This can result in the view exceeding the parent’s bounds, which may or"},{"type":"text","text":" "},{"type":"text","text":"may not be the effect you want."}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can think of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" as the creation of a "},{"inlineContent":[{"type":"text","text":"counter proposal"}],"type":"emphasis"},{"type":"text","text":" "},{"type":"text","text":"to the view size proposed to a view by its parent. The ideal size of a"},{"type":"text","text":" "},{"type":"text","text":"view, and the specific effects of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" depends on the"},{"type":"text","text":" "},{"type":"text","text":"particular view and how you have configured it."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To create a view that fixes the view’s size in either the horizontal or"},{"type":"text","text":" "},{"type":"text","text":"vertical dimensions, see "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/labeledcontentstyleconfiguration\/content-swift.struct\/fixedsize()"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/LabeledContentStyleConfiguration/Content-swift.struct/fixedSize()":{"title":"fixedSize()","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fixedSize","kind