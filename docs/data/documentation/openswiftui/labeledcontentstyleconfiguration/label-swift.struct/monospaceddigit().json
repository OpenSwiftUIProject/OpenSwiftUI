{"metadata":{"roleHeading":"Instance Method","externalID":"s:15OpenSwiftUICore4ViewPAAE15monospacedDigitQryF::SYNTHESIZED::s:11OpenSwiftUI32LabeledContentStyleConfigurationV5LabelV","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"monospacedDigit","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"}],"extendedModule":"OpenSwiftUICore","title":"monospacedDigit()","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"symbolKind":"method","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Data\/EnvironmentKeys\/EnvironmentAdditions.swift#L329","fileName":"EnvironmentAdditions.swift"},"platforms":[{"beta":false,"introducedAt":"13.0","deprecated":false,"name":"iOS","unavailable":false},{"beta":false,"introducedAt":"10.15","deprecated":false,"name":"macOS","unavailable":false},{"beta":false,"introducedAt":"13.0","deprecated":false,"name":"tvOS","unavailable":false},{"beta":false,"introducedAt":"1.0","deprecated":false,"name":"visionOS","unavailable":false},{"beta":false,"introducedAt":"6.0","deprecated":false,"name":"watchOS","unavailable":false}]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Modifies the fonts of all child views to use fixed-width digits, if","type":"text"},{"text":" ","type":"text"},{"text":"possible, while leaving other characters proportionally spaced.","type":"text"}],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"monospacedDigit","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":"\n","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"anchor":"return-value","text":"Return Value","type":"heading","level":2},{"inlineContent":[{"text":"A view whose child views’ fonts use fixed-width numeric","type":"text"},{"text":" ","type":"text"},{"text":"characters, while leaving other characters proportionally spaced.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Using fixed-width digits allows you to easily align numbers of the","type":"text"},{"text":" ","type":"text"},{"text":"same size in a table-like arrangement. This feature is also known as","type":"text"},{"text":" ","type":"text"},{"text":"“tabular figures” or “tabular numbers.”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This modifier only affects numeric characters, and leaves all other","type":"text"},{"text":" ","type":"text"},{"text":"characters unchanged.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows the effect of "},{"type":"codeVoice","code":"monospacedDigit()"},{"type":"text","text":" on"},{"type":"text","text":" "},{"type":"text","text":"multiple child views. The example consists of two "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":" views"},{"type":"text","text":" "},{"type":"text","text":"inside an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"},{"type":"text","text":". Each "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" contains two "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button"},{"type":"text","text":" views, with"},{"type":"text","text":" "},{"type":"text","text":"the second "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" applying the "},{"type":"codeVoice","code":"monospacedDigit()"},{"type":"text","text":" modifier to its"},{"type":"text","text":" "},{"type":"text","text":"contents. As a result, the digits in the buttons in the trailing"},{"type":"text","text":" "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" are the same width, which in turn gives the buttons equal widths."}]},{"type":"codeListing","syntax":"swift","code":["var body: some View {","    HStack(alignment: .top) {","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        .monospacedDigit()","    }","    .padding()","    .navigationTitle(\"monospacedDigit() Child Views\")","}"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a child view’s base font doesn’t support fixed-width digits, the font"},{"type":"text","text":" "},{"type":"text","text":"remains unchanged."}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration\/Label-swift.struct"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/labeledcontentstyleconfiguration\/label-swift.struct\/monospaceddigit()"]}],"sections":[],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration\/Label-swift.struct\/monospacedDigit()","interfaceLanguage":"swift"},"references":{"doc://OpenSwiftUI/documentation/OpenSw