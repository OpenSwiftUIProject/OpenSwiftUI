{"kind":"symbol","abstract":[{"text":"Isolates the geometry (e.g. position and size) of the view","type":"text"},{"text":" ","type":"text"},{"text":"from its parent view.","type":"text"}],"variants":[{"paths":["\/documentation\/openswiftui\/labeledcontentstyleconfiguration\/label-swift.struct\/geometrygroup()"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyleConfiguration\/Label-swift.struct"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":"\n","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"By default OpenSwiftUI views push position and size changes down","type":"text"},{"text":" ","type":"text"},{"text":"through the view hierarchy, so that only views that draw","type":"text"},{"text":" ","type":"text"},{"text":"something (known as leaf views) apply the current animation to","type":"text"},{"text":" ","type":"text"},{"text":"their frame rectangle. However in some cases this coalescing","type":"text"},{"text":" ","type":"text"},{"text":"behavior can give undesirable results; inserting a geometry","type":"text"},{"text":" ","type":"text"},{"text":"group can correct that. A group acts as a barrier between the","type":"text"},{"text":" ","type":"text"},{"text":"parent view and its subviews, forcing the position and size","type":"text"},{"text":" ","type":"text"},{"text":"values to be resolved and animated by the parent, before being","type":"text"},{"text":" ","type":"text"},{"text":"passed down to each subview.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example below shows one use of this function: ensuring that"},{"type":"text","text":" "},{"type":"text","text":"the member views of each row in the stack apply (and animate"},{"type":"text","text":" "},{"type":"text","text":"as) a single geometric transform from their ancestor view,"},{"type":"text","text":" "},{"type":"text","text":"rather than letting the effects of the ancestor views be"},{"type":"text","text":" "},{"type":"text","text":"applied separately to each leaf view. If the members of"},{"type":"text","text":" "},{"code":"ItemView","type":"codeVoice"},{"type":"text","text":" may be added and removed at different times the"},{"type":"text","text":" "},{"type":"text","text":"group ensures that they stay locked together as animations are"},{"type":"text","text":" "},{"type":"text","text":"applied."}]},{"type":"codeListing","syntax":"swift","code":["VStack {","    ForEach(items) { item in","        ItemView(item: item)","            .geometryGroup()","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns: a new view whose geometry is isolated from that of its"},{"type":"text","text":" "},{"type":"text","text":"parent view."}]}],"kind":"content"}],"metadata":{"roleHeading":"Instance Method","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"externalID":"s:15OpenSwiftUICore4ViewPAAE13geometryGroupQryF::SYNTHESIZED::s:11OpenSwiftUI32LabeledContentStyleConfigurationV5LabelV","platforms":[{"name":"iOS","deprecated":false,"introducedAt":"13.0","unavailable":false,"beta":false},{"name":"macOS","deprecated":false,"introducedAt":"10.15","unavailable":false,"beta":false},{"name":"tvOS"