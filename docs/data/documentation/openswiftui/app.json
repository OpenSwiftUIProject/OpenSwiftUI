{"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"A type that represents the structure and behavior of an app.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"App"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"Create an app by declaring a structure that conforms to the ","type":"text"},{"code":"App","type":"codeVoice"},{"text":" protocol.","type":"text"},{"text":" ","type":"text"},{"text":"Implement the required ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/App\/body-swift.property"},{"text":" computed property","type":"text"},{"text":" ","type":"text"},{"text":"to define the app’s content:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@main","struct MyApp: App {","    var body: some Scene {","        WindowGroup {","            Text(\"Hello, world!\")","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Precede the structure’s declaration with the"},{"type":"text","text":" "},{"identifier":"https:\/\/docs.swift.org\/swift-book\/ReferenceManual\/Attributes.html#ID626","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"attribute to indicate that your custom "},{"code":"App","type":"codeVoice"},{"type":"text","text":" protocol conformer provides the"},{"type":"text","text":" "},{"type":"text","text":"entry point into your app. The protocol provides a default implementation of"},{"type":"text","text":" "},{"type":"text","text":"the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/App\/main()"},{"type":"text","text":" method that the system calls to launch your app."},{"type":"text","text":" "},{"type":"text","text":"You can have exactly one entry point among all of your app’s files."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Compose the app’s body from instances that conform to the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Scene"},{"type":"text","text":" "},{"type":"text","text":"protocol. Each scene contains the root view of a view hierarchy and has a"},{"type":"text","text":" "},{"type":"text","text":"life cycle managed by the system. OpenSwiftUI provides some concrete scene types"},{"type":"text","text":" "},{"type":"text","text":"to handle common scenarios, like for displaying documents or settings. You"},{"type":"text","text":" "},{"type":"text","text":"can also create custom scenes."}]},{"type":"codeListing","syntax":"swift","code":["@main","struct Mail: App {","    var body: some Scene {","        WindowGroup {","            MailViewer()","        }","        Settings {","            SettingsView()","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can declare state in your app to share across all of its scenes. For"},{"type":"text","text":" "},{"type":"text","text":"example, you can use the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StateObject","type":"reference","isActive":true},{"type":"text","text":" attribute to initialize a"},{"type":"text","text":" "},{"type":"text","text":"data model, and then provide that model on a view input as an"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ObservedObject","type":"reference","isActive":true},{"type":"text","text":" or through the environment as an"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentObject","type":"reference","isActive":true},{"type":"text","text":" to scenes in the app:"}]},{"type":"codeListing","synt