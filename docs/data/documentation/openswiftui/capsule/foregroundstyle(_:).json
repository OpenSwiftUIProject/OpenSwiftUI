{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Capsule\/foregroundStyle(_:)"},"metadata":{"roleHeading":"Instance Method","role":"symbol","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Shape\/ShapeStyle\/ForegroundStyleModifier.swift#L112","fileName":"ForegroundStyleModifier.swift"},"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"externalID":"s:15OpenSwiftUICore4ViewPAAE15foregroundStyleyQrqd__AA05ShapeF0Rd__lF::SYNTHESIZED::s:15OpenSwiftUICore7CapsuleV","platforms":[{"unavailable":false,"deprecated":false,"beta":false,"name":"iOS","introducedAt":"13.0"},{"unavailable":false,"deprecated":false,"beta":false,"name":"macOS","introducedAt":"10.15"},{"unavailable":false,"deprecated":false,"beta":false,"name":"tvOS","introducedAt":"13.0"},{"unavailable":false,"deprecated":false,"beta":false,"name":"visionOS","introducedAt":"1.0"},{"unavailable":false,"deprecated":false,"beta":false,"name":"watchOS","introducedAt":"6.0"}],"title":"foregroundStyle(_:)","symbolKind":"method","extendedModule":"OpenSwiftUICore","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"foregroundStyle","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}]},"abstract":[{"text":"Sets a view’s foreground elements to use a given style.","type":"text"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Capsule"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/capsule\/foregroundstyle(_:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"foregroundStyle"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"style"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:15OpenSwiftUICore10ShapeStyleP","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","text":"ShapeStyle"},{"kind":"text","text":"\n"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The color or pattern to use when filling in the"},{"type":"text","text":" "},{"type":"text","text":"foreground elements. To indicate a specific value, use "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","isActive":true},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"ShapeStyle\/image(_:sourceRect:scale:)","type":"codeVoice"},{"type":"text","text":", or one of the gradient"},{"type":"text","text":" "},{"type":"text","text":"types, like"},{"type":"text","text":" "},{"code":"ShapeStyle\/linearGradient(colors:startPoint:endPoint:)","type":"codeVoice"},{"type":"text","text":". To set a"},{"type":"text","text":" "},{"type":"text","text":"style that’s relative to the containing view’s style, use one of the"},{"type":"text","text":" "},{"type":"text","text":"semantic styles, like "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/primary","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}],"name":"style"}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"A view that uses the given foreground style.","type":"text"}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to style"},{"type":"text","text":" "},{"type":"text","text":"foreground content like text, shapes, and template images"},{"type":"text","text":" "},{"type":"text","text":"(including symbols):"}]},{"type":"codeListing","code":["HStack {","    Image(systemName: \"triangle.fill\")","    Text(\"Hello, world!\")","    RoundedRectangle(cornerRadius: 5)","        .frame(width: 40, height: 20)","}",".foregroundStyle(.teal)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example above creates a row of "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/teal","isActive":true},{"type":"text","text":" foreground"},{"type":"text","text":" "},{"type":"text","text":"elements:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use any style that conforms to the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","type":"reference","isActive":true},{"type":"text","text":" protocol,"},{"type":"text","text":" "},{"type":"text","text":"like the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/teal","type":"reference","isActive":true},{"type":"text","text":" color in the example above, or the"},{"type":"text","text":" "},{"type":"codeVoice","code":"ShapeStyle\/linearGradient(colors:startPoint:endPoint:)"},{"type":"text","text":" gradient"},{"type":"text","text":" "},{"type":"text","text":"shown below:"}]},{"type":"codeListing","code":["Text(\"Gradient Text\")","    .font(.largeTitle)","    .foregroundStyle(","        .linearGradient(","            colors: [.yellow, .blue],","            startPoint: .top,","            endPoint: .bottom","        )","    )"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to fill a single "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape"},{"type":"text","text":" instance with a style,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape\/fill(style:)"},{"type":"text","text":" shape modifier instead because it’s more"},{"type":"text","text":" "},{"type":"text","text":"efficient."}]}],"style":"tip","name":"Tip"},{"type":"paragraph","inlineContent":[{"text":"OpenSwiftUI creates a context-dependent render for a given style.","type":"text"},{"text":" ","type":"text"},{"text":"For example, a ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","isActive":true},{"text":" that you load from an asset catalog","type":"text"},{"text":" ","type":"text"},{"text":"can have different light and dark appearances, while some styles","type":"text"},{"text":" ","type":"text"},{"text":"also vary by platform.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Hierarchical foreground styles like ","type":"text"},{"type":"codeVoice","code":"ShapeStyle\/secondary"},{"text":" ","type":"text"},{"text":"don’t impose a style of their own, but instead modify other styles.","type":"text"},{"text":" ","type":"text"},{"text":"In particular, they modify the primary","type":"text"},{"text":" ","type":"text"},{"text":"level of the current foreground style to the degree given by","type":"text"},{"text":" ","type":"text"},{"text":"the hierarchical style’s name.","type":"text"},{"text":" ","type":"text"},{"text":"To find the current foreground style to modify, OpenSwiftUI looks for","type":"text"},{"text":" ","type":"text"},{"text":"the innermost containing style that you apply with the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"foregroundStyle(_:)"},{"text":" or the ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/foregroundColor(_:)","isActive":true},{"text":" modifier.","type":"text"},{"text":" ","type":"text"},{"text":"If you haven’t specified a style, OpenSwiftUI uses the default foreground","type":"text"},{"text":" ","type":"text"},{"text":"style, as in the following example:","type":"text"}]},{"type":"codeListing","code":["VStack(alignment: .leading) {","    Label(\"Primary\", systemImage: \"1.square.fill\")","    Label(\"Secondary\", systemImage: \"2.square.fill\")","        .foregroundStyle(.secondary)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"If you add a foreground style on the enclosing","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference"},{"text":", the hierarchical styling responds accordingly:","type":"text"}]},{"type":"codeListing","code":["VStack(alignment: .leading) {","    Label(\"Primary\", systemImage: \"1.square.fill\")","    Label(\"Secondary\", systemImage: \"2.square.fill\")","        .foregroundStyle(.secondary)","}",".foregroundStyle(.blue)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you apply a custom style to a view, the view disables the vibrancy"},{"type":"text","text":" "},{"type":"text","text":"effect for foreground elements in that view, or in any of its child"},{"type":"text","text":" "},{"type":"text","text":"views, that it would otherwise gain from adding a background material"},{"type":"text","text":" "},{"type":"text","text":"— for example, using the "},{"type":"codeVoice","code":"View\/background(_:ignoresSafeAreaEdges:)"},{"type":"text","text":" "},{"type":"text","text":"modifier. However, hierarchical styles applied to the default foreground"},{"type":"text","text":" "},{"type":"text","text":"don’t disable vibrancy."}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View/foregroundColor(_:)":{"url":"\/documentation\/openswiftui\/view\/foregroundcolor(_:)","title":"foregroundColor(_:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"foregroundColor","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Color","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore5ColorV"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/foregroundColor(_:)","type":"topic","role":"symbol","deprecated":true,"abstract":[{"text":"Sets the color of the foreground elements displayed by this view.","type":"text"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Color":{"type":"topic","role":"symbol","title":"Color","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Color","kind":"identifier"}],"navigatorTitle":[{"text":"Color","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","url":"\/documentation\/openswiftui\/color","abstract":[{"type":"text","text":"A representation of a color that adapts to a given context."}],"kind":"symbol"},"doc://OpenSwiftUI/