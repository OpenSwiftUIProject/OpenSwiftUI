tifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Capsule\/transaction(value:_:)"},"abstract":[{"type":"text","text":"Applies the given transaction mutation function to all animations used"},{"type":"text","text":" "},{"type":"text","text":"within the view."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Capsule"]]},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"transaction"},{"kind":"text","text":"("},{"kind":"externalParam","text":"value"},{"kind":"text","text":": "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:SQ","text":"Equatable"},{"kind":"text","text":", "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"transform"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Transaction","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Transaction","preciseIdentifier":"s:15OpenSwiftUICore11TransactionV"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A value to monitor for changes."}]}],"name":"value"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The transformation to apply to transactions"},{"type":"text","text":" "},{"type":"text","text":"within this view."}]}],"name":"transform"}],"kind":"parameters"},{"content":[{"level":2,"anchor":"return-value","text":"Return Value","type":"heading"},{"inlineContent":[{"type":"text","text":"A view that wraps this view and applies a transformation to"},{"type":"text","text":" "},{"type":"text","text":"all transactions used within the view whenever "},{"type":"codeVoice","code":"value"},{"type":"text","text":" changes."}],"type":"paragraph"}],"kind":"content"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to change or replace the animation used in a view."},{"type":"text","text":" "},{"type":"text","text":"Consider three identical views controlled by a"},{"type":"text","text":" "},{"type":"text","text":"button that changes all three simultaneously:"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The first view animates rotating the “Rotation” "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"type":"text","text":" view by 360"},{"type":"text","text":" "},{"type":"text","text":"degrees."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The second uses the "},{"type":"codeVoice","code":"transaction(_:)"},{"type":"text","text":" modifier to change the"},{"type":"text","text":" "},{"type":"text","text":"animation by adding a delay to the start of the animation"},{"type":"text","text":" "},{"type":"text","text":"by two seconds and then increases the rotational speed of the"},{"type":"text","text":" "},{"type":"text","text":"“Rotation\\nModified” "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"type":"text","text":" view animation by a factor of 2."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The third uses the "},{"type":"codeVoice","code":"transaction(_:)"},{"type":"text","text":" modifier to disable animations"},{"type":"text","text":" "},{"type":"text","text":"affecting the “Animation\\nReplaced” "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" view."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"The following code implements these animations:","type":"text"}]},{"syntax":"swift","code":["struct TransactionExample: View {","    @State var flag = false","","    var body: some View {","        VStack(spacing: 50) {","            HStack(spacing: 30) {","                Text(\"Rotation\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","","                Text(\"Rotation\\nModified\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","                    .transaction(value: flag) { t in","                        t.animation =","                            t.animation?.delay(2.0).speed(2)","                    }","","                Text(\"Animation\\nReplaced\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","                    .transaction(value: flag) { t in","                        t.disableAnimations = true","                    }","            }","","            Button(\"Animate\") {","                withAnimation(.easeIn(duration: 2.0)) {","                    flag.toggle()","                }","            }","        }","    }","}"],"type":"codeListing"}],"kind":"content"}],"sections":[],"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Text":{"url":"\/documentation\/openswiftui\/text","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Text"}],"title":"Text","abstract":[],"role":"symbol","identifier":"doc:\/\/OpenSw