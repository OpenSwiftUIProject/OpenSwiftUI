er\/OverlayModifier.swift#L239"}},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Capsule"]]},"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"abstract":[{"type":"text","text":"Layers the views that you specify in front of this view."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"overlay"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"externalParam","text":"alignment"},{"kind":"text","text":": "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment","kind":"typeIdentifier","text":"Alignment","preciseIdentifier":"s:15OpenSwiftUICore9AlignmentV"},{"kind":"text","text":" = .center, "},{"kind":"attribute","text":"@"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder","kind":"attribute","text":"ViewBuilder","preciseIdentifier":"s:15OpenSwiftUICore11ViewBuilderV"},{"kind":"text","text":" "},{"kind":"externalParam","text":"content"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"text":"The alignment that the modifier uses to position the","type":"text"},{"text":" ","type":"text"},{"text":"implicit ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true,"type":"reference"},{"text":" that groups the foreground views. The default","type":"text"},{"text":" ","type":"text"},{"text":"is ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}],"name":"alignment"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder","isActive":true},{"type":"text","text":" that you use to declare the views to"},{"type":"text","text":" "},{"type":"text","text":"draw in front of this view, stacked in the order that you list them."},{"type":"text","text":" "},{"type":"text","text":"The last view that you list appears at the front of the stack."}]}],"name":"content"}],"kind":"parameters"},{"content":[{"text":"Return Value","type":"heading","level":2,"anchor":"return-value"},{"inlineContent":[{"text":"A view that uses the specified content as a foreground.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Use this modifier to place one or more views in front of another view."},{"type":"text","text":" "},{"type":"text","text":"For example, you can place a group of stars on a "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/RoundedRectangle","type":"reference"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["RoundedRectangle(cornerRadius: 8)","    .frame(width: 200, height: 100)","    .overlay(alignment: .topLeading) { Star(color: .red) }","    .overlay(alignment: .topTrailing) { Star(color: .yellow) }","    .overlay(alignment: .bottomLeading) { Star(color: .green) }","    .overlay(alignment: .bottomTrailing) { Star(color: .blue) }"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The example above assumes that you’ve defined a "},{"code":"Star","type":"codeVoice"},{"type":"text","text":" view with a"},{"type":"text","text":" "},{"type":"text","text":"parameterized color:"}],"type":"paragraph"},{"syntax":"swift","code":["struct Star: View {","    var color = Color.yellow","","    var body: some View {","        Image(systemName: \"star.fill\")","            .foregroundStyle(color)","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"By setting different "},{"type":"codeVoice","code":"alignment"},{"type":"text","text":" values for each modifier, you make the"},{"type":"text","text":" "},{"type":"text","text":"stars appear in different places on the rectangle:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you specify more than one view in the "},{"type":"codeVoice","code":"content"},{"type":"text","text":" closure, the modifier"},{"type":"text","text":" "},{"type":"text","text":"collects all of the views in the closure into an implicit "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"taking them in order from back to front. For example, you can place a"},{"type":"text","text":" "},{"type":"text","text":"star and a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Circle","isActive":true},{"type":"text","text":" on a field of "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/blue","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["Color.blue","    .frame(width: 200, height: 200)","    .overlay {","        Circle()","            .frame(width: 100, height: 100)","        Star()","    }"],"type":"codeListing"},{"inlineContent":[{"text":"Both the overlay modifier and the implicit ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"text":" composed from the","type":"text"},{"text":" ","type":"text"},{"text":"overlay content — the circle and the star — use a default","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center"},{"text":" alignment. The star appears centered on the circle,","type":"text"},{"text":" ","type":"text"},{"text":"and both appear as a composite view centered in front of the square:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"If you specify an alignment for the overlay, it applies to the implicit","type":"text"},{"text":" ","type":"text"},{"text":"stack rather than to the individual views in the closure. You can see","type":"text"},{"text":" ","type":"text"},{"text":"this if you add the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/bottom"},{"text":" alignment:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["Color.blue","    .frame(width: 200, height: 200)","    .overlay(alignment: .bottom) {","        Circle()","            .frame(width: 100, height: 100)","        Star()","    }"],"type":"codeListing"},{"inlineContent":[{"text":"The circle and the star move down as a unit to align the stack’s bottom","type":"text"},{"text":" ","type":"text"},{"text":"edge with the bottom edge of the square, while the star remains","type":"text"},{"text":" ","type":"text"},{"text":"centered on the circle:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"To control the placement of individual items inside the ","type":"text"},{"type":"codeVoice","code":"content"},{"text":" ","type":"text"},{"text":"closure, either use a different overlay modifier for each item, as the","type":"text"},{"text":" ","type":"text"},{"text":"earlier example of stars in the corners of a rectangle demonstrates, or","type":"text"},{"text":" ","type":"text"},{"text":"add an explicit ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true},{"text":" inside the content closure with its own","type":"text"},{"text":" ","type":"text"},{"text":"alignment:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["Color.blue","    .frame(width: 200, height: 200)","    .overlay(alignment: .bottom) {","        ZStack(alignment: .bottom) {","            Circle()","                .frame(width: 100, height: 100)","            Star()","        }","    }"],"type":"codeListing"},{"inlineContent":[{"text":"The stack alignment ensures that the star’s bottom edge aligns with the","type":"text"},{"text":" ","type":"text"},{"text":"circle’s, while the overlay aligns the composite view with the square:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can achieve layering without an overlay modifier by putting both the"},{"type":"text","text":" "},{"type":"text","text":"modified view and the overlay content into a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","type":"reference","isActive":true},{"type":"text","text":". This can"},{"type":"text","text":" "},{"type":"text","text":"produce a simpler view hierarchy, but changes the layout priority that"},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI applies to the views. Use the overlay modifier when you want the"},{"type":"text","text":" "},{"type":"text","text":"modified view to dominate the layout."}],"type":"paragraph"},{"inlineContent":[{"text":"If you want to specify a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","type":"reference","isActive":true},{"text":" like a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","type":"reference","isActive":true},{"text":" or a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Material","type":"reference","isActive":true},{"text":" as the overlay, use","type":"text"},{"text":" ","type":"text"},{"code":"View\/overlay(_:ignoresSafeAreaEdges:)","type":"codeVoice"},{"text":" instead. To specify a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape","type":"reference","isActive":true},{"text":", use ","type":"text"},{"code":"View\/overlay(_:in:fillStyle:)","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Alignment":{"url":"\/documentation\/openswiftui\/alignment","abstract":[{"type":"text","text":"An alignment in both axes."}],"navigatorTitle":[{"text":"Alignment","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Alignment","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment","role":"symbol","type":"topic","title":"Alignment"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ShapeStyle":{"abstract":[{"type":"text","text":"A color or pattern to use when rendering a shape."}],"type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"S