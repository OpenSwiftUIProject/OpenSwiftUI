{"sections":[],"abstract":[{"type":"text","text":"Adds an asynchronous task to perform before this view appears."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/capsule\/task(priority:_:)"]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Capsule"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Capsule\/task(priority:_:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"task"},{"kind":"text","text":"("},{"kind":"externalParam","text":"priority"},{"kind":"text","text":": "},{"preciseIdentifier":"s:ScP","kind":"typeIdentifier","text":"TaskPriority"},{"kind":"text","text":" = .userInitiated, "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"action"},{"kind":"text","text":": "},{"kind":"attribute","text":"@escaping"},{"kind":"text","text":" () "},{"kind":"keyword","text":"async"},{"kind":"text","text":" -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","text":"View"},{"kind":"text","text":"\n"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The task priority to use when creating the asynchronous"},{"type":"text","text":" "},{"type":"text","text":"task. The default priority is"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/taskpriority\/userinitiated"},{"type":"text","text":","}]}],"name":"priority"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure that OpenSwiftUI calls as an asynchronous task"},{"type":"text","text":" "},{"type":"text","text":"before the view appears. OpenSwiftUI will automatically cancel the task"},{"type":"text","text":" "},{"type":"text","text":"at some point after the view disappears before the action completes."}]}],"name":"action"}]},{"kind":"content","content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that runs the specified action asynchronously before"},{"type":"text","text":" "},{"type":"text","text":"the view appears."}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Use this modifier to perform an asynchronous task with a lifetime that"},{"type":"text","text":" "},{"type":"text","text":"matches that of the modified view. If the task doesn’t finish"},{"type":"text","text":" "},{"type":"text","text":"before OpenSwiftUI removes the view or the view changes identity, OpenSwiftUI"},{"type":"text","text":" "},{"type":"text","text":"cancels the task."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"await"},{"type":"text","text":" keyword inside the task to"},{"type":"text","text":" "},{"type":"text","text":"wait for an asynchronous call to complete, or to wait on the values of"},{"type":"text","text":" "},{"type":"text","text":"an "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/asyncsequence","isActive":true},{"type":"text","text":" "},{"type":"text","text":"instance. For example, you can modify a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" view to start a task"},{"type":"text","text":" "},{"type":"text","text":"that loads content from a remote resource:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let url = URL(string: \"https:\/\/example.com\")!","@State private var message = \"Loading...\"","","var body: some View {","    Text(message)","        .task {","            do {","                var receivedLines = [String]()","                for try await line in url.lines {","                    receivedLines.append(line)","                    message = \"Received \\(receivedLines.count) lines\"","                }","            } catch {","                message = \"Failed to load\"","            }","        }","}"]},{"inlineContent":[{"type":"text","text":"This example uses the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url\/3767315-lines"},{"type":"text","text":" "},{"type":"text","text":"method to get the content stored at the specified"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url"},{"type":"text","text":" as an"},{"type":"text","text":" "},{"type":"text","text":"asynchronous sequence of strings. When each new line arrives, the body"},{"type":"text","text":" "},{"type":"text","text":"of the "},{"type":"codeVoice","code":"for"},{"type":"text","text":"-"},{"type":"codeVoice","code":"await"},{"type":"text","text":"-"},{"type":"codeVoice","code":"in"},{"type":"text","text":" loop stores the line in an array of strings"},{"type":"text","text":" "},{"type":"text","text":"and updates the content of the text view to report the latest line"},{"type":"text","text":" "},{"type":"text","text":"count."}],"type":"paragraph"}]}],"metadata":{"title":"task(priority:_:)","roleHeading":"Instance Method","role":"symbol","platforms":[{"beta":false,"deprecated":false,"unavailable":false,"name":"iOS","introducedAt":"13.0"},{"beta":false,"deprecated":false,"unavailable":false,"name":"macOS","introducedAt":"10.15"},{"beta":false,"deprecated":false,"unavailable":false,"name":"tvOS","introducedAt":"13.0"},{"beta":false,"deprecated":false,"unavailable":false,"name":"visionOS","introducedAt":"1.0"},{"beta":false,"deprecated":false,"unavailable":false,"name":"watchOS","introducedAt":"6.0"}],"extendedModule":"OpenSwiftUICore","externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE4task8priority_QrScP_yyYaYbctF::SYNTHESIZED::s:15OpenSwiftUICore7CapsuleV","symbolKind":"method","remoteSource":{"fileName":"TaskModifier.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/Modifier\/ViewModifier\/TaskModifier.swift#L67"},"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"task","kind":"identifier"},{"text":"(","kind":"text"},{"text":"priority","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:ScP","text":"TaskPriority","kind":"typeIdentifier"},{"text":", () ","kind":"text"},{"text":"async","kind":"keyword"},{"text":" -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}]},"references":{"https://developer.apple.com/documentation/swift/taskpriority/userinitiated":{"type":"link","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/taskpriority\/userinitiated","title":"userInitiated","titleInlineContent":[{"text":"userInitiated","type":"text"}],"url":"https:\/\/developer.apple.com\/documentation\/swift\/taskpriority\/userinitiated"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Capsule/task(priority:_:)":{"abstract":[{"type":"text","text":"Ad