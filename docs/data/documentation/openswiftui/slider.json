{"abstract":[{"type":"text","text":"A control for selecting a value from a bounded linear range of values."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/init(value:in:onEditingChanged:)","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/init(value:in:step:onEditingChanged:)"],"anchor":"Creating-a-slider","title":"Creating a slider"},{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/init(value:in:label:onEditingChanged:)","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/init(value:in:step:label:onEditingChanged:)","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/init(value:in:label:minimumValueLabel:maximumValueLabel:onEditingChanged:)","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/init(value:in:step:label:minimumValueLabel:maximumValueLabel:onEditingChanged:)"],"anchor":"Creating-a-slider-with-labels","title":"Creating a slider with labels"},{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/init(value:in:onEditingChanged:label:)","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/init(value:in:step:onEditingChanged:label:)","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/init(value:in:onEditingChanged:minimumValueLabel:maximumValueLabel:label:)","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/init(value:in:step:onEditingChanged:minimumValueLabel:maximumValueLabel:label:)"],"anchor":"Deprecated-initializers","title":"Deprecated initializers"},{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/body"],"anchor":"Instance-Properties","title":"Instance Properties","generated":true},{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/View-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"relationshipsSections":[{"identifiers":["doc:\/\/OpenSwiftUI\/s8SendableP","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Slider","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Label","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"ValueLabel","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Label","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":", ","kind":"text"},{"text":"ValueLabel","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Overview","anchor":"overview","level":2},{"type":"paragraph","inlineContent":[{"text":"A slider consists of a “thumb” image that the user moves between two","type":"text"},{"text":" ","type":"text"},{"text":"extremes of a linear “track”. The ends of the track represent the minimum","type":"text"},{"text":" ","type":"text"},{"text":"and maximum possible values. As the user moves the thumb, the slider","type":"text"},{"text":" ","type":"text"},{"text":"updates its bound value.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The following example shows a slider bound to the value ","type":"text"},{"type":"codeVoice","code":"speed"},{"text":". As the","type":"text"},{"text":" ","type":"text"},{"text":"slider updates this value, a bound ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view shows the value updating.","type":"text"},{"text":" ","type":"text"},{"text":"The ","type":"text"},{"type":"codeVoice","code":"onEditingChanged"},{"text":" closure passed to the slider receives callbacks when","type":"text"},{"text":" ","type":"text"},{"text":"the user drags the slider. The example uses this to change the","type":"text"},{"text":" ","type":"text"},{"text":"color of the value text.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["@State private var speed = 50.0","@State private var isEditing = false","","var body: some View {","    VStack {","        Slider(","            value: $speed,","            in: 0...100,","            onEditingChanged: { editing in","                isEditing = editing","            }","        )","        Text(\"\\(speed)\")","            .foregroundColor(isEditing ? .red : .blue)","    }","}"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also use a "},{"type":"codeVoice","code":"step"},{"type":"text","text":" parameter to provide incremental steps along the"},{"type":"text","text":" "},{"type":"text","text":"path of the slider. For example, if you have a slider with a range of "},{"type":"codeVoice","code":"0"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"codeVoice","code":"100"},{"type":"text","text":", and you set the "},{"type":"codeVoice","code":"step"},{"type":"text","text":" value to "},{"type":"codeVoice","code":"5"},{"type":"text","text":", the slider’s increments would be"},{"type":"text","text":" "},{"type":"codeVoice","code":"0"},{"type":"text","text":", "},{"type":"codeVoice","code":"5"},{"type":"text","text":", "},{"type":"codeVoice","code":"10"},{"type":"text","text":", and so on. The following example shows this approach, and"},{"type":"text","text":" "},{"type":"text","text":"also adds optional minimum and maximum value labels."}]},{"type":"codeListing","syntax":"swift","code":["@State private var speed = 50.0","@State private var isEditing = false","","var body: some View {","    Slider(","        value: $speed,","        in: 0...100,","        step: 5","    ) {","        Text(\"Speed\")","    } minimumValueLabel: {","        Text(\"0\")","    } maximumValueLabel: {","        Text(\"100\")","    } onEditingChanged: { editing in","        isEditing = editing","    }","    Text(\"\\(speed)\")","        .foregroundColor(isEditing ? .red : .blue)","}"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"The slider also uses the ","type":"text"},{"code":"step","type":"codeVoice"},{"text":" to increase or decrease the value when a","type":"text"},{"text":" ","type":"text"},{"text":"VoiceOver user adjusts the slider with voice commands.","type":"text"}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider"},"metadata":{"title":"Slider","modules":[{"name":"OpenSwiftUI"}],"roleHeading":"Structure","externalID":"s:11OpenSwiftUI6SliderV","platforms":[],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Slider","kind":"identifier"}],"navigatorTitle":[{"text":"Slider","kind":"identifier"}],"symbolKind":"struct","remoteSource":{"fileName":"Slider.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/Control\/Slider\/Slider.swift#L80"},"role":"symbol"},"sections":[],"variants":[{"paths":["\/documentation\/openswiftui\/slider"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftui\/view","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"type":"topic","