ations"],"anchor":"Default-Implementations","title":"Default Implementations","generated":true}],"sections":[],"metadata":{"roleHeading":"Structure","externalID":"s:11OpenSwiftUI6SliderV","modules":[{"name":"OpenSwiftUI"}],"platforms":[],"navigatorTitle":[{"text":"Slider","kind":"identifier"}],"role":"symbol","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/Control\/Slider\/Slider.swift#L80","fileName":"Slider.swift"},"symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Slider","kind":"identifier"}],"title":"Slider"},"kind":"symbol","relationshipsSections":[{"identifiers":["doc:\/\/OpenSwiftUI\/s8SendableP","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"],"kind":"relationships","title":"Conforms To","type":"conformsTo"}],"abstract":[{"type":"text","text":"A control for selecting a value from a bounded linear range of values."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Slider","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Label","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"ValueLabel","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Label","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":", ","kind":"text"},{"text":"ValueLabel","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A slider consists of a “thumb” image that the user moves between two"},{"type":"text","text":" "},{"type":"text","text":"extremes of a linear “track”. The ends of the track represent the minimum"},{"type":"text","text":" "},{"type":"text","text":"and maximum possible values. As the user moves the thumb, the slider"},{"type":"text","text":" "},{"type":"text","text":"updates its bound value."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows a slider bound to the value "},{"type":"codeVoice","code":"speed"},{"type":"text","text":". As the"},{"type":"text","text":" "},{"type":"text","text":"slider updates this value, a bound "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" view shows the value updating."},{"type":"text","text":" "},{"type":"text","text":"The "},{"type":"codeVoice","code":"onEditingChanged"},{"type":"text","text":" closure passed to the slider receives callbacks when"},{"type":"text","text":" "},{"type":"text","text":"the user drags the slider. The example uses this to change the"},{"type":"text","text":" "},{"type":"text","text":"color of the value text."}]},{"type":"codeListing","code":["@State private var speed = 50.0","@State private var isEditing = false","","var body: some View {","    VStack {","        Slider(","            value: $speed,","            in: 0...100,","            onEditingChanged: { editing in","                isEditing = editing","            }","        )","        Text(\"\\(speed)\")","            .foregroundColor(isEditing ? .red : .blue)","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also use a "},{"type":"codeVoice","code":"step"},{"type":"text","text":" parameter to provide incremental steps along the"},{"type":"text","text":" "},{"type":"text","text":"path of the slider. For example, if you have a slider with a range of "},{"type":"codeVoice","code":"0"},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"codeVoice","code":"100"},{"type":"text","text":", and you set the "},{"type":"codeVoice","code":"step"},{"type":"text","text":" value to "},{"type":"codeVoice","code":"5"},{"type":"text","text":", the slider’s increments would be"},{"type":"text","text":" "},{"type":"codeVoice","code":"0"},{"type":"text","text":", "},{"type":"codeVoice","code":"5"},{"type":"text","text":", "},{"type":"codeVoice","code":"10"},{"type":"text","text":", and so on. The following example shows this approach, and"},{"type":"text","text":" "},{"type":"text","text":"also adds optional minimum and maximum value labels."}]},{"type":"codeListing","code":["@State private var speed = 50.0","@State private var isEditing = false","","var body: some View {","    Slider(","        value: $speed,","        in: 0...100,","        step: 5","    ) {","        Text(\"Speed\")","    } minimumValueLabel: {","        Text(\"0\")","    } maximumValueLabel: {","        Text(\"100\")","    } onEditingChanged: { editing in","        isEditing = editing","    }","    Text(\"\\(speed)\")","        .foregroundColor(isEditing ? .red : .blue)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The slider also uses the "},{"code":"step","type":"codeVoice"},{"type":"text","text":" to increase or decrease the value when a"},{"type":"text","text":" "},{"type":"text","text":"VoiceOver user adjusts the slider with voice commands."}]}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Slider/init(value:in:step:onEditingChanged:minimumValueLabel:maximumValueLabel:label:)":{"deprecated":true,"fragments":[{"text":"init","kind":"identifier