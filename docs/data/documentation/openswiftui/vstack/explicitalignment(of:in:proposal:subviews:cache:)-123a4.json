anguages":["swift"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","type":"reference"},{"type":"text","text":" guide that the method calculates"},{"type":"text","text":" "},{"type":"text","text":"the position of."}]}],"name":"guide"},{"content":[{"inlineContent":[{"type":"text","text":"The region that the container view’s parent allocates to the"},{"type":"text","text":" "},{"type":"text","text":"container view, specified in the parent’s coordinate space."}],"type":"paragraph"}],"name":"bounds"},{"content":[{"inlineContent":[{"type":"text","text":"A proposed size for the container."}],"type":"paragraph"}],"name":"proposal"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A collection of proxy instances that represent the"},{"type":"text","text":" "},{"type":"text","text":"views arranged by the container. You can use the proxies in the"},{"type":"text","text":" "},{"type":"text","text":"collection to get information about the subviews as you determine"},{"type":"text","text":" "},{"type":"text","text":"where to place the guide."}]}],"name":"subviews"},{"content":[{"inlineContent":[{"type":"text","text":"Optional storage for calculated data that you can share among"},{"type":"text","text":" "},{"type":"text","text":"the methods of your custom layout container. See"},{"type":"text","text":" "},{"code":"makeCache(subviews:)","type":"codeVoice"},{"type":"text","text":" for details."}],"type":"paragraph"}],"name":"cache"}],"kind":"parameters"},{"content":[{"anchor":"return-value","level":2,"type":"heading","text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The guide’s position relative to the "},{"type":"codeVoice","code":"bounds"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Return "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" to indicate that the guide doesn’t have an explicit"},{"type":"text","text":" "},{"type":"text","text":"value."}]}],"kind":"content"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Implement this method to return a value for the specified alignment"},{"type":"text","text":" "},{"type":"text","text":"guide of a custom layout container. The value you return affects"},{"type":"text","text":" "},{"type":"text","text":"the placement of the container as a whole, but it doesn’t affect how the"},{"type":"text","text":" "},{"type":"text","text":"container arranges subviews relative to one another."}],"type":"paragraph"},{"inlineContent":[{"text":"You can use this method to put an alignment guide in a nonstandard","type":"text"},{"text":" ","type":"text"},{"text":"position. For example, you can raise the container’s bottom edge","type":"text"},{"text":" ","type":"text"},{"text":"alignment guide by 10 points:","type":"text"}],"type":"paragraph"},{"code":["extension BasicVStack {","    func explicitAlignment(","        of guide: VerticalAlignment,","        in bounds: CGRect,","        proposal: ProposedViewSize,","        subviews: Subviews,","        cache: inout ()","    ) -> CGFloat? {","        if guide == .bottom {","            return bounds.minY - 10","        }","        return nil","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The above example returns "},{"code":"nil","type":"codeVoice"},{"type":"text","text":" for other guides to indicate that they"},{"type":"text","text":" "},{"type":"text","text":"don’t have an explicit value. A guide without an explicit value behaves"},{"type":"text","text":" "},{"type":"text","text":"as it would for any other view. If you don’t implement the"},{"type":"text","text":" "},{"type":"text","text":"method, the protocol’s default implementation merges the"},{"type":"text","text":" "},{"type":"text","text":"sub