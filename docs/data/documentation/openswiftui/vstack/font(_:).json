{"abstract":[{"type":"text","text":"Sets the default font for text in this view."}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack\/font(_:)","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"font","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"font","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Font","preciseIdentifier":"s:15OpenSwiftUICore4FontV","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Font"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":"\n","kind":"text"}]}]},{"kind":"parameters","parameters":[{"name":"font","content":[{"type":"paragraph","inlineContent":[{"text":"The default font to use in this view.","type":"text"}]}]}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"text":"A view with the default font set to the value you supply.","type":"text"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"inlineContent":[{"text":"Use ","type":"text"},{"type":"codeVoice","code":"font(_:)"},{"text":" to apply a specific font to all of the text in a view.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The example below shows the effects of applying fonts to individual","type":"text"},{"text":" ","type":"text"},{"text":"views and to view hierarchies. Font information flows down the view","type":"text"},{"text":" ","type":"text"},{"text":"hierarchy as part of the environment, and remains in effect unless","type":"text"},{"text":" ","type":"text"},{"text":"overridden at the level of an individual view or view container.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Here, the outermost "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":" applies a 16-point system font as a"},{"type":"text","text":" "},{"type":"text","text":"default font to views contained in that "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":". Inside that stack,"},{"type":"text","text":" "},{"type":"text","text":"the example applies a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Font\/largeTitle"},{"type":"text","text":" font to just the first text"},{"type":"text","text":" "},{"type":"text","text":"view; this explicitly overrides the default. The remaining stack and the"},{"type":"text","text":" "},{"type":"text","text":"views contained with it continue to use the 16-point system font set by"},{"type":"text","text":" "},{"type":"text","text":"their containing view:"}],"type":"paragraph"},{"type":"codeListing","code":["VStack {","    Text(\"Font applied to a text view.\")","        .font(.largeTitle)","","    VStack {","        Text(\"These 2 text views have the same font\")","        Text(\"applied to their parent hierarchy\")","    }","}",".font(.system(size: 16, weight: .light, design: .default))"],"syntax":"swift"},{"inlineContent":[],"type":"paragraph"}]}],"metadata":{"title":"font(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"font"},{"kind":"text","text":"("},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore