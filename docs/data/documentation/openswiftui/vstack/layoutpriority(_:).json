{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"text":"Sets the priority by which a parent layout should apportion space to","type":"text"},{"text":" ","type":"text"},{"text":"this child.","type":"text"}],"sections":[],"metadata":{"externalID":"s:15OpenSwiftUICore4ViewPAAE14layoutPriorityyQrSdF::SYNTHESIZED::s:15OpenSwiftUICore6VStackV","platforms":[{"beta":false,"deprecated":false,"name":"iOS","introducedAt":"13.0","unavailable":false},{"beta":false,"deprecated":false,"name":"macOS","introducedAt":"10.15","unavailable":false},{"beta":false,"deprecated":false,"name":"tvOS","introducedAt":"13.0","unavailable":false},{"beta":false,"deprecated":false,"name":"visionOS","introducedAt":"1.0","unavailable":false},{"beta":false,"deprecated":false,"name":"watchOS","introducedAt":"6.0","unavailable":false}],"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"title":"layoutPriority(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"layoutPriority"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"Double","preciseIdentifier":"s:Sd"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"symbolKind":"method","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/LayoutPriority.swift#L49","fileName":"LayoutPriority.swift"},"roleHeading":"Instance Method","extendedModule":"OpenSwiftUICore","role":"symbol"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"layoutPriority","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"value","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"},{"text":"\n","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"name":"value","content":[{"type":"paragraph","inlineContent":[{"text":"The priority by which a parent layout apportions","type":"text"},{"text":" ","type":"text"},{"text":"space to the child.","type":"text"}]}]}],"kind":"parameters"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"Views typically have a default priority of ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" which causes space to be","type":"text"},{"text":" ","type":"text"},{"text":"apportioned evenly to all sibling views. Raising a view’s layout","type":"text"},{"text":" ","type":"text"},{"text":"priority encourages the higher priority view to shrink later when the","type":"text"},{"text":" ","type":"text"},{"text":"group is shrunk and stretch sooner when the group is stretched.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["HStack {","    Text(\"This is a moderately long string.\")","        .font(.largeTitle)","        .border(Color.gray)","","    Spacer()","","    Text(\"This is a higher priority string.\")","        .font(.largeTitle)","        .layoutPriority(1)","        .border(Color.gray)","}"],"type":"codeListing"},{"inlineContent":[{"text":"In the example above, the first ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"text":" element has the default","type":"text"},{"text":" ","type":"text"},{"text":"priority ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" which causes its view to shrink dramatically due to the","type":"text"},{"text":" ","type":"text"},{"text":"higher priority of the second ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"text":" element, even though all of their","type":"text"},{"text":" ","type":"text"},{"text":"other attributes (font, font size and character count) are the same.","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"A parent layout offers the child views with the highest layout priority","type":"text"},{"text":" ","type":"text"},{"text":"all the space offered to the parent minus the minimum space required for","type":"text"},{"text":" ","type":"text"},{"text":"all its lower-priority children.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/openswiftui\/vstack\/layoutpriority(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack\/layoutPriority(_:)","interfaceLanguage":"swift"},"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/VStack":{"title":"VStack","navigatorTitle":[{"kind":"identifier","text":"VStack"}],"abstract":[{"type":"text","text":"A view that arranges its subviews in a vertical line."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VStack"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"topic","url":"\/documentation\/openswiftui\/vstack"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"D