:"text"},{"text":"border encompasses the padded region:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"You can omit either or both of the parameters. If you omit the ","type":"text"},{"code":"length","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"OpenSwiftUI uses a default amount of padding. If you","type":"text"},{"text":" ","type":"text"},{"text":"omit the ","type":"text"},{"code":"edges","type":"codeVoice"},{"text":", OpenSwiftUI applies the padding to all edges. Omit both","type":"text"},{"text":" ","type":"text"},{"text":"to add a default padding all the way around a view. OpenSwiftUI chooses a","type":"text"},{"text":" ","type":"text"},{"text":"default amount of padding that’s appropriate for the platform and","type":"text"},{"text":" ","type":"text"},{"text":"the presentation context.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["VStack {","    Text(\"Text with default padding.\")","        .padding()","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"type":"codeListing"},{"inlineContent":[{"text":"The example above looks like this in iOS under typical conditions:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To control the amount of padding independently for each edge, use"},{"type":"text","text":" "},{"code":"View\/padding(_:)-6pgqq","type":"codeVoice"},{"type":"text","text":". To pad all outside edges of a view by a"},{"type":"text","text":" "},{"type":"text","text":"specified amount, use "},{"code":"View\/padding(_:)-68shk","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/openswiftui\/vstack\/padding(_:_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"https://developer.apple.com/documentation/Swift/OptionSet":{"type":"link","titleInlineContent":[{"