\/openswiftui\/vstack\/padding(_:_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"padding"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"edges"},{"kind":"text","text":": "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4EdgeO","text":"Edge"},{"kind":"text","text":"."},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4EdgeO3SetV","text":"Set"},{"kind":"text","text":" = .all, "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"length"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat"},{"kind":"text","text":"? = nil) -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"},{"kind":"text","text":"\n"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The set of edges to pad for this view. The default","type":"text"},{"text":" ","type":"text"},{"text":"is ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set\/all"},{"text":".","type":"text"}]}],"name":"edges"},{"content":[{"type":"paragraph","inlineContent":[{"text":"An amount, given in points, to pad this view on the","type":"text"},{"text":" ","type":"text"},{"text":"specified edges. If you set the value to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", OpenSwiftUI uses","type":"text"},{"text":" ","type":"text"},{"text":"a platform-specific default amount. The default value of this","type":"text"},{"text":" ","type":"text"},{"text":"parameter is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}]}],"name":"length"}],"kind":"parameters"},{"content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that’s padded by the specified amount on the"},{"type":"text","text":" "},{"type":"text","text":"specified edges."}]}],"kind":"content"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to add a specified amount of padding to one or more"},{"type":"text","text":" "},{"type":"text","text":"edges of the view. Indicate the edges to pad by naming either a single"},{"type":"text","text":" "},{"type":"text","text":"value from "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set","isActive":true},{"type":"text","text":", or by specifying an"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/Swift\/OptionSet","isActive":true},{"type":"text","text":" "},{"type":"text","text":"that contains edge values:"}]},{"type":"codeListing","code":["VStack {","    Text(\"Text padded by 20 points on the bottom and trailing edges.\")","        .padding([.bottom, .trailing], 20)","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The order in which you apply modifiers matters. The example above","type":"text"},{"text":" ","type":"text"},{"text":"applies the padding before applying the border to ensure that the","type":"text"},{"text":" ","type":"text"},{"text":"border encompasses the padded region:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can omit either or both of the parameters. If you omit the "},{"type":"codeVoice","code":"length"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI uses a default amount of padding. If you"},{"type":"text","text":" "},{"type":"text","text":"omit the "},{"type":"codeVoice","code":"edges"},{"type":"text","text":", OpenSwiftUI applies the padding to all edges. Omit both"},{"type":"text","text":" "},{"type":"text","text":"to add a default padding all the way around a view. OpenSwiftUI chooses a"},{"type":"text","text":" "},{"type":"text","text":"default amount of padding that’s appropriate for the platform and"},{"type":"text","text":" "},{"type":"text","text":"the presentation context."}]},{"type":"codeListing","code":["VStack {","    Text(\"Text with default padding.\")","        .padding()","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The example above looks like this in iOS under typical conditions:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To control the amount of padding independently for each edge, use"},{"type":"text","text":" "},{"type":"codeVoice","code":"View\/padding(_:)-6pgqq"},{"type":"text","text":". To pad all outside edges of a view by a"},{"type":"text","text":" "},{"type":"text","text":"specified amount, use "},{"type":"codeVoice","code":"View\/padding(_:)-68shk"},{"type":"text","text":"."}]}],"kind":"content"}],"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack\/padding(_:_:)","interfaceLanguage":"swift"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftui\/view","kin