{"abstract":[{"type":"text","text":"Creates a view that represents the body of a toggle."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/SwitchToggleStyle\/makeBody(configuration:)"},"metadata":{"modules":[{"name":"OpenSwiftUI"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"makeBody","kind":"identifier"},{"text":"(","kind":"text"},{"text":"configuration","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Configuration","kind":"typeIdentifier","preciseIdentifier":"s:11OpenSwiftUI11ToggleStyleP13Configurationa"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"externalID":"s:11OpenSwiftUI17SwitchToggleStyleV8makeBody13configurationQrAA0eF13ConfigurationV_tF","platforms":[{"beta":false,"name":"iOS","unavailable":false,"deprecated":false,"introducedAt":"13.0"},{"beta":false,"name":"macOS","unavailable":false,"deprecated":false,"introducedAt":"10.15"},{"beta":false,"name":"tvOS","unavailable":false,"deprecated":false,"introducedAt":"13.0"},{"beta":false,"name":"visionOS","unavailable":false,"deprecated":false,"introducedAt":"1.0"},{"beta":false,"name":"watchOS","unavailable":false,"deprecated":false,"introducedAt":"6.0"}],"title":"makeBody(configuration:)","role":"symbol","remoteSource":{"fileName":"SwitchToggleStyle.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/Toggle\/SwitchToggleStyle.swift#L69"},"roleHeading":"Instance Method","symbolKind":"method"},"variants":[{"paths":["\/documentation\/openswiftui\/switchtogglestyle\/makebody(configuration:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/SwitchToggleStyle"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"makeBody","kind":"identifier"},{"text":"(","kind":"text"},{"text":"configuration","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Configuration","preciseIdentifier":"s:11OpenSwiftUI11ToggleStyleP13Configurationa","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/Configuration"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":"\n","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The properties of the toggle, including a"},{"type":"text","text":" "},{"type":"text","text":"label and a binding to the toggle’s state."}]}],"name":"configuration"}]},{"kind":"content","content":[{"anchor":"return-value","level":2,"type":"heading","text":"Return Value"},{"inlineContent":[{"text":"A view that has behavior and appearance that enables it","type":"text"},{"text":" ","type":"text"},{"text":"to function as a ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true},{"text":".","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement this method when you define a custom toggle style that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle","type":"reference","isActive":true},{"type":"text","text":" protocol. Use the "},{"code":"configuration","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"input — a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration","type":"reference","isActive":true},{"type":"text","text":" instance — to access the"},{"type":"text","text":" "},{"type":"text","text":"toggle’s label and state. Return a view that has the appearance and"},{"type":"text","text":" "},{"type":"text","text":"behavior of a toggle. For example you can create a toggle that displays"},{"type":"text","text":" "},{"type":"text","text":"a label and a circle that’s either empty or filled with a checkmark:"}]},{"type":"codeListing","syntax":"swift","code":["struct ChecklistToggleStyle: ToggleStyle {","    func makeBody(configuration: Configuration) -> some View {","        Button {","            configuration.isOn.toggle()","        } label: {","            HStack {","                Image(systemName: configuration.isOn","                        ? \"checkmark.circle.fill\"","                        : \"circle\")","                configuration.label","            }","        }","        .tint(.primary)","        .buttonStyle(.borderless)","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"ChecklistToggleStyle","type":"codeVoice"},{"text":" toggle style provides a way to both observe","type":"text"},{"text":" ","type":"text"},{"text":"and modify the toggle state: the circle fills for the on state, and","type":"text"},{"text":" ","type":"text"},{"text":"users can tap or click the toggle to change the state. By using a","type":"text"},{"text":" ","type":"text"},{"text":"customized ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button"},{"text":" to compose the toggle’s body, OpenSwiftUI","type":"text"},{"text":" ","type":"text"},{"text":"automatically provides the behaviors that users expect from a","type":"text"},{"text":" ","type":"text"},{"text":"control that has button-like characteristics.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can present a collection of toggles that use this style in a stack:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When updating a view hierarchy, the system calls your implementation"},{"type":"text","text":" "},{"type":"text","text":"of the "},{"code":"makeBody(configuration:)","type":"codeVoice"},{"type":"text","text":" method for each "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle"},{"type":"text","text":" instance"},{"type":"text","text":" "},{"type":"text","text":"that uses the associated style."}]},{"type":"heading","text":"Modify the current style","level":3,"anchor":"Modify-the-current-style"},{"type":"paragraph","inlineContent":[{"text":"Rather than create an entirely new style, you can alternatively","type":"text"},{"text":" ","type":"text"},{"text":"modify a toggle’s current style. Use the ","type":"text"},{"code":"Toggle\/init(_:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"initializer inside the ","type":"text"},{"code":"makeBody(configuration:)","type":"codeVoice"},{"text":" method to create","type":"text"},{"text":" ","type":"text"},{"text":"and modify a toggle based on a ","type":"text"},{"code":"configuration","type":"codeVoice"},{"text":" value. For example,","type":"text"},{"text":" ","type":"text"},{"text":"you can create a style that adds padding and a red border to the","type":"text"},{"text":" ","type":"text"},{"text":"current style:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct RedBorderToggleStyle: ToggleStyle {","    func makeBody(configuration: Configuration) -> some View {","        Toggle(configuration)","            .padding()","            .border(.red)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you create a "},{"type":"codeVoice","code":"redBorder"},{"type":"text","text":" static variable from this style,"},{"type":"text","text":" "},{"type":"text","text":"you can apply the style to toggles that already use another style, like"},{"type":"text","text":" "},{"type":"text","text":"the built-in "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true},{"type":"text","text":" and "},{"type":"codeVoice","code":"ToggleStyle\/button"},{"type":"text","text":" styles:"}]},{"type":"codeListing","syntax":"swift","code":["Toggle(\"Switch\", isOn: $isSwitchOn)","    .toggleStyle(.redBorder)","    .toggleStyle(.switch)","","Toggle(\"Button\", isOn: $isButtonOn)","    .toggleStyle(.redBorder)","    .toggleStyle(.button)"]},{"type":"paragraph","inlineContent":[{"text":"Both toggles appear with the usual styling, each with a red border:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"Apply the custom style closer to the toggle than the","type":"text"},{"text":" ","type":"text"},{"text":"modified style because OpenSwiftUI evaluates style view modifiers in order","type":"text"},{"text":" ","type":"text"},{"text":"from outermost to innermost. If you apply the styles in the other","type":"text"},{"text":" ","type":"text"},{"text":"order, the red border style doesn’t have an effect, because the","type":"text"},{"text":" ","type":"text"},{"text":"built-in styles override it completely.","type":"text"}]}]}],"sections":[],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ToggleStyle/switch":{"abstract":[],"role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","type":"topic","title":"switch","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"k