     .border(Color.gray)","}"]},{"inlineContent":[{"text":"In the example above, the first ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" element has the default","type":"text"},{"text":" ","type":"text"},{"text":"priority ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" which causes its view to shrink dramatically due to the","type":"text"},{"text":" ","type":"text"},{"text":"higher priority of the second ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" element, even though all of their","type":"text"},{"text":" ","type":"text"},{"text":"other attributes (font, font size and character count) are the same.","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A parent layout offers the child views with the highest layout priority"},{"type":"text","text":" "},{"type":"text","text":"all the space offered to the parent minus the minimum space required for"},{"type":"text","text":" "},{"type":"text","text":"all its lower-priority children."}],"type":"paragraph"}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image\/layoutPriority(_:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Sets the priority by which a parent layout should apportion space to"},{"type":"text","text":" "},{"type":"text","text":"this child."}],"kind":"symbol","metadata":{"remoteSource":{"fileName":"LayoutPriority.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/LayoutPriority.swift#L49"},"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"sy