{"metadata":{"role":"symbol","platforms":[{"beta":false,"name":"iOS","introducedAt":"13.0","deprecated":false,"unavailable":false},{"beta":false,"name":"macOS","introducedAt":"10.15","deprecated":false,"unavailable":false},{"beta":false,"name":"tvOS","introducedAt":"13.0","deprecated":false,"unavailable":false},{"beta":false,"name":"visionOS","introducedAt":"1.0","deprecated":false,"unavailable":false},{"beta":false,"name":"watchOS","introducedAt":"6.0","deprecated":false,"unavailable":false}],"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"extendedModule":"OpenSwiftUICore","symbolKind":"method","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"multilineTextAlignment","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore13TextAlignmentO","text":"TextAlignment","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}],"externalID":"s:15OpenSwiftUICore4ViewPAAE22multilineTextAlignmentyQrAA0fG0OF::SYNTHESIZED::s:15OpenSwiftUICore5ImageV","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/View\/Text\/Util\/EnvironmentParagraphStyle.swift#L383","fileName":"EnvironmentParagraphStyle.swift"},"title":"multilineTextAlignment(_:)"},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image\/multilineTextAlignment(_:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"multilineTextAlignment"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"alignment"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TextAlignment","text":"TextAlignment","preciseIdentifier":"s:15OpenSwiftUICore13TextAlignmentO"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A value that you use to align multiple lines of"},{"type":"text","text":" "},{"type":"text","text":"text within a view."}]}],"name":"alignment"}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"inlineContent":[{"text":"A view that aligns the lines of multiline ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"text":" instances","type":"text"},{"text":" ","type":"text"},{"text":"it contains.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to set an alignment for a multiline block of text."},{"type":"text","text":" "},{"type":"text","text":"For example, the modifier centers the contents of the following"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" view:"}]},{"type":"codeListing","code":["Text(\"This is a block of text that shows up in a text element as multiple lines.\\(\"\\n\") Here we have chosen to center this text.\")","    .frame(width: 200)","    .multilineTextAlignment(.center)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The text in the above example spans more than one line because:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The newline character introduces a line break.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The frame modifier limits the space available to the text view, and","type":"text"},{"text":" ","type":"text"},{"text":"by default a text view wraps lines that don’t fit in the available","type":"text"},{"text":" ","type":"text"},{"text":"width. As a result, the text before the explicit line break wraps to","type":"text"},{"text":" ","type":"text"},{"text":"three lines, and the text after uses two lines.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"The modifier applies the alignment to the all the lines of text in","type":"text"},{"text":" ","type":"text"},{"text":"the view, regardless of why wrapping occurs:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier has no effect on a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"type":"text","text":" view that contains only one"},{"type":"text","text":" "},{"type":"text","text":"line of text, because a text view has a width that exactly matches the"},{"type":"text","text":" "},{"type":"text","text":"width of its widest line. If you want to align an entire text view"},{"type":"text","text":" "},{"type":"text","text":"rather than its contents, set the aligment of its container, like a"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference","isActive":true},{"type":"text","text":" or a frame that you create with the"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/frame(minWidth:idealWidth:maxWidth:minHeight:idealHeight:maxHeight:alignment:)","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"modifier."}]},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"You can use this modifier to control the alignment of a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"view that you create with the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/init(_:style:)","isActive":true,"type":"reference"},{"text":" initializer","type":"text"},{"text":" ","type":"text"},{"text":"to display localized dates and times, including when the view uses","type":"text"},{"text":" ","type":"text"},{"text":"only a single line, but only when that view appears in a widget.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier also affects the content alignment of other text container"},{"type":"text","text":" "},{"type":"text","text":"types, like "},{"type":"codeVoice","code":"TextEditor"},{"type":"text","text":" and "},{"type":"codeVoice","code":"TextField"},{"type":"text","text":". In those cases, the"},{"type":"text","text":" "},{"type":"text","text":"modifier sets the alignment even when the view contains only a single"},{"type":"text","text":" "},{"type":"text","text":"line because view’s width isn’t dictated by the width of the text it"},{"type":"text","text":" "},{"type":"text","text":"contains."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier operates by setting the"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/multilineTextAlignment","type":"reference","isActive":true},{"type":"text","text":" value in the environment,"},{"type":"text","text":" "},{"type":"text","text":"so it affects all the text containers in the modified view hierarchy."},{"type":"text","text":" "},{"type":"text","text":"For example, you can apply the modifier to a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference","isActive":true},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"configure all the text views inside the stack."}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image"]]},"kind":"symbol","abstract":[{"type":"text","text":"Sets the alignment of a text view that contains multiple lines of text."}],"variants":[{"paths":["\/documentation\/openswiftui\/image\/multilinetextalignment(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Image":{"type":"topic","navigatorTitle":[{"text":"Image","kind":"identifier"}],"title":"Image","url":"\/documentation\/openswiftui\/image","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image","abstract":[],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Image","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Text":{"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Text","kind":"identifier"}],"role":"symbol","url":"\/documentation\/openswiftui\/text","type":"topic","navigatorTitle":[{"text":"Text","kind":"identifier"}],"title":"Text","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","abstract":[]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/VStack":{"