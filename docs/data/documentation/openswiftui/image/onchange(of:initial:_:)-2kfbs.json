":"codeVoice","code":"playState"},{"type":"text","text":" changes model."}]},{"code":["struct PlayerView: View {","    var episode: Episode","    @State private var playState: PlayState = .paused","","    var body: some View {","        VStack {","            Text(episode.title)","            Text(episode.showTitle)","            PlayButton(playState: $playState)","        }","        .onChange(of: playState) {","            model.playStateDidChange(state: playState)","        }","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image\/onChange(of:initial:_:)-2kfbs"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Image/onChange(of:initial:_:)-2kfbs":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image\/onChange(of:initial:_:)-2kfbs","url":"\/documentation\/openswiftui\/image\/onchange(of:initial:_:)-2kfbs","title":"onChange(of:initial:_:)","type":"topic","kind":"symbol","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"onChange","kind":"identifier"},{"text":"<","kind":"text"},{"text":"V","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"of","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"V","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"initial","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":", () -> ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Adds a modifier for this view that fires an action when a specific"},{"type":"text","text":" "},{"type":"text","text":"value changes."}]},"do