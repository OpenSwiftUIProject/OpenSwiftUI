{"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image\/toggleStyle(_:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Sets the style for toggles in a view hierarchy."}],"metadata":{"role":"symbol","externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lF::SYNTHESIZED::s:15OpenSwiftUICore5ImageV","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"toggleStyle"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lFQO1Sqd__mfp","kind":"typeIdentifier","text":"S"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"}],"symbolKind":"method","title":"toggleStyle(_:)","roleHeading":"Instance Method","extendedModule":"OpenSwiftUICore","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/Toggle\/ToggleStyle.swift#L481","fileName":"ToggleStyle.swift"}},"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/image\/togglestyle(_:)"]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"toggleStyle","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"style","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"S","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lFQO1Sqd__mfp"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:11OpenSwiftUI11ToggleStyleP","text":"ToggleStyle","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle"},{"text":"\n","kind":"text"}],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The toggle style to set. Use one of the built-in"},{"type":"text","text":" "},{"type":"text","text":"values, like "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","type":"reference","isActive":true},{"type":"text","text":" or "},{"type":"codeVoice","code":"ToggleStyle\/button"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or a custom style that you define by creating a type that conforms"},{"type":"text","text":" "},{"type":"text","text":"to the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle","type":"reference","isActive":true},{"type":"text","text":" protocol."}],"type":"paragraph"}],"name":"style"}]},{"content":[{"type":"heading","anchor":"return-value","text":"Return Value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that uses the specified toggle style for itself"},{"type":"text","text":" "},{"type":"text","text":"and its child views."}]}],"kind":"content"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier on a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference","isActive":true},{"text":" instance to set a style that defines","type":"text"},{"text":" ","type":"text"},{"text":"the control’s appearance and behavior. For example, you can choose","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","type":"reference","isActive":true},{"text":" style:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Toggle(\"Vibrate on Ring\", isOn: $vibrateOnRing)","    .toggleStyle(.switch)"]},{"type":"paragraph","inlineContent":[{"text":"Built-in styles typically have a similar appearance across platforms,","type":"text"},{"text":" ","type":"text"},{"text":"tailored to the platform’s overall style:","type":"text"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Platform","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Appearance"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iOS, iPadOS"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"macOS","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]]]},{"type":"heading","level":3,"text":"Styling toggles in a hierarchy","anchor":"Styling-toggles-in-a-hierarchy"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set a style for all toggle instances within a view hierarchy"},{"type":"text","text":" "},{"type":"text","text":"by applying the style modifier to a container view. For example, you"},{"type":"text","text":" "},{"type":"text","text":"can apply the "},{"code":"ToggleStyle\/button","type":"codeVoice"},{"type":"text","text":" style to an "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","isActive":true},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["HStack {","    Toggle(isOn: $isFlagged) {","        Label(\"Flag\", systemImage: \"flag.fill\")","    }","    Toggle(isOn: $isMuted) {","        Label(\"Mute\", systemImage: \"speaker.slash.fill\")","    }","}",".toggleStyle(.button)"]},{"type":"paragraph","inlineContent":[{"text":"The example above has the following appearance when ","type":"text"},{"type":"codeVoice","code":"isFlagged"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"isMuted"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"false"},{"text":":","type":"text"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Appearance"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iOS, iPadOS"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"macOS","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]]]},{"type":"heading","level":3,"text":"Automatic styling","anchor":"Automatic-styling"},{"type":"paragraph","inlineContent":[{"text":"If you don’t set a style, OpenSwiftUI assumes a value of","type":"text"},{"text":" ","type":"text"},{"code":"ToggleStyle\/automatic","type":"codeVoice"},{"text":", which corresponds to a context-specific","type":"text"},{"text":" ","type":"text"},{"text":"default. Specify the automatic style explicitly to override a","type":"text"},{"text":" ","type":"text"},{"text":"container’s style and revert to the default:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["HStack {","    Toggle(isOn: $isShuffling) {","        Label(\"Shuffle\", systemImage: \"shuffle\")","    }","    Toggle(isOn: $isRepeating) {","        Label(\"Repeat\", systemImage: \"repeat\")","    }","","    Divider()","","    Toggle(\"Enhance Sound\", isOn: $isEnhanced)","        .toggleStyle(.automatic) \/\/ Revert to the default style.","}",".toggleStyle(.button) \/\/ Use button style for toggles in the stack.",".labelStyle(.iconOnly) \/\/ Omit the title from any labels."]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The style that OpenSwiftUI uses as the default depends on both the platform"},{"type":"text","text":" "},{"type":"text","text":"and the context. In macOS, the default in most contexts is a"},{"type":"text","text":" "},{"code":"ToggleStyle\/checkbox","type":"codeVoice"},{"type":"text","text":", while in iOS, the default toggle style is a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true},{"type":"text","text":":"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Appearance"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iOS, iPadOS"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"macOS","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]]]},{"style":"note","type":"aside","content":[{"inlineContent":[{"text":"Like toggle style does for toggles, the ","type":"text"},{"code":"View\/labelStyle(_:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"modifier sets the style for ","type":"text"},{"code":"Label","type":"codeVoice"},{"text":" instances in the hierarchy. The","type":"text"},{"text":" ","type":"text"},{"text":"example above demostrates the compact ","type":"text"},{"code":"LabelStyle\/iconOnly","type":"codeVoice"},{"text":" style,","type":"text"},{"text":" ","type":"text"},{"text":"which is useful for button toggles in space-constrained contexts.","type":"text"},{"text":" ","type":"text"},{"text":"Always include a descriptive title for better accessibility.","type":"text"}],"type":"paragraph"}],"name":"Note"},{"type":"paragraph","inlineContent":[{"text":"For more information about how OpenSwiftUI chooses a default toggle style,","type":"text"},{"text":" ","type":"text"},{"text":"see the ","type":"text"},{"type":"codeVoice","code":"ToggleStyle\/automatic"},{"text":" style.","type":"text"}]}],"kind":"content"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"url":"\/documentation\/openswiftui\/view","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Image/toggleStyle(_:)":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"toggleStyle"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"S","preciseIdentifier":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lFQO1Sqd__mfp"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"abstract":[{"type":"text","text":"Sets the style for toggles in a view hierarchy."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image\/toggleStyle(_:)","kind":"symbol","url":"\/documentation\/openswiftui\/image\/togglestyle(_:)","role":"symbol","type":"topic","title":"toggleStyle(_:)"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ToggleStyle":{