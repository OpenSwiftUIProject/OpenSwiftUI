{"kind":"symbol","abstract":[{"text":"Modifies the fonts of all child views to use fixed-width digits, if","type":"text"},{"text":" ","type":"text"},{"text":"possible, while leaving other characters proportionally spaced.","type":"text"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"monospacedDigit","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"A view whose child views’ fonts use fixed-width numeric","type":"text"},{"text":" ","type":"text"},{"text":"characters, while leaving other characters proportionally spaced.","type":"text"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Using fixed-width digits allows you to easily align numbers of the","type":"text"},{"text":" ","type":"text"},{"text":"same size in a table-like arrangement. This feature is also known as","type":"text"},{"text":" ","type":"text"},{"text":"“tabular figures” or “tabular numbers.”","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This modifier only affects numeric characters, and leaves all other","type":"text"},{"text":" ","type":"text"},{"text":"characters unchanged.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The following example shows the effect of ","type":"text"},{"code":"monospacedDigit()","type":"codeVoice"},{"text":" on","type":"text"},{"text":" ","type":"text"},{"text":"multiple child views. The example consists of two ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"text":" views","type":"text"},{"text":" ","type":"text"},{"text":"inside an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"},{"text":". Each ","type":"text"},{"code":"VStack","type":"codeVoice"},{"text":" contains two ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button"},{"text":" views, with","type":"text"},{"text":" ","type":"text"},{"text":"the second ","type":"text"},{"code":"VStack","type":"codeVoice"},{"text":" applying the ","type":"text"},{"code":"monospacedDigit()","type":"codeVoice"},{"text":" modifier to its","type":"text"},{"text":" ","type":"text"},{"text":"contents. As a result, the digits in the buttons in the trailing","type":"text"},{"text":" ","type":"text"},{"code":"VStack","type":"codeVoice"},{"text":" are the same width, which in turn gives the buttons equal widths.","type":"text"}]},{"code":["var body: some View {","    HStack(alignment: .top) {","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        .monospacedDigit()","    }","    .padding()","    .navigationTitle(\"monospacedDigit() Child Views\")","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a child view’s base font doesn’t support fixed-width digits, the font"},{"type":"text","text":" "},{"type":"text","text":"remains unchanged."}]}]}],"identifier"