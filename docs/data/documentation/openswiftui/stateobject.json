e","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/DynamicProperty":{"type":"topic","url":"\/documentation\/openswiftui\/dynamicproperty","abstract":[{"text":"An interface for a stored variable that updates an external property of a","type":"text"},{"text":" ","type":"text"},{"text":"view.","type":"text"}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DynamicProperty","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/DynamicProperty","navigatorTitle":[{"text":"DynamicProperty","kind":"identifier"}],"kind":"symbol","role":"symbol","title":"DynamicProperty"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"https://swiftpackageindex.com/openswiftuiproject/openobservation/main/documentation/openobservation/observable":{"titleInlineContent":[{"text":"Observable","type":"text"}],"type":"link","title":"Observable","url":"https:\/\/swiftpackageindex.com\/openswiftuiproject\/openobservation\/main\/documentation\/openobservation\/observable","identifier":"https:\/\/swiftpackageindex.com\/openswiftuiproject\/openobservation\/main\/documentation\/openobservation\/observable"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/App":{"title":"App","url":"\/documentation\/openswiftui\/app","type":"topic","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/App","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"App"}],"abstract":[{"type":"text","text":"A type that represents the structure and behavior of an app."}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"App"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ObservedObject":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ObservedObject"}],"url":"\/documentation\/openswiftui\/observedobject","type":"topic","kind":"symbol","abstract":[{"text":"A property wrapper type that subscribes to an observable object and","type":"text"},{"text":" ","type":"text"},{"text":"invalidates a view whenever the observable object changes.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ObservedObject","title":"ObservedObject","navigatorTitle":[{"kind":"identifier","text":"ObservedObject"}],"role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/EnvironmentObject":{"type":"topic","title":"EnvironmentObject","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EnvironmentObject","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentObject","navigatorTitle":[{"text":"EnvironmentObject","kind":"identifier"}],"abstract":[{"type":"text","text":"A property wrapper type for an observable object that a parent or ancestor"},{"type":"text","text":" "},{"type":"text","text":"view supplies."}],"url":"\/documentation\/openswiftui\/environmentobject","kind":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftui\/view","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"type":"topic","title":"View","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View/id(_:)":{"type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\