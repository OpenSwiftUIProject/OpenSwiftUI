e environment, and remains in effect unless"},{"type":"text","text":" "},{"type":"text","text":"overridden at the level of an individual view or view container."}],"type":"paragraph"},{"inlineContent":[{"text":"Here, the outermost ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference","isActive":true},{"text":" applies a 16-point system font as a","type":"text"},{"text":" ","type":"text"},{"text":"default font to views contained in that ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference","isActive":true},{"text":". Inside that stack,","type":"text"},{"text":" ","type":"text"},{"text":"the example applies a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Font\/largeTitle","type":"reference","isActive":true},{"text":" font to just the first text","type":"text"},{"text":" ","type":"text"},{"text":"view; this explicitly overrides the default. The remaining stack and the","type":"text"},{"text":" ","type":"text"},{"text":"views contained with it continue to use the 16-point system font set by","type":"text"},{"text":" ","type":"text"},{"text":"their containing view:","type":"text"}],"type":"paragraph"},{"code":["VStack {","    Text(\"Font applied to a text view.\")","        .font(.largeTitle)","","    VStack {","        Text(\"These 2 text views have the same font\")","        Text(\"applied to their parent hierarchy\")","    }","}",".font(.system(size: 16, weight: .light, design: .default))"],"type":"codeListing","syntax":"swift"},{"inlineContent":[],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/openswiftui\/divider\/font(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Divider"]]},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Divider\/font(_:)","interf