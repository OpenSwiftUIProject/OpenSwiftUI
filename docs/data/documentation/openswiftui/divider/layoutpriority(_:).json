"},{"type":"text","text":" "},{"type":"text","text":"priority "},{"type":"codeVoice","code":"0"},{"type":"text","text":" which causes its view to shrink dramatically due to the"},{"type":"text","text":" "},{"type":"text","text":"higher priority of the second "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" element, even though all of their"},{"type":"text","text":" "},{"type":"text","text":"other attributes (font, font size and character count) are the same."}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A parent layout offers the child views with the highest layout priority"},{"type":"text","text":" "},{"type":"text","text":"all the space offered to the parent minus the minimum space required for"},{"type":"text","text":" "},{"type":"text","text":"all its lower-priority children."}],"type":"paragraph"}]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Divider"]]},"variants":[{"paths":["\/documentation\/openswiftui\/divider\/layoutpriority(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftui\/view","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"type":"topic","title":"View","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text