 dimensions:"}]},{"code":["Text(\"A single line of text, too long to fit in a box.\")","    .fixedSize()","    .frame(width: 200, height: 200)","    .border(Color.gray)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This can result in the view exceeding the parent’s bounds, which may or"},{"type":"text","text":" "},{"type":"text","text":"may not be the effect you want."}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can think of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" as the creation of a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"counter proposal"}]},{"type":"text","text":" "},{"type":"text","text":"to the view size proposed to a view by its parent. The ideal size of a"},{"type":"text","text":" "},{"type":"text","text":"view, and the specific effects of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" depends on the"},{"type":"text","text":" "},{"type":"text","text":"particular view and how you have configured it."}]},{"type":"paragraph","inlineContent":[{"text":"To create a view that fixes the view’s size in either the horizontal or","type":"text"},{"text":" ","type":"text"},{"text":"vertical dimensions, see ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)","isActive":true,"type":"reference"},{"text":".","type":"text"}]}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Divider":{"type":"topic","navigatorTitle":[{"text":"Divider","kind":"identifier"}],"url":"\/documentation\/openswiftui\/divider","abstract":[{"type":"text","text":"A visual element that can be used to separate other content."}],"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Divider","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Divider","kind":"identifier"}],"title":"Div