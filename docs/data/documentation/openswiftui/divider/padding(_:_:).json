eContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can omit either or both of the parameters. If you omit the "},{"type":"codeVoice","code":"length"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI uses a default amount of padding. If you"},{"type":"text","text":" "},{"type":"text","text":"omit the "},{"type":"codeVoice","code":"edges"},{"type":"text","text":", OpenSwiftUI applies the padding to all edges. Omit both"},{"type":"text","text":" "},{"type":"text","text":"to add a default padding all the way around a view. OpenSwiftUI chooses a"},{"type":"text","text":" "},{"type":"text","text":"default amount of padding that’s appropriate for the platform and"},{"type":"text","text":" "},{"type":"text","text":"the presentation context."}],"type":"paragraph"},{"syntax":"swift","code":["VStack {","    Text(\"Text with default padding.\")","        .padding()","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The example above looks like this in iOS under typical conditions:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"To control the amount of padding independently for each edge, use","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"View\/padding(_:)-6pgqq"},{"text":". To pad all outside edges of a view by a","type":"text"},{"text":" ","type":"text"},{"text":"specified amount, use ","type":"text"},{"type":"codeVoice","code":"View\/padding(_:)-68shk"},{"text":".","type":"text"}],"type":"paragraph"}]}],"abstract":[{"type":"text","text":"Adds an equal padding amount to specific edges of this view."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/divider\/padding(_:_:)"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Edge/Set":{"identifier":"doc:\/\/OpenSwiftUI\/document