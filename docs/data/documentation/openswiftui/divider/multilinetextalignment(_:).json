{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Divider"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"abstract":[{"type":"text","text":"Sets the alignment of a text view that contains multiple lines of text."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/divider\/multilinetextalignment(_:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"multilineTextAlignment","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"alignment","kind":"internalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TextAlignment","text":"TextAlignment","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore13TextAlignmentO"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":"\n","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"A value that you use to align multiple lines of"},{"type":"text","text":" "},{"type":"text","text":"text within a view."}],"type":"paragraph"}],"name":"alignment"}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"inlineContent":[{"text":"A view that aligns the lines of multiline ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference"},{"text":" instances","type":"text"},{"text":" ","type":"text"},{"text":"it contains.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier to set an alignment for a multiline block of text.","type":"text"},{"text":" ","type":"text"},{"text":"For example, the modifier centers the contents of the following","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Text(\"This is a block of text that shows up in a text element as multiple lines.\\(\"\\n\") Here we have chosen to center this text.\")","    .frame(width: 200)","    .multilineTextAlignment(.center)"]},{"type":"paragraph","inlineContent":[{"text":"The text in the above example spans more than one line because:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"The newline character introduces a line break.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The frame modifier limits the space available to the text view, and"},{"type":"text","text":" "},{"type":"text","text":"by default a text view wraps lines that don’t fit in the available"},{"type":"text","text":" "},{"type":"text","text":"width. As a result, the text before the explicit line break wraps to"},{"type":"text","text":" "},{"type":"text","text":"three lines, and the text after uses two lines."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier applies the alignment to the all the lines of text in"},{"type":"text","text":" "},{"type":"text","text":"the view, regardless of why wrapping occurs:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier has no effect on a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" view that contains only one"},{"type":"text","text":" "},{"type":"text","text":"line of text, because a text view has a width that exactly matches the"},{"type":"text","text":" "},{"type":"text","text":"width of its widest line. If you want to align an entire text view"},{"type":"text","text":" "},{"type":"text","text":"rather than its contents, set the aligment of its container, like a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true},{"type":"text","text":" or a frame that you create with the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/frame(minWidth:idealWidth:maxWidth:minHeight:idealHeight:maxHeight:alignment:)","isActive":true},{"type":"text","text":" "},{"type":"text","text":"modifier."}]},{"type":"aside","style":"note","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"You can use this modifier to control the alignment of a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"view that you create with the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/init(_:style:)","type":"reference","isActive":true},{"text":" initializer","type":"text"},{"text":" ","type":"text"},{"text":"to display localized dates and times, including when the view uses","type":"text"},{"text":" ","type":"text"},{"text":"only a single line, but only when that view appears in a widget.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"text":"The modifier also affects the content alignment of other text container","type":"text"},{"text":" ","type":"text"},{"text":"types, like ","type":"text"},{"code":"TextEditor","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"TextField","type":"codeVoice"},{"text":". In those cases, the","type":"text"},{"text":" ","type":"text"},{"text":"modifier sets the alignment even when the view contains only a single","type":"text"},{"text":" ","type":"text"},{"text":"line because view’s width isn’t dictated by the width of the text it","type":"text"},{"text":" ","type":"text"},{"text":"contains.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier operates by setting the"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/multilineTextAlignment","type":"reference","isActive":true},{"type":"text","text":" value in the environment,"},{"type":"text","text":" "},{"type":"text","text":"so it affects all the text containers in the modified view hierarchy."},{"type":"text","text":" "},{"type":"text","text":"For example, you can apply the modifier to a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference","isActive":true},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"configure all the text views inside the stack."}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Divider\/multilineTextAlignment(_:)"},"kind":"symbol","metadata":{"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/View\/Text\/Util\/EnvironmentParagraphStyle.swift#L383","fileName":"EnvironmentParagraphStyle.swift"},"roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"multilineTextAlignment","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore13TextAlignmentO","text":"TextAlignment","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIde