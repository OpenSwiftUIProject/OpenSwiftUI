ronmentValues\/isEnabled-25iby","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/isEnabled-480iv","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/isLuminanceReduced","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/layoutDirection","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/legibilityWeight","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/locale","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/openURL","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/pixelLength","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/scenePhase","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/sizeCategory","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/timeZone"]},{"title":"Subscripts","generated":true,"anchor":"Subscripts","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/subscript(_:)-1zt8d","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/subscript(_:)-3epud"]}],"abstract":[{"type":"text","text":"A collection of environment values propagated through a view hierarchy."}],"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EnvironmentValues","kind":"identifier"}]}],"kind":"declarations"},{"kind":"content","content":[{"level":2,"anchor":"overview","text":"Overview","type":"heading"},{"inlineContent":[{"text":"OpenSwiftUI exposes a collection of values to your app’s views in an","type":"text"},{"text":" ","type":"text"},{"code":"EnvironmentValues","type":"codeVoice"},{"text":" structure. To read a value from the structure,","type":"text"},{"text":" ","type":"text"},{"text":"declare a property using the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Environment","isActive":true,"type":"reference"},{"text":" property wrapper and","type":"text"},{"text":" ","type":"text"},{"text":"specify the value’s key path. For example, you can read the current locale:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["@Environment(\\.locale) var locale: Locale"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Use the property you declare to dynamically control a view’s layout."},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI automatically sets or updates many environment values, like"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/pixelLength","isActive":true,"type":"reference"},{"type":"text","text":", "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/scenePhase","isActive":true,"type":"reference"},{"type":"text","text":", or"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/locale","isActive":true,"type":"reference"},{"type":"text","text":", based on device characteristics, system state,"},{"type":"text","text":" "},{"type":"text","text":"or user settings. For others, like "},{"type":"codeVoice","code":"EnvironmentValues\/lineLimit"},{"type":"text","text":", OpenSwiftUI"},{"type":"text","text":" "},{"type":"text","text":"provides a reasonable default value."}],"type":"paragraph"},{"inlineContent":[{"text":"You can set or override some values using the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/environment(_:_:)","type":"reference"},{"text":" ","type":"text"},{"text":"view modifier:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["MyView()","    .environment(\\.lineLimit, 2)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The value that you set affects the environment for the view that you modify"},{"type":"text","text":" "},{"type":"text","text":"— including its descendants in the view hierarchy — but only up to the"},{"type":"text","text":" "},{"type":"text","text":"point where you apply a different environment modifier."}],"type":"paragraph"},{"inlineContent":[{"text":"OpenSwiftUI provides dedicated view modifiers for setting some values, which","type":"text"},{"text":" ","type":"text"},{"text":"typically makes your code easier to read. For example, rather than setting","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"EnvironmentValues\/lineLimit","type":"codeVoice"},{"text":" value directly, as in the previous","type":"text"},{"text":" ","type":"text"},{"text":"example, you should instead use the ","type":"text"},{"code":"View\/lineLimit(_:)","type":"codeVoice"},{"text":" modifier:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["MyView()","    .lineLimit(2)"],"type":"codeListing"},{"inlineContent":[{"text":"In some cases, using a dedicated view modifier provides additional","type":"text"},{"text":" ","type":"text"},{"text":"functionality. For example, you must use the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"View\/preferredColorScheme(_:)"},{"text":" modifier rather than setting","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/colorScheme"},{"text":" directly to ensure that the new","type":"text"},{"text":" ","type":"text"},{"text":"value propagates up to the presenting container when presenting a view","type":"text"},{"text":" ","type":"text"},{"text":"like a popover:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["MyView()","    .popover(isPresented: $isPopped) {","        PopoverContent()","            .preferredColorScheme(.dark)","    }"],"type":"codeListing"},{"inlineContent":[{"text":"Create a custom environment value by declaring a new property","type":"text"},{"text":" ","type":"text"},{"text":"in an extension to the environment values structure and applying","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Entry()","isActive":true},{"text":" macro to the variable declaration:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["extension EnvironmentValues {","    @Entry var myCustomValue: String = \"Default value\"","}","","extension View {","    func myCustomValue(_ myCustomValue: String) -> some View {","        environment(\\.myCustomValue, myCustomValue)","    }","}"]},{"inlineContent":[{"type":"text","text":"Clients of your value then access the value in the usual way, reading it"},{"type":"text","text":" "},{"type":"text","text":"with the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Environment","type":"reference","isActive":true},{"type":"text","text":" property wrapper, and setting it with the"},{"type":"text","text":" "},{"code":"myCustomValue","type":"codeVoice"},{"type":"text","text":" view modifier."}],"type":"paragraph"}]}],"metadata":{"role":"symbol","title":"EnvironmentValues","symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"EnvironmentValues","kind":"identifier"}],"externalID":"s:15OpenSwiftUICore17EnvironmentValuesV","roleHeading":"Structure","modules":[{"name":"OpenSwiftUI"}],"navigatorTitle":[{"text":"EnvironmentValues","kind":"identifier"}],"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Data\/Environment\/EnvironmentValues.swift#L74","fileName":"EnvironmentValues.swift"}},"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"relationshipsSections":[{"title":"Conforms To