UI\/Environment","isActive":true},{"type":"text","text":" property wrapper and"},{"type":"text","text":" "},{"type":"text","text":"specify the value’s key path. For example, you can read the current locale:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@Environment(\\.locale) var locale: Locale"]},{"inlineContent":[{"type":"text","text":"Use the property you declare to dynamically control a view’s layout."},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI automatically sets or updates many environment values, like"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/pixelLength"},{"type":"text","text":", "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/scenePhase"},{"type":"text","text":", or"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/locale"},{"type":"text","text":", based on device characteristics, system state,"},{"type":"text","text":" "},{"type":"text","text":"or user settings. For others, like "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/lineLimit"},{"type":"text","text":", OpenSwiftUI"},{"type":"text","text":" "},{"type":"text","text":"provides a reasonable default value."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can set or override some values using the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/environment(_:_:)"},{"type":"text","text":" "},{"type":"text","text":"view modifier:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["MyView()","    .environment(\\.lineLimit, 2)"]},{"inlineContent":[{"text":"The value that you set affects the environment for the view that you modify","type":"text"},{"text":" ","type":"text"},{"text":"— including its descendants in the view hierarchy — but only up to the","type":"text"},{"text":" ","type":"text"},{"text":"point where you apply a different environment modifier.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"OpenSwiftUI provides dedicated view modifiers for setting some values, which"},{"type":"text","text":" "},{"type":"text","text":"typically makes your code easier to read. For example, rather than setting"},{"type":"text","text":" "},{"type":"text","text":"the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/lineLimit"},{"type":"text","text":" value directly, as in the previous"},{"type":"text","text":" "},{"type":"text","text":"example, you should instead use the "},{"code":"View\/lineLimit(_:)","type":"codeVoice"},{"type":"text","text":" modifier:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["MyView()","    .lineLimit(2)"]},{"inlineContent":[{"type":"text","text":"In some cases, using a dedicated view modifier provides additional"},{"type":"text","text":" "},{"type":"text","text":"functionality. For example, you must use the"},{"type":"text","text":" "},{"type":"codeVoice","code":"View\/preferredColorScheme(_:)"},{"type":"text","text":" modifier rather than setting"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/colorScheme","type":"reference"},{"type":"text","text":" directly to ensure that the new"},{"type":"text","text":" "},{"type":"text","text":"value propagates up to the presenting container when presenting a view"},{"type":"text","text":" "},{"type":"text","text":"like a popover:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["MyView()","    .popover(isPresented: $isPopped) {","        PopoverContent()","            .preferredColorScheme(.dark)","    }"]},{"inlineContent":[{"type":"text","text":"Create a custom environment value by declaring a new property"},{"type":"text","text":" "},{"type":"text","text":"in an extension to the environment values structure and applying"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Entry()"},{"type":"text","text":" macro to the variable declaration:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["extension EnvironmentValues {","    @Entry var myCustomValue: String = \"Default value\"","}","","extension View {","    func myCustomValue(_ myCustomValue: String) -> some View {","        environment(\\.myCustomValue, myCustomValue)","    }","}"]},{"inlineContent":[{"type":"text","text":"Clients of your value then access the value in the usual way, reading it"},{"type":"text","text":" "},{"type":"text","text":"with the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Environment","type":"reference","isActive":true},{"type":"text","text":" property wrapper, and setting it with the"},{"type":"text","text":" "},{"type":"codeVoice","code":"myCustomValue"},{"type":"text","text":" view modifier."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/environmentvalues"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/EnvironmentValues/scenePhase":{"abstract":[],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"scenePhase","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ScenePhase","preciseIdentifier":"s:11OpenSwiftUI10ScenePhaseO","kind":"typeIdentifier"}],"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/scenePhase","title":"scenePhase","url":"\/documentation\/openswiftui\/environmentvalues\/scenephase",