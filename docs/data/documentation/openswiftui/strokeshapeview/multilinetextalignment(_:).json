contains."}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Use this modifier to set an alignment for a multiline block of text.","type":"text"},{"text":" ","type":"text"},{"text":"For example, the modifier centers the contents of the following","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"text":" view:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["Text(\"This is a block of text that shows up in a text element as multiple lines.\\(\"\\n\") Here we have chosen to center this text.\")","    .frame(width: 200)","    .multilineTextAlignment(.center)"],"syntax":"swift"},{"inlineContent":[{"text":"The text in the above example spans more than one line because:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The newline character introduces a line break."}]}]},{"content":[{"inlineContent":[{"text":"The frame modifier limits the space available to the text view, and","type":"text"},{"text":" ","type":"text"},{"text":"by default a text view wraps lines that don’t fit in the available","type":"text"},{"text":" ","type":"text"},{"text":"width. As a result, the text before the explicit line break wraps to","type":"text"},{"text":" ","type":"text"},{"text":"three lines, and the text after uses two lines.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The modifier applies the alignment to the all the lines of text in"},{"type":"text","text":" "},{"type":"text","text":"the view, regardless of why wrapping occurs:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"The modifier has no effect on a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view that contains only one","type":"text"},{"text":" ","type":"text"},{"text":"line of text, because a text view has a width that exactly matches the","type":"text"},{"text":" ","type":"text"},{"text":"width of its widest line. If you want to align an entire text view","type":"text"},{"text":" ","type":"text"},{"text":"rather than its contents, set the aligment of its container, like a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true,"type":"reference"},{"text":" or a frame that you create with the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/frame(minWidth:idealWidth:maxWidth:minHeight:idealHeight:maxHeight:alignment:)","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"modifier.","type":"text"}],"type":"paragraph"},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use this modifier to control the alignment of a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" "},{"type":"text","text":"view that you create with the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/init(_:style:)","isActive":true},{"type":"text","text":" initializer"},{"type":"text","text":" "},{"type":"text","text":"to display localized dates and times, including when the view uses"},{"type":"text","text":" "},{"type":"text","text":"only a single line, but only when that view appears in a widget."}]}]},{"inlineContent":[{"type":"text","text":"The modifier also affects the content alignment of other text container"},{"type":"text","text":" "},{"type":"text","text":"types, like "},{"code":"TextEditor","type":"codeVoice"},{"type":"text","text":" and "},{"code":"TextField","type":"codeVoice"},{"type":"text","text":". In those cases, the"},{"type":"text","text":" "},{"type":"text","text":"modifier sets the alignment even when the view contains only a single"},{"type":"text","text":" "},{"type":"text","text":"line because view’s width isn’t dictated by the width of the text it"},{"type":"text","text":" "},{"type":"text","text":"contains."}],"type":"paragraph"},{"inlineContent":[{"text":"The modifier operates by setting the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/multilineTextAlignment"},{"text":" value in the environment,","type":"text"},{"text":" ","type":"text"},{"text":"so it affects all the text containers in the modified view hierarchy.","type":"text"},{"text":" ","type":"text"},{"text":"For example, you can apply the modifier to a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"configure all the text views inside the stack.","type":"text"}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StrokeShapeView\/multilineTextAlignment(_:)","interfaceLanguage":"swift"},"metadata":{"externalID":"s:15OpenSwiftUICore4ViewPAAE22multilineTextAlignmentyQrAA0fG0OF::SYNTHESIZED::s:15OpenSwiftUICore15StrokeShapeViewV","symbolKind":"method","platforms":[{"name":"iOS","beta":false,"unavailable":false,"introducedAt":"13.0","deprecated":false},{"name":"macOS","beta":false,"unavailable":false,"introducedAt":"10.15","deprecated":false},{"name":"tvOS","beta":false,"unavailable":false,"introducedAt":"13.0","deprecated":false},{"name":"visionOS","beta":false,"unavailable":false,"introducedAt":"1.0","deprecated":false},{"name":"watchOS","beta":false,"unavailable":false,"introducedAt":"6.0","deprecated":false}],"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"role":"symbol","roleHe