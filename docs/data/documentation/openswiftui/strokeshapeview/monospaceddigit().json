iews, with"},{"type":"text","text":" "},{"type":"text","text":"the second "},{"code":"VStack","type":"codeVoice"},{"type":"text","text":" applying the "},{"code":"monospacedDigit()","type":"codeVoice"},{"type":"text","text":" modifier to its"},{"type":"text","text":" "},{"type":"text","text":"contents. As a result, the digits in the buttons in the trailing"},{"type":"text","text":" "},{"code":"VStack","type":"codeVoice"},{"type":"text","text":" are the same width, which in turn gives the buttons equal widths."}]},{"code":["var body: some View {","    HStack(alignment: .top) {","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        .monospacedDigit()","    }","    .padding()","    .navigationTitle(\"monospacedDigit() Child Views\")","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a child view’s base font doesn’t support fixed-width digits, the font"},{"type":"text","text":" "},{"type":"text","text":"remains unchanged."}]}]}],"kind":"symbol","variants":[{"paths":["\/documentation\/openswiftui\/strokeshapeview\/monospaceddigit()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StrokeShapeView\/monospacedDigit()"},"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StrokeShapeView"]]},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/StrokeShapeView/monospacedDigit()":{"type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StrokeShapeView\/monospacedDigit()","abstract":[{"type":"text","text":"Modifies the fonts of al