xt"},{"text":" ","type":"text"},{"text":"may not be the effect you want.","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"You can think of ","type":"text"},{"type":"codeVoice","code":"fixedSize()"},{"text":" as the creation of a ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"counter proposal","type":"text"}]},{"text":" ","type":"text"},{"text":"to the view size proposed to a view by its parent. The ideal size of a","type":"text"},{"text":" ","type":"text"},{"text":"view, and the specific effects of ","type":"text"},{"type":"codeVoice","code":"fixedSize()"},{"text":" depends on the","type":"text"},{"text":" ","type":"text"},{"text":"particular view and how you have configured it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"To create a view that fixes the view’s size in either the horizontal or","type":"text"},{"text":" ","type":"text"},{"text":"vertical dimensions, see ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)","isActive":true,"type":"reference"},{"text":".","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StrokeShapeView"]]},"kind":"symbol","variants":[{"paths":["\/documentation\/openswiftui\/strokeshapeview\/fixedsize()"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Fixes this view at its ideal size.","type":"text"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View/fixedSize(horizontal:vertical:)":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fixedSize"},{"kind":"text","text":"("},{"kind":"externalParam","text":"horizontal"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":", "},{"kind":"externalParam","text":"vertical"},{"kind":"text",