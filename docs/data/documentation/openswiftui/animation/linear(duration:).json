{"sections":[],"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/linear(duration:)","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation"]]},"metadata":{"symbolKind":"method","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"linear"},{"kind":"text","text":"("},{"kind":"externalParam","text":"duration"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"TimeInterval","preciseIdentifier":"c:@T@NSTimeInterval"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Animation","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV"}],"remoteSource":{"fileName":"BezierAnimation.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Animation\/Animation\/BezierAnimation.swift#L313"},"roleHeading":"Type Method","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"title":"linear(duration:)","extendedModule":"OpenSwiftUICore","role":"symbol","platforms":[{"unavailable":false,"beta":false,"name":"iOS","introducedAt":"13.0","deprecated":false},{"unavailable":false,"beta":false,"name":"macOS","introducedAt":"10.15","deprecated":false},{"unavailable":false,"beta":false,"name":"tvOS","introducedAt":"13.0","deprecated":false},{"unavailable":false,"beta":false,"name":"visionOS","introducedAt":"1.0","deprecated":false},{"unavailable":false,"beta":false,"name":"watchOS","introducedAt":"6.0","deprecated":false}],"externalID":"s:15OpenSwiftUICore9AnimationV6linear8durationACSd_tFZ"},"abstract":[{"type":"text","text":"An animation that moves at a constant speed during a specified"},{"type":"text","text":" "},{"type":"text","text":"duration."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/animation\/linear(duration:)"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"linear","kind":"identifier"},{"text":"(","kind":"text"},{"text":"duration","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TimeInterval","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSTimeInterval"},{"text":") -> ","kind":"text"},{"text":"Animation","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"duration","content":[{"type":"paragraph","inlineContent":[{"text":"The length of time, expressed in seconds, that","type":"text"},{"text":" ","type":"text"},{"text":"the animation takes to complete.","type":"text"}]}]}]},{"kind":"content","content":[{"anchor":"return-value","type":"heading","level":2,"text":"Return Value"},{"inlineContent":[{"text":"A linear animation with a specified duration.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A linear animation provides a mechanical feel to the motion because its"},{"type":"text","text":" "},{"type":"text","text":"speed is consistent from start to finish of the animation. This"},{"type":"text","text":" "},{"type":"text","text":"constant speed makes a linear animation ideal for animating the"},{"type":"text","text":" "},{"type":"text","text":"movement of objects where changes in the speed might feel awkward, such"},{"type":"text","text":" "},{"type":"text","text":"as with an activity indicator."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"linear(duration:)"},{"type":"text","text":" when you want to specify the time it takes"},{"type":"text","text":" "},{"type":"text","text":"for the animation to complete. Otherwise, use "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/linear","isActive":true},{"type":"text","text":" to perform the"},{"type":"text","text":" "},{"type":"text","text":"animation for a default length of time."}]},{"type":"paragraph","inlineContent":[{"text":"The following code shows an example of using linear animation with a","type":"text"},{"text":" ","type":"text"},{"text":"duration of two seconds to animate the movement of a circle as it moves","type":"text"},{"text":" ","type":"text"},{"text":"between the leading and trailing edges of the view. The color of the","type":"text"},{"text":" ","type":"text"},{"text":"circle also animates from red to blue as it moves across the view.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["struct ContentView: View {","    @State private var isActive = false","","    var body: some View {","        VStack(alignment: isActive ? .trailing : .leading) {","            Circle()","                .fill(isActive ? Color.red : Color.blue)","                .frame(width: 50, height: 50)","","            Button(\"Animate\") {","                withAnimation(.linear(duration: 2.0)) {","                    isActive.toggle()","                }","            }","            .frame(maxWidth: .infinity)","        }","    }","}"]}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Animation/linear":{"kind":"symbol","abstract":[{"type":"text","text":"An animation that moves at a constant speed."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/linear","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"linear"},{"kind":"text","text":": "},{"kind":