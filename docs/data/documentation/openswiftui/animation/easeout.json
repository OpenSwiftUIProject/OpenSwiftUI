.","type":"text"}]},{"code":["struct ContentView: View {","    @State private var scale = 0.5","","    var body: some View {","        VStack {","            Circle()","                .scale(scale)","                .animation(.easeOut, value: scale)","            HStack {","                Button(\"+\") { scale += 0.1 }","                Button(\"-\") { scale -= 0.1 }","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Animation/easeOut":{"type":"topic","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"easeOut"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV","text":"Animation"}],"title":"easeOut","abstract":[{"text":"An animation that starts quickly and then slows towards the end of the","type":"text"},{"text":" ","type":"text"},{"text":"movement.","type":"text"}],"url":"\/documentation\/openswiftui\/animation\/easeout","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/easeOut"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Animation":{"title":"Animation","url":"\/documentation\/openswiftui\/animation","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation","navigatorTitle":[{"text":"Animation","kind":"identifier"}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Animation","kind":"identifier"}],"abstract":[{"text":"The way a view changes over time to create a smooth visual transition from","type":"text"},{"text":" ","type":"text"},{"text":"one state to another.","type":"text"}],"type":"topic"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the use