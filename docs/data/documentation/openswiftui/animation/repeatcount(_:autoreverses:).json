{"kind":"symbol","abstract":[{"text":"Repeats the animation for a specific number of times.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"repeatCount"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"repeatCount"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Int","preciseIdentifier":"s:Si"},{"kind":"text","text":", "},{"kind":"externalParam","text":"autoreverses"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","text":" = true) -> "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation","text":"Animation","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV"}]}]},{"kind":"parameters","parameters":[{"name":"repeatCount","content":[{"type":"paragraph","inlineContent":[{"text":"The number of times that the animation repeats. Each","type":"text"},{"text":" ","type":"text"},{"text":"repeated sequence starts at the beginning when ","type":"text"},{"code":"autoreverse","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"code":"false","type":"codeVoice"},{"text":".","type":"text"}]}]},{"name":"autoreverses","content":[{"type":"paragraph","inlineContent":[{"text":"A Boolean value that indicates whether the animation","type":"text"},{"text":" ","type":"text"},{"text":"sequence plays in reverse after playing forward. Autoreverse counts","type":"text"},{"text":" ","type":"text"},{"text":"towards the ","type":"text"},{"code":"repeatCount","type":"codeVoice"},{"text":". For instance, a ","type":"text"},{"code":"repeatCount","type":"codeVoice"},{"text":" of one plays","type":"text"},{"text":" ","type":"text"},{"text":"the animation forward once, but it doesn’t play in reverse even if","type":"text"},{"text":" ","type":"text"},{"code":"autoreverse","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":". When ","type":"text"},{"code":"autoreverse","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"code":"repeatCount","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"2","type":"codeVoice"},{"text":", the animation moves forward, then reverses, then","type":"text"},{"text":" ","type":"text"},{"text":"stops.","type":"text"}]}]}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"An animation that repeats for specific number of times."}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this method to repeat the animation a specific number of times. For","type":"text"},{"text":" ","type":"text"},{"text":"example, in the following code, the animation moves a truck from one","type":"text"},{"text":" ","type":"text"},{"text":"edge of the view to the other edge. It repeats this animation three","type":"text"},{"text":" ","type":"text"},{"text":"times.","type":"text"}]},{"type":"codeListing","code":["struct ContentView: View {","    @State private var driveForward = true","","    private var driveAnimation: Animation {","        .easeInOut","        .repeatCount(3, autoreverses: true)","        .speed(0.5)","    }","","    var body: some View {","        VStack(alignment: driveForward ? .leading : .trailing, spacing: 40) {","            Image(systemName: \"box.truck\")","                .font(.system(size: 48))","                .animation(driveAnimation, value: driveForward)","","            HStack {","                Spacer()","                Button(\"Animate\") {","                    driveForward.toggle()","                }","                Spacer()","            }","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The first time the animation runs, the truck moves from the leading"},{"type":"text","text":" "},{"type":"text","text":"edge to the trailing edge of the view. The second time the animation"},{"type":"text","text":" "},{"type":"text","text":"runs, the truck moves from the trailing edge to the leading edge"},{"type":"text","text":" "},{"type":"text","text":"because "},{"type":"codeVoice","code":"autoreverse"},{"type":"text","text":" is "},{"type":"codeVoice","code":"true"},{"type":"text","text":". If "},{"type":"codeVoice","code":"autoreverse"},{"type":"text","text":" were "},{"type":"codeVoice","code":"false"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"truck would jump back to leading edge before moving to the trailing"},{"type":"text","text":" "},{"type":"text","text":"edge. The third time the animation runs, the truck moves from the"},{"type":"text","text":" "},{"type":"text","text":"leading to the trailing edge of the view."}]}]}],"variants":[{"paths":["\/documentation\/openswiftui\/animation\/repeatcount(_:autoreverses:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation"]]},"metadata":{"roleHeading":"Instance Method","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Animation\/Animation\/RepeatAnimiation.swift#L71","fileName":"RepeatAnimiation.swift"},"platforms":[{"unavailable":false,"introducedAt":"13.0","name":"iOS","beta":false,"deprecated":false},{"unavailable":false,"introducedAt":"10.15","name":"macOS","beta":false,"deprecated":false},{"unavailable":false,"introducedAt":"13.0","name":"tvOS","beta":false,"deprecated":false},{"unavailable":false,"introducedAt":"