{"abstract":[{"type":"text","text":"An animation that moves at a constant speed."}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"linear"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV","text":"Animation"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" }"}]}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"A linear animation with the default duration.","type":"text"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A linear animation provides a mechanical feel to the motion because its"},{"type":"text","text":" "},{"type":"text","text":"speed is consistent from start to finish of the animation. This"},{"type":"text","text":" "},{"type":"text","text":"constant speed makes a linear animation ideal for animating the"},{"type":"text","text":" "},{"type":"text","text":"movement of objects where changes in the speed might feel awkward, such"},{"type":"text","text":" "},{"type":"text","text":"as with an activity indicator."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code shows an example of using linear animation to"},{"type":"text","text":" "},{"type":"text","text":"animate the movement of a circle as it moves between the leading and"},{"type":"text","text":" "},{"type":"text","text":"trailing edges of the view. The circle also animates its color change"},{"type":"text","text":" "},{"type":"text","text":"as it moves across the view."}]},{"type":"codeListing","code":["struct ContentView: View {","    @State private var isActive = false","","    var body: some View {","        VStack(alignment: isActive ? .trailing : .leading) {","            Circle()","                .fill(isActive ? Color.red : Color.blue)","                .frame(width: 50, height: 50)","","            Button(\"Animate\") {","                withAnimation(.linear) {","                    isActive.toggle()","                }","            }","            .frame(maxWidth: .infinity)","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"linear"},{"type":"text","text":" animation has a default duration of 0.35 seconds. To"},{"type":"text","text":" "},{"type":"text","text":"specify a different duration, use "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/linear(duration:)","isActive":true},{"type":"text","text":"."}]}]}],"sections":[],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/linear","interfaceLanguage":"swift"},"metadata":{"symbolKind":"property","role":"symbol","remoteSource":{"fileName":"BezierAnimation.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Animation\/Animation\/BezierAnimation.swift#L362"},"roleHeading":"Type Property","externalID":"s:15OpenSwiftUICore9AnimationV6linearACvpZ","extendedModule":"OpenSwiftUICore","title":"linear","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"platforms":[{"unavailable":false,"beta":false,"name":"iOS","introducedAt":"13.0","deprecated":false},{"unavailable":false,"beta":false,"name":"macOS","introducedAt":"10.15","deprecated":false},{"unavailable":false,"beta":false,"name":"tvOS","introducedAt":"13.0","deprecated":false},{"unavailable":false,"beta":false,"name":"visionOS","introducedAt":"1.0","deprecated":false},{"unavailable":false,"beta":false,"name":"watchOS","introducedAt":"6.0","deprecated":false}],"fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"linear"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Animation","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV"}]},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"paths":["\/documentation\/openswiftui\/animation\/linear"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Animation/linear":{"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"linear","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Animation","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV"}],"type":"topic","role":"symbol","title":"linear","kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/linear","url":"\/documentation\/openswiftui\/animation\/linear","abstract":[{"text":"An animation that moves at a constant speed.","type":"text"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Animation":{"title":"Animation","url":"\/documentation\/openswiftui\/animation","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation","navigatorTitle":[{"text":"Animation","kind":"identifier"}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Animation","kind":"identifier"}],"abstract":[{"text":"The way a view changes over time to create a smooth visual transition from","type":"text"},{"text":" ","type":"text"},{"text":"one state to another.","type":"text"}],"type":"topic"},"doc://OpenSwiftUI/documentation/OpenSwif