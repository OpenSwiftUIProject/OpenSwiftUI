e to create a smooth visual transition from"},{"type":"text","text":" "},{"type":"text","text":"one state to another."}],"role":"symbol","type":"topic","url":"\/documentation\/openswiftui\/animation","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Animation/linear":{"kind":"symbol","abstract":[{"type":"text","text":"An animation that moves at a constant speed."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/linear","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"linear"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV","text":"Animation"}],"type":"topic","title":"linear","url":"\/documentation\/openswiftui\/animation\/linear","role":"symbol"}}}