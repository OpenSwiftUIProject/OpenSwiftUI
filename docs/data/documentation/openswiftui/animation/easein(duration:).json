text"},{"text":"a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Circle","type":"reference","isActive":true},{"text":" using an ease in animation with a duration of one","type":"text"},{"text":" ","type":"text"},{"text":"second.","type":"text"}]},{"code":["struct ContentView: View {","    @State private var scale = 0.5","","    var body: some View {","        VStack {","            Circle()","                .scale(scale)","                .animation(.easeIn(duration: 1.0), value: scale)","            HStack {","                Button(\"+\") { scale += 0.1 }","                Button(\"-\") { scale -= 0.1 }","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/easeIn(duration:)"},"kind":"symbol","abstract":[{"type":"text","text":"An animation with a specified duration that starts slowly and then"},{"type":"text","text":" "},{"type":"text","text":"increases speed towards the end of the movement."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation"]]},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Animation/easeIn(duration:)":{"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"easeIn","kind":"identifier"},{"text":"(","kind":"text"},{"text":"duration","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TimeInterval","preciseIdentifier":"c:@T@NSTimeInterval","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Animation","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV","kind":"typeIdentifier"}],"title":"easeIn(duration:)","kind":"symbol","type":"topic","role":"symbol","url":"\/documentation\/openswiftui\/animation\/easein(durat