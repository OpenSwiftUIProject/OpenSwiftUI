mate button."}]},{"syntax":"swift","code":["struct ContentView: View {","    @State private var degrees = Double.zero","","    var body: some View {","        VStack {","            Spacer()","            Text(\"Hello\")","                .font(.largeTitle)","                .rotation3DEffect(.degrees(degrees), axis: (x: 0, y: 1, z: 0))","","            Spacer()","            Button(\"Animate\") {","                withAnimation {","                    degrees = (degrees == .zero) ? 180 : .zero","                }","            }","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To use the "},{"type":"codeVoice","code":"default"},{"type":"text","text":" animation when adding the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/animation(_:value:)","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"view modifier, specify it explicitly as the animation type. For"},{"type":"text","text":" "},{"type":"text","text":"instance, the following code shows an example of the "},{"type":"codeVoice","code":"default"},{"type":"text","text":" "},{"type":"text","text":"animation to spin the text “Hello” each time someone clicks the Animate"},{"type":"text","text":" "},{"type":"text","text":"button."}]},{"syntax":"swift","code":["struct ContentView: View {","    @State private var degrees = Double.zero","","    var body: some View {","        VStack {","            Spacer()","            Text(\"Hello\")","                .font(.largeTitle)","                .rotationEffect(.degrees(degrees))","                .animation(.default, value: degrees)","","            Spacer()","            Button(\"Animate\") {","                degrees = (degrees == .zero) ? 360 : .zero","            }","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"type":"codeVoice","code":"default"},{"text":" animation instance is only equal to other ","type":"text"},{"type":"codeVoice","code":"default"},{"text":" ","type":"text"},{"text":"animation instances (using ","type":"text"},{"type":"codeVoice","code":"=="},{"text":"), and not equal to other animation","type":"text"},{"text":" ","type":"text"},{"text":"instances even when the animations are identical. For example, if you","type":"text"},{"text":" ","type":"text"},{"text":"create an animation using the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/spring(response:dampingFraction:blendDuration:)","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"modifier with the same parameter values that ","type":"text"},{"type":"codeVoice","code":"default"},{"text":" uses, the","type":"text"},{"text":" ","type":"text"},{"text":"animation isn’t equal to ","type":"text"},{"type":"codeVoice","code":"default"},{"text":". This behavior lets you","type":"text"},{"text":" ","type":"text"},{"text":"differentiate between animations that you intentionally choose and","type":"text"},{"text":" ","type":"text"},{"text":"those that use the ","type":"text"},{"type":"codeVoice","code":"default"},{"text":" animation.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/animation\/default"]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation"]]},"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Animation":{"kind":"symbol","title":"Animation","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Animation"}],"navigatorTitle":[{"kind":"identifier","text":"Animation"}],"abstract":[{"type":"text","text":"The way a view changes over time to create a smooth visual transition from"},{"type":"text","text":" "},{"type":"text","text":"one state to another."}],"role":"symbol","type":"to