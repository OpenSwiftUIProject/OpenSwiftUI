{"sections":[],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","abstract":[{"text":"An animation created from a cubic Bézier timing curve.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"timingCurve"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"p1x"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"},{"kind":"text","text":", "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"p1y"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":", "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"p2x"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"},{"kind":"text","text":", "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"p2y"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sd","kind":"typeIdentifier","text":"Double"},{"kind":"text","text":", "},{"kind":"externalParam","text":"duration"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@T@NSTimeInterval","kind":"typeIdentifier","text":"TimeInterval"},{"kind":"text","text":" = 0.35) -> "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV","text":"Animation"}]}]},{"kind":"parameters","parameters":[{"name":"p1x","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The x-coordinate of the first control point of the cubic"},{"type":"text","text":" "},{"type":"text","text":"Bézier curve."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The y-coordinate of the first control point of the cubic","type":"text"},{"text":" ","type":"text"},{"text":"Bézier curve.","type":"text"}]}],"name":"p1y"},{"name":"p2x","content":[{"inlineContent":[{"text":"The x-coordinate of the second control point of the cubic","type":"text"},{"text":" ","type":"text"},{"text":"Bézier curve.","type":"text"}],"type":"paragraph"}]},{"name":"p2y","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The y-coordinate of the second control point of the cubic"},{"type":"text","text":" "},{"type":"text","text":"Bézier curve."}]}]},{"name":"duration","content":[{"type":"paragraph","inlineContent":[{"text":"The length of time, expressed in seconds, the animation","type":"text"},{"text":" ","type":"text"},{"text":"takes to complete.","type":"text"}]}]}]},{"content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"A cubic Bézier timing curve animation.","type":"text"}]}],"kind":"content"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this method to create a timing curve based on the control points of","type":"text"},{"text":" ","type":"text"},{"text":"a cubic Bézier curve. A cubic Bézier timing curve consists of a line","type":"text"},{"text":" ","type":"text"},{"text":"whose starting point is ","type":"text"},{"code":"(0, 0)","type":"codeVoice"},{"text":" and whose end point is ","type":"text"},{"code":"(1, 1)","type":"codeVoice"},{"text":". Two","type":"text"},{"text":" ","type":"text"},{"text":"additional control points, ","type":"text"},{"code":"(p1x, p1y)","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"(p2x, p2y)","type":"codeVoice"},{"text":", define the","type":"text"},{"text":" ","type":"text"},{"text":"shape of the curve.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The slope of the line defines the speed of the animation at that point"},{"type":"text","text":" "},{"type":"text","text":"in time. A steep slopes causes the animation to appear to run faster,"},{"type":"text","text":" "},{"type":"text","text":"while a shallower slope appears to run slower. The following"},{"type":"text","text":" "},{"type":"text","text":"illustration shows a timing curve where the animation starts and"},{"type":"text","text":" "},{"type":"text","text":"finishes fast, but appears slower through the middle section of the"},{"type":"text","text":" "},{"type":"text","text":"animation."}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"The following code uses the timing curve from the previous","type":"text"},{"text":" ","type":"text"},{"text":"illustration to animate a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Circle","type":"reference"},{"text":" as its size changes.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct ContentView: View {","    @State private var scale = 1.0","","    var body: some View {","        VStack {","            Circle()","                .scaleEffect(scale)","                .animation(","                    .timingCurve(0.1, 0.75, 0.85, 0.35, duration: 2.0),","                    value: scale)","","            Button(\"Animate\") {","                if scale == 1.0 {","                    scale = 0.25","                } else {","                    scale = 1.0","                }","            }","        }","    }","}"]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation"]]},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/timingCurve(_:_:_:_:duration:)","interfaceLanguage":"swift"},"metadata":{"externalID":"s:15OpenSwiftUICore9AnimationV11timingCurve___