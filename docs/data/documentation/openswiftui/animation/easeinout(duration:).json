 you want to specify the time it takes","type":"text"},{"text":" ","type":"text"},{"text":"for the animation to complete. Otherwise, use ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/easeInOut","isActive":true},{"text":" to perform","type":"text"},{"text":" ","type":"text"},{"text":"the animation for a default length of time.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The following code shows an example of animating the size changes of","type":"text"},{"text":" ","type":"text"},{"text":"a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Circle"},{"text":" using an ease in and out animation with a duration of","type":"text"},{"text":" ","type":"text"},{"text":"one second.","type":"text"}]},{"code":["struct ContentView: View {","    @State private var scale = 0.5","","    var body: some View {","        VStack {","            Circle()","                .scale(scale)","                .animation(.easeInOut(duration: 1.0), value: scale)","            HStack {","                Button(\"+\") { scale += 0.1 }","                Button(\"-\") { scale -= 0.1 }","            }","        }","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/easeInOut(duration:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/animation\/easeinout(duration:)"]}],"metadata":{"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"easeInOut","kind":"identifier"},{"text":"(","kind":"text"},{"text":"duration","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"TimeInterval","kind":"typeIdentifier","preciseIdentifier":"c:@T@NSTimeInterval"},{"text":") -> ","kind":"text"},{"text":"