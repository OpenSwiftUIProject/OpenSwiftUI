{"sections":[],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/spacing(subviews:cache:)","interfaceLanguage":"swift"},"abstract":[{"type":"text","text":"Returns the preferred spacing values of the composite view."}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout"]]},"metadata":{"modules":[{"name":"OpenSwiftUI"}],"remoteSource":{"fileName":"Layout.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Layout.swift#L344"},"symbolKind":"method","externalID":"s:15OpenSwiftUICore6LayoutP7spacing8subviews5cacheAA11ViewSpacingVAA0D8SubviewsV_5CacheQzztF","required":true,"role":"symbol","title":"spacing(subviews:cache:)","roleHeading":"Instance Method","platforms":[{"unavailable":false,"beta":false,"name":"iOS","deprecated":false,"introducedAt":"13.0"},{"unavailable":false,"beta":false,"name":"macOS","deprecated":false,"introducedAt":"10.15"},{"unavailable":false,"beta":false,"name":"tvOS","deprecated":false,"introducedAt":"13.0"},{"unavailable":false,"beta":false,"name":"visionOS","deprecated":false,"introducedAt":"1.0"},{"unavailable":false,"beta":false,"name":"watchOS","deprecated":false,"introducedAt":"6.0"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spacing","kind":"identifier"},{"text":"(","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Subviews","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa"},{"text":", ","kind":"text"},{"text":"cache","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Cache","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa"},{"text":") -> ","kind":"text"},{"text":"ViewSpacing","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/layout\/spacing(subviews:cache:)"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"defaultImplementationsSections":[{"title":"Layout Implementations","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/spacing(subviews:cache:)-2dxih"],"anchor":"Layout-Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"spacing"},{"kind":"text","text":"("},{"kind":"externalParam","text":"subviews"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","text":"Subviews","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cache"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa","text":"Cache","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV","text":"ViewSpacing","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"name":"subviews","content":[{"type":"paragraph","inlineContent":[{"text":"A collection of proxy instances that represent the","type":"text"},{"text":" ","type":"text"},{"text":"views that the container arranges. You can use the proxies in the","type":"text"},{"text":" ","type":"text"},{"text":"collection to get information about the subviews as you determine","type":"text"},{"text":" ","type":"text"},{"text":"how much spacing the container prefers around it.","type":"text"}]}]},{"name":"cache","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Optional storage for calculated data that you can share among"},{"type":"text","text":" "},{"type":"text","text":"the methods of your custom layout container. See"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/makeCache(subviews:)","isActive":true,"type":"reference"},{"type":"text","text":" for details."}]}]}]},{"content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"A "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing"},{"type":"text","text":" instance that describes the preferred"},{"type":"text","text":" "},{"type":"text","text":"spacing around the container view."}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Implement this method to provide custom spacing preferences"},{"type":"text","text":" "},{"type":"text","text":"for a layout container. The value you return affects"},{"type":"text","text":" "},{"type":"text","text":"the spacing around the container, but it doesn’t affect how the"},{"type":"text","text":" "},{"type":"text","text":"container arranges subviews relative to one another inside the"},{"type":"text","text":" "},{"type":"text","text":"container."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Create a custom "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","type":"reference","isActive":true},{"type":"text","text":" instance for your container by"},{"type":"text","text":" "},{"type":"text","text":"initializing one with default values, and then merging that with"},{"type":"text","text":" "},{"type":"text","text":"spacing instances of certain subviews. For example, if you define"},{"type":"text","text":" "},{"type":"text","text":"a basic vertical stack that places subviews in a column, you could"},{"type":"text","text":" "},{"type":"text","text":"use the spacing preferences of the subview edges that make"},{"type":"text","text":" "},{"type":"text","text":"contact with the container’s edges:"}],"type":"paragraph"},{"syntax":"swift","code":["extension BasicVStack {","    func spacing(subviews: Subviews, cache: inout ()) -> ViewSpacing {","        var spacing = ViewSpacing()","","        for index in subviews.indices {","            var edges: Edge.Set = [.leading, .trailing]","            if index == 0 { edges.formUnion(.top) }","            if index == subviews.count - 1 { edges.formUnion(.bottom) }","            spacing.formUnion(subviews[index].spacing, edges: edges)","        }","","        return spacing","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"In the above example, the first and last subviews contribute to the"},{"type":"text","text":" "},{"type":"text","text":"spacing above and below the container, respectively, while all subviews"},{"type":"text","text":" "},{"type":"text","text":"affect the spacing on the leading and trailing edges."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you don’t implement this method, the protocol provides a default"},{"type":"text","text":" "},{"type":"text","text":"implementation that merges the spacing preferences across all subviews on all edges."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Layout/spacing(subviews:cache:)-2dxih":{"role":"symbol","title":"spacing(subviews:cache:)","type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","tex