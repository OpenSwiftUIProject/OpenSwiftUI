{"abstract":[{"text":"Returns the preferred spacing values of the composite view.","type":"text"}],"variants":[{"paths":["\/documentation\/openswiftui\/layout\/spacing(subviews:cache:)-2dxih"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"symbolKind":"method","role":"symbol","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"extendedModule":"OpenSwiftUICore","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"text":"spacing","kind":"identifier"},{"text":"(","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Subviews","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa"},{"text":", ","kind":"text"},{"text":"cache","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Cache","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa"},{"text":") -> ","kind":"text"},{"text":"ViewSpacing","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV"}],"roleHeading":"Instance Method","title":"spacing(subviews:cache:)","externalID":"s:15OpenSwiftUICore6LayoutPAAE7spacing8subviews5cacheAA11ViewSpacingVAA0D8SubviewsV_5CacheQzztF","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Layout.swift#L747","fileName":"Layout.swift"}},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/spacing(subviews:cache:)-2dxih","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spacing","kind":"identifier"},{"text":"(","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews","text":"Subviews","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa"},{"text":", ","kind":"text"},{"text":"cache","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache","text":"Cache","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa"},{"text":") -> ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","text":"ViewSpacing","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A collection of proxy instances that represent the","type":"text"},{"text":" ","type":"text"},{"text":"views that the container arranges. You can use the proxies in the","type":"text"},{"text":" ","type":"text"},{"text":"collection to get information about the subviews as you determine","type":"text"},{"text":" ","type":"text"},{"text":"how much spacing the container prefers around it.","type":"text"}]}],"name":"subviews"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Optional storage for calculated data that you can share among","type":"text"},{"text":" ","type":"text"},{"text":"the methods of your custom layout container. See","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/makeCache(subviews:)"},{"text":" for details.","type":"text"}]}],"name":"cache"}]},{"content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","type":"reference"},{"text":" instance that describes the preferred","type":"text"},{"text":" ","type":"text"},{"text":"spacing around the container view.","type":"text"}]}],"kind":"content"},{"content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement this method to provide custom spacing preferences"},{"type":"text","text":" "},{"type":"text","text":"for a layout container. The value you return affects"},{"type":"text","text":" "},{"type":"text","text":"the spacing around the container, but it doesn’t affect how the"},{"type":"text","text":" "},{"type":"text","text":"container arranges subviews relative to one another inside the"},{"type":"text","text":" "},{"type":"text","text":"container."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a custom "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","isActive":true},{"type":"text","text":" instance for your container by"},{"type":"text","text":" "},{"type":"text","text":"initializing one with default values, and then merging that with"},{"type":"text","text":" "},{"type":"text","text":"spacing instances of certain subviews. For example, if you define"},{"type":"text","text":" "},{"type":"text","text":"a basic vertical stack that places subviews in a column, you could"},{"type":"text","text":" "},{"type":"text","text":"use the spacing preferences of the subview edges that make"},{"type":"text","text":" "},{"type":"text","text":"contact with the container’s edges:"}]},{"type":"codeListing","code":["extension BasicVStack {","    func spacing(subviews: Subviews, cache: inout ()) -> ViewSpacing {","        var spacing = ViewSpacing()","","        for index in subviews.indices {","            var edges: Edge.Set = [.leading, .trailing]","            if index == 0 { edges.formUnion(.top) }","            if index == subviews.count - 1 { edges.formUnion(.bottom) }","            spacing.formUnion(subviews[index].spacing, edges: edges)","        }","","        return spacing","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the above example, the first and last subviews contribute to the"},{"type":"text","text":" "},{"type":"text","text":"spacing above and below the container, respectively, while all subviews"},{"type":"text","text":" "},{"type":"text","text":"affect the spacing on the leading and trailing edges."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you don’t implement this method, the protocol provides a default"},{"type":"text","text":" "},{"type":"text","text":"implementation that merges the spacing preferences across all subviews on all edges."}]}],"kind":"content"}],"sections":[],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Layout/makeCache(subviews:)":{"url":"\/documentation\/openswiftui\/layout\/makecache(subviews:)","kind":"symbol","abstract":[{"type":"text","text":"Creates and initializes a cache for a layout instance."}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"makeCache","kind":"identifier"},{"text":"(","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Subviews","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Cache","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa"}],"type":"topic","required":true,"defaultImplementations":1,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/makeCache(subviews:)","title":"makeCache(subviews:)"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Layout/Subviews":{"title":"Layout.Subviews","abstract":[{"type":"text","text":"A collection of proxies for the subviews of a layout view."}],"url":"\/documentation\/openswiftui\/layout\/subviews","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"Subviews"}],"fragments":[{"kind":"keyword","text":"typealias"},{"kind":"text","text":" "},{"kind":"identifier","text":"Subviews"}],"kind":"symbol","type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Layout/Cache":{"type":"topic","abstract":[{"text":"Cached values associated with the layout instance.","type":"text"}],"title":"Cache","fragments":[{"kind":"keyword","text":"associatedtype"},{"kind":"text","text":" "},{"kind":"identifier","text":"Cache"},{"kind":"text","text":" = "},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"}],"role":"symbol","required":true,"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache","url":"\/documentation\/openswiftui\/layout\/cache"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Layout/spacing(subviews:cache:)-2dxih":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spacing","kind":"identifier"},{"text":"(","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Subviews","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cache","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Cache","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"ViewSpacing","preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV","kind":"typeIdentifier"}],"title":"spacing(subviews:cache:)","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/spacing(subviews:cache:)-2dxih","kind":"symbol","type":"topic","url":"\/documentation\/openswiftui\/layout\/spacing(subviews:cache:)-2dxih","abstract":[{"text":"Returns the preferred spacing values of the composite view.","type":"text"}],"role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Layout":{"abstract":[{"type":"text","text":"A type that defines the geometry of a collection of views."}],"url":"\/documentation\/openswiftui\/layout","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout","type":"topic","title":"Layout","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Layout"}],"navigatorTitle":[{"kind":"identifier","text":"Layout"}],"kind":"symbol","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ViewSpacing":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewSpacing","kind":"identifier"}],"title":"ViewSpacing","url":"\/documentation\/openswiftui\/viewspacing","kind":"symbol","type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","abstract":[{"text":"A collection of the geometric spacing preferences of a view.","type":"text"}],"role":"symbol","navigatorTitle":[{"text":"ViewSpacing","kind":"identifier"}]}}}