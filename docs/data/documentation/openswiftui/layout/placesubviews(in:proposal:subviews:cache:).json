{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/placeSubviews(in:proposal:subviews:cache:)"},"metadata":{"externalID":"s:15OpenSwiftUICore6LayoutP13placeSubviews2in8proposal8subviews5cacheySo6CGRectV_AA16ProposedViewSizeVAA0dF0V5CacheQzztF","platforms":[{"introducedAt":"13.0","deprecated":false,"unavailable":false,"name":"iOS","beta":false},{"introducedAt":"10.15","deprecated":false,"unavailable":false,"name":"macOS","beta":false},{"introducedAt":"13.0","deprecated":false,"unavailable":false,"name":"tvOS","beta":false},{"introducedAt":"1.0","deprecated":false,"unavailable":false,"name":"visionOS","beta":false},{"introducedAt":"6.0","deprecated":false,"unavailable":false,"name":"watchOS","beta":false}],"remoteSource":{"fileName":"Layout.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Layout.swift#L511"},"required":true,"symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"placeSubviews"},{"kind":"text","text":"("},{"kind":"externalParam","text":"in"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CGRect","preciseIdentifier":"c:@S@CGRect"},{"kind":"text","text":", "},{"kind":"externalParam","text":"proposal"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"ProposedViewSize","preciseIdentifier":"s:15OpenSwiftUICore16ProposedViewSizeV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"subviews"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Subviews","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cache"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Cache","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa"},{"kind":"text","text":")"}],"modules":[{"name":"OpenSwiftUI"}],"title":"placeSubviews(in:proposal:subviews:cache:)","role":"symbol","roleHeading":"Instance Method"},"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Assigns positions to each of the layout’s subviews."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/layout\/placesubviews(in:proposal:subviews:cache:)"]}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"placeSubviews","kind":"identifier"},{"text":"(","kind":"text"},{"text":"in","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"bounds","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"CGRect","preciseIdentifier":"c:@S@CGRect","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"proposal","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ProposedViewSize","preciseIdentifier":"s:15OpenSwiftUICore16ProposedViewSizeV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Subviews","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cache","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Cache","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache","kind":"typeIdentifier"},{"text":")","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The region that the container view’s parent allocates to the","type":"text"},{"text":" ","type":"text"},{"text":"container view, specified in the parent’s coordinate space.","type":"text"},{"text":" ","type":"text"},{"text":"Place all the container’s subviews within the region.","type":"text"},{"text":" ","type":"text"},{"text":"The size of this region matches a size that your container","type":"text"},{"text":" ","type":"text"},{"text":"previously returned from a call to the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/sizeThatFits(proposal:subviews:cache:)","isActive":true,"type":"reference"},{"text":" method.","type":"text"}]}],"name":"bounds"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The size proposal from which the container generated the","type":"text"},{"text":" ","type":"text"},{"text":"size that the parent used to create the ","type":"text"},{"code":"bounds","type":"codeVoice"},{"text":" parameter.","type":"text"},{"text":" ","type":"text"},{"text":"The parent might propose more than one size before calling the","type":"text"},{"text":" ","type":"text"},{"text":"placement method, but it always uses one of the proposals and the","type":"text"},{"text":" ","type":"text"},{"text":"corresponding returned size when placing the container.","type":"text"}]}],"name":"proposal"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A collection of proxies that represent the","type":"text"},{"type":"text","text":" "},{"type":"text","text":"views that the container arranges. Use the proxies in the collection"},{"type":"text","text":" "},{"type":"text","text":"to get information about the subviews and to tell the subviews"},{"type":"text","text":" "},{"type":"text","text":"where to appear."}]}],"name":"subviews"},{"content":[{"inlineContent":[{"type":"text","text":"Optional storage for calculated data that you can share among"},{"type":"text","text":" "},{"type":"text","text":"the methods of your custom layout container. See"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/makeCache(subviews:)"},{"type":"text","text":" for details."}],"type":"paragraph"}],"name":"cache"}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"discussion","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenSwiftUI calls your implementation of this method to tell your"},{"type":"text","text":" "},{"type":"text","text":"custom layout container to place its subviews. From this method, call"},{"type":"text","text":" "},{"type":"text","text":"the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutSubview\/place(at:anchor:proposal:)"},{"type":"text","text":" method on each"},{"type":"text","text":" "},{"type":"text","text":"element in "},{"code":"subviews","type":"codeVoice"},{"type":"text","text":" to tell the subviews where to appear in the"},{"type":"text","text":" "},{"type":"text","text":"user interface."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, you can create a basic vertical stack that places views"},{"type":"text","text":" "},{"type":"text","text":"in a column, with views horizontally aligned on their leading edge:"}]},{"type":"codeListing","syntax":"swift","code":["struct BasicVStack: Layout {","    func placeSubviews(","        in bounds: CGRect,","        proposal: ProposedViewSize,","        subviews: Subviews,","        cache: inout ()","    ) {","        var point = bounds.origin","        for subview in subviews {","            subview.place(at: point, anchor: .topLeading, proposal: .unspecified)","            point.y += subview.dimensions(in: .unspecified).height","        }","    }","","    \/\/ This layout also needs a sizeThatFits() implementation.","}"]},{"type":"paragraph","inlineContent":[{"text":"The example creates a placement point that starts at the origin of the","type":"text"},{"text":" ","type":"text"},{"text":"specified ","type":"text"},{"type":"codeVoice","code":"bounds"},{"text":" input and uses that to place the first subview. It","type":"text"},{"text":" ","type":"text"},{"text":"then moves the point in the y dimension by the subview’s height,","type":"text"},{"text":" ","type":"text"},{"text":"which it reads using the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutSubview\/dimensions(in:)","type":"reference"},{"text":" method.","type":"text"},{"text":" ","type":"text"},{"text":"This prepares the point for the next iteration of the loop. All","type":"text"},{"text":" ","type":"text"},{"text":"subview operations use an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/unspecified","type":"reference"},{"text":" size","type":"text"},{"text":" ","type":"text"},{"text":"proposal to indicate that subviews should use and report their ideal","type":"text"},{"text":" ","type":"text"},{"text":"size.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"A more complex layout container might add space between subviews","type":"text"},{"text":" ","type":"text"},{"text":"according to their ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutSubview\/spacing","isActive":true,"type":"reference"},{"text":" preferences, or a","type":"text"},{"text":" ","type":"text"},{"text":"fixed space based on input configuration. For example, you can extend","type":"text"},{"text":" ","type":"text"},{"text":"the basic vertical stack’s placement method to calculate the","type":"text"},{"text":" ","type":"text"},{"text":"preferred distances between adjacent subviews and store the results in","type":"text"},{"text":" ","type":"text"},{"text":"an array:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let spacing: [CGFloat] = subviews.indices.dropLast().map { index in","    subviews[index].spacing.distance(","        to: subviews[index + 1].spacing,","        along: .vertical)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The spacing’s "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing\/distance(to:along:)","isActive":true,"type":"reference"},{"type":"text","text":" method considers the"},{"type":"text","text":" "},{"type":"text","text":"preferences of adjacent views on the edge where they meet. It returns"},{"type":"text","text":" "},{"type":"text","text":"the smallest distance that satisfies both views’ preferences for the"},{"type":"text","text":" "},{"type":"text","text":"given edge. For example, if one view prefers at least "},{"code":"2","type":"codeVoice"},{"type":"text","text":" points on its"},{"type":"text","text":" "},{"type":"text","text":"bottom edge, and the next view prefers at least "},{"code":"8","type":"codeVoice"},{"type":"text","text":" points on its top"},{"type":"text","text":" "},{"type":"text","text":"edge, the distance method returns "},{"code":"8","type":"codeVoice"},{"type":"text","text":", because that’s the smallest"},{"type":"text","text":" "},{"type":"text","text":"value that satisfies both preferences."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Update the placement calculations to use the spacing values:"}]},{"type":"codeListing","syntax":"swift","code":["var point = bounds.origin","for (index, subview) in subviews.enumerated() {","    if index > 0 { point.y += spacing[index - 1] } \/\/ Add spacing.","    subview.place(at: point, anchor: .topLeading, proposal: .unspecified)","    point.y += subview.dimensions(in: .unspecified).height","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Be sure that you use computations during placement that are consistent"},{"type":"text","text":" "},{"type":"text","text":"with those in your implementation of other protocol methods for a given"},{"type":"text","text":" "},{"type":"text","text":"set of inputs. For example, if you add spacing during placement,"},{"type":"text","text":" "},{"type":"text","text":"make sure your implementation of"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/sizeThatFits(proposal:subviews:cache:)","isActive":true},{"type":"text","text":" accounts for the extra space."},{"type":"text","text":" "},{"type":"text","text":"Similarly, if the sizing method returns different values for different"},{"type":"text","text":" "},{"type":"text","text":"size proposals, make sure the placement method responds to its"},{"type":"text","text":" "},{"type":"codeVoice","code":"proposal"},{"type":"text","text":" input in the same way."}]}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Layout/Cache":{"abstract":[{"text":"Cached values associated with the layout instance.","type":"text"}],"role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache","kind":"symbol","type":"topic","required":true,"fragments":[{"text":"associatedtype","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Cache","kind":"identifier"},{"text":" = ","kind":"text"},{"preciseIdentifier":"s:s4Voida","text":"Void","kind":"typeIdentifier"}],"title":"Cache","url":"\/documentation\/openswiftui\/layout\/cache"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Layout/Subviews":{"kind":"symbol","role":"symbol","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Subviews","kind":"identifier"}],"navigatorTitle":[{"text":"Subviews","kind":"identifier"}],"identifier":"doc:\