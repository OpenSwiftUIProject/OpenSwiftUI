{"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"placeSubviews"},{"kind":"text","text":"("},{"kind":"externalParam","text":"in"},{"kind":"text","text":" "},{"kind":"internalParam","text":"bounds"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CGRect","preciseIdentifier":"c:@S@CGRect"},{"kind":"text","text":", "},{"kind":"externalParam","text":"proposal"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize","text":"ProposedViewSize","preciseIdentifier":"s:15OpenSwiftUICore16ProposedViewSizeV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"subviews"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews","text":"Subviews","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cache"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache","text":"Cache","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa"},{"kind":"text","text":")"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"bounds","content":[{"inlineContent":[{"type":"text","text":"The region that the container view’s parent allocates to the"},{"type":"text","text":" "},{"type":"text","text":"container view, specified in the parent’s coordinate space."},{"type":"text","text":" "},{"type":"text","text":"Place all the container’s subviews within the region."},{"type":"text","text":" "},{"type":"text","text":"The size of this region matches a size that your container"},{"type":"text","text":" "},{"type":"text","text":"previously returned from a call to the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/sizeThatFits(proposal:subviews:cache:)"},{"type":"text","text":" method."}],"type":"paragraph"}]},{"name":"proposal","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The size proposal from which the container generated the"},{"type":"text","text":" "},{"type":"text","text":"size that the parent used to create the "},{"type":"codeVoice","code":"bounds"},{"type":"text","text":" parameter."},{"type":"text","text":" "},{"type":"text","text":"The parent might propose more than one size before calling the"},{"type":"text","text":" "},{"type":"text","text":"placement method, but it always uses one of the proposals and the"},{"type":"text","text":" "},{"type":"text","text":"corresponding returned size when placing the container."}]}]},{"name":"subviews","content":[{"type":"paragraph","inlineContent":[{"text":"A collection of proxies that represent the","type":"text"},{"text":" ","type":"text"},{"text":"views that the container arranges. Use the proxies in the collection","type":"text"},{"text":" ","type":"text"},{"text":"to get information about the subviews and to tell the subviews","type":"text"},{"text":" ","type":"text"},{"text":"where to appear.","type":"text"}]}]},{"name":"cache","content":[{"inlineContent":[{"type":"text","text":"Optional storage for calculated data that you can share among"},{"type":"text","text":" "},{"type":"text","text":"the methods of your custom layout container. See"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/makeCache(subviews:)"},{"type":"text","text":" for details."}],"type":"paragraph"}]}]},{"content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"OpenSwiftUI calls your implementation of this method to tell your"},{"type":"text","text":" "},{"type":"text","text":"custom layout container to place its subviews. From this method, call"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutSubview\/place(at:anchor:proposal:)","isActive":true},{"type":"text","text":" method on each"},{"type":"text","text":" "},{"type":"text","text":"element in "},{"type":"codeVoice","code":"subviews"},{"type":"text","text":" to tell the subviews where to appear in the"},{"type":"text","text":" "},{"type":"text","text":"user interface."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, you can create a basic vertical stack that places views"},{"type":"text","text":" "},{"type":"text","text":"in a column, with views horizontally aligned on their leading edge:"}],"type":"paragraph"},{"code":["struct BasicVStack: Layout {","    func placeSubviews(","        in bounds: CGRect,","        proposal: ProposedViewSize,","        subviews: Subviews,","        cache: inout ()","    ) {","        var point = bounds.origin","        for subview in subviews {","            subview.place(at: point, anchor: .topLeading, proposal: .unspecified)","            point.y += subview.dimensions(in: .unspecified).height","        }","    }","","    \/\/ This layout also needs a sizeThatFits() implementation.","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The example creates a placement point that starts at the origin of the","type":"text"},{"text":" ","type":"text"},{"text":"specified ","type":"text"},{"type":"codeVoice","code":"bounds"},{"text":" input and uses that to place the first subview. It","type":"text"},{"text":" ","type":"text"},{"text":"then moves the point in the y dimension by the subview’s height,","type":"text"},{"text":" ","type":"text"},{"text":"which it reads using the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutSubview\/dimensions(in:)","type":"reference","isActive":true},{"text":" method.","type":"text"},{"text":" ","type":"text"},{"text":"This prepares the point for the next iteration of the loop. All","type":"text"},{"text":" ","type":"text"},{"text":"subview operations use an ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/unspecified","type":"reference","isActive":true},{"text":" size","type":"text"},{"text":" ","type":"text"},{"text":"proposal to indicate that subviews should use and report their ideal","type":"text"},{"text":" ","type":"text"},{"text":"size.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A more complex layout container might add space between subviews","type":"text"},{"text":" ","type":"text"},{"text":"according to their ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutSubview\/spacing"},{"text":" preferences, or a","type":"text"},{"text":" ","type":"text"},{"text":"fixed space based on input configuration. For example, you can extend","type":"text"},{"text":" ","type":"text"},{"text":"the basic vertical stack’s placement method to calculate the","type":"text"},{"text":" ","type":"text"},{"text":"preferred distances between adjacent subviews and store the results in","type":"text"},{"type":"text","text":" "},{"type":"text","text":"an array:"}],"type":"paragraph"},{"code":["let spacing: [CGFloat] = subviews.indices.dropLast().map { index in","    subviews[index].spacing.distance(","        to: subviews[index + 1].spacing,","        along: .vertical)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The spacing’s ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing\/distance(to:along:)","type":"reference","isActive":true},{"text":" method considers the","type":"text"},{"text":" ","type":"text"},{"text":"preferences of adjacent views on the edge where they meet. It returns","type":"text"},{"text":" ","type":"text"},{"text":"the smallest distance that satisfies both views’ preferences for the","type":"text"},{"text":" ","type":"text"},{"text":"given edge. For example, if one view prefers at least ","type":"text"},{"code":"2","type":"codeVoice"},{"text":" points on its","type":"text"},{"text":" ","type":"text"},{"text":"bottom edge, and the next view prefers at least ","type":"text"},{"code":"8","type":"codeVoice"},{"text":" points on its top","type":"text"},{"text":" ","type":"text"},{"text":"edge, the distance method returns ","type":"text"},{"code":"8","type":"codeVoice"},{"text":", because that’s the smallest","type":"text"},{"text":" ","type":"text"},{"text":"value that satisfies both preferences.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Update the placement calculations to use the spacing values:"}],"type":"paragraph"},{"code":["var point = bounds.origin","for (index, subview) in subviews.enumerated() {","    if index > 0 { point.y += spacing[index - 1] } \/\/ Add spacing.","    subview.place(at: point, anchor: .topLeading, proposal: .unspecified)","    point.y += subview.dimensions(in: .unspecified).height","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Be sure that you use computations during placement that are consistent","type":"text"},{"text":" ","type":"text"},{"text":"with those in your implementation of other protocol methods for a given","type":"text"},{"text":" ","type":"text"},{"text":"set of inputs. For example, if you add spacing during placement,","type":"text"},{"text":" ","type":"text"},{"text":"make sure your implementation of","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/sizeThatFits(proposal:subviews:cache:)","isActive":true,"type":"reference"},{"text":" accounts for the extra space.","type":"text"},{"text":" ","type":"text"},{"text":"Similarly, if the sizing method returns different values for different","type":"text"},{"text":" ","type":"text"},{"text":"size proposals, make sure the placement method responds to its","type":"text"},{"text":" ","type":"text"},{"code":"proposal","type":"codeVoice"},{"text":" input in the same way.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/openswiftui\/layout\/placesubviews(in:proposal:subviews:cache:)"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/placeSubviews(in:proposal:subviews:cache:)"},"sections":[],"kind":"symbol","metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"placeSubviews"},{"kind":"text","text":"("},{"kind":"externalParam","text":"in"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@S@CGRect","text":"CGRect"},{"kind":"text","text":", "},{"kind":"externalParam","text":"proposal"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore16ProposedViewSizeV","text":"ProposedViewSize"},{"kind":"text","text":", "},{"kind":"externalParam","text":"subviews"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","text":"Subviews"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cache"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa","text":"Cache"},{"kind":"text","text":")"}],"platforms":[{"name":"iOS","unavailable":false,"introducedAt":