{"metadata":{"externalID":"s:15OpenSwiftUICore6LayoutP9makeCache8subviews0F0QzAA0D8SubviewsV_tF","platforms":[{"name":"iOS","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"name":"macOS","introducedAt":"10.15","deprecated":false,"unavailable":false,"beta":false},{"name":"tvOS","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"introducedAt":"1.0","name":"visionOS","deprecated":false,"beta":false,"unavailable":false},{"introducedAt":"6.0","name":"watchOS","deprecated":false,"beta":false,"unavailable":false}],"modules":[{"name":"OpenSwiftUI"}],"role":"symbol","remoteSource":{"fileName":"Layout.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Layout.swift#L274"},"required":true,"title":"makeCache(subviews:)","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"makeCache","kind":"identifier"},{"text":"(","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Subviews","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Cache","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa"}],"roleHeading":"Instance Method"},"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/layout\/makecache(subviews:)"]}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"makeCache","kind":"identifier"},{"text":"(","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","text":"Subviews","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa","text":"Cache","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"subviews","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A collection of proxy instances that represent the"},{"type":"text","text":" "},{"type":"text","text":"views that the container arranges. You can use the proxies in the"},{"type":"text","text":" "},{"type":"text","text":"collection to get information about the subviews as you"},{"type":"text","text":" "},{"type":"text","text":"calculate values to store in the cache."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","anchor":"return-value","text":"Return Value","level":2},{"type":"paragraph","inlineContent":[{"text":"Storage for calculated data that you share among","type":"text"},{"text":" ","type":"text"},{"text":"the methods of your custom layout container.","type":"text"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can optionally use a cache to preserve calculated values across"},{"type":"text","text":" "},{"type":"text","text":"calls to a layout container’s methods. Many layout types don’t need"},{"type":"text","text":" "},{"type":"text","text":"a cache, because OpenSwiftUI automatically reuses both the results of"},{"type":"text","text":" "},{"type":"text","text":"calls into the layout and the values that the layout reads from its"},{"type":"text","text":" "},{"type":"text","text":"subviews. Rely on the protocol’s default implementation of this method"},{"type":"text","text":" "},{"type":"text","text":"if you don’t need a cache."}]},{"type":"paragraph","inlineContent":[{"text":"However you might find a cache useful when:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The layout container repeats complex, intermediate calculations"},{"type":"text","text":" "},{"type":"text","text":"across calls like "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/sizeThatFits(proposal:subviews:cache:)","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/placeSubviews(in:proposal:subviews:cache:)","isActive":true},{"type":"text","text":", and"},{"type":"text","text":" "},{"type":"codeVoice","code":"explicitAlignment(of:in:proposal:subviews:cache:)"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"You might be able to improve performance by calculating values"},{"type":"text","text":" "},{"type":"text","text":"once and storing them in a cache."}]}]},{"content":[{"inlineContent":[{"text":"The layout container reads many ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutValueKey"},{"text":" values from","type":"text"},{"text":" ","type":"text"},{"text":"subviews. It might be more efficient to do that once and store the","type":"text"},{"text":" ","type":"text"},{"text":"results in the cache, rather than rereading the subviews’ values before","type":"text"},{"text":" ","type":"text"},{"text":"each layout call.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"You want to maintain working storage, like temporary Swift arrays,","type":"text"},{"text":" ","type":"text"},{"text":"across calls into the layout, to minimize the number of allocation","type":"text"},{"text":" ","type":"text"},{"text":"events.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only implement a cache if profiling shows that it improves performance."}]},{"level":3,"text":"Initialize a cache","anchor":"Initialize-a-cache","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement the "},{"type":"codeVoice","code":"makeCache(subviews:)"},{"type":"text","text":" method to create a cache."},{"type":"text","text":" "},{"type":"text","text":"You can add computed values to the cache right away, using information"},{"type":"text","text":" "},{"type":"text","text":"from the "},{"type":"codeVoice","code":"subviews"},{"type":"text","text":" input parameter, or you can do that later. The"},{"type":"text","text":" "},{"type":"text","text":"methods of the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout"},{"type":"text","text":" protocol that can access the cache"},{"type":"text","text":" "},{"type":"text","text":"take the cache as an in-out parameter, which enables you to modify"},{"type":"text","text":" "},{"type":"text","text":"the cache anywhere that you can read it."}]},{"type":"paragraph","inlineContent":[{"text":"You can use any storage type that makes sense for your layout","type":"text"},{"text":" ","type":"text"},{"text":"algorithm, but be sure that you only store data that you derive","type":"text"},{"text":" ","type":"text"},{"text":"from the layout and its subviews (lazily, if possible). For this to","type":"text"},{"text":" ","type":"text"},{"text":"work correctly, OpenSwiftUI needs to be able to call this method to","type":"text"},{"text":" ","type":"text"},{"text":"recreate the cache without changing the layout result.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you return a cache from this method, you implicitly define a type"},{"type":"text","text":" "},{"type":"text","text":"for your cache. Be sure to either make the type of the "},{"code":"cache","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"parameters on your other "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout","isActive":true},{"type":"text","text":" protocol methods match, or use"},{"type":"text","text":" "},{"type":"text","text":"a type alias to define the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache","isActive":true},{"type":"text","text":" associated type."}]},{"level":3,"text":"Update the cache","anchor":"Update-the-cache","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"If the layout container or any of its subviews change, OpenSwiftUI","type":"text"},{"text":" ","type":"text"},{"text":"calls the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/updateCache(_:subviews:)","type":"reference","isActive":true},{"text":" method so you can","type":"text"},{"text":" ","type":"text"},{"text":"modify or invalidate the contents of the","type":"text"},{"text":" ","type":"text"},{"text":"cache. The default implementation of that method calls the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"makeCache(subviews:)"},{"text":" method to recreate the cache, but you can","type":"text"},{"text":" ","type":"text"},{"text":"provide your own implementation of the update method to take an","type":"text"},{"text":" ","type":"text"},{"text":"incremental approach, if appropriate.","type":"text"}]}]}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/makeCache(subviews:)"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout"]]},"sections":[],"defaultImplementationsSections":[{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layou