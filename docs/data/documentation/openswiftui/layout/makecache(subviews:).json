{"defaultImplementationsSections":[{"title":"Layout Implementations","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/makeCache(subviews:)-8jzt5"],"anchor":"Layout-Implementations"}],"metadata":{"platforms":[{"name":"iOS","beta":false,"deprecated":false,"introducedAt":"13.0","unavailable":false},{"name":"macOS","beta":false,"deprecated":false,"introducedAt":"10.15","unavailable":false},{"name":"tvOS","beta":false,"deprecated":false,"introducedAt":"13.0","unavailable":false},{"name":"visionOS","beta":false,"deprecated":false,"introducedAt":"1.0","unavailable":false},{"name":"watchOS","beta":false,"deprecated":false,"introducedAt":"6.0","unavailable":false}],"role":"symbol","roleHeading":"Instance Method","modules":[{"name":"OpenSwiftUI"}],"externalID":"s:15OpenSwiftUICore6LayoutP9makeCache8subviews0F0QzAA0D8SubviewsV_tF","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"makeCache","kind":"identifier"},{"text":"(","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Subviews","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Cache","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa"}],"title":"makeCache(subviews:)","remoteSource":{"fileName":"Layout.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Layout.swift#L274"},"symbolKind":"method","required":true},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/layout\/makecache(subviews:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"makeCache"},{"kind":"text","text":"("},{"kind":"externalParam","text":"subviews"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","text":"Subviews","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa","text":"Cache","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache"}]}]},{"kind":"parameters","parameters":[{"name":"subviews","content":[{"type":"paragraph","inlineContent":[{"text":"A collection of proxy instances that represent the","type":"text"},{"text":" ","type":"text"},{"text":"views that the container arranges. You can use the proxies in the","type":"text"},{"text":" ","type":"text"},{"text":"collection to get information about the subviews as you","type":"text"},{"text":" ","type":"text"},{"text":"calculate values to store in the cache.","type":"text"}]}]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"Storage for calculated data that you share among","type":"text"},{"text":" ","type":"text"},{"text":"the methods of your custom layout container.","type":"text"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"You can optionally use a cache to preserve calculated values across","type":"text"},{"text":" ","type":"text"},{"text":"calls to a layout container’s methods. Many layout types don’t need","type":"text"},{"text":" ","type":"text"},{"text":"a cache, because OpenSwiftUI automatically reuses both the results of","type":"text"},{"text":" ","type":"text"},{"text":"calls into the layout and the values that the layout reads from its","type":"text"},{"text":" ","type":"text"},{"text":"subviews. Rely on the protocol’s default implementation of this method","type":"text"},{"text":" ","type":"text"},{"text":"if you don’t need a cache.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"However you might find a cache useful when:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The layout container repeats complex, intermediate calculations","type":"text"},{"text":" ","type":"text"},{"text":"across calls like ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/sizeThatFits(proposal:subviews:cache:)"},{"text":",","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/placeSubviews(in:proposal:subviews:cache:)"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"explicitAlignment(of:in:proposal:subviews:cache:)"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"You might be able to improve performance by calculating values","type":"text"},{"text":" ","type":"text"},{"text":"once and storing them in a cache.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The layout container reads many "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutValueKey"},{"type":"text","text":" values from"},{"type":"text","text":" "},{"type":"text","text":"subviews. It might be more efficient to do that once and store the"},{"type":"text","text":" "},{"type":"text","text":"results in the cache, rather than rereading the subviews’ values before"},{"type":"text","text":" "},{"type":"text","text":"each layout call."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You want to maintain working storage, like temporary Swift arrays,"},{"type":"text","text":" "},{"type":"text","text":"across calls into the layout, to minimize the number of allocation"},{"type":"text","text":" "},{"type":"text","text":"events."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Only implement a cache if profiling shows that it improves performance."}]},{"type":"heading","level":3,"text":"Initialize a cache","anchor":"Initialize-a-cache"},{"type":"paragraph","inlineContent":[{"text":"Implement the ","type":"text"},{"code":"makeCache(subviews:)","type":"codeVoice"},{"text":" method to create a cache.","type":"text"},{"text":" ","type":"text"},{"text":"You can add computed values to the cache right away, using information","type":"text"},{"text":" ","type":"text"},{"text":"from the ","type":"text"},{"code":"subviews","type":"codeVoice"},{"text":" input parameter, or you can do that later. The","type":"text"},{"text":" ","type":"text"},{"text":"methods of the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout","type":"reference","isActive":true},{"text":" protocol that can access the cache","type":"text"},{"text":" ","type":"text"},{"text":"take the cache as an in-out parameter, which enables you to modify","type":"text"},{"text":" ","type":"text"},{"text":"the cache anywhere that you can read it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can use any storage type that makes sense for your layout","type":"text"},{"text":" ","type":"text"},{"text":"algorithm, but be sure that you only store data that you derive","type":"text"},{"text":" ","type":"text"},{"text":"from the layout and its subviews (lazily, if possible). For this to","type":"text"},{"text":" ","type":"text"},{"text":"work correctly, OpenSwiftUI needs to be able to call this method to","type":"text"},{"text":" ","type":"text"},{"text":"recreate the cache without changing the layout result.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"When you return a cache from this method, you implicitly define a type","type":"text"},{"text":" ","type":"text"},{"text":"for your cache. Be sure to either make the type of the ","type":"text"},{"code":"cache","type":"codeVoice"},{"text":" ","type":"text"},{"text":"parameters on your other ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout","isActive":true,"type":"reference"},{"text":" protocol methods match, or use","type":"text"},{"text":" ","type":"text"},{"text":"a type alias to define the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache","isActive":true,"type":"reference"},{"text":" associated type.","type":"text"}]},{"type":"heading","level":3,"text":"Update the cache","anchor":"Update-the-cache"},{"type":"paragraph","inlineContent":[{"text":"If the layout container or any of its subviews change, OpenSwiftUI","type":"text"},{"text":" ","type":"text"},{"text":"calls the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/updateCache(_:subviews:)","isActive":true,"type":"reference"},{"text":" method so you can","type":"text"},{"text":" ","type":"text"},{"text":"modify or invalidate the contents of the","type":"text"},{"text":" ","type":"text"},{"text":"cache. The default implementation of that method calls the","type":"text"},{"text":" ","type":"text"},{"code":"makeCache(subviews:)","type":"codeVoice"},{"text":" method to recreate the cache, but you can","type":"text"},{"text":" ","type":"text"},{"text":"provide your own implementation of the update method to take an","type":"text"},{"text":" ","type":"text"},{"text":"incremental approach, if appropriate.","type":"text"}]}]}],"abstract":[{"type":"text","text":"Creates and initializes a cache for a layout instance."}]