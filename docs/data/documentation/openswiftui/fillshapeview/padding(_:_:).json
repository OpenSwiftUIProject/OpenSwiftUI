ode":"nil"},{"type":"text","text":"."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"anchor":"return-value","text":"Return Value","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"A view that’s padded by the specified amount on the"},{"type":"text","text":" "},{"type":"text","text":"specified edges."}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier to add a specified amount of padding to one or more","type":"text"},{"text":" ","type":"text"},{"text":"edges of the view. Indicate the edges to pad by naming either a single","type":"text"},{"text":" ","type":"text"},{"text":"value from ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set","isActive":true},{"text":", or by specifying an","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/Swift\/OptionSet","isActive":true},{"text":" ","type":"text"},{"text":"that contains edge values:","type":"text"}]},{"type":"codeListing","code":["VStack {","    Text(\"Text padded by 20 points on the bottom and trailing edges.\")","        .padding([.bottom, .trailing], 20)","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The order in which you apply modifiers matters. The example above"},{"type":"text","text":" "},{"type":"text","text":"applies the padding before applying the border to ensure that the"},{"type":"text","text":" "},{"type":"text","text":"border encompasses the padded region:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can omit either or both of the parameters. If you omit the "},{"type":"codeVoice","code":"length"},{"type":"text","tex