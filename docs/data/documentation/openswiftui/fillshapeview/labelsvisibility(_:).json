s"},{"type":"text","text":" "},{"type":"text","text":"combined label and control element:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Always provide a label for controls, even when you hide the label,"},{"type":"text","text":" "},{"type":"text","text":"because OpenSwiftUI uses labels for other purposes, including accessibility."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On iOS, a "},{"code":"Picker","type":"codeVoice"},{"type":"text","text":" within a "},{"code":"Menu","type":"codeVoice"},{"type":"text","text":" hides its label by default. You can use"},{"type":"text","text":" "},{"type":"text","text":"this modifier to explicitly show the label in that context:"}],"type":"paragraph"},{"code":["Menu {","    Picker(\"Flavor\", selection: $selectedFlavor) {","        Text(\"Chocolate\").tag(Flavor.chocolate)","        Text(\"Vanilla\").tag(Flavor.vanilla)","        Text(\"Strawberry\").tag(Flavor.strawberry)","    }","    .labelsVisibility(.visible)","}"],"syntax":"swift","type":"codeListing"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This modifier doesn’t work for all labels. It applies to"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent","isActive":true},{"type":"text","text":" elements, including controls like "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true},{"type":"text","text":", but not to controls like a bordered button where the label"},{"type":"text","text":" "},{"type":"text","text":"is inside the button’s border."}]}],"type":"aside"}],"kind":"content"}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/FillShapeView\/labelsVisibility(_:)","interfaceLanguage":"swift"},"re