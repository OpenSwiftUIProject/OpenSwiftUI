{"abstract":[{"type":"text","text":"Fixes this view at its ideal size."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fixedSize","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":"\n","kind":"text"}]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"A view that fixes this view at its ideal size.","type":"text"}]}],"kind":"content"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"During the layout of the view hierarchy, each view proposes a size to","type":"text"},{"text":" ","type":"text"},{"text":"each child view it contains. If the child view doesn’t need a fixed size","type":"text"},{"text":" ","type":"text"},{"text":"it can accept and conform to the size offered by the parent.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" view placed in an explicitly sized frame wraps"},{"type":"text","text":" "},{"type":"text","text":"and truncates its string to remain within its parent’s bounds:"}]},{"syntax":"swift","type":"codeListing","code":["Text(\"A single line of text, too long to fit in a box.\")","    .frame(width: 200, height: 200)","    .border(Color.gray)"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"