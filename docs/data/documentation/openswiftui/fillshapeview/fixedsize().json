 in a box.\")","    .fixedSize()","    .frame(width: 200, height: 200)","    .border(Color.gray)"]},{"inlineContent":[{"type":"text","text":"This can result in the view exceeding the parent’s bounds, which may or"},{"type":"text","text":" "},{"type":"text","text":"may not be the effect you want."}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can think of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" as the creation of a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"counter proposal"}]},{"type":"text","text":" "},{"type":"text","text":"to the view size proposed to a view by its parent. The ideal size of a"},{"type":"text","text":" "},{"type":"text","text":"view, and the specific effects of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" depends on the"},{"type":"text","text":" "},{"type":"text","text":"particular view and how you have configured it."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To create a view that fixes the view’s size in either the horizontal or"},{"type":"text","text":" "},{"type":"text","text":"vertical dimensions, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)"},{"type":"text","text":"."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/fillshapeview\/fixedsize()"]}],"sections":[],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/FillShapeView/fixedSize()":{"title":"fixedSize()","abstract":[{"text":"Fixes this v