pe":"paragraph"},{"inlineContent":[{"text":"When the value changes, the new version of the closure will be called,","type":"text"},{"text":" ","type":"text"},{"text":"so any captured values will have their values from the time that the","type":"text"},{"text":" ","type":"text"},{"text":"observed value has its new value. The old and new observed values are","type":"text"},{"text":" ","type":"text"},{"text":"passed into the closure. In the following code example, ","type":"text"},{"code":"PlayerView","type":"codeVoice"},{"text":" ","type":"text"},{"text":"passes both the old and new values to the model.","type":"text"}],"type":"paragraph"},{"code":["struct PlayerView: View {","    var episode: Episode","    @State private var playState: PlayState = .paused","","    var body: some View {","        VStack {","            Text(episode.title)","            Text(episode.showTitle)","            PlayButton(playState: $playState)","        }","        .onChange(of: playState) { oldState, newState in","            model.playStateDidChange(from: oldState, to: newState)","        }","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/unevenroundedrectangle\/onchange(of:initial:_:)-6n463"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnevenRoundedRectangle"]]},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/UnevenRoundedRectangle/onChange(of:initial:_:)-6n463":{"url":"\/documentation\/openswiftui\/unevenro