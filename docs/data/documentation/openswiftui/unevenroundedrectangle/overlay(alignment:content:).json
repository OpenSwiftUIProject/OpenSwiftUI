hy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UnevenRoundedRectangle"]]},"variants":[{"paths":["\/documentation\/openswiftui\/unevenroundedrectangle\/overlay(alignment:content:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Layers the views that you specify in front of this view.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"overlay"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"externalParam","text":"alignment"},{"kind":"text","text":": "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment","kind":"typeIdentifier","text":"Alignment","preciseIdentifier":"s:15OpenSwiftUICore9AlignmentV"},{"kind":"text","text":" = .center, "},{"kind":"attribute","text":"@"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder","kind":"attribute","text":"ViewBuilder","preciseIdentifier":"s:15OpenSwiftUICore11ViewBuilderV"},{"kind":"text","text":" "},{"kind":"externalParam","text":"content"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"alignment","content":[{"type":"paragraph","inlineContent":[{"text":"The alignment that the modifier uses to position the","type":"text"},{"text":" ","type":"text"},{"text":"implicit ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"text":" that groups the foreground views. The default","type":"text"},{"text":" ","type":"text"},{"text":"is ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center","isActive":true,"type":"reference"},{"text":".","type":"text"}]}]},{"name":"content","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder"},{"type":"text","text":" that you use to declare the views to"},{"type":"text","text":" "},{"type":"text","text":"draw in front of this view, stacked in the order that you list them."},{"type":"text","text":" "},{"type":"text","text":"The last view that you list appears at the front of the stack."}]}]}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that uses the specified content as a foreground."}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier to place one or more views in front of another view.","type":"text"},{"text":" ","type":"text"},{"text":"For example, you can place a group of stars on a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/RoundedRectangle","type":"reference"},{"text":":","type":"text"}]},{"code":["RoundedRectangle(cornerRadius: 8)","    .frame(width: 200, height: 100)","    .overlay(alignment: .topLeading) { Star(color: .red) }","    .overlay(alignment: .topTrailing) { Star(color: .yellow) }","    .overlay(alignment: .bottomLeading) { Star(color: .green) }","    .overlay(alignment: .bottomTrailing) { Star(color: .blue) }"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example above assumes that you’ve defined a "},{"type":"codeVoice","code":"Star"},{"type":"text","text":" view with a"},{"type":"text","text":" "},{"type":"text","text":"parameterized color:"}]},{"code":["struct Star: View {","    var color = Color.yellow","","    var body: some View {","        Image(systemName: \"star.fill\")","            .foregroundStyle(color)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"By setting different ","type":"text"},{"code":"alignment","type":"codeVoice"},{"text":" values for each modifier, you make the","type":"text"},{"text":" ","type":"text"},{"text":"stars appear in different places on the rectangle:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you specify more than one view in the "},{"type":"codeVoice","code":"content"},{"type":"text","text":" closure, the modifier"},{"type":"text","text":" "},{"type":"text","text":"collects all of the views in the closure into an implicit "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true,"type":"reference"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"taking them in order from back to front. For example, you can place a"},{"type":"text","text":" "},{"type":"text","text":"star and a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Circle","isActive":true,"type":"reference"},{"type":"text","text":" on a field of "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/blue","isActive":true,"type":"reference"},{"type":"text","text":":"}]},{"code":["Color.blue","    .frame(width: 200, height: 200)","    .overlay {","        Circle()","            .frame(width: 100, height: 100)","        Star()","    }"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both the overlay modifier and the implicit "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","type":"reference","isActive":true},{"type":"text","text":" composed from the"},{"type":"text","text":" "},{"type":"text","text":"overlay content — the circle and the star — use a default"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center","type":"reference","isActive":true},{"type":"text","text":" alignment. The star appears centered on the circle,"},{"type":"text","text":" "},{"type":"text","text":"and both appear as a composite view centered in front of the square:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"If you specify an alignment for the overlay, it applies to the implicit","type":"text"},{"text":" ","type":"text"},{"text":"stack rather than to the individual views in the closure. You can see","type":"text"},{"text":" ","type":"text"},{"text":"this if you add the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/bottom"},{"text":" alignment:","type":"text"}]},{"code":["Color.blue","    .frame(width: 200, height: 200)","    .overlay(alignment: .bottom) {","        Circle()","            .frame(width: 100, height: 100)","        Star()","    }"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The circle and the star move down as a unit to align the stack’s bottom"},{"type":"text","text":" "},{"type":"text","text":"edge with the bottom edge of the square, while the star remains"},{"type":"text","text":" "},{"type":"text","text":"centered on the circle:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"To control the placement of individual items inside the ","type":"text"},{"code":"content","type":"codeVoice"},{"text":" ","type":"text"},{"text":"closure, either use a different overlay modifier for each item, as the","type":"text"},{"text":" ","type":"text"},{"text":"earlier example of stars in the corners of a rectangle demonstrates, or","type":"text"},{"text":" ","type":"text"},{"text":"add an explicit ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","type":"reference"},{"text":" inside the content closure with its own","type":"text"},{"text":" ","type":"text"},{"text":"alignment:","type":"text"}]},{"code":["Color.blue","    .frame(width: 200, height: 200)","    .overlay(alignment: .bottom) {","        ZStack(alignment: .bottom) {","            Circle()","                .frame(width: 100, height: 100)","            Star()","        }","    }"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The stack alignment ensures that the star’s bottom edge aligns with the"},{"type":"text","text":" "},{"type":"text","text":"circle’s, while the overlay aligns the composite view with the square:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"You can achieve layering without an overlay modifier by putting both the","type":"text"},{"text":" ","type":"text"},{"text":"modified view and the overlay content into a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","type":"reference"},{"text":". This can","type":"text"},{"text":" ","type":"text"},{"text":"produce a simpler view hierarchy, but changes the layout priority that","type":"text"},{"text":" ","type":"text"},{"text":"OpenSwiftUI applies to the views. Use the overlay modifier when you want the","type":"text"},{"text":" ","type":"text"},{"text":"modified view to dominate the layout.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to specify a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle"},{"type":"text","text":" like a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color"},{"type":"text","text":" or a"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Material"},{"type":"text","text":" as the overlay, use"},{"type":"text","text":" "},{"type":"codeVoice","code":"View\/overlay(_:ignoresSafeAreaEdges:)"},{"type":"text","text":" instead. To specify a"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape"},{"type":"text","text":", use "},{"type":"codeVoice","code":"View\/overlay(_:in:fillStyle:)"},{"type":"text","text":"."}]}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Shape":{"abstract":[{"text":"A 2D shape that you can use when drawing a view.","type":"text"}],"url":"\/documentation\/openswiftui\/shape","title":"Shape","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"Shape"}],"type":"topic","navigatorTitle":[{"kind":"identifier","text":"Shape"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Material":{"title":"Material","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Material","kind":"symbol","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Material","kind":"identifier"}],"url":"\/documentation\/openswiftui\/material","role":"symbol","abstract":[{"type":"text","text":"A background material type."}],"navigatorTitle":[{"text":"Material","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/O