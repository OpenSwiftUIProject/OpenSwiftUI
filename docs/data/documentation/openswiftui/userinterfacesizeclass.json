iew","level":2,"type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"You receive a size class value when you read either the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/horizontalSizeClass","isActive":true,"type":"reference"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/verticalSizeClass","isActive":true,"type":"reference"},{"text":" environment value. The value tells","type":"text"},{"text":" ","type":"text"},{"text":"you about the amount of space available to your views in a given","type":"text"},{"text":" ","type":"text"},{"text":"direction. You can read the size class like any other of the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues","isActive":true,"type":"reference"},{"text":", by creating a property with the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Environment","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"property wrapper:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["@Environment(\\.horizontalSizeClass) private var horizontalSizeClass","@Environment(\\.verticalSizeClass) private var verticalSizeClass"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenSwiftUI sets the size class based on several factors, including:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The current device type."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The orientation of the device."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The appearance of Slide Over and Split View on iPad.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"text":"Several built-in views change their behavior