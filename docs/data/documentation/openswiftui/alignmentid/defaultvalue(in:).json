xt":" "},{"type":"text","text":"return a value that’s one-third of the height of the view:"}],"type":"paragraph"},{"code":["private struct FirstThirdAlignment: AlignmentID {","    static func defaultValue(in context: ViewDimensions) -> CGFloat {","        context.height \/ 3","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"You can override the default value that this method returns for a"},{"type":"text","text":" "},{"type":"text","text":"particular guide by adding the"},{"type":"text","text":" "},{"type":"codeVoice","code":"View\/alignmentGuide(_:computeValue:)"},{"type":"text","text":" view modifier to a"},{"type":"text","text":" "},{"type":"text","text":"particular view."}],"type":"paragraph"}]}],"kind":"symbol","abstract":[{"type":"text","text":"Calculates a default value for the corresponding guide in the specified"},{"type":"text","text":" "},{"type":"text","text":"context."}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/AlignmentID":{"title":"AlignmentID","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"AlignmentID"}],"type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID","abstract":[{"type":"text","text":"A type that you use to create custom alignment guides."}],"navigatorTitle":[{"kind":"identifier","text":"AlignmentID"}],"url":"\/documentation\/openswiftui\/alignmentid"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/AlignmentID/defaultValue(in:)":{"required":true,"abstract":[{"type":"text","text":"Calculates a default value for the corresponding guide in the specified"},{"type":"text","text":" "},{"type":"text","text":"context."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID\/defaultValue(in:)","title":"defaultValue(in:)","type":"topic","url":"\/documentation\/openswiftui\/alignmentid\/defaultvalue(in:)","role":"symbol","kind":"symbol","fragments"