{"metadata":{"navigatorTitle":[{"text":"VerticalAlignment","kind":"identifier"}],"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Alignment\/AlignmentGuide.swift#L498","fileName":"AlignmentGuide.swift"},"modules":[{"name":"OpenSwiftUI"}],"title":"VerticalAlignment","externalID":"s:15OpenSwiftUICore17VerticalAlignmentV","symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"VerticalAlignment","kind":"identifier"}],"role":"symbol","roleHeading":"Structure"},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@frozen"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VerticalAlignment"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Overview","anchor":"overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use vertical alignment guides to position views"},{"type":"text","text":" "},{"type":"text","text":"relative to one another vertically, like when you place views side-by-side"},{"type":"text","text":" "},{"type":"text","text":"in an "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","isActive":true,"type":"reference"},{"type":"text","text":" or when you create a row of views in a "},{"code":"Grid","type":"codeVoice"},{"type":"text","text":" using"},{"type":"text","text":" "},{"code":"GridRow","type":"codeVoice"},{"type":"text","text":". The following example demonstrates common built-in"},{"type":"text","text":" "},{"type":"text","text":"vertical alignments:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"You can generate the example above by creating a series of rows","type":"text"},{"text":" ","type":"text"},{"text":"implemented as horizontal stacks, where you configure each stack with a","type":"text"},{"text":" ","type":"text"},{"text":"different alignment guide:","type":"text"}]},{"syntax":"swift","code":["private struct VerticalAlignmentGallery: View {","    var body: some View {","        VStack(spacing: 30) {","            row(alignment: .top, text: \"Top\")","            row(alignment: .center, text: \"Center\")","            row(alignment: .bottom, text: \"Bottom\")","            row(alignment: .firstTextBaseline, text: \"First Text Baseline\")","            row(alignment: .lastTextBaseline, text: \"Last Text Baseline\")","        }","    }","","    private func row(alignment: VerticalAlignment, text: String) -> some View {","        HStack(alignment: alignment, spacing: 0) {","            Color.red.frame(height: 1)","            Text(text).font(.title).border(.gray)","            Color.red.frame(height: 1)","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"During layout, OpenSwiftUI aligns the views inside each stack by bringing"},{"type":"text","text":" "},{"type":"text","text":"together the specified guides of the affected views. OpenSwiftUI calculates"},{"type":"text","text":" "},{"type":"text","text":"the position of a guide for a particular view based on the characteristics"},{"type":"text","text":" "},{"type":"text","text":"of the view. For example, the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/center","type":"reference","isActive":true},{"type":"text","text":" guide appears"},{"type":"text","text":" "},{"type":"text","text":"at half the height of the view. You can override the guide calculation for a"},{"type":"text","text":" "},{"type":"text","text":"particular view using the "},{"type":"codeVoice","code":"View\/alignmentGuide(_:computeValue:)"},{"type":"text","text":" "},{"type":"text","text":"view modifier."}]},{"text":"Text baseline alignment","anchor":"Text-baseline-alignment","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/firstTextBaseline"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/lastTextBaseline"},{"type":"text","text":" guide to match the bottom of either"},{"type":"text","text":" "},{"type":"text","text":"the top- or bottom-most line of text that a view contains, respectively."},{"type":"text","text":" "},{"type":"text","text":"Text baseline alignment excludes the parts of characters that descend"},{"type":"text","text":" "},{"type":"text","text":"below the baseline, like the tail on lower case g and j:"}]},{"syntax":"swift","code":["row(alignment: .firstTextBaseline, text: \"fghijkl\")"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you use a text baseline alignment on a view that contains no text,"},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI applies the equivalent of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/bottom"},{"type":"text","text":" alignment"},{"type":"text","text":" "},{"type":"text","text":"instead. For the row in the example above, OpenSwiftUI matches the bottom of"},{"type":"text","text":" "},{"type":"text","text":"the horizontal lines with the baseline of the text:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Aligning a text view to its baseline rather than to the bottom of its frame"},{"type":"text","text":" "},{"type":"text","text":"produces the best layout effect in many cases, like when creating forms."},{"type":"text","text":" "},{"type":"text","text":"For example, you can align the baseline of descriptive text in"},{"type":"text","text":" "},{"type":"text","text":"one "},{"code":"GridRow","type":"codeVoice"},{"type":"text","text":" cell with the baseline of a text field, or the label"},{"type":"text","text":" "},{"type":"text","text":"of a checkbox, in another cell in the same row."}]},{"text":"Custom alignment guides","anchor":"Custom-alignment-guides","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"You can create a custom vertical alignment guide by first creating a type","type":"text"},{"text":" ","type":"text"},{"text":"that conforms to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID"},{"text":" protocol, and then using that type to","type":"text"},{"text":" ","type":"text"},{"text":"initalize a new static property on ","type":"text"},{"code":"VerticalAlignment","type":"codeVoice"},{"text":":","type":"text"}]},{"syntax":"swift","code":["private struct FirstThirdAlignment: AlignmentID {","    static func defaultValue(in context: ViewDimensions) -> CGFloat {","        context.height \/ 3","    }","}","","extension VerticalAlignment {","    static let firstThird = VerticalAlignment(FirstThirdAlignment.self)","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"You implement the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID\/defaultValue(in:)"},{"text":" method to calculate","type":"text"},{"text":" ","type":"text"},{"text":"a default value for the custom alignment guide. The method receives a","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions"},{"text":" instance that you can use to calculate a","type":"text"},{"text":" ","type":"text"},{"text":"value based on characteristics of the view. The example above places","type":"text"},{"text":" ","type":"text"},{"text":"the guide at one-third of the height of the view as measured from the","type":"text"},{"text":" ","type":"text"},{"text":"view’s origin.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"You can then use the custom alignment guide like any built-in guide. For","type":"text"},{"text":" ","type":"text"},{"text":"example, you can use it as the ","type":"text"},{"code":"alignment","type":"codeVoice"},{"text":" parameter to an ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","isActive":true,"type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or to alter the guide calculation for a specific view using the","type":"text"},{"text":" ","type":"text"},{"code":"View\/alignmentGuide(_:computeValue:)","type":"codeVoice"},{"text":" view modifier.","type":"text"}]},{"text":"Composite alignment","anchor":"Composite-alignment","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Combine a "},{"type":"codeVoice","code":"VerticalAlignment"},{"type":"text","text":" with a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment"},{"type":"text","text":" to create a"},{"type":"text","text":" "},{"type":"text","text":"composite "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment"},{"type":"text","text":" that indicates both vertical and horizontal"},{"type":"text","text":" "},{"type":"text","text":"positioning in one value. For example, you could combine your custom"},{"type":"text","text":" "},{"type":"codeVoice","code":"firstThird"},{"type":"text","text":" vertical alignment from the previous section with a built-in"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/center"},{"type":"text","text":" horizontal alignment to use in a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"type":"text","text":":"}]},{"syntax":"swift","code":["struct LayeredHorizontalStripes: View {","    var body: some View {","        ZStack(alignment: Alignment(horizontal: .center, vertical: .firstThird)) {","            horizontalStripes(color: .blue)","                .frame(width: 180, height: 90)","            horizontalStripes(color: .green)","                .frame(width: 70, height: 60)","        }","    }","","    private func horizontalStripes(color: Color) -> some View {","        VStack(spacing: 1) {","            ForEach(0..<3) { _ in color }","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example above uses widths and heights that generate two mismatched"},{"type":"text","text":" "},{"type":"text","text":"sets of three vertical stripes. The "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true},{"type":"text","text":" centers the two sets"},{"type":"text","text":" "},{"type":"text","text":"horizontally and aligns them vertically one-third from the top"},{"type":"text","text":" "},{"type":"text","text":"of each set. This aligns the bottom edges of the top stripe from each set:"}]},{"type":"paragraph","inlineContent":[]}],"kind":"content"}],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment"},"kind":"symbol","topicSections":[{"anchor":"Getting-guides","title":"Getting guides","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/top","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/center","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/bottom","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/firstTextBaseline","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/lastTextBaseline"]},{"anchor":"Creating-a-custom-alignment","title":"Creating a custom alignment","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/init(_:)"]},{"anchor":"Instance-Methods","title":"Instance Methods","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/combineExplicit(_:)"],"generated":true}],"relationshipsSections":[{"type":"conformsTo","title":"Conforms To","kind":"relationships","identifiers":["doc:\/\/OpenSwiftUI\/s15BitwiseCopyableP","doc:\/\/OpenSwiftUI\/SQ","doc:\/\/OpenSwiftUI\/s8SendableP"]}],"sections":[],"seeAlsoSections":[{"anchor":"Aligning-views","title":"Aligning views","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions"],"generated":true}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/verticalalignment"]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"abstract":[{"type":"text","text":"An alignment position along the vertical axis."}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/VerticalAlignment/firstTextBaseline":{"role":"symbol","kind":"symbol","title":"firstTextBaseline","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"firstTextBaseline","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore17VerticalAlignmentV","text":"VerticalAlignment","kind":"typeIdentifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/firstTextBaseline","abstract":[{"type":"text","text":"A guide that marks the top-most text baseline in a view."}],"type":"topic","url":"\/documentation\/openswiftui\/verticalalignment\/firsttextbaseline"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/AlignmentID/defaultValue(in