ifier":"doc:\/\/OpenSwiftUI\/SQ","type":"unresolvable"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/VerticalAlignment/firstTextBaseline":{"abstract":[{"text":"A guide that marks the top-most text baseline in a view.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/firstTextBaseline","role":"symbol","kind":"symbol","type":"topic","url":"\/documentation\/openswiftui\/verticalalignment\/firsttextbaseline","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"firstTextBaseline","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore17VerticalAlignmentV","text":"VerticalAlignment","kind":"typeIdentifier"}],"title":"firstTextBaseline"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/VerticalAlignment/combineExplicit(_:)":{"url":"\/documentation\/openswiftui\/verticalalignment\/combineexplicit(_:)","kind":"symbol","abstract":[{"type":"text","text":"Merges a sequence of explicit alignment values produced by"},{"type":"text","text":" "},{"type":"text","text":"this instance."}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"combineExplicit"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat"},{"kind":"text","text":"?"}],"type":"topic","title":"combineExplicit(_:)","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/combineExplicit(_:)","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/HorizontalAlignment":{"navigatorTitle":[{"text":"HorizontalAlignment","kind":"identifier"}],"title":"HorizontalAlignment","abstract":[{"type":"text","text":"An alignment position along the horizontal axis."}],"type":"topic","role":"symbol","url":"\/documentation\/openswiftui\/horizontalalignment","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"HorizontalAlignment","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment"},"doc://OpenSwiftUI/s8SendableP":{"title":"Swift.Sendable","type":"unresolvable","identifier":"doc:\/\/OpenSwiftUI\/s8SendableP"}}}