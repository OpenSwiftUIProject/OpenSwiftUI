{"abstract":[{"text":"A view that asynchronously loads and displays an image.","type":"text"}],"kind":"symbol","metadata":{"role":"symbol","roleHeading":"Structure","externalID":"s:11OpenSwiftUI10AsyncImageV","title":"AsyncImage","modules":[{"name":"OpenSwiftUI"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncImage","kind":"identifier"}],"symbolKind":"struct","remoteSource":{"fileName":"AsyncImage.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/Image\/AsyncImage.swift#L77"},"navigatorTitle":[{"text":"AsyncImage","kind":"identifier"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/asyncimage"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"preciseIdentifier":"s:ScM","kind":"attribute","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AsyncImage"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"Content"},{"kind":"text","text":"> "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Content"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"This view uses the shared","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/Foundation\/URLSession","type":"reference"},{"text":" ","type":"text"},{"text":"instance to load an image from the specified URL, and then display it.","type":"text"},{"text":" ","type":"text"},{"text":"For example, you can display an icon that’s stored on a server:","type":"text"}]},{"syntax":"swift","code":["AsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\"))","    .frame(width: 200, height: 200)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Until the image loads, the view displays a standard placeholder that"},{"type":"text","text":" "},{"type":"text","text":"fills the available space. After the load completes successfully, the view"},{"type":"text","text":" "},{"type":"text","text":"updates to display the image. In the example above, the icon is smaller"},{"type":"text","text":" "},{"type":"text","text":"than the frame, and so appears smaller than the placeholder."}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"You can specify a custom placeholder using","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage\/init(url:scale:content:placeholder:)"},{"text":". With this initializer, you can","type":"text"},{"text":" ","type":"text"},{"text":"also use the ","type":"text"},{"type":"codeVoice","code":"content"},{"text":" parameter to manipulate the loaded image.","type":"text"},{"text":" ","type":"text"},{"text":"For example, you can add a modifier to make the loaded image resizable:","type":"text"}]},{"syntax":"swift","code":["AsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\")) { image in","    image.resizable()","} placeholder: {","    ProgressView()","}",".frame(width: 50, height: 50)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For this example, OpenSwiftUI shows a "},{"code":"ProgressView","type":"codeVoice"},{"type":"text","text":" first, and then the"},{"type":"text","text":" "},{"type":"text","text":"image scaled to fit in the specified frame:"}]},{"type":"paragraph","inlineContent":[]},{"content":[{"type":"paragraph","inlineContent":[{"text":"You can’t apply image-specific modifiers, like","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"Image\/resizable(capInsets:resizingMode:)"},{"text":", directly to an ","type":"text"},{"type":"codeVoice","code":"AsyncImage"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Instead, apply them to the ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image","isActive":true},{"text":" instance that your ","type":"text"},{"type":"codeVoice","code":"content"},{"text":" ","type":"text"},{"text":"closure gets when defining the view’s appearance.","type":"text"}]}],"type":"aside","style":"important","name":"Important"},{"type":"paragraph","inlineContent":[{"text":"To gain more control over the loading process, use the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage\/init(url:scale:transaction:content:)","type":"reference"},{"text":" initializer, which takes a","type":"text"},{"text":" ","type":"text"},{"code":"content","type":"codeVoice"},{"text":" closure that receives an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImagePhase","type":"reference"},{"text":" to indicate","type":"text"},{"text":" ","type":"text"},{"text":"the state of the loading operation. Return a view that’s appropriate","type":"text"},{"text":" ","type":"text"},{"text":"for the current phase:","type":"text"}]},{"syntax":"swift","code":["AsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\")) { phase in","    if let image = phase.image {","        image \/\/ Displays the loaded image.","    } else if phase.error != nil {","        Color.red \/\/ Indicates an error.","    } else {","        Color.blue \/\/ Acts as a placeholder.","    }","}"],"type":"codeListing"}]}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OpenSwiftUI\/documentation