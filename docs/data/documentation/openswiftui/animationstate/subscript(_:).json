ate values, ","type":"text"},{"type":"codeVoice","code":"paused"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"pauseTime"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["private struct PausableState<Value: VectorArithmetic>: AnimationStateKey {","    var paused = false","    var pauseTime: TimeInterval = 0.0","","    static var defaultValue: Self { .init() }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Use that key with the subscript operator of the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationState","isActive":true},{"type":"text","text":" "},{"type":"text","text":"structure to get and set a value for the key. For more convenient"},{"type":"text","text":" "},{"type":"text","text":"access to the key value, extend "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationContext","isActive":true},{"type":"text","text":" with a computed"},{"type":"text","text":" "},{"type":"text","text":"property that gets and sets the key’s value."}],"type":"paragraph"},{"code":["extension AnimationContext {","    fileprivate var pausableState: PausableState<Value> {","        get { state[PausableState<Value>.self] }","        set { state[PausableState<Value>.self] = newValue }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"To access the state values in a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/CustomAnimation","isActive":true},{"type":"text","text":", call the custom"},{"type":"text","text":" "},{"type":"text","text":"computed property, then read and write the state values that the"},{"type":"text","text":" "},{"type":"text","text":"custom "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationStateKey","isActive":true},{"type":"text","text":" provides."}],"type":"paragraph"},{"code":["struct PausableA