auseTime"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["private struct PausableState<Value: VectorArithmetic>: AnimationStateKey {","    var paused = false","    var pauseTime: TimeInterval = 0.0","","    static var defaultValue: Self { .init() }","}"]},{"inlineContent":[{"text":"Use that key with the subscript operator of the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationState"},{"text":" ","type":"text"},{"text":"structure to get and set a value for the key. For more convenient","type":"text"},{"text":" ","type":"text"},{"text":"access to the key value, extend ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationContext"},{"text":" with a computed","type":"text"},{"text":" ","type":"text"},{"text":"property that gets and sets the key’s value.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["extension AnimationContext {","    fileprivate var pausableState: PausableState<Value> {","        get { state[PausableState<Value>.self] }","        set { state[PausableState<Value>.self] = newValue }","    }","}"]},{"inlineContent":[{"text":"To access the state values in a ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/CustomAnimation","isActive":true},{"text":", call the custom","type":"text"},{"text":" ","type":"text"},{"text":"computed property, then read and write the state values that the","type":"text"},{"text":" ","type":"text"},{"text":"custom ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationStateKey","isActive":true},{"text":" provides.","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct PausableAnimation: CustomAnimation {","    let base: Animation","","    func animate<V>(value: V, time: TimeInterval, context: inout AnimationContext<V>) -> V? where V : VectorArithmetic {","        let paused = context.environment.animationPaused","","        let pausableState = context.pausableState","        var pauseTime = pausableState.pauseTime","        if pausableState.paused != paused {","            pauseTime = time - pauseTime","            context.pausableState = PausableState(paused: paused, pauseTime: pauseTime)","        }","","        let effectiveTime = paused ? pauseTime : time - pauseTime","        let result = base.animate(value: value, time: effectiveTime, context: &context)","        return result","    }","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/animationstate\/subscript(_:)"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Accesses the state for a custom key."}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/AnimationContext":{"role":"symbol","title":"AnimationContext","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationContext","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"text":"AnimationContext","kind":"identifier"}],"kind":"symbol","type":"topic","abstract":[{"text":"Contextual values that a custom animation can use to manage state and","type":"text"},{"text":" ","type":"text"},{"text":"access a view’s environment.","type":"text"}],"navigatorTitle":[{"text":"AnimationContext","kind":"identifier"}],"url":"\/documentation\/openswiftui\/animationcontext"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/AnimationStateKey/Value":{"title":"Value","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationStateKey\/Value","url":"\/documentation\/openswiftui\/animationstatekey\/value","role":"symbol","kind":"symbol","required":true,"abstract":[{"type":"text","text":"The associated type representing the type of the animation state key’s"},{"type":"text","te