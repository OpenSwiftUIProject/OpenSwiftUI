{"metadata":{"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ProposedViewSize"}],"remoteSource":{"fileName":"Layout.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Layout.swift#L878"},"externalID":"s:15OpenSwiftUICore16ProposedViewSizeV","symbolKind":"struct","title":"ProposedViewSize","role":"symbol","modules":[{"name":"OpenSwiftUI"}],"navigatorTitle":[{"kind":"identifier","text":"ProposedViewSize"}],"roleHeading":"Structure"},"abstract":[{"type":"text","text":"A proposal for the size of a view."}],"topicSections":[{"title":"Initializers","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/init(_:)","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/init(width:height:)"],"anchor":"Initializers","generated":true},{"title":"Instance Properties","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/height","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/width"],"anchor":"Instance-Properties","generated":true},{"title":"Instance Methods","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/replacingUnspecifiedDimensions(by:)"],"anchor":"Instance-Methods","generated":true},{"title":"Type Properties","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/infinity","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/unspecified","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/zero"],"anchor":"Type-Properties","generated":true}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProposedViewSize","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"inlineContent":[{"text":"During layout in OpenSwiftUI, views choose their own size, but they do that","type":"text"},{"text":" ","type":"text"},{"text":"in response to a size proposal from their parent view. When you create","type":"text"},{"text":" ","type":"text"},{"text":"a custom layout using the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout","isActive":true,"type":"reference"},{"text":" protocol, your layout container","type":"text"},{"text":" ","type":"text"},{"text":"participates in this process using ","type":"text"},{"code":"ProposedViewSize","type":"codeVoice"},{"text":" instances.","type":"text"},{"text":" ","type":"text"},{"text":"The layout protocol’s methods take a proposed size input that you","type":"text"},{"text":" ","type":"text"},{"text":"can take into account when arranging views and calculating the size of","type":"text"},{"text":" ","type":"text"},{"text":"the composite container. Similarly, your layout proposes a size to each","type":"text"},{"text":" ","type":"text"},{"text":"of its own subviews when it measures and places them.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Layout containers typically measure their subviews by proposing several"},{"type":"text","text":" "},{"type":"text","text":"sizes and looking at the responses. The container can use this information"},{"type":"text","text":" "},{"type":"text","text":"to decide how to allocate space among its subviews. A"},{"type":"text","text":" "},{"type":"text","text":"layout might try the following special proposals:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/zero","type":"reference"},{"text":" proposal; the view responds with its minimum size.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/infinity"},{"type":"text","text":" proposal; the view responds with its maximum size."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/unspecified"},{"type":"text","text":" proposal; the view responds with its ideal size."}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"A layout might also try special cases for one dimension at a time. For","type":"text"},{"text":" ","type":"text"},{"text":"example, an ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","isActive":true,"type":"reference"},{"text":" might measure the flexibility of its subviews’","type":"text"},{"text":" ","type":"text"},{"text":"widths, while using a fixed value for the height.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OpenSwiftUI\/s15BitwiseCopyableP","doc:\/\/OpenSwiftUI\/SQ","doc:\/\/OpenSwiftUI\/s8SendableP"],"type":"conformsTo","kind":"relationships"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/proposedviewsize"]}],"sections":[],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ProposedViewSize":{"kind":"symbol","role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProposedViewSize","kind":"identifier"}],"navigatorTitle":[{"text":"ProposedViewSize","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/document