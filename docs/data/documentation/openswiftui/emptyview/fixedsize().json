,{"kind":"text","text":" "},{"kind":"identifier","text":"fixedSize"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View"},{"kind":"text","text":"\n"}]}],"kind":"declarations"},{"content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that fixes this view at its ideal size."}]}],"kind":"content"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"During the layout of the view hierarchy, each view proposes a size to"},{"type":"text","text":" "},{"type":"text","text":"each child view it contains. If the child view doesn’t need a fixed size"},{"type":"text","text":" "},{"type":"text","text":"it can accept and conform to the size offered by the parent."}],"type":"paragraph"},{"inlineContent":[{"text":"For example, a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference"},{"text":" view placed in an explicitly sized frame wraps","type":"text"},{"text":" ","type":"text"},{"text":"and truncates its string to remain within its parent’s bounds:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["Text(\"A single line of text, too long to fit in a box.\")","    .frame(width: 200, height: 200)","    .border(Color.gray)"],"type":"codeListing"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"code":"fixedSize()","type":"codeVoice"},{"type":"text","text":" modifier can be used to create a view that maintains"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"emphasis","inlineContent":[{"text":"ideal size","type":"text"}]},{"type":"text","text":" of its children both dimensions:"}],"type":"