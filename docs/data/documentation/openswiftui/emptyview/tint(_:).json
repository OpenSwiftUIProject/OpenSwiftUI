 var body: some View {","        HStack {","            Button {","                \/\/ Answer the call","            } label: {","                Label(\"Answer\", systemImage: \"phone\")","            }","            .tint(.green)","            Button {","                \/\/ Decline the call","            } label: {","                Label(\"Decline\", systemImage: \"phone.down\")","            }","            .tint(.red)","        }","        .buttonStyle(.borderedProminent)","        .padding()","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some controls adapt to the tint color differently based on their style,"},{"type":"text","text":" "},{"type":"text","text":"the current platform, and the surrounding context. For example, in"},{"type":"text","text":" "},{"type":"text","text":"macOS, a button with the "},{"type":"codeVoice","code":"PrimitiveButtonStyle\/bordered"},{"type":"text","text":" style doesn’t"},{"type":"text","text":" "},{"type":"text","text":"tint its background, but one with the"},{"type":"text","text":" "},{"type":"codeVoice","code":"PrimitiveButtonStyle\/borderedProminent"},{"type":"text","text":" style does. In macOS, neither"},{"type":"text","text":" "},{"type":"text","text":"of these button styles tint their label, but they do in other platforms."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/emptyview\/tint(_:)"]}],"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/EmptyView":{"type":"topic","url":"\/documentation\/openswiftui\/emptyview","navigatorTitle":[{"kind":"identifier","text":"EmptyView"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EmptyView","abstract":[{"text":"A view that doesn’t contain any content.","type":"text"}],"title":"EmptyView","role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Empt