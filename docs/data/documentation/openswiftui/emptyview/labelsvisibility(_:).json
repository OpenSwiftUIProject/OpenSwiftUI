cessibility."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"On iOS, a "},{"code":"Picker","type":"codeVoice"},{"type":"text","text":" within a "},{"code":"Menu","type":"codeVoice"},{"type":"text","text":" hides its label by default. You can use"},{"type":"text","text":" "},{"type":"text","text":"this modifier to explicitly show the label in that context:"}],"type":"paragraph"},{"code":["Menu {","    Picker(\"Flavor\", selection: $selectedFlavor) {","        Text(\"Chocolate\").tag(Flavor.chocolate)","        Text(\"Vanilla\").tag(Flavor.vanilla)","        Text(\"Strawberry\").tag(Flavor.strawberry)","    }","    .labelsVisibility(.visible)","}"],"type":"codeListing","syntax":"swift"},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This modifier doesn’t work for all labels. It applies to"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent","type":"reference","isActive":true},{"type":"text","text":" elements, including controls like "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":" and"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference","isActive":true},{"type":"text","text":", but not to controls like a bordered button where the label"},{"type":"text","text":" "},{"type":"text","text":"is inside the button’s border."}]}],"type":"aside"}]}],"kind":"symbol","abstract":[{"type":"text","text":"Controls the visibility of labels of any controls contained within this"},{"type":"text","text":" "},{"type":"text","text":"view."}],"sections":[],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EmptyView"]]},"variants":[{"paths":["\/documentation\/openswiftui\/emptyview\/labelsvisibility(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc:/