/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa"},{"text":", ","kind":"text"},{"text":"cache","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Cache","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Cache","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP5CacheQa"},{"text":") -> ","kind":"text"},{"text":"CGFloat","kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV"},{"text":"?","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","isActive":true,"type":"reference"},{"type":"text","text":" guide that the method calculates"},{"type":"text","text":" "},{"type":"text","text":"the position of."}]}],"name":"guide"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The region that the container view’s parent allocates to the"},{"type":"text","text":" "},{"type":"text","text":"container view, specified in the parent’s coordinate space."}]}],"name":"bounds"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A proposed size for the container.","type":"text"}]}],"name":"proposal"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A collection of proxy instances that represent the","type":"text"},{"text":" ","type":"text"},{"text":"views arranged by the container. You can use the proxies in the","type":"text"},{"text":" ","type":"text"},{"text":"collection to get information about the subviews as you determine","type":"text"},{"text":" ","type":"text"},{"text":"where to place the guide.","type":"text"}]}],"name":"subviews"},{"content":[{"inlineContent":[{"type":"text","text":"Optional storage for calculated data that you can share among"},{"type":"text","text":" "},{"type":"text","text":"the methods of your custom layout container. See"},{"type":"text","text":" "},{"type":"codeVoice","code":"makeCache(subviews:)"},{"type":"text","text":" for details."}],"type":"paragraph"}],"name":"cache"}],"kind":"parameters"},{"content":[{"text":"Return Value","anchor":"return-value","level":2,"type":"heading"},{"inlineContent":[{"text":"The guide’s position relative to the ","type":"text"},{"code":"bounds","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Return ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" to indicate that the guide doesn’t have an explicit","type":"text"},{"text":" ","type":"text"},{"text":"value.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Implement this method to return a value for the specified alignment","type":"text"},{"text":" ","type":"text"},{"text":"guide of a custom layout container. The value you return affects","type":"text"},{"text":" ","type":"text"},{"text":"the placement of the container as a whole, but it doesn’t affect how the","type":"text"},{"text":" ","type":"text"},{"text":"container arranges subviews relative to one another.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can use this method to put an alignment guide in a nonstandard"},{"type":"text","text":" "},{"type":"text","text":"position. For example, you can indent the container’s leading edge"},{"type":"text","text":" "},{"type":"text","text":"alignment guide by 10 points:"}],"type":"paragraph"},{"syntax":"swift","code":["extension BasicVStack {","    func explicitAlignment(","        of guide: HorizontalAlignment,","        in bounds: CGRect,","        proposal: ProposedViewSize,","        subviews: Subviews,","        cache: inout ()","    ) -> CGFloat? {","        if guide == .leading {","            return bounds.minX + 10","        }","        return nil","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The above example returns "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" for other guides to indicate that they"},{"type":"text","text":" "},{"type":"text","text":"don’t have an explicit value. A guide without an explicit value behaves"},{"type":"text","text":" "},{"type":"text","text":"as it would for any other view. If you don’t implement the"},{"type":"text","text":" "},{"type":"text","text":"method, the protocol’s default implementation merges the"},{"type":"text","text":" "},{"type":"text","text":"subviews’ guides."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStackLayout"]]},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/VStackLayout/explicitAlignment(of:in:proposal:subviews:cache:)-10bbm":{"abstract":[{"type":"text","text":"Returns the position of the specified horizontal alignment guide along"},{"type":"text","text":" "},{"type":"text","text":"the x axis."}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"explicitAlignment","kind":"identifier"},{"text":"(","kind":"text"},{"text":"of","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"HorizontalAlignment","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore19HorizontalAlignmentV"},{"text":", ","kind":"text"},{"text":"in","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CGRect","kind":"typeIdentifier","preciseIdentifier":"c:@S@CGRect"},{"text":", ","kind":"text"},{"text":"proposal","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ProposedViewSize","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore16ProposedViewSizeV"},{"text":", ","kind":"text"},{"text":"subviews","kind":"ext