ntentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"monospacedDigit","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":"\n","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"text":"A view whose child views’ fonts use fixed-width numeric","type":"text"},{"text":" ","type":"text"},{"text":"characters, while leaving other characters proportionally spaced.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Using fixed-width digits allows you to easily align numbers of the","type":"text"},{"text":" ","type":"text"},{"text":"same size in a table-like arrangement. This feature is also known as","type":"text"},{"text":" ","type":"text"},{"text":"“tabular figures” or “tabular numbers.”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This modifier only affects numeric characters, and leaves all other"},{"type":"text","text":" "},{"type":"text","text":"characters unchanged."}],"type":"paragraph"},{"inlineContent":[{"text":"The following example shows the effect of ","type":"text"},{"type":"codeVoice","code":"monospacedDigit()"},{"text":" on","type":"text"},{"text":" ","type":"text"},{"text":"multiple child views. The example consists of two ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference"},{"text":" views","type":"text"},{"text":" ","type":"text"},{"text":"inside an ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","type":"reference"},{"text":". Each ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":" contains two ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button","type":"reference"},{"text":" views, with","type":"text"},{"text":" ","type":"text"},{"text":"the second ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":" applying the ","type":"text"},{"type":"codeVoice","code":"monospacedDigit()"},{"text":" modifier to its","type":"text"},{"text":" ","type":"text"},{"text":"contents. As a result, the digits in the buttons in the trailing","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":" are the same width, which in turn gives the buttons equal widths.","type":"text"}],"type":"paragraph"},{"code":["var body: some View {","    HStack(alignment: .top) {","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        .monospacedDigit()","    }","    .padding()","    .navigationTitle(\"monospacedDigit() Child Views\")","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"If a child view’s base font doesn’t support fixed-width digits, the font","type":"text"},{"text":" ","type":"text"},{"text":"remains unchanged.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/HStack":{"type":"topic","navigatorTitle":[{"text":"HStack","kind":"identifier"}],"title":"HStack","url":"\/documentation\/openswiftui\/hstack","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","abstract":[{"text":"A view that arr