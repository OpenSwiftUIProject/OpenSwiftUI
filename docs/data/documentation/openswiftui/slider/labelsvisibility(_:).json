xt"},{"text":" ","type":"text"},{"text":"element in the available space, while it centers the second toggle’s","type":"text"},{"text":" ","type":"text"},{"text":"combined label and control element:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always provide a label for controls, even when you hide the label,"},{"type":"text","text":" "},{"type":"text","text":"because OpenSwiftUI uses labels for other purposes, including accessibility."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On iOS, a "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":" within a "},{"type":"codeVoice","code":"Menu"},{"type":"text","text":" hides its label by default. You can use"},{"type":"text","text":" "},{"type":"text","text":"this modifier to explicitly show the label in that context:"}]},{"type":"codeListing","syntax":"swift","code":["Menu {","    Picker(\"Flavor\", selection: $selectedFlavor) {","        Text(\"Chocolate\").tag(Flavor.chocolate)","        Text(\"Vanilla\").tag(Flavor.vanilla)","        Text(\"Strawberry\").tag(Flavor.strawberry)","    }","    .labelsVisibility(.visible)","}"]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This modifier doesn’t work for all labels. It applies to"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent"},{"type":"text","text":" elements, including controls like "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle"},{"type":"text","text":", but not to controls like a bordered button where the label"},{"type":"text","text":" "},{"type":"text","text":"is inside the button’s border."}]}],"name":"Note"}],"kind":"content"}],"references":{"doc://OpenSwiftUI/doc