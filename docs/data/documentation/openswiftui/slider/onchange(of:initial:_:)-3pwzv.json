d task."}]},{"type":"paragraph","inlineContent":[{"text":"When the value changes, the new version of the closure will be called,","type":"text"},{"text":" ","type":"text"},{"text":"so any captured values will have their values from the time that the","type":"text"},{"text":" ","type":"text"},{"text":"observed value has its new value. The old and new observed values are","type":"text"},{"text":" ","type":"text"},{"text":"passed into the closure. In the following code example, ","type":"text"},{"code":"PlayerView","type":"codeVoice"},{"text":" ","type":"text"},{"text":"passes both the old and new values to the model.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct PlayerView: View {","    var episode: Episode","    @State private var playState: PlayState = .paused","","    var body: some View {","        VStack {","            Text(episode.title)","            Text(episode.showTitle)","            PlayButton(playState: $playState)","        }","        .onChange(of: playState) { oldState, newState in","            model.playStateDidChange(from: oldState, to: newState)","        }","    }","}"]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/slider\/onchange(of:initial:_:)-3pwzv"]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider"]]},"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Slider":{"kind":"symbol","navigatorTitle":[{"text":"Slider","kind":"identifier"}],"url":"\/documentation\/openswiftui\/slider","type":"topic","role":"symbol","abstract":[{"type":"text","text":"A control for selecting a value from a bounded linear range of values."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider","title":"Slider","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Slider","kind":"identifier"}]},"doc://OpenSwiftUI/documentati