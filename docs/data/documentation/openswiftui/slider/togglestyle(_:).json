ive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle"},{"type":"text","text":" instance to set a style that defines"},{"type":"text","text":" "},{"type":"text","text":"the control’s appearance and behavior. For example, you can choose"},{"type":"text","text":" "},{"type":"text","text":"the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch"},{"type":"text","text":" style:"}]},{"code":["Toggle(\"Vibrate on Ring\", isOn: $vibrateOnRing)","    .toggleStyle(.switch)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Built-in styles typically have a similar appearance across platforms,"},{"type":"text","text":" "},{"type":"text","text":"tailored to the platform’s overall style:"}]},{"rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Appearance","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iOS, iPadOS"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]]],"type":"table","header":"row"},{"anchor":"Styling-toggles-in-a-hierarchy","type":"heading","level":3,"text":"Styling toggles in a hierarchy"},{"type":"paragraph","inlineContent":[{"text":"You can set a style for all toggle instances within a view hierarchy","type":"text"},{"text":" ","type":"text"},{"text":"by applying the style modifier to a container view. For example, you","type":"text"},{"text":" ","type":"text"},{"text":"can apply the ","type":"text"},{"code":"ToggleStyle\/button","type":"codeVoice"},{"text":" style to an ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","isActive":true,"type":"reference"},{"text":":","type":"text"}]},{"code":["HStack {","    Toggle(isOn: $isFlagged) {","        Label(\"Flag\", systemImage: \"flag.fill\")","    }","    Toggle(isOn: $isMuted) {","        Label(\"Mute\", systemImage: \"speaker.slash.fill\")","    }","}",".toggleStyle(.button)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example above has the following appearance when "},{"code":"isFlagged","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"code":"true","type":"codeVoice"},{"type":"text","text":" and "},{"code":"isMuted","type":"codeVoice"},{"type":"text","text":" is "},{"code":"false","type":"codeVoice"},{"type":"text","text":":"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Platform"}]}],[{"type":"paragraph","inlineContent":[{"text":"Appearance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS, iPadOS"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS"}]}],[{"type":"paragraph","inlineContent":[]}]]],"type":"table","header":"row"},{"anchor":"Automatic-styling","type":"heading","level":3,"text":"Automatic styling"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you don’t set a style, OpenSwiftUI assumes a value of"},{"type":"text","text":" "},{"type":"codeVoice","code":"ToggleStyle\/automatic"},{"type":"text","text":", which corresponds to a context-specific"},{"type":"text","text":" "},{"type":"text","text":"default. Specify the automatic style explicitly to override a"},{"type":"text","text":" "},{"type":"text","text":"container’s style and revert to the default:"}]},{"code":["HStack {","    Toggle(isOn: $isShuffling) {","        Label(\"Shuffle\", systemImage: \"shuffle\")","    }","    Toggle(isOn: $isRepeating) {","        Label(\"Repeat\", systemImage: \"repeat\")","    }","","    Divider()","","    Toggle(\"Enhance Sound\", isOn: $isEnhanced)","        .toggleStyle(.automatic) \/\/ Revert to the default style.","}",".toggleStyle(.button) \/\/ Use button style for toggles in the stack.",".labelStyle(.iconOnly) \/\/ Omit the title from any labels."],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The style that OpenSwiftUI uses as the default depends on both the platform"},{"type":"text","text":" "},{"type":"text","text":"and the context. In macOS, the default in most contexts is a"},{"type":"text","text":" "},{"type":"codeVoice","code":"ToggleStyle\/checkbox"},{"type":"text","text":", while in iOS, the default toggle style is a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true},{"type":"text","text":":"}]},{"rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Appearance","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iOS, iPadOS"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"macOS","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]]],"type":"table","header":"row"},{"content":[{"inlineContent":[{"type":"text","text":"Like toggle style does for toggles, the "},{"type":"codeVoice","code":"View\/labelStyle(_:)"},{"type":"text","text":" "},{"type":"text","text":"modifier sets the style for "},{"type":"codeVoice","code":"Label"},{"type":"text","text":" instances in the hierarchy. The"},{"type":"text","text":" "},{"type":"text","text":"example above demostrates the compact "},{"type":"codeVoice","code":"LabelStyle\/iconOnly"},{"type":"text","text":" style,"},{"type":"text","text":" "},{"type":"text","text":"which is useful for button toggles in space-constrained contexts."},{"type":"text","text":" "},{"type":"text","text":"Always include a descriptive title for better accessibility."}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"type":"paragraph","inlin