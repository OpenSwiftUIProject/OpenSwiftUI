r":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lFQO1Sqd__mfp"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"ToggleStyle","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle","preciseIdentifier":"s:11OpenSwiftUI11ToggleStyleP"},{"text":"\n","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"name":"style","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The toggle style to set. Use one of the built-in"},{"type":"text","text":" "},{"type":"text","text":"values, like "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch"},{"type":"text","text":" or "},{"code":"ToggleStyle\/button","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or a custom style that you define by creating a type that conforms"},{"type":"text","text":" "},{"type":"text","text":"to the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle"},{"type":"text","text":" protocol."}]}]}]},{"kind":"content","content":[{"anchor":"return-value","level":2,"text":"Return Value","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that uses the specified toggle style for itself"},{"type":"text","text":" "},{"type":"text","text":"and its child views."}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Use this modifier on a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true,"type":"reference"},{"text":" instance to set a style that defines","type":"text"},{"text":" ","type":"text"},{"text":"the control’s appearance and behavior. For example, you can choose","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true,"type":"reference"},{"text":" style:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["Toggle(\"Vibrate on Ring\", isOn: $vibrateOnRing)","    .toggleStyle(.switch)"],"type":"codeListing"},{"inlineContent":[{"text":"Built-in styles typically have a similar appearance across platforms,","type":"text"},{"text":" ","type":"text"},{"text":"tailored to the platform’s overall style:","type":"text"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Appearance"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"iOS, iPadOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]]},{"type":"heading","text":"Styling toggles in a hierarchy","level":3,"anchor":"Styling-toggles-in-a-hierarchy"},{"inlineContent":[{"text":"You can set a style for all toggle instances within a view hierarchy","type":"text"},{"text":" ","type":"text"},{"text":"by applying the style modifier to a container view. For example, you","type":"text"},{"text":" ","type":"text"},{"text":"can apply the ","type":"text"},{"type":"codeVoice","code":"ToggleStyle\/button"},{"text":" style to an ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["HStack {","    Toggle(isOn: $isFlagged) {","        Label(\"Flag\", systemImage: \"flag.fill\")","    }","    Toggle(isOn: $isMuted) {","        Label(\"Mute\", systemImage: \"speaker.slash.fill\")","    }","}",".toggleStyle(.button)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The example above has the following appearance when "},{"type":"codeVoice","code":"isFlagged"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"codeVoice","code":"true"},{"type":"text","text":" and "},{"type":"codeVoice","code":"isMuted"},{"type":"text","text":" is "},{"type":"codeVoice","code":"false"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Appearance"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"iOS, iPadOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]]},{"type":"heading","text":"Automatic styling","level":3,"anchor":"Automatic-styling"},{"inlineContent":[{"type":"text","text":"If you don’t set a style, OpenSwiftUI assumes a value of"},{"type":"text","text":" "},{"type":"codeVoice","code":"ToggleStyle\/automatic"},{"type":"text","text":", which corresponds to a context-specific"},{"type":"text","text":" "},{"type":"text","text":"default. Specify the automatic style explicitly to override a"},{"type":"text","text":" "},{"type":"text","text":"container’s style and revert to the default:"}],"type":"paragraph"},{"syntax":"swift","code":["HStack {","    Toggle(isOn: $isShuffling) {","        Label(\"Shuffle\", systemImage: \"shuffle\")","    }","    Toggle(isOn: $isRepeating) {","        Label(\"Repeat\", systemImage: \"repeat\")","    }","","    Divider()","","    Toggle(\"Enhance Sound\", isOn: $isEnhanced)","        .toggleStyle(.automatic) \/\/ Revert to the default style.","}",".toggleStyle(.button) \/\/ Use button style for toggles in the stack.",".labelStyle(.iconOnly) \/\/ Omit the title from any labels."],"type":"codeListing"},{"inlineContent":[{"text":"The style that OpenSwiftUI uses as the default depends on both the platform","type":"text"},{"text":" ","type":"text"},{"text":"and the context. In macOS, the default in most contexts is a","type":"text"},{"text":" ","type":"text"},{"code":"ToggleStyle\/checkbox","type":"codeVoice"},{"text":", while in iOS, the default toggle style is a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Platform"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Appearance"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS, iPadOS"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]]},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"Like toggle style does for toggles, the "},{"type":"codeVoice","code":"View\/labelStyle(_:)"},{"type":"text","text":" "},{"type":"text","text":"modifier sets the style for "},{"type":"codeVoice","code":"Label"},{"type":"text","text":" instances in the hierarchy. The"},{"type":"text","text":" "},{"type":"text","text":"example above demostrates the compact "},{"type":"codeVoice","code":"LabelStyle\/iconOnly"},{"type":"text","text":" style,"},{"type":"text","text":" "},{"type":"text","text":"which is useful for button toggles in space-constrained contexts."},{"type":"text","text":" "},{"type":"text","text":"Always include a descriptive title for better accessibility."}],"type":"paragraph"}]},{"inlineContent":[{"text":"For more information about how OpenSwiftUI chooses a default toggle style,","type":"text"},{"text":" ","type":"text"},{"text":"see the ","type":"text"},{"code":"ToggleStyle\/automatic","type":"codeVoice"},{"text":" style.","type":"text"}],"type":"paragraph"}]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider\/toggleStyle(_:)","interfaceLanguage":"swift"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Slider":{"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Slider","kind":"identifier"}],"title":"Slider","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Slider","abstract":[{"type":"text","text":"A control for selecting a value from a bounded linear range of values."}],"type":"topic","url":"\/documentation\/openswiftui\/slider","navigatorTitle":[{"text":"Slider","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Toggle":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","url":"\/documentation\/openswiftui\/toggle","navigatorTitle":[{"kind":"identifier","text":"Toggle"}],"type":"topic","abstract":[],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Toggle"}],"role":"symbol","kind":"symbol","title":"Toggle"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftui\/view","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"type":"topic","title":"View","abstract":[{"type":"text","text":"A type that represents part of your app’s user interf