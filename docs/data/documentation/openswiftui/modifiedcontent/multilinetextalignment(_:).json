guage":"swift"}],"paths":["\/documentation\/openswiftui\/modifiedcontent\/multilinetextalignment(_:)"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"multilineTextAlignment","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"alignment","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore13TextAlignmentO","text":"TextAlignment","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TextAlignment"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":"\n","kind":"text"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"alignment","content":[{"inlineContent":[{"text":"A value that you use to align multiple lines of","type":"text"},{"text":" ","type":"text"},{"text":"text within a view.","type":"text"}],"type":"paragraph"}]}]},{"content":[{"text":"Return Value","anchor":"return-value","level":2,"type":"heading"},{"inlineContent":[{"text":"A view that aligns the lines of multiline ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"text":" instances","type":"text"},{"text":" ","type":"text"},{"text":"it contains.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Use this modifier to set an alignment for a multiline block of text."},{"type":"text","text":" "},{"type":"text","text":"For example, the modifier centers the contents of the following"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference"},{"type":"text","text":" view:"}],"type":"paragraph"},{"syntax":"swift","code":["Text(\"This is a block of text that shows up in a text element as multiple lines.\\(\"\\n\") Here we have chosen to center this text.\")","    .frame(width: 200)","    .multilineTextAlignment(.center)"],"type":"codeListing"},{"inlineContent":[{"text":"The text in the above example spans more than one line because:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The newline character introduces a line break."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The frame modifier limits the space available to the text view, and"},{"type":"text","text":" "},{"type":"text","text":"by default a text view wraps lines that don’t fit in the available"},{"type":"text","text":" "},{"type":"text","text":"width. As a result, the text before the explicit line break wraps to"},{"type":"text","text":" "},{"type":"text","text":"three lines, and the text after uses two lines."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The modifier applies the alignment to the all the lines of text in"},{"type":"text","text":" "},{"type":"text","text":"the view, regardless of why wrapping occurs:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"The modifier has no effect on a ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"text":" view that contains only one","type":"text"},{"text":" ","type":"text"},{"text":"line of text, because a text view has a width that exactly matches the","type":"text"},{"text":" ","type":"text"},{"text":"width of its widest line. If you want to align an entire text view","type":"text"},{"text":" ","type":"text"},{"text":"rather than its contents, set the aligment of its container, like a","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true},{"text":" or a frame that you create with the","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/frame(minWidth:idealWidth:maxWidth:minHeight:idealHeight:maxHeight:alignment:)","isActive":true},{"text":" ","type":"text"},{"text":"modifier.","type":"text"}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use this modifier to control the alignment of a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" "},{"type":"text","text":"view that you create with the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/init(_:style:)","isActive":true},{"type":"text","text":" initializer"},{"type":"text","text":" "},{"type":"text","text":"to display localized dates and times, including when the view uses"},{"type":"text","text":" "},{"type":"text","text":"only a single line, but only when that view appears in a widget."}]}],"name":"Note","style":"note","type":"aside"},{"inlineContent":[{"text":"The modifier also affects the content alignment of other text container","type":"text"},{"text":" ","type":"text"},{"text":"types, like ","type":"text"},{"type":"codeVoice","code":"TextEditor"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"TextField"},{"text":". In those cases, the","type":"text"},{"text":" ","type":"text"},{"text":"modifier sets the alignment even when the view contains only a single","type":"text"},{"text":" ","type":"text"},{"text":"line because view’s width isn’t dictated by the width of the text it","type":"text"},{"text":" ","type":"text"},{"text":"contains.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The modifier operates by setting the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/multilineTextAlignment","type":"reference"},{"text":" value in the environment,","type":"text"},{"text":" ","type":"text"},{"text":"so it affects all the text containers in the modified view hierarchy.","type":"text"},{"text":" ","type":"text"},{"text":"For example, you can apply the modifier to a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference"},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"configure all the text views inside the stack.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Text/init(_:style:)":{"url":"\/documentation\/openswiftui\/text\/init(_:style:)","abstract":[],"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Date","kind":"typeIdentifier","preciseIdentifier":"s:10Foundation4DateV"},{"text":", ","kind":"text"},{"text":"style","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Text","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4TextV"},{"text":".","kind":"text"},{"text":"DateStyle","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4TextV9DateStyleV"},{"text":")","kind":"text"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/init(_:style:)","type":"topic","title":"init(_:style:)"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and prov