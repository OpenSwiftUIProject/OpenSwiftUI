major":0,"patch":0},"abstract":[{"type":"text","text":"Adds a modifier for this view that fires an action when a specific"},{"type":"text","text":" "},{"type":"text","text":"value changes."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ModifiedContent\/onChange(of:initial:_:)-sgbs"},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"onChange"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"externalParam","text":"of"},{"kind":"text","text":" "},{"kind":"internalParam","text":"value"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":", "},{"kind":"externalParam","text":"initial"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":" = false, "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"action"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:SQ","kind":"typeIdentifier","text":"Equatable"},{"kind":"text","text":"\n"}],"languages":["swift"]}]},{"parameters":[{"name":"value","content":[{"inlineContent":[{"type":"text","text":"The value to check against when determining whether"},{"type":"text","text":" "},{"type":"text","text":"to run the closure."}],"type":"paragraph"}]},{"name":"initial","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether the action should be run when this view initially"},{"type":"text","text":" "},{"type":"text","text":"appears."}]}]},{"name":"action","content":[{"inlineContent":[{"type":"text","text":"A closure to run when the value changes."}],"type":"paragraph"}]},{"name":"oldValue","content":[{"inlineContent":[{"type":"text","text":"The old value that failed the comparison check (or the"},{"type":"text","text":" "},{"type":"text","text":"initial value when requested)."}],"type":"paragraph"}]},{"name":"newValue","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The new value that failed the comparison check."}]}]}],"kind":"parameters"},{"content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"text":"A view that fires an action when the specified value changes.","type":"text"}]}],"kind":"content"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"You can use ","type":"text"},{"type":"codeVoice","code":"onChange"},{"text":" to trigger a side effect as the result of a","type":"text"},{"text":" ","type":"text"},{"text":"value changing, such as an ","type":"text"},{"type":"codeVoice","code":"Environment"},{"text":" key or a ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The system may call the action closure on the main actor, so avoid","type":"text"},{"text":" ","type":"text"},{"text":"long-running tasks in the closure. If you need to perform such tasks,","type":"text"},{"text":" ","type":"text"},{"text":"detach an asynchronous background task.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When the value changes, the new version of the closure will be called,","type":"text"},{"text":" ","type":"text"},{"text":"so any captured values will have their values from the time that the","type":"text"},{"text":" ","type":"text"},{"text":"observed value has its new value. The old and new observed values are","type":"text"},{"text":" ","type":"text"},{"text":"passed into the closure. In the following code example, ","type":"text"},{"code":"PlayerView","type":"codeVoice"},{"text":" ","type":"text"},{"text":"passes both the old and new values to the model.","type":"text"}],"type":"paragraph"},{"code":["struct PlayerView: View {","    var episode: Episode","    @State private var playState: PlayState = .paused","","    var body: some View {","        VStack {","            Text(episode.title)","            Text(episode.showTitle)","            PlayButton(playState: $playState)","        }","        .onChange(of: playState) { oldState, newState in","            model.playStateDidChange(from: oldState, to: newState)","        }","    }","}"],"syntax":"swift","type":"codeListing"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/openswiftui\/modifiedcontent\/onchange(of:initial:_:)-sgbs"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ModifiedContent"]]},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftui\/view","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"type":"topic","title":"View","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ModifiedContent/onChange(of:initial:_:)-sgbs":{"type":"topic","role":"symbol","url":"\/documentation\/openswiftui\/modifiedcontent\/onchange(of:initial:_:)-sgbs","title":"onChange(of:initial:_:)","abstract":[{"text":"Adds a modifier for this view that fires an action when a specific","type":"text"},{"text":" ","type":"text"},{"text":"value changes.","type":"text"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"onChange","kind":"identifier"},{"text":"<","kind":"text"},{"text":"V","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"of","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"V","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"initial","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":", (","kind":"text"},{"text":"V","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"V","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ModifiedContent\/onChange(of:initial:_:)-sgbs"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ModifiedContent":{"title":"ModifiedContent","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ModifiedContent","url":"\/documentation\/openswiftui\/modifiedcontent","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ModifiedContent"}],"navigatorTitle":[{"kind":"identifier","text":"ModifiedContent"}],"abstract":[{"type":"text","text":"A value with a modifier applied to it."}]}}}