ion\/OpenSwiftUI\/ModifiedContent\/task(priority:_:)","interfaceLanguage":"swift"},"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"task"},{"kind":"text","text":"("},{"kind":"externalParam","text":"priority"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:ScP","text":"TaskPriority"},{"kind":"text","text":" = .userInitiated, "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"action"},{"kind":"text","text":": "},{"kind":"attribute","text":"@escaping"},{"kind":"text","text":" () "},{"kind":"keyword","text":"async"},{"kind":"text","text":" -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:s4Voida","text":"Void"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"},{"kind":"text","text":"\n"}]}],"kind":"declarations"},{"parameters":[{"name":"priority","content":[{"inlineContent":[{"text":"The task priority to use when creating the asynchronous","type":"text"},{"text":" ","type":"text"},{"text":"task. The default priority is","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/taskpriority\/userinitiated","type":"reference"},{"text":",","type":"text"}],"type":"paragraph"}]},{"name":"action","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure that OpenSwiftUI calls as an asynchronous task"},{"type":"text","text":" "},{"type":"text","text":"before the view appears. OpenSwiftUI will automatically cancel the task"},{"type":"text","text":" "},{"type":"text","text":"at some point after the view disappears before the action completes."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"return-value","text":"Return Value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"A view that runs the specified action asynchronously before","type":"text"},{"text":" ","type":"text"},{"text":"the view appears.","type":"text"}]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to perform an asynchronous task with a lifetime that"},{"type":"text","text":" "},{"type":"text","text":"matches that of the modified view. If the task doesn’t finish"},{"type":"text","text":" "},{"type":"text","text":"before OpenSwiftUI removes the view or the view changes identity, OpenSwiftUI"},{"type":"text","text":" "},{"type":"text","text":"cancels the task."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the "},{"type":"codeVoice","code":"await"},{"type":"text","text":" keyword inside the task to"},{"type":"text","text":" "},{"type":"text","text":"wait for an asynchronous call to complete, or to wait on the values of"},{"type":"text","text":" "},{"type":"text","text":"an "},{"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/asyncsequence","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"instance. For example, you can modify a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"type":"text","text":" view to start a task"},{"type":"text","text":" "},{"type":"text","text":"that loads content from a remote resource:"}]},{"type":"codeListing","syntax":"swift","code":["let url = URL(string: \"https:\/\/example.com\")!","@State private var message = \"Loading...\"","","var body: some View {","    Text(message)","        .task {","            do {","                var receivedLines = [String]()","                for try await line in url.lines {","                    receivedLines.append(line)","                    message = \"Received \\(receivedLines.count) lines\"","                }","            } catch {","                message = \"Failed to load\"","            }","        }","}"]},{"type":"paragraph","inlineContent":[{"text":"This example uses the","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url\/3767315-lines","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"method to get the content stored at the specified","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url","type":"reference","isActive":true},{"text":" as an","type":"text"},{"text":" ","type":"text"},{"text":"asynchronous sequence of strings. When each new line arrives, the body","type":"text"},{"text":" ","type":"text"},{"text":"of the ","type":"text"},{"code":"for","type":"codeVoice"},{"text":"-","type":"text"},{"code":"await","type":"codeVoice"},{"text":"-","type":"text"},{"code":"in","type":"codeVoice"},{"text":" loop stores the line in an array of strings","type":"text"},{"text":" ","type":"text"},{"text":"and updates the content of the text view to report the latest line","type":"text"},{"text":" ","type":"text"},{"text":"count.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/modifiedcontent\/task(priority:_:)"]}],"references":{"https://developer.apple.com/documentation/swift/asyncsequence":{"type":"link","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/asyncsequence","title":"AsyncSequence","url":"https:\/\/developer.apple.com\/documentation\/swift\/asyncsequence","titleInlineContent":[{"type":"text","text":"AsyncSequence"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui