lineContent":[{"text":"A view that fixes this view at its ideal size.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"During the layout of the view hierarchy, each view proposes a size to"},{"type":"text","text":" "},{"type":"text","text":"each child view it contains. If the child view doesn’t need a fixed size"},{"type":"text","text":" "},{"type":"text","text":"it can accept and conform to the size offered by the parent."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" view placed in an explicitly sized frame wraps"},{"type":"text","text":" "},{"type":"text","text":"and truncates its string to remain within its parent’s bounds:"}]},{"type":"codeListing","syntax":"swift","code":["Text(\"A single line of text, too long to fit in a box.\")","    .frame(width: 200, height: 200)","    .border(Color.gray)"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" modifier can be used to create a view that maintains"},{"type":"text","text":" "},{"type":"text","text":"the "},{"inlineContent":[{"text":"ideal size","type":"text"}],"type":"emphasis"},{"type":"text","text":" of its children both dimensions:"}]},{"type":"codeListing","syntax":"swift","code":["Text(\"A single line of text, too long to fit in a box.\")","    .fixedSize()","    .frame(width: 200, height: 200)","    .border(Color.gray)"]},{"type":"paragraph","inlineContent":[{"text":"This can result in the view exceeding the parent’s bounds, which may or","type":"text"},{"text":" ","type":"text"},{"text":"may not be the effect you want.","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can think of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" as the creation of a "},{"inlineContent":[{"text":"counter proposal","type":"text"}],"type":"emphasis"},{"type":"text","text":" "},{"type":"text","text":"to the view size proposed to a view by its parent. The ideal size of a"},{"type":"text","text":" "},{"type":"text","text":"view, and the specific effects of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" depends on the"},{"type":"text","text":" "},{"type":"text","text":"particular view and how you have configured it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a view that fixes the view’s size in either the horizontal or"},{"type":"text","text":" "},{"type":"text","text":"vertical dimensions, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)"},{"type":"text","text":"."}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/openswiftui\/modifiedcontent\/fixedsize()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ModifiedContent\/fixedSize()"},"abstract":[{"type":"text","text":"Fixes this view at its ideal size."}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ModifiedContent"]]},"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ModifiedContent":{"abstract":[{"text":"A value with a modifier applied to it.","type":"text"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ModifiedContent","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ModifiedContent","type":"topic","role":"symbol","navigatorTitle":[{"text":"ModifiedContent","kind":"identifie