ation\/openswiftui\/modifiedcontent\/geometrygroup()","title":"geometryGroup()","kind":"symbol","abstract":[{"type":"text","text":"Isolates the geometry (e.g. position and size) of the view"},{"type":"text","text":" "},{"type":"text","text":"from its parent view."}],"role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ModifiedContent":{"title":"ModifiedContent","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ModifiedContent","url":"\/documentation\/openswiftui\/modifiedcontent","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ModifiedContent"}],"navigatorTitle":[{"kind":"identifier","text":"ModifiedContent"}],"abstract":[{"type":"text","text":"A value with a modifier applied to it."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"}}}