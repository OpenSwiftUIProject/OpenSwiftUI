 colors, respectively.","type":"text"}],"type":"paragraph"},{"code":["struct ControlTint: View {","    var body: some View {","        HStack {","            Button {","                \/\/ Answer the call","            } label: {","                Label(\"Answer\", systemImage: \"phone\")","            }","            .tint(.green)","            Button {","                \/\/ Decline the call","            } label: {","                Label(\"Decline\", systemImage: \"phone.down\")","            }","            .tint(.red)","        }","        .buttonStyle(.borderedProminent)","        .padding()","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some controls adapt to the tint color differently based on their style,"},{"type":"text","text":" "},{"type":"text","text":"the current platform, and the surrounding context. For example, in"},{"type":"text","text":" "},{"type":"text","text":"macOS, a button with the "},{"code":"PrimitiveButtonStyle\/bordered","type":"codeVoice"},{"type":"text","text":" style doesn’t"},{"type":"text","text":" "},{"type":"text","text":"tint its background, but one with the"},{"type":"text","text":" "},{"code":"PrimitiveButtonStyle\/borderedProminent","type":"codeVoice"},{"type":"text","text":" style does. In macOS, neither"},{"type":"text","text":" "},{"type":"text","text":"of these button styles tint their label, but they do in other platforms."}]}],"kind":"content"}],"schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftui\/view","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"type":"topic","title":"View","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"fragments":[{"text":"protocol","kind":"k