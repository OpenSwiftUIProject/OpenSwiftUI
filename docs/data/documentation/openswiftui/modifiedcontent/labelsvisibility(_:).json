{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ModifiedContent\/labelsVisibility(_:)"},"sections":[],"variants":[{"paths":["\/documentation\/openswiftui\/modifiedcontent\/labelsvisibility(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ModifiedContent"]]},"kind":"symbol","abstract":[{"type":"text","text":"Controls the visibility of labels of any controls contained within this"},{"type":"text","text":" "},{"type":"text","text":"view."}],"schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"labelsVisibility","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"visibility","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore10VisibilityO","text":"Visibility","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Visibility"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":"\n","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Use this modifier when you want to omit a label from one or more","type":"text"},{"text":" ","type":"text"},{"text":"labeled content in your user interface. For example, the first ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"in the following example hides its label:","type":"text"}]},{"code":["VStack {","    Toggle(isOn: $toggle1) {","        Text(\"Toggle 1\")","    }","    .labelsVisibility(.hidden)","","    Toggle(isOn: $toggle2) {","        Text(\"Toggle 2\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference","isActive":true},{"type":"text","text":" in the example above centers the first toggle’s control"},{"type":"text","text":" "},{"type":"text","text":"element in the available space, while it centers the second toggle’s"},{"type":"text","text":" "},{"type":"text","text":"combined label and control element:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always provide a label for controls, even when you hide the label,"},{"type":"text","text":" "},{"type":"text","text":"because OpenSwiftUI uses labels for other purposes, including accessibility."}]},{"type":"paragraph","inlineContent":[{"text":"On iOS, a ","type":"text"},{"code":"Picker","type":"codeVoice"},{"text":" within a ","type":"text"},{"code":"Menu","type":"codeVoice"},{"text":" hides its label by default. You can use","type":"text"},{"text":" ","type":"text"},{"text":"this modifier to explicitly show the label in that context:","type":"text"}]},{"code":["Menu {","    Picker(\"Flavor\", selection: $selectedFlavor) {","        Text(\"Chocolate\").tag(Flavor.chocolate)","        Text(\"Vanilla\").tag(Flavor.vanilla)","        Text(\"Strawberry\").tag(Flavor.strawberry)","    }","    .labelsVisibility(.visible)","}"],"type":"codeListing","syntax":"swift"},{"style":"note","name":"Note","type":"aside","content":[{"inlineContent":[{"type":"text","text":"This modifier doesn’t work for all labels. It applies to"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent","isActive":true,"type":"reference"},{"type":"text","text":" elements, including controls like "},{"code":"Picker","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true,"type":"reference"},{"type":"text","text":", but not to controls like a bordered button where the label"},{"type":"text","text":" "},{"type":"text","text":"is inside the button’s border."}],"type":"paragraph"}]}],"kind":"content"}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"labelsVisibility"},{"kind":"text","text":"("},{"preciseIdentifier":"s:15OpenSwiftUICore10VisibilityO","kind":"typeIdentifier","text":"Visibility"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"}],"remoteSource":{"fileName":"LabelVisibility.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/LabelContent\/LabelVisibility.swift#L60"},"title":"labelsVisibility(_:)","roleHeading":"Instance Method","externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE16labelsVisibilityyQrAA0G0OF::SYNTHESIZED::s:15OpenSwiftUICore15ModifiedContentV","symbolKind":"method","role":"symbol","platforms":[{"introducedAt":"13.0","deprecated":false,"unavailable":false,"name":"iOS","beta":false},{"introducedAt":"10.15","deprecated":false,"unavailable":false,"name":"macOS","beta":false},{"introducedAt":"13.0","deprecated":false,"unavailable":false,"name":"tvOS","beta":false},{"introducedAt":"1.0","deprecated":false,"unavailable":false,"name":"visionOS","beta":false},{"introducedAt":"6.0","deprecated":false,"unavailable":false,"name":"watchOS","beta":false}],"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"extendedModule":"OpenSwiftUICo