{"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingView\/sizingOptions","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/nshostingview\/sizingoptions"]}],"abstract":[{"text":"The options for how the hosting view creates and updates constraints","type":"text"},{"text":" ","type":"text"},{"text":"based on the size of its SwiftUI content.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingView"]]},"metadata":{"title":"sizingOptions","modules":[{"name":"OpenSwiftUI"}],"symbolKind":"property","roleHeading":"Instance Property","externalID":"s:11OpenSwiftUI13NSHostingViewC13sizingOptionsAA0d6SizingG0Vvp","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizingOptions","kind":"identifier"},{"text":": ","kind":"text"},{"text":"NSHostingSizingOptions","preciseIdentifier":"s:11OpenSwiftUI22NSHostingSizingOptionsV","kind":"typeIdentifier"}],"remoteSource":{"fileName":"NSHostingView.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/Integration\/Hosting\/AppKit\/View\/NSHostingView.swift#L62"},"role":"symbol","platforms":[]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizingOptions","kind":"identifier"},{"text":": ","kind":"text"},{"text":"NSHostingSizingOptions","preciseIdentifier":"s:11OpenSwiftUI22NSHostingSizingOptionsV","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingSizingOptions"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"text":"NSHostingView can create minimum, maximum, and ideal (content size)","type":"text"},{"text":" ","type":"text"},{"text":"constraints that are derived from its SwiftUI view content. These","type":"text"},{"text":" ","type":"text"},{"text":"constraints are only created when Auto Layout constraints are otherwise","type":"text"},{"text":" ","type":"text"},{"text":"being used in the containing window.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If the NSHostingView is set as the ","type":"text"},{"code":"contentView","type":"codeVoice"},{"text":" of an ","type":"text"},{"code":"NSWindow","type":"codeVoice"},{"text":", it","type":"text"},{"text":" ","type":"text"},{"text":"will also update the window’s ","type":"text"},{"code":"contentMinSize","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"contentMaxSize","type":"codeVoice"},{"text":" ","type":"text"},{"text":"based on the minimum and maximum size of its SwiftUI content.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"sizingOptions","type":"codeVoice"},{"text":" defaults to ","type":"text"},{"code":".standardBounds","type":"codeVoice"},{"text":" (which includes","type":"text"},{"text":" ","type":"text"},{"code":"minSize","type":"codeVoice"},{"text":", ","type":"text"},{"code":"intrinsicContentSize","type":"codeVoice"},{"text":", and ","type":"text"},{"code":"maxSize","type":"codeVoice"},{"text":"), but can be set to an","type":"text"},{"text":" ","type":"text"},{"text":"explicit value to control this behavior. For instance, setting a value","type":"text"},{"text":" ","type":"text"},{"text":"of ","type":"text"},{"code":".minSize","type":"codeVoice"},{"text":" will only create the constraints necessary to maintain the","type":"text"},{"text":" ","type":"text"},{"text":"minimum size of the SwiftUI content, or setting a value of ","type":"text"},{"code":"[]","type":"codeVoice"},{"text":" will","type":"text"},{"text":" ","type":"text"},{"text":"create no constraints at all.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If a use case can make assumptions about the size of the ","type":"text"},{"code":"NSHostingView","type":"codeVoice"},{"text":" ","type":"text"},{"text":"relative to its displayed content, such as the always being displayed in","type":"text"},{"text":" ","type":"text"},{"text":"a fixed frame, setting this to a value with fewer options can improve","type":"text"},{"text":" ","type":"text"},{"text":"performance as it reduces the amount of layout measurements that need to","type":"text"},{"text":" ","type":"text"},{"text":"be performed. If an ","type":"text"},{"code":"NSHostingView","type":"codeVoice"},{"text":" has a ","type":"text"},{"code":"frame","type":"codeVoice"},{"text":" that is smaller or","type":"text"},{"text":" ","type":"text"},{"text":"larger than that required to display its SwiftUI content, the content","type":"text"},{"text":" ","type":"text"},{"text":"will be centered within that frame.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"sections":[],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/NSHostingSizingOptions":{"role":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NSHostingSizingOptions","kind":"identifier"}],"abstract":[{"text":"Options for how hosting views and controllers reflect their","type":"text"},{"text":" ","type":"text"},{"text":"content’s size into Auto Layout constraints.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingSizingOptions","type":"topic","kind":"symbol","url":"\/documentation\/openswiftui\/nshostingsizingoptions","title":"NSHostingSizingOptions","navigatorTitle":[{"text":"NSHostingSizingOptions","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/NSHostingView":{"title":"NSHostingView","kind":"symbol","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingView","url":"\/documentation\/openswiftui\/nshostingview","abstract":[{"text":"An AppKit view that hosts a SwiftUI view hierarchy.","type":"text"}],"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NSHostingView","kind":"identifier"}],"navigatorTitle":[{"text":"NSHostingView","kind":"identifier"}],"type":"topic"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/NSHostingView/sizingOptions":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingView\/sizingOptions","url":"\/documentation\/openswiftui\/nshostingview\/sizingoptions","role":"symbol","abstract":[{"type":"text","text":"The options for how the hosting view creates and updates constraints"},{"type":"text","text":" "},{"type":"text","text":"based on the size of its SwiftUI content."}],"title":"sizingOptions","kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sizingOptions"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:11OpenSwiftUI22NSHostingSizingOptionsV","text":"NSHostingSizingOptions"}],"type":"topic"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"}}}