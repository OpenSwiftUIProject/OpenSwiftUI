{"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"preciseIdentifier":"s:ScM","text":"MainActor","kind":"attribute"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizingOptions","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:11OpenSwiftUI22NSHostingSizingOptionsV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingSizingOptions","text":"NSHostingSizingOptions","kind":"typeIdentifier"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"keyword"},{"text":" }","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"NSHostingView can create minimum, maximum, and ideal (content size)","type":"text"},{"text":" ","type":"text"},{"text":"constraints that are derived from its SwiftUI view content. These","type":"text"},{"text":" ","type":"text"},{"text":"constraints are only created when Auto Layout constraints are otherwise","type":"text"},{"text":" ","type":"text"},{"text":"being used in the containing window.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If the NSHostingView is set as the "},{"type":"codeVoice","code":"contentView"},{"type":"text","text":" of an "},{"type":"codeVoice","code":"NSWindow"},{"type":"text","text":", it"},{"type":"text","text":" "},{"type":"text","text":"will also update the window’s "},{"type":"codeVoice","code":"contentMinSize"},{"type":"text","text":" and "},{"type":"codeVoice","code":"contentMaxSize"},{"type":"text","text":" "},{"type":"text","text":"based on the minimum and maximum size of its SwiftUI content."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"sizingOptions"},{"type":"text","text":" defaults to "},{"type":"codeVoice","code":".standardBounds"},{"type":"text","text":" (which includes"},{"type":"text","text":" "},{"type":"codeVoice","code":"minSize"},{"type":"text","text":", "},{"type":"codeVoice","code":"intrinsicContentSize"},{"type":"text","text":", and "},{"type":"codeVoice","code":"maxSize"},{"type":"text","text":"), but can be set to an"},{"type":"text","text":" "},{"type":"text","text":"explicit value to control this behavior. For instance, setting a value"},{"type":"text","text":" "},{"type":"text","text":"of "},{"type":"codeVoice","code":".minSize"},{"type":"text","text":" will only create the constraints necessary to maintain the"},{"type":"text","text":" "},{"type":"text","text":"minimum size of the SwiftUI content, or setting a value of "},{"type":"codeVoice","code":"[]"},{"type":"text","text":" will"},{"type":"text","text":" "},{"type":"text","text":"create no constraints at all."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a use case can make assumptions about the size of the "},{"type":"codeVoice","code":"NSHostingView"},{"type":"text","text":" "},{"type":"text","text":"relative to its displayed content, such as the always being displayed in"},{"type":"text","text":" "},{"type":"text","text":"a fixed frame, setting this to a value with fewer options can improve"},{"type":"text","text":" "},{"type":"text","text":"performance as it reduces the amount of layout measurements that need to"},{"type":"text","text":" "},{"type":"text","text":"be performed. If an "},{"type":"codeVoice","code":"NSHostingView"},{"type":"text","text":" has a "},{"type":"codeVoice","code":"frame"},{"type":"text","text":" that is smaller or"},{"type":"text","text":" "},{"type":"text","text":"larger than that required to display its SwiftUI content, the content"},{"type":"text","text":" "},{"type":"text","text":"will be centered within that frame."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/nshostingview\/sizingoptions"]}],"metadata":{"symbolKind":"property","role":"symbol","modules":[{"name":"OpenSwiftUI"}],"title":"sizingOptions","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/Integration\/Hosting\/AppKit\/View\/NSHostingView.swift#L62","fileName":"NSHostingView.swift"},"roleHeading":"Instance Property","externalID":"s:11OpenSwiftUI13NSHostingViewC13sizingOptionsAA0d6SizingG0Vvp","platforms":[],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizingOptions","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:11OpenSwiftUI22NSHostingSizingOptionsV","text":"NSHostingSizingOptions","kind":"typeIdentifier"}]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingView\/sizingOptions"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingView"]]},"abstract":[{"type":"text","text":"The options for how the hosting view creates and updates constraints"},{"type":"text","text":" "},{"type":"text","text":"based on the size of its SwiftUI content."}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/NSHostingSizingOptions":{"url":"\/documentation\/openswiftui\/nshostingsizingoptions","kind":"symbol","title":"NSHostingSizingOptions","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"NSHostingSizingOptions"}],"abstract":[{"type":"text","text":"Options for how hosting views and controllers reflect their"},{"type":"text","text":" "},{"type":"text","text":"content’s size into Auto Layout constraints."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingSizingOptions","type":"topic","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"NSHostingSizingOptions"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/NSHostingView":{"url":"\/documentation\/openswiftui\/nshostingview","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingView","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"NSHostingView"}],"navigatorTitle":[{"kind":"identifier","text":"NSHostingView"}],"abstract":[{"type":"text","text":"An AppKit view that hosts a SwiftUI view hierarchy."}],"title":"NSHostingView","kind":"symbol","type":"topic"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/NSHostingView/sizingOptions":{"abstract":[{"type":"text","text":"The options for how the hosting view creates and updates constraints"},{"type":"text","text":" "},{"type":"text","text":"based on the size of its SwiftUI content."}],"url":"\/documentation\/openswiftui\/nshostingview\/sizingoptions","type":"topic","title":"sizingOptions","kind":"symbol","role":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"sizingOptions"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"NSHostingSizingOptions","preciseIdentifier":"s:11OpenSwiftUI22NSHostingSizingOptionsV"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSHostingView\/sizingOptions"}}}