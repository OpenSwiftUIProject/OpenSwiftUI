 view placed in an explicitly sized frame wraps"},{"type":"text","text":" "},{"type":"text","text":"and truncates its string to remain within its parent’s bounds:"}]},{"code":["Text(\"A single line of text, too long to fit in a box.\")","    .frame(width: 200, height: 200)","    .border(Color.gray)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"fixedSize()","type":"codeVoice"},{"text":" modifier can be used to create a view that maintains","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"inlineContent":[{"type":"text","text":"ideal size"}],"type":"emphasis"},{"text":" of its children both dimensions:","type":"text"}]},{"code":["Text(\"A single line of text, too long to fit in a box.\")","    .fixedSize()","    .frame(width: 200, height: 200)","    .border(Color.gray)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This can result in the view exceeding the parent’s bounds, which may or","type":"text"},{"text":" ","type":"text"},{"text":"may not be the effect you want.","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"You can think of ","type":"text"},{"code":"fixedSize()","type":"codeVoice"},{"text":" as the creation of a ","type":"text"},{"inlineContent":[{"text":"counter proposal","type":"text"}],"type":"emphasis"},{"text":" ","type":"text"},{"text":"to the view size proposed to a view by its parent. The ideal size of a","type":"text"},{"text":" ","type":"text"},{"text":"view, and the specific effects of ","type":"text"},{"code":"fixedSize()","type":"codeVoice"},{"text":" depends on the","type":"text"},{"text":" ","type":"text"},{"text":"particular view and how you have configured it.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a view that fixes the view’s size in either the horizontal or"},{"type":"text","text":" "},{"type":"text","text":"vertical dimensions, see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)"},{"type":"text","text":"."}]}]}],"metadata":{"symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fixedSize"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"}],"title":"fixedSize()","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/FixedSizeLayout.swift#L144","fileName":"FixedSizeLayout.swift"},"role":"symbol","extendedModule":"OpenSwiftUICore","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"roleHeading":"Instance Method","platforms":[{"introducedAt":"13.0","beta":false,"deprecated":false,"unavailable":false,"name":"iOS"},{"introducedAt":"10.15","beta":false,"deprecated":false,"unavailable":false,"name":"macOS"},{"introducedAt":"13.0","beta":false,"deprecated":false,"unavailable":false,"name":"tvOS"},{"introducedAt":"1.0","beta":false,"deprecated":false,"unavailable":false,"name":"visionOS"},{"name":"watchOS","introducedAt":"6.0","deprecated":false,"beta":false,"unavailable":false}],"externalID":"s:15OpenSwiftUICore4ViewPAAE9fixedSizeQryF::SYNTHESIZED::s:15OpenSwiftUICore9RectangleV"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Rectangle/fixedSize()":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Rectangle\/fixedSize()","abstract":[{"text":"Fixes this view at its ideal size.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/openswiftui\/rectangle\/fixedsize()","title":"fixedSize()","role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fixedSize"},{"k