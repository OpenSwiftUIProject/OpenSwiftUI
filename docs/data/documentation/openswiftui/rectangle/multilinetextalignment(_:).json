{"abstract":[{"text":"Sets the alignment of a text view that contains multiple lines of text.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"multilineTextAlignment"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"alignment"},{"kind":"text","text":": "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TextAlignment","kind":"typeIdentifier","text":"TextAlignment","preciseIdentifier":"s:15OpenSwiftUICore13TextAlignmentO"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"alignment","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A value that you use to align multiple lines of"},{"type":"text","text":" "},{"type":"text","text":"text within a view."}]}]}]},{"content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that aligns the lines of multiline "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" instances"},{"type":"text","text":" "},{"type":"text","text":"it contains."}]}],"kind":"content"},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"text":"Use this modifier to set an alignment for a multiline block of text.","type":"text"},{"text":" ","type":"text"},{"text":"For example, the modifier centers the contents of the following","type":"text"},{"text":" ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"text":" view:","type":"text"}],"type":"paragraph"},{"code":["Text(\"This is a block of text that shows up in a text element as multiple lines.\\(\"\\n\") Here we have chosen to center this text.\")","    .frame(width: 200)","    .multilineTextAlignment(.center)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The text in the above example spans more than one line because:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The newline character introduces a line break.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The frame modifier limits the space available to the text view, and","type":"text"},{"text":" ","type":"text"},{"text":"by default a text view wraps lines that don’t fit in the available","type":"text"},{"text":" ","type":"text"},{"text":"width. As a result, the text before the explicit line break wraps to","type":"text"},{"text":" ","type":"text"},{"text":"three lines, and the text after uses two lines.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier applies the alignment to the all the lines of text in"},{"type":"text","text":" "},{"type":"text","text":"the view, regardless of why wrapping occurs:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"The modifier has no effect on a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference"},{"text":" view that contains only one","type":"text"},{"text":" ","type":"text"},{"text":"line of text, because a text view has a width that exactly matches the","type":"text"},{"text":" ","type":"text"},{"text":"width of its widest line. If you want to align an entire text view","type":"text"},{"text":" ","type":"text"},{"text":"rather than its contents, set the aligment of its container, like a","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference"},{"text":" or a frame that you create with the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/frame(minWidth:idealWidth:maxWidth:minHeight:idealHeight:maxHeight:alignment:)","type":"reference"},{"text":" ","type":"text"},{"text":"modifier.","type":"text"}]},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"You can use this modifier to control the alignment of a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" "},{"type":"text","text":"view that you create with the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/init(_:style:)"},{"type":"text","text":" initializer"},{"type":"text","text":" "},{"type":"text","text":"to display localized dates and times, including when the view uses"},{"type":"text","text":" "},{"type":"text","text":"only a single line, but only when that view appears in a widget."}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier also affects the content alignment of other text container"},{"type":"text","text":" "},{"type":"text","text":"types, like "},{"code":"TextEditor","type":"codeVoice"},{"type":"text","text":" and "},{"code":"TextField","type":"codeVoice"},{"type":"text","text":". In those cases, the"},{"type":"text","text":" "},{"type":"text","text":"modifier sets the alignment even when the view contains only a single"},{"type":"text","text":" "},{"type":"text","text":"line because view’s width isn’t dictated by the width of the text it"},{"type":"text","text":" "},{"type":"text","text":"contains."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier operates by setting the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/multilineTextAlignment","isActive":true},{"type":"text","text":" value in the environment,"},{"type":"text","text":" "},{"type":"text","text":"so it affects all the text containers in the modified view hierarchy."},{"type":"text","text":" "},{"type":"text","text":"For example, you can apply the modifier to a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true},{"type":"text","text":" to"},{"type":"text","text":" "},{"type":"text","text":"configure all the text views inside the stack."}]}],"kind":"content"}],"sections":[],"metadata":{"externalID":"s:15OpenSwiftUICore4ViewPAAE22multilineTextAlignmentyQrAA0fG0OF::SYNTHESIZED::s:15OpenSwiftUICore9RectangleV","title":"multilineTextAlignment(_:)","role":"symbol","extendedModule":"OpenSwiftUICore","platforms":[{"beta":false,"unavailable":false,"introducedAt":"13.0","name":"iOS","deprecated":false},{"beta":false,"unavailable":false,"introducedAt":"10.15","name":"macOS","deprecated":false},{"beta":false,"unavailable":false,"introducedAt":"13.0","name":"tvOS","deprecated":false},{"beta":false,"unavailable":false,"introducedAt":"1.0","name":"visionOS","deprecated":false},{"beta":false,"unavailable":false,"introducedAt":"6.0","name":"watchOS","deprecated":false}],"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"symbolKind":"method","remoteSource":{"fileName":"EnvironmentParagraphStyle.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/View\/Text\/Util\/EnvironmentParagraphStyle.swift#L383"},"roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"multilineTextAlignment","kind":"identifie