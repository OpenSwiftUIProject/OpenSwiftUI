iscussion","level":2},{"inlineContent":[{"type":"text","text":"Use this modifier to differentiate among certain selectable views,"},{"type":"text","text":" "},{"type":"text","text":"like the possible values of a "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":" or the tabs of a "},{"type":"codeVoice","code":"TabView"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"Tag values can be of any type that conforms to the"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/hashable","isActive":true},{"type":"text","text":" protocol."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This modifier will write the tag value for the type "},{"type":"codeVoice","code":"V"},{"type":"text","text":", as well as"},{"type":"text","text":" "},{"type":"codeVoice","code":"Optional<V>"},{"type":"text","text":" if "},{"type":"codeVoice","code":"includeOptional"},{"type":"text","text":" is enabled. Containers checking for"},{"type":"text","text":" "},{"type":"text","text":"tags of either type will see the value as set."}],"type":"paragraph"},{"inlineContent":[{"text":"In the example below, the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach","isActive":true,"type":"reference"},{"text":" loop in the ","type":"text"},{"code":"Picker","type":"codeVoice"},{"text":" view","type":"text"},{"text":" ","type":"text"},{"text":"builder iterates over the ","type":"text"},{"code":"Flavor","type":"codeVoice"},{"text":" enumeration. It extracts the string","type":"text"},{"text":" ","type":"text"},{"text":"value of each enumeration element for use in constructing the row","type":"text"},{"text":" ","type":"text"},{"text":"label, and uses the enumeration value as input to the ","type":"text"},{"code":"tag(_:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"modifier.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swi