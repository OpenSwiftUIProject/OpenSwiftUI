{"abstract":[{"type":"text","text":"Hides the labels of any controls contained within this view."}],"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Rectangle\/labelsHidden()","interfaceLanguage":"swift"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"labelsHidden"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"kind":"text","text":"\n"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Use this modifier when you want to omit a label from one or more"},{"type":"text","text":" "},{"type":"text","text":"controls in your user interface. For example, the first "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle"},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"text","text":"the following example hides its label:"}],"type":"paragraph"},{"syntax":"swift","code":["VStack {","    Toggle(isOn: $toggle1) {","        Text(\"Toggle 1\")","    }","    .labelsHidden()","","    Toggle(isOn: $toggle2) {","        Text(\"Toggle 2\")","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":" in the example above centers the first toggle’s control"},{"type":"text","text":" "},{"type":"text","text":"element in the available space, while it centers the second toggle’s"},{"type":"text","text":" "},{"type":"text","text":"combined label and control element:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"Always provide a label for controls, even when you hide the label,","type":"text"},{"text":" ","type":"text"},{"text":"because SwiftUI uses labels for other purposes, including accessibility.","type":"text"}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":"This modifier doesn’t work for all labels. It applies to"},{"type":"text","text":" "},{"type":"text","text":"labels that are separate from the rest of the control’s interface,"},{"type":"text","text":" "},{"type":"text","text":"like they are for "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference"},{"type":"text","text":", but not to controls like a bordered"},{"type":"text","text":" "},{"type":"text","text":"button where the label is inside the button’s border."}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Rectangle"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/openswiftui\/rectangle\/labelshidden()"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"labelsHidden","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}],"externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE12labelsHiddenQryF::SYNTHESIZED::s:15OpenSwiftUICore9RectangleV","title":"labelsHidden()","extendedModule":"OpenSwiftUICore","platforms":[{"beta":false,"introducedAt":"13.0","deprecated":false,"unavailable":false,