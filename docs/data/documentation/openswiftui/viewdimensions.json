":"text"},{"text":" ","type":"text"},{"text":"offset for the guide. For example, you could compute a default offset","type":"text"},{"text":" ","type":"text"},{"text":"for a custom ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","type":"reference","isActive":true},{"text":" as a fraction of the view’s ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions\/height","type":"reference","isActive":true},{"text":":","type":"text"}]},{"type":"codeListing","code":["private struct FirstThirdAlignment: AlignmentID {","    static func defaultValue(in context: ViewDimensions) -> CGFloat {","        context.height \/ 3","    }","}","","extension VerticalAlignment {","    static let firstThird = VerticalAlignment(FirstThirdAlignment.self)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As another example, you could use the view dimensions instance to look"},{"type":"text","text":" "},{"type":"text","text":"up the offset of an existing guide and modify it:"}]},{"type":"codeListing","code":["struct ViewDimensionsOffset: View {","    var body: some View {","        VStack(alignment: .leading) {","            Text(\"Default\")","            Text(\"Indented\")","                .alignmentGuide(.leading) { context in","                    context[.leading] - 10","                }","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The example above indents the second text view because the subtraction","type":"text"},{"text":" ","type":"text"},{"text":"moves the second text view’s leading guide in the negative x direction,","type":"text"},{"text":" ","type":"text"},{"text":"Openwhich is to the left in the view’s coordinate space. As a result,","type":"text"},{"text":" ","type":"text"},{"text":"OpenSwiftUI moves the second text view to the right, relative to the first","type":"text"},{"text":" ","type":"text"},{"text":"text view, to keep their leading guides aligned:","type":"text"}]},{"inlineContent":[],"type":"paragraph"},{"text":"Layout direction","level":3,"type":"heading","anchor":"Layout-direction"},{"inlineContent":[{"type":"text","text":"The discussion above describes a left-to-right language environment,"},{"type":"text","text":" "},{"type":"text","text":"but you don’t change your guide calculation to operate in a right-to-left"},{"type":"text","text":" "},{"type":"text","text":"environment. OpenSwiftUI moves the view’s origin from the left to the right side"},{"type":"text","text":" "},{"type":"text","text":"of the view and inverts the positive x direction. As a result,"},{"type":"text","text":" "},{"type":"text","text":"the existing calculation produces the same effect, but in the opposite"},{"type":"text","text":" "},{"type":"text","text":"direction."}],"type":"paragraph"},{"inlineContent":[{"text":"You can see this if you use the ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/environment(_:_:)","isActive":true},{"type":"text","text":" "},{"type":"text","text":"modifier to set the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/layoutDirection","isActive":true},{"type":"text","text":" property for the"},{"type":"text","text":" "},{"type":"text","text":"view that you defined above:"}],"type":"paragraph"},{"code":["ViewDimensionsOffset()","    .environment(\\.layoutDirection, .rightToLeft)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"With no change in your guide, this produces the desired effect —"},{"type":"text","text":" "},{"type":"text","text":"it indents the second text view’s right side, relative to the"},{"type":"text","text":" "},{"type":"text","text":"first text view’s right side. The leading edge is now on the right,"},{"type":"text","text":" "},{"type":"text","text":"and the direction of the offset is reversed:"