{"seeAlsoSections":[{"generated":true,"anchor":"Aligning-views","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID"],"title":"Aligning views"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewDimensions","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Overview","level":2,"anchor":"overview","type":"heading"},{"inlineContent":[{"text":"This structure contains the size and alignment guides of a view.","type":"text"},{"text":" ","type":"text"},{"text":"You receive an instance of this structure to use in a variety of","type":"text"},{"text":" ","type":"text"},{"text":"layout calculations, like when you:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Define a default value for a custom alignment guide;","type":"text"},{"text":" ","type":"text"},{"text":"see ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID\/defaultValue(in:)","isActive":true,"type":"reference"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Modify an alignment guide on a view;"},{"type":"text","text":" "},{"type":"text","text":"see "},{"type":"codeVoice","code":"View\/alignmentGuide(_:computeValue:)-9mdoh"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Ask for the dimensions of a subview of a custom view layout;"},{"type":"text","text":" "},{"type":"text","text":"see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutSubview\/dimensions(in:)"},{"type":"text","text":"."}]}]}],"type":"unorderedList"},{"text":"Custom alignment guides","level":3,"anchor":"Custom-alignment-guides","type":"heading"},{"inlineContent":[{"text":"You receive an instance of this structure as the ","type":"text"},{"code":"context","type":"codeVoice"},{"text":" parameter to","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID\/defaultValue(in:)","isActive":true},{"text":" method that you implement to produce","type":"text"},{"text":" ","type":"text"},{"text":"the default offset for an alignment guide, or as the first argument to the","type":"text"},{"text":" ","type":"text"},{"text":"closure you provide to the ","type":"text"},{"code":"View\/alignmentGuide(_:computeValue:)-6y3u2","type":"codeVoice"},{"text":" ","type":"text"},{"text":"view modifier to override the default calculation for an alignment guide.","type":"text"},{"text":" ","type":"text"},{"text":"In both cases you can use the instance, if helpful, to calculate the","type":"text"},{"text":" ","type":"text"},{"text":"offset for the guide. For example, you could compute a default offset","type":"text"},{"text":" ","type":"text"},{"text":"for a custom ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","isActive":true},{"text":" as a fraction of the view’s ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions\/height","isActive":true},{"text":":","type":"text"}],"type":"paragraph"},{"code":["private struct FirstThirdAlignment: AlignmentID {","    static func defaultValue(in context: ViewDimensions) -> CGFloat {","        context.height \/ 3","    }","}","","extension VerticalAlignment {","    static let firstThird = VerticalAlignment(FirstThirdAlignment.self)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"As another example, you could use the view dimensions instance to look","type":"text"},{"text":" ","type":"text"},{"text":"up the offset of an existing guide and modify it:","type":"text"}],"type":"paragraph"},{"code":["struct ViewDimensionsOffset: View {","    var body: some View {","        VStack(alignment: .leading) {","            Text(\"Default\")","            Text(\"Indented\")","                .alignmentGuide(.leading) { context in","                    context[.leading] - 10","                }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The example above indents the second text view because the subtraction","type":"text"},{"text":" ","type":"text"},{"text":"moves the second text view’s leading guide in the negative x direction,","type":"text"},{"text":" ","type":"text"},{"text":"Openwhich is to the left in the view’s coordinate space. As a result,","type":"text"},{"text":" ","type":"text"},{"text":"OpenSwiftUI moves the second text view to the right, relative to the first","type":"text"},{"text":" ","type":"text"},{"text":"text view, to keep their leading guides aligned:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"text":"Layout direction","level":3,"anchor":"Layout-direction","type":"heading"},{"inlineContent":[{"text":"The discussion above describes a left-to-right language environment,","type":"text"},{"text":" ","type":"text"},{"text":"but you don’t change your guide calculation to operate in a right-to-left","type":"text"},{"text":" ","type":"text"},{"text":"environment. OpenSwiftUI moves the view’s origin from the left to the right side","type":"text"},{"text":" ","type":"text"},{"text":"of the view and inverts the positive x direction. As a result,","type":"text"},{"text":" ","type":"text"},{"text":"the existing calculation produces the same effect, but in the opposite","type":"text"},{"text":" ","type":"text"},{"text":"direction.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can see this if you use the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/environment(_:_:)","isActive":true},{"type":"text","text":" "},{"type":"text","text":"modifier to set the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/layoutDirection","isActive":true},{"type":"text","text":" property for the"},{"type":"text","text":" "},{"type":"text","text":"view that you defined above:"}],"type":"paragraph"},{"code":["ViewDimensionsOffset()","    .environment(\\.layoutDirection, .rightToLeft)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"With no change in your guide, this produces the desired effect —","type":"text"},{"text":" ","type":"text"},{"text":"it indents the second text view’s right side, relative to the","type":"text"},{"text":" ","type":"text"},{"text":"first text view’s right side. The leading edge is now on the right,","type":"text"},{"text":" ","type":"text"},{"text":"and the direction of the offset is reversed:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"relationshipsSections":[{"kind":"relationships","type":"conformsTo","identifiers":["doc:\/\/OpenSwiftUI\/s8CopyableP","doc:\/\/OpenSwiftUI\/SQ"],"title":"Conforms To"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/documentation\/openswiftui\/viewdimensions"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"roleHeading":"Structure","role":"symbol","modules":[{"name":"OpenSwiftUI"}],"symbolKind":"struct","externalID":"s:15OpenSwiftUICore14ViewDimensionsV","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewDimensions","kind":"identifier"}],"navigatorTitle":[{"text":"ViewDimensions","kind":"identifier"}],"remoteSource":{"fileName":"ViewDimensions.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSw