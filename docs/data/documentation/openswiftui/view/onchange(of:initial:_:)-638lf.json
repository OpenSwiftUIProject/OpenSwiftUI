rs":[{"name":"value","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The value to check against when determining whether"},{"type":"text","text":" "},{"type":"text","text":"to run the closure."}]}]},{"name":"initial","content":[{"inlineContent":[{"type":"text","text":"Whether the action should be run when this view initially"},{"type":"text","text":" "},{"type":"text","text":"appears."}],"type":"paragraph"}]},{"name":"action","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure to run when the value changes."}]}]},{"name":"oldValue","content":[{"inlineContent":[{"text":"The old value that failed the comparison check (or the","type":"text"},{"text":" ","type":"text"},{"text":"initial value when requested).","type":"text"}],"type":"paragraph"}]},{"name":"newValue","content":[{"inlineContent":[{"text":"The new value that failed the comparison check.","type":"text"}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that fires an action when the specified value changes."}]}],"kind":"content"},{"content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"You can use ","type":"text"},{"type":"codeVoice","code":"onChange"},{"text":" to trigger a side effect as the result of a","type":"text"},{"text":" ","type":"text"},{"text":"value changing, such as an ","type":"text"},{"type":"codeVoice","code":"Environment"},{"text":" key or a ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The system may call the action closure on the main actor, so avoid"},{"type":"text","text":" "},{"type":"text","text":"long-running tasks in the closure. If you need to perform such tasks,"},{"type":"text","text":" "},{"type":"text","text":"detach an asynchronous background task."}],"type":"paragraph"},{"inlineContent":[{"text":"When the value changes, the new version of the closure will be called,","type":"text"},{"text":" ","type":"text"},{"text":"so any captured values will have their values from the time that the","type":"text"},{"text":" ","type":"text"},{"text":"observed value has its new value. The old and new observed values are","type":"text"},{"text":" ","type":"text"},{"text":"passed into the closure. In the following code example, ","type":"text"},{"type":"codeVoice","code":"PlayerView"},{"text":" ","type":"text"},{"text":"passes both the old and new values to the model.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct PlayerView: View {","    var episode: Episode","    @State private var playState: PlayState = .paused","","    var body: some View {","        VStack {","            Text(episode.title)","            Text(episode.showTitle)","            PlayButton(playState: $playState)","        }","        .onChange(of: playState) { oldState, newState in","            model.playStateDidChange(from: oldState, to: newState)","        }","    }","}"],"type":"codeListing"}],"kind":"content"}],"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/onChange(of:initial:_:)-638lf","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View/onChange(of:initial:_:)-638lf":{"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"onChange"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"externalParam","text":"of"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":", "},{"kind":"externalParam","text":"initial"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":", ("},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":", "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"}],"abstract":[{"type":"text","text":"Adds a modifier for this view that fires an action when a specific"},{"type":"text","text":" "},{"type":"text","text":"value changes."}],"url":"\/documentation\/openswiftui\/view\/onchange(of:initial:_:)-638lf","role":"symbol","kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/onChange(of:initial:_:)-638lf","title":"onChange(of:initial:_:)"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"url":"\/documentation\/openswiftui\/view","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","role":"symbol"}}}