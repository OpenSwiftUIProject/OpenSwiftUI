{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"]]},"abstract":[{"type":"text","text":"Hides this view unconditionally."}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"hidden"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","text":"Return Value","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A hidden view."}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"inlineContent":[{"type":"text","text":"Hidden views are invisible and can’t receive or respond to interactions."},{"type":"text","text":" "},{"type":"text","text":"However, they do remain in the view hierarchy and affect layout. Use"},{"type":"text","text":" "},{"type":"text","text":"this modifier if you want to include a view for layout purposes, but"},{"type":"text","text":" "},{"type":"text","text":"don’t want it to display."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["HStack {","    Image(systemName: \"a.circle.fill\")","    Image(systemName: \"b.circle.fill\")","    Image(systemName: \"c.circle.fill\")","        .hidden()","    Image(systemName: \"d.circle.fill\")","}"]},{"inlineContent":[{"type":"text","text":"The third circle takes up space, because it’s still present, but"},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI doesn’t draw it onscreen."}],"type":"paragraph"},{"inlineCon