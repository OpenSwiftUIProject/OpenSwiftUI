{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"]]},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/layoutPriority(_:)","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"roleHeading":"Instance Method","platforms":[{"name":"iOS","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"name":"macOS","introducedAt":"10.15","deprecated":false,"unavailable":false,"beta":false},{"name":"tvOS","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"name":"visionOS","introducedAt":"1.0","deprecated":false,"unavailable":false,"beta":false},{"name":"watchOS","introducedAt":"6.0","deprecated":false,"unavailable":false,"beta":false}],"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"symbolKind":"method","role":"symbol","externalID":"s:15OpenSwiftUICore4ViewPAAE14layoutPriorityyQrSdF","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/LayoutPriority.swift#L49","fileName":"LayoutPriority.swift"},"extendedModule":"OpenSwiftUICore","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"layoutPriority","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Double","kind":"typeIdentifier","preciseIdentifier":"s:Sd"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"title":"layoutPriority(_:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"layoutPriority"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"value"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sd","text":"Double"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"},{"kind":"text","text":"\n"}],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"name":"value","content":[{"inlineContent":[{"text":"The priority by which a parent layout apportions","type":"text"},{"text":" ","type":"text"},{"text":"space to the child.","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Views typically have a default priority of "},{"code":"0","type":"codeVoice"},{"type":"text","text":" which causes space to be"},{"type":"text","text":" "},{"type":"text","text":"apportioned evenly to all sibling views. Raising a view’s layout"},{"type":"text","text":" "},{"type":"text","text":"priority encourages the higher priority view to shrink later when the"},{"type":"text","text":" "},{"type":"text","text":"group is shrunk and stretch sooner when the group is stretched."}]},{"type":"codeListing","syntax":"swift","code":["HStack {","    Text(\"This is a moderately long string.\")","        .font(.largeTitle)","        .border(Color.gray)","","    Spacer()","","    Text(\"This is a higher priority string.\")","        .font(.largeTitle)","        .layoutPriority(1)","        .border(Color.gray)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the example above, the first "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"type":"text","text":" element has the default"},{"type":"text","text":" "},{"type":"text","text":"priority "},{"type":"codeVoice","code":"0"},{"type":"text","text":" which causes its view to shrink dramatically due to the"},{"type":"text","text":" "},{"type":"text","text":"higher priority of the second "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"type":"text","text":" element, even though all of their"},{"type":"text","text":" "},{"type":"text","text":"other attributes (font, font size and character count) are the same."}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"A parent layout offers the child views with the highest layout priority","type":"text"},{"text":" ","type":"text"},{"text":"all the space offered to the parent minus the minimum space required for","type":"text"},{"text":" ","type":"text"},{"text":"all its lower-priority children.","type":"text"}]}]}],"abstract":[{"type":"text","text":"Sets the priority by which a parent layout should apportion space to"},{"type":"text","text":" "},{"type":"text","text":"this child."}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/view\/layoutpriority(_:)"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View/layoutPriority(_:)":{"title":"layoutPriority(_:)","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/layoutPriority(_:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"layoutPriority","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Sd","text":"Double","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind