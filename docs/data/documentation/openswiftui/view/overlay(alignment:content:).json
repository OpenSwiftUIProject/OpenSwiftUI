{"kind":"symbol","metadata":{"platforms":[{"name":"iOS","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"name":"macOS","introducedAt":"10.15","deprecated":false,"unavailable":false,"beta":false},{"name":"tvOS","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"name":"visionOS","introducedAt":"1.0","deprecated":false,"unavailable":false,"beta":false},{"name":"watchOS","introducedAt":"6.0","deprecated":false,"unavailable":false,"beta":false}],"roleHeading":"Instance Method","title":"overlay(alignment:content:)","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"overlay"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"externalParam","text":"alignment"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Alignment","preciseIdentifier":"s:15OpenSwiftUICore9AlignmentV"},{"kind":"text","text":", "},{"kind":"externalParam","text":"content"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"remoteSource":{"fileName":"OverlayModifier.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Modifier\/ViewModifier\/OverlayModifier.swift#L239"},"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"role":"symbol","extendedModule":"OpenSwiftUICore","externalID":"s:15OpenSwiftUICore4ViewPAAE7overlay9alignment7contentQrAA9AlignmentV_qd__yXEtAaBRd__lF"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"]]},"abstract":[{"type":"text","text":"Layers the views that you specify in front of this view."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/view\/overlay(alignment:content:)"]}],"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"overlay"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"externalParam","text":"alignment"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment","preciseIdentifier":"s:15OpenSwiftUICore9AlignmentV","text":"Alignment"},{"kind":"text","text":" = .center, "},{"kind":"attribute","text":"@"},{"kind":"attribute","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder","preciseIdentifier":"s:15OpenSwiftUICore11ViewBuilderV","text":"ViewBuilder"},{"kind":"text","text":" "},{"kind":"externalParam","text":"content"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"},{"kind":"text","text":"\n"}]}]},{"kind":"parameters","parameters":[{"name":"alignment","content":[{"inlineContent":[{"type":"text","text":"The alignment that the modifier uses to position the"},{"type":"text","text":" "},{"type":"text","text":"implicit "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true,"type":"reference"},{"type":"text","text":" that groups the foreground views. The default"},{"type":"text","text":" "},{"type":"text","text":"is "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"}]},{"name":"content","content":[{"inlineContent":[{"type":"text","text":"A "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder","type":"reference","isActive":true},{"type":"text","text":" that you use to declare the views to"},{"type":"text","text":" "},{"type":"text","text":"draw in front of this view, stacked in the order that you list them."},{"type":"text","text":" "},{"type":"text","text":"The last view that you list appears at the front of the stack."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that uses the specified content as a foreground."}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use this modifier to place one or more views in front of another view."},{"type":"text","text":" "},{"type":"text","text":"For example, you can place a group of stars on a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/RoundedRectangle","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"code":["RoundedRectangle(cornerRadius: 8)","    .frame(width: 200, height: 100)","    .overlay(alignment: .topLeading) { Star(color: .red) }","    .overlay(alignment: .topTrailing) { Star(color: .yellow) }","    .overlay(alignment: .bottomLeading) { Star(color: .green) }","    .overlay(alignment: .bottomTrailing) { Star(color: .blue) }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The example above assumes that you’ve defined a "},{"type":"codeVoice","code":"Star"},{"type":"text","text":" view with a"},{"type":"text","text":" "},{"type":"text","text":"parameterized color:"}],"type":"paragraph"},{"code":["struct Star: View {","    var color = Color.yellow","","    var body: some View {","        Image(systemName: \"star.fill\")","            .foregroundStyle(color)","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"By setting different ","type":"text"},{"type":"codeVoice","code":"alignment"},{"text":" values for each modifier, you make the","type":"text"},{"text":" ","type":"text"},{"text":"stars appear in different places on the rectangle:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you specify more than one view in the "},{"type":"codeVoice","code":"content"},{"type":"text","text":" closure, the modifier"},{"type":"text","text":" "},{"type":"text","text":"collects all of the views in the closure into an implicit "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"taking them in order from back to front. For example, you can place a"},{"type":"text","text":" "},{"type":"text","text":"star and a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Circle","isActive":true},{"type":"text","text":" on a field of "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/blue","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"code":["Color.blue","    .frame(width: 200, height: 200)","    .overlay {","        Circle()","            .frame(width: 100, height: 100)","        Star()","    }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Both the overlay modifier and the implicit "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"type":"text","text":" composed from the"},{"type":"text","text":" "},{"type":"text","text":"overlay content — the circle and the star — use a default"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center"},{"type":"text","text":" alignment. The star appears centered on the circle,"},{"type":"text","text":" "},{"type":"text","text":"and both appear as a composite view centered in front of the square:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"If you specify an alignment for the overlay, it applies to the implicit","type":"text"},{"text":" ","type":"text"},{"text":"stack rather than to the individual views in the closure. You can see","type":"text"},{"text":" ","type":"text"},{"text":"this if you add the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/bottom"},{"text":" alignment:","type":"text"}],"type":"paragraph"},{"code":["Color.blue","    .frame(width: 200, height: 200)","    .overlay(alignment: .bottom) {","        Circle()","            .frame(width: 100, height: 100)","        Star()","    }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The circle and the star move down as a unit to align the stack’s bottom"},{"type":"text","text":" "},{"type":"text","text":"edge with the bottom edge of the square, while the star remains"},{"type":"text","text":" "},{"type":"text","text":"centered on the circle:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To control the placement of individual items inside the "},{"code":"content","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"closure, either use a different overlay modifier for each item, as the"},{"type":"text","text":" "},{"type":"text","text":"earlier example of stars in the corners of a rectangle demonstrates, or"},{"type":"text","text":" "},{"type":"text","text":"add an explicit "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true},{"type":"text","text":" inside the content closure with its own"},{"type":"text","text":" "},{"type":"text","text":"alignment:"}],"type":"paragraph"},{"code":["Color.blue","    .frame(width: 200, height: 200)","    .overlay(alignment: .bottom) {","        ZStack(alignment: .bottom) {","            Circle()","                .frame(width: 100, height: 100)","            Star()","        }","    }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The stack alignment ensures that the star’s bottom edge aligns with the","type":"text"},{"text":" ","type":"text"},{"text":"circle’s, while the overlay aligns the composite view with the square:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can achieve layering without an overlay modifier by putting both the"},{"type":"text","text":" "},{"type":"text","text":"modified view and the overlay content into a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true},{"type":"text","text":". This can"},{"type":"text","text":" "},{"type":"text","text":"produce a simpler view hierarchy, but changes the layout priority that"},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI applies to the views. Use the overlay modifier when you want the"},{"type":"text","text":" "},{"type":"text","text":"modified view to dominate the layout."}],"type":"paragraph"},{"inlineContent":[{"text":"If you want to specify a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","type":"reference"},{"text":" like a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","type":"reference"},{"text":" or a","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Material","type":"reference"},{"text":" as the overlay, use","type":"text"},{"text":" ","type":"text"},{"code":"View\/overlay(_:ignoresSafeAreaEdges:)","type":"codeVoice"},{"text":" instead. To specify a","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape","type":"reference"},{"text":", use ","type":"text"},{"code":"View\/overlay(_:in:fillStyle:)","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/overlay(alignment:content:)"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Material":{"abstract":[{"type":"text","text":"A background material type."}],"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Material"}],"title":"Material","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Material","role":"symbol","kind":"symbol","url":"\/documentation\/openswiftui\/material","navigatorTitle":[{"kind":"identifier","text":"Material"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Alignment":{"url":"\/documentation\/openswiftui\/alignment","abstract":[{"type":"text","text":"An alignment in both axes."}],"navigatorTitle":[{"text":"Alignment","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Alignment","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment","role":"symbol","type":"topic","title":"Alignment"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ZStack":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ZStack","