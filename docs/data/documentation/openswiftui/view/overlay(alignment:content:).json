{"sections":[],"abstract":[{"text":"Layers the views that you specify in front of this view.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/view\/overlay(alignment:content:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/overlay(alignment:content:)"},"metadata":{"extendedModule":"OpenSwiftUICore","platforms":[{"deprecated":false,"unavailable":false,"name":"iOS","introducedAt":"13.0","beta":false},{"deprecated":false,"unavailable":false,"name":"macOS","introducedAt":"10.15","beta":false},{"deprecated":false,"unavailable":false,"name":"tvOS","introducedAt":"13.0","beta":false},{"deprecated":false,"unavailable":false,"name":"visionOS","introducedAt":"1.0","beta":false},{"deprecated":false,"unavailable":false,"name":"watchOS","introducedAt":"6.0","beta":false}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"overlay","kind":"identifier"},{"text":"<","kind":"text"},{"text":"V","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"alignment","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Alignment","preciseIdentifier":"s:15OpenSwiftUICore9AlignmentV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"content","kind":"externalParam"},{"text":": () -> ","kind":"text"},{"text":"V","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"}],"externalID":"s:15OpenSwiftUICore4ViewPAAE7overlay9alignment7contentQrAA9AlignmentV_qd__yXEtAaBRd__lF","title":"overlay(alignment:content:)","remoteSource":{"fileName":"OverlayModifier.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Modifier\/ViewModifier\/OverlayModifier.swift#L239"},"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"roleHeading":"Instance Method","role":"symbol"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"]]},"kind":"symbol","schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"overlay","kind":"identifier"},{"text":"<","kind":"text"},{"text":"V","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"alignment","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Alignment","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore9AlignmentV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment"},{"text":" = .center, ","kind":"text"},{"text":"@","kind":"attribute"},{"text":"ViewBuilder","kind":"attribute","preciseIdentifier":"s:15OpenSwiftUICore11ViewBuilderV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder"},{"text":" ","kind":"text"},{"text":"content","kind":"externalParam"},{"text":": () -> ","kind":"text"},{"text":"V","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"V","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":"\n","kind":"text"}]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The alignment that the modifier uses to position the"},{"type":"text","text":" "},{"type":"text","text":"implicit "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"type":"text","text":" that groups the foreground views. The default"},{"type":"text","text":" "},{"type":"text","text":"is "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center"},{"type":"text","text":"."}],"type":"paragraph"}],"name":"alignment"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder"},{"type":"text","text":" that you use to declare the views to"},{"type":"text","text":" "},{"type":"text","text":"draw in front of this view, stacked in the order that you list them."},{"type":"text","text":" "},{"type":"text","text":"The last view that you list appears at the front of the stack."}]}],"name":"content"}],"kind":"parameters"},{"content":[{"type":"heading","anchor":"return-value","text":"Return Value","level":2},{"type":"paragraph","inlineContent":[{"text":"A view that uses the specified content as a foreground.","type":"text"}]}],"kind":"content"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to place one or more views in front of another view."},{"type":"text","text":" "},{"type":"text","text":"For example, you can place a group of stars on a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/RoundedRectangle","type":"reference","isActive":true},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["RoundedRectangle(cornerRadius: 8)","    .frame(width: 200, height: 100)","    .overlay(alignment: .topLeading) { Star(color: .red) }","    .overlay(alignment: .topTrailing) { Star(color: .yellow) }","    .overlay(alignment: .bottomLeading) { Star(color: .green) }","    .overlay(alignment: .bottomTrailing) { Star(color: .blue) }"]},{"type":"paragraph","inlineContent":[{"text":"The example above assumes that you’ve defined a ","type":"text"},{"type":"codeVoice","code":"Star"},{"text":" view with a","type":"text"},{"text":" ","type":"text"},{"text":"parameterized color:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["struct Star: View {","    var color = Color.yellow","","    var body: some View {","        Image(systemName: \"star.fill\")","            .foregroundStyle(color)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"By setting different "},{"code":"alignment","type":"codeVoice"},{"type":"text","text":" values for each modifier, you make the"},{"type":"text","text":" "},{"type":"text","text":"stars appear in different places on the rectangle:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"If you specify more than one view in the ","type":"text"},{"code":"content","type":"codeVoice"},{"text":" closure, the modifier","type":"text"},{"text":" ","type":"text"},{"text":"collects all of the views in the closure into an implicit ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true,"type":"reference"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"taking them in order from back to front. For example, you can place a","type":"text"},{"text":" ","type":"text"},{"text":"star and a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Circle","isActive":true,"type":"reference"},{"text":" on a field of ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/blue","isActive":true,"type":"reference"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["Color.blue","    .frame(width: 200, height: 200)","    .overlay {","        Circle()","            .frame(width: 100, height: 100)","        Star()","    }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both the overlay modifier and the implicit "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"type":"text","text":" composed from the"},{"type":"text","text":" "},{"type":"text","text":"overlay content — the circle and the star — use a default"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center"},{"type":"text","text":" alignment. The star appears centered on the circle,"},{"type":"text","text":" "},{"type":"text","text":"and both appear as a composite view centered in front of the square:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"If you specify an alignment for the overlay, it applies to the implicit","type":"text"},{"text":" ","type":"text"},{"text":"stack rather than to the individual views in the closure. You can see","type":"text"},{"text":" ","type":"text"},{"text":"this if you add the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/bottom","isActive":true,"type":"reference"},{"text":" alignment:","type":"text"}]},{"type":"codeListing","code":["Color.blue","    .frame(width: 200, height: 200)","    .overlay(alignment: .bottom) {","        Circle()","            .frame(width: 100, height: 100)","        Star()","    }"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The circle and the star move down as a unit to align the stack’s bottom"},{"type":"text","text":" "},{"type":"text","text":"edge with the bottom edge of the square, while the star remains"},{"type":"text","text":" "},{"type":"text","text":"centered on the circle:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"To control the placement of individual items inside the ","type":"text"},{"code":"content","type":"codeVoice"},{"text":" ","type":"text"},{"text":"closure, either use a different overlay modifier for each item, as the","type":"text"},{"text":" ","type":"text"},{"text":"earlier example of stars in the corners of a rectangle demonstrates, or","type":"text"},{"text":" ","type":"text"},{"text":"add an explicit ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true},{"text":" inside the content closure with its own","type":"text"},{"text":" ","type":"text"},{"text":"alignment:","type":"text"}]},{"code":["Color.blue","    .frame(width: 200, height: 200)","    .overlay(alignment: .bottom) {","        ZStack(alignment: .bottom) {","            Circle()","                .frame(width: 100, height: 100)","            Star()","        }","    }"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The stack alignment ensures that the star’s bottom edge aligns with the","type":"text"},{"text":" ","type":"text"},{"text":"circle’s, while the overlay aligns the composite view with the square:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can achieve layering without an overlay modifier by putting both the"},{"type":"text","text":" "},{"type":"text","text":"modified view and the overlay content into a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true,"type":"reference"},{"type":"text","text":". This can"},{"type":"text","text":" "},{"type":"text","text":"produce a simpler view hierarchy, but changes the layout priority that"},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI applies to the views. Use the overlay modifier when you want the"},{"type":"text","text":" "},{"type":"text","text":"modified view to dominate the layout."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you want to specify a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","isActive":true},{"type":"text","text":" like a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","isActive":true},{"type":"text","text":" or a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Material","isActive":true},{"type":"text","text":" as the overlay, use"},{"type":"text","text":" "},{"type":"codeVoice","code":"View\/overlay(_:ignoresSafeAreaEdges:)"},{"type":"text","text":" instead. To specify a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape","isActive":true},{"type":"text","text":", use "},{"type":"codeVoice","code":"View\/overlay(_:in:fillStyle:)"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Alignment":{"abstract":[{"type":"text","text":"An alignment in both axes."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Alignment"}],"title":"Alignment","navigatorTitle":[{"kind":"identifier","text":"Alignment"}],"role":"symbol","type":"topic","url":"\/documentation\/openswiftui\/alignment","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment","kind":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ShapeStyle":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","abstract":[{"text":"A color or pattern to use when rendering a shape.","type":"text"}],"title":"ShapeStyle","navigatorTitle":[{"text":"ShapeStyle","kind":"identifier"}],"kind":"symbol","type":"topic","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ShapeStyle","kind":"identifier"}],"url":"\/documentation\/openswiftui\/shapestyle","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Color":{"abstract":[{"type":"text","text":"A representation of a c