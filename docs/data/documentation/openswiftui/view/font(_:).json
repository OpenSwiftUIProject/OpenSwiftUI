ference"},{"type":"text","text":" applies a 16-point system font as a"},{"type":"text","text":" "},{"type":"text","text":"default font to views contained in that "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference"},{"type":"text","text":". Inside that stack,"},{"type":"text","text":" "},{"type":"text","text":"the example applies a "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Font\/largeTitle","type":"reference"},{"type":"text","text":" font to just the first text"},{"type":"text","text":" "},{"type":"text","text":"view; this explicitly overrides the default. The remaining stack and the"},{"type":"text","text":" "},{"type":"text","text":"views contained with it continue to use the 16-point system font set by"},{"type":"text","text":" "},{"type":"text","text":"their containing view:"}]},{"type":"codeListing","syntax":"swift","code":["VStack {","    Text(\"Font applied to a text view.\")","        .font(.largeTitle)","","    VStack {","        Text(\"These 2 text views have the same font\")","        Text(\"applied to their parent hierarchy\")","    }","}",".font(.system(size: 16, weight: .light, design: .default))"]},{"type":"paragraph","inlineContent":[]}]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/font(_:)","interfaceLanguage":"swift"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"url":"\/documentation\/openswiftui\/view","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","role":"symbol"},