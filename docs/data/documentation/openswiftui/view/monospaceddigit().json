,"text":" "},{"kind":"identifier","text":"monospacedDigit"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"},{"kind":"text","text":"\n"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view whose child views’ fonts use fixed-width numeric"},{"type":"text","text":" "},{"type":"text","text":"characters, while leaving other characters proportionally spaced."}]}],"kind":"content"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using fixed-width digits allows you to easily align numbers of the"},{"type":"text","text":" "},{"type":"text","text":"same size in a table-like arrangement. This feature is also known as"},{"type":"text","text":" "},{"type":"text","text":"“tabular figures” or “tabular numbers.”"}]},{"type":"paragraph","inlineContent":[{"text":"This modifier only affects numeric characters, and leaves all other","type":"text"},{"text":" ","type":"text"},{"text":"characters unchanged.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example shows the effect of "},{"code":"monospacedDigit()","type":"codeVoice"},{"type":"text","text":" on"},{"type":"text","text":" "},{"type":"text","text":"multiple child views. The example consists of two "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":" views"},{"type":"text","text":" "},{"type":"text","text":"inside an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"},{"type":"text","text":". Each "},{"code":"VStack","type":"codeVoice"},{"type":"text","text":" contains two "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button"},{"type":"text","text":" views, with"},{"type":"text","text":" "},{"type":"text","text":"the second "},{"code":"VStack","type":"codeVoice"},{"type":"text","text":" applying the "},{"code":"monospacedDigit()","type":"codeVoice"},{"type":"text","text":" modifier to its"},{"type":"text","text":" "},{"type":"text","text":"contents. As a result, the digits in the buttons in the trailing"},{"type":"text","text":" "},{"code":"VStack","type":"codeVoice"},{"type":"text","text":" are the same width, which in turn gives the buttons equal widths."}]},{"type":"codeListing","code":["var body: some View {","    HStack(alignment: .top) {","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        .monospacedDigit()","    }","    .padding()","    .navigationTitle(\"monospacedDigit() Child Views\")","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"If a child view’s base font doesn’t support fixed-width digits, the font","type":"text"},{"text":" ","type":"text"},{"text":"remains unchanged.","type":"text"}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/view\/monospaceddigit()"]}],"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Button":{"type":"topic","navigatorTitle":[{"text":"Button","kind":"identifier"}],"title":"Button","url":"\/documentation\/openswiftui\/button","abstract":[],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button","role":"symbol","kind":"symbol","fragments":[{"text":"struct","kin