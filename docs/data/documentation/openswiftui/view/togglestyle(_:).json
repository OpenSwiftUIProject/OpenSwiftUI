2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use this modifier on a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true},{"type":"text","text":" instance to set a style that defines"},{"type":"text","text":" "},{"type":"text","text":"the control’s appearance and behavior. For example, you can choose"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true},{"type":"text","text":" style:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["Toggle(\"Vibrate on Ring\", isOn: $vibrateOnRing)","    .toggleStyle(.switch)"]},{"inlineContent":[{"type":"text","text":"Built-in styles typically have a similar appearance across platforms,"},{"type":"text","text":" "},{"type":"text","text":"tailored to the platform’s overall style:"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Platform"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Appearance"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"iOS, iPadOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]]},{"text":"Styling toggles in a hierarchy","anchor":"Styling-toggles-in-a-hierarchy","level":3,"type":"heading"},{"inlineContent":[{"text":"You can set a style for all toggle instances within a view hierarchy","type":"text"},{"text":" ","type":"text"},{"text":"by applying the style modifier to a container view. For example, you","type":"text"},{"text":" ","type":"text"},{"text":"can apply the ","type":"text"},{"code":"ToggleStyle\/button","type":"codeVoice"},{"text":" style to an ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["HStack {","    Toggle(isOn: $isFlagged) {","        Label(\"Flag\", systemImage: \"flag.fill\")","    }","    Toggle(isOn: $isMuted) {","        Label(\"Mute\", systemImage: \"speaker.slash.fill\")","    }","}",".toggleStyle(.button)"]},{"inlineContent":[{"text":"The example above has the following appearance when ","type":"text"},{"code":"isFlagged","type":"codeVoice"},{"text":" is","type":"text"},{"text":" ","type":"text"},{"code":"true","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"isMuted","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"false","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Appearance"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iOS, iPadOS"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]]]},{"text":"Automatic styling","anchor":"Automatic-styling","level":3,"type":"heading"},{"inlineContent":[{"text":"If you don’t set a style, OpenSwiftUI assumes a value of","type":"text"},{"text":" ","type":"text"},{"code":"ToggleStyle\/automatic","type":"codeVoice"},{"text":", which corresponds to a context-specific","type":"text"},{"text":" ","type":"text"},{"text":"default. Specify the automatic style explicitly to override a","type":"text"},{"text":" ","type":"text"},{"text":"container’s style and revert to the default:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["HStack {","    Toggle(isOn: $isShuffling) {","        Label(\"Shuffle\", systemImage: \"shuffle\")","    }","    Toggle(isOn: $isRepeating) {","        Label(\"Repeat\", systemImage: \"repeat\")","    }","","    Divider()","","    Toggle(\"Enhance Sound\", isOn: $isEnhanced)","        .toggleStyle(.automatic) \/\/ Revert to the default style.","}",".toggleStyle(.button) \/\/ Use button style for toggles in the stack.",".labelStyle(.iconOnly) \/\/ Omit the title from any labels."]},{"inlineContent":[{"type":"text","text":"The style that OpenSwiftUI uses as the default depends on both the platform"},{"type":"text","text":" "},{"type":"text","text":"and the context. In macOS, the default in most contexts is a"},{"type":"text","text":" "},{"type":"codeVoice","code":"ToggleStyle\/checkbox"},{"type":"text","text":", while in iOS, the default toggle style is a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true},{"type":"text","text":":"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Platform"}]}],[{"type":"paragraph","inlineContent":[{"text":"Appearance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS, iPadOS"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]]},{"content":[{"inlineContent":[{"text":"Like toggle style does for toggles, the ","type":"text"},{"code":"View\/labelStyle(_:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"modifier sets the style for ","type":"text"},{"code":"Label","type":"codeVoice"},{"text":" instances in the hierarchy. The","type":"text"},{"text":" ","type":"text"},{"text":"example above demostrates the compact ","type":"text"},{"code":"LabelStyle\/iconOnly","type":"codeVoice"},{"text":" style,","type":"text"},{"text":" ","type":"text"},{"text":"which is useful for button toggles in space-constrained contexts.","type":"text"},{"text":" ","type":"text"},{"text":"Always include a descriptive title for better accessibility.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"inlineContent":[{"type":"text","text":"For more information about how OpenSwiftUI chooses a default toggle style,"},{"type":"text","text":" "},{"type":"text","text":"see the "},{"code":"ToggleStyle\/automatic","type":"codeVoice"},{"type":"text","text":" style."}],"type":"paragraph"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Toggle":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","url":"\/documentation\/openswiftui\/toggle","navigatorTitle":[{"kind":"identifier","text":"Toggle"}],"type":"topic","abstract":[],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Toggle"}],"role":"symbol","kind":"symbol","title":"Toggle"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ToggleStyle":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"ToggleStyle"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle","role":"symbol","title":"ToggleStyle","type":"topic","url":"\/documentation\/openswiftui\/togglestyle","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"ToggleStyle"}],"abstract":[{"type":"text","text":"The appearance and behavior of a toggle."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ToggleStyle/switch":{"abstract":[],"role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","type":"topic","title":"switch","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":"