ype":"text","text":"This example shows a linear gauge tinted with a"},{"type":"text","text":" "},{"type":"text","text":"gradient from "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/blue"},{"type":"text","text":" to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/red"},{"type":"text","text":"."}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct ControlTint: View {","    var body: some View {","        Gauge(value: 75, in: 0...100) {","            Text(\"Temperature\")","        }","        .gaugeStyle(.linearCapacity)","        .tint(Gradient(colors: [.blue, .orange, .red]))","    }","}"]},{"inlineContent":[{"type":"text","text":"Some controls adapt to the tint color differently based on their style,"},{"type":"text","text":" "},{"type":"text","text":"the current platform, and the surrounding context. For example, in"},{"type":"text","text":" "},{"type":"text","text":"macOS, a button with the "},{"code":"PrimitiveButtonStyle\/bordered","type":"codeVoice"},{"type":"text","text":" style doesn’t"},{"type":"text","text":" "},{"type":"text","text":"tint its background, but one with the"},{"type":"text","text":" "},{"code":"PrimitiveButtonStyle\/borderedProminent","type":"codeVoice"},{"type":"text","text":" style does. In macOS, neither"},{"type":"text","text":" "},{"type":"text","text":"of these button styles tint their label, but they do in other platforms."}],"type":"paragraph"}]}],"kind":"symbol","sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/tint(_:)-8l4zc"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View/tint(_:)-8l4zc":{"title":"tint(_:)","type":"topic","kind":"symbol","fragments":[{"text":"func