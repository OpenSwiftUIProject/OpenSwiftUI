"text":"S","kind":"typeIdentifier"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"ShapeStyle","preciseIdentifier":"s:15OpenSwiftUICore10ShapeStyleP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The tint to apply.","type":"text"}]}],"name":"tint"}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Use this method to override the default accent color for this view with","type":"text"},{"text":" ","type":"text"},{"text":"a given styling. Unlike an app’s accent color, which can be","type":"text"},{"text":" ","type":"text"},{"text":"overridden by user preference, tint is always respected and should","type":"text"},{"text":" ","type":"text"},{"text":"be used as a way to provide additional meaning to the control.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Controls which are unable to style themselves using the given type of","type":"text"},{"text":" ","type":"text"},{"code":"ShapeStyle","type":"codeVoice"},{"text":" will try to approximate the styling as best as they can","type":"text"},{"text":" ","type":"text"},{"text":"(i.e. controls which can not style themselves using a gradient will","type":"text"},{"text":" ","type":"text"},{"text":"attempt to use the color of the gradient’s first stop).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example shows a linear gauge tinted with a"},{"type":"text","text":" "},{"type":"text","text":"gradient from "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/blue","type":"reference"},{"type":"text","text":" to "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/red","type":"reference"},{"type":"text","text":"."}]},{"syntax":"swift","type":"codeListing","code":["struct ControlTint: View {","    var body: some View {","        Gauge(value: 75, in: 0...100) {","            Text(\"Temperature\")","        }","        .gaugeStyle(.linearCapacity)","        .tint(Gradient(colors: [.blue, .orange, .red]))","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some controls adapt to the tint color differently based on their style,"},{"type":"text","text":" "},{"type":"text","text":"the current platform, and the surrounding context. For example, in"},{"type":"text","text":" "},{"type":"text","text":"macOS, a button with the "},{"type":"codeVoice","code":"PrimitiveButtonStyle\/bordered"},{"type":"text","text":" style doesn’t"},{"type":"text","text":" "},{"type":"text","text":"tint its background, but one with the"},{"type":"text","text":" "},{"type":"codeVoice","code":"PrimitiveButtonStyle\/borderedProminent"},{"type":"text","text":" style does. In macOS, neither"},{"type":"text","text":" "},{"type":"text","text":"of these button styles tint their label, but they do in other platforms."}]}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/view\/tint(_:)-8l4zc"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View/tint(_:)-8l4zc":{"abstract":[{"type":"text","text":"Sets the tint within this view."}],"ident