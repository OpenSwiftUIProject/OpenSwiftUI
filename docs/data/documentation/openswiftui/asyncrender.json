{"abstract":[{"type":"text","text":"Understand how OpenSwiftUI performs asynchronous rendering when hosted in UIKit views."}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"metadata":{"title":"Async Rendering in UIKit Integration","modules":[{"name":"OpenSwiftUI"}],"role":"collectionGroup"},"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenSwiftUI can perform view graph updates and display list rendering on a background thread to improve frame rates and reduce main thread blocking. This async rendering capability is particularly important for smooth animations."}]},{"type":"heading","level":2,"anchor":"Architecture","text":"Architecture"},{"type":"paragraph","inlineContent":[{"text":"The async rendering pipeline involves several key components:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"DisplayLink: Manages the render loop and switches between main thread and async thread rendering"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"ViewGraph: Provides ","type":"text"},{"code":"updateOutputsAsync","type":"codeVoice"},{"text":" to update the view graph on a background thread","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"UIHostingViewBase: Coordinates the rendering process and manages the display link","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"ViewRendererHost: Protocol that provides ","type":"text"},{"code":"render","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"renderAsync","type":"codeVoice"},{"text":" methods","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"heading","level":2,"anchor":"How-Async-Rendering-Works","text":"How Async Rendering Works"},{"type":"heading","level":3,"anchor":"The-Rendering-Flow","text":"The Rendering Flow"},{"type":"paragraph","inlineContent":[{"text":"When a view needs to update, the following sequence occurs:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"code":"DisplayLink","type":"codeVoice"},{"type":"text","text":" fires on a CADisplayLink callback"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"UIHostingViewBase.displayLinkTimer"},{"text":" is called with the current timestamp","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"isAsyncThread"},{"type":"text","text":" is true, "},{"type":"codeVoice","code":"ViewRendererHost.renderAsync"},{"type":"text","text":" is invoked"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"ViewGraph.updateOutputsAsync","type":"codeVoice"},{"text":" attempts to update outputs on the async thread","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"If successful, the display list is rendered asynchronously","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"If async update fails, rendering falls back to the main thread","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"type":"heading","level":3,"anchor":"The-Async-Thread","text":"The Async Thread"},{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenSwiftUI creates a dedicated async rendering thread:"}]},{"syntax":"swift","type":"codeListing","code":["thread.name = \"org.OpenSwiftUIProject.OpenSwiftUI.AsyncRenderer\"","thread.qualityOfService = .userInteractive"]},{"type":"paragraph","inlineContent":[{"text":"This thread runs a separate RunLoop and processes display link callbacks when async rendering is enabled.","type":"text"}]},{"type":"heading","level":2,"anchor":"Conditions-for-Async-Rendering","text":"Conditions for Async Rendering"},{"type":"paragraph","inlineContent":[{"text":"Async rendering is only possible when specific conditions are met. The ","type":"text"},{"type":"codeVoice","code":"updateOutputsAsync"},{"text":" method checks:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["guard _rootDisplayList.allowsAsyncUpdate(),","      hostPreferenceValues.allowsAsyncUpdate(),","      sizeThatFitsObservers.isEmpty || _rootLayoutComputer.allowsAsyncUpdate()","else {","    return nil","}"]},{"type":"heading","level":3,"anchor":"Key-Requirements","text":"Key Requirements"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"hostPreferenceValues must be non-nil: This attribute is set during "},{"type":"codeVoice","code":"instantiateOutputs"},{"type":"text","text":" when the view contains dynamic containers like "},{"type":"codeVoice","code":"ForEach"},{"type":"text","text":" or conditional views ("},{"type":"codeVoice","code":"if"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"else"},{"type":"text","text":")"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Attributes must allow async updates: An attribute allows async update when its value state does not contain both "},{"type":"codeVoice","code":"dirty"},{"type":"text","text":" and "},{"type":"codeVoice","code":"mainThread"},{"type":"text","text":" flags"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"No pending properties needing update: The host’s ","type":"text"},{"code":"propertiesNeedingUpdate","type":"codeVoice"},{"text":" must be empty","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"No pending transactions: The view graph must not have pending transactions"}]}]}],"type":"orderedList"},{"type":"heading","level":3,"anchor":"The-hostPreferenceValues-Requirement","text":"The hostPreferenceValues Requirement"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"hostPreferenceValues"},{"type":"text","text":" is set during "},{"type":"codeVoice","code":"ViewGraph.instantiateOutputs"},{"type":"text","text":":"}]},{"code":["hostPreferenceValues = WeakAttribute(outputs.preferences[HostPreferencesKey.self])"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This only works when the view hierarchy contains a ","type":"text"},{"type":"codeVoice","code":"DynamicContainer"},{"text":". Dynamic containers are created by:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ForEach"},{"text":" views","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Conditional content (","type":"text"},{"code":"if","type":"codeVoice"},{"text":"\/","type":"text"},{"code":"else","type":"codeVoice"},{"text":" statements)","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Optional view unwrapping","type":"text"}]}]}]},{"inlineContent":[{"text":"Without these dynamic elements, ","type":"text"},{"code":"hostPreferenceValues","type":"codeVoice"},{"text":" remains nil and ","type":"text"},{"code":"allowsAsyncUpdate()","type":"codeVoice"},{"text":" returns false.","type":"text"}],"type":"paragraph"},{"text":"Examples","level":2,"anchor":"Examples","type":"heading"},{"text":"Views That Support Async Rendering","level":3,"anchor":"Views-That-Support-Async-Rendering","type":"heading"},{"inlineContent":[{"text":"Views with dynamic content like ","type":"text"},{"code":"ForEach","type":"codeVoice"},{"text":" enable async rendering:","type":"text"}],"type":"paragraph"},{"code":["struct AsyncRenderExample: View {","    @State private var items = [6]","","    var body: some View {","        VStack(spacing: 10) {","            ForEach(items, id: \\.self) { item in","                Color.blue.opacity(Double(item) \/ 6.0)","                    .frame(height: 50)","                    .transition(.slide)","            }","        }","        .animation(.easeInOut(duration: 2), value: items)","        .onAppear {","            items.removeAll { $0 == 6 }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"In this example, the ","type":"text"},{"type":"codeVoice","code":"ForEach"},{"text":" creates a ","type":"text"},{"type":"codeVoice","code":"DynamicContainer"},{"text":", which sets up the ","type":"text"},{"type":"codeVoice","code":"hostPreferenceValues"},{"text":" attribute, enabling async rendering during the animation.","type":"text"}],"type":"paragraph"},{"text":"Views That Cannot Use Async Rendering","level":3,"anchor":"Views-That-Cannot-Use-Async-Rendering","type":"heading"},{"inlineContent":[{"type":"text","text":"Views without dynamic containers cannot use async rendering:"}],"type":"paragraph"},{"code":["struct NoAsyncRenderExample: View {","    @State private var showRed = false","","    var body: some View {","        VStack {","            Color(platformColor: showRed ? .red : .blue)","                .onAppear {","                    let animation = Animation.linear(duration: 5)","                        .logicallyComplete(after: 1)","                    withAnimation(animation, completionCriteria: .logicallyComplete) {","                        showRed.toggle()","                    } completion: {","                        print(\"Complete\")","                    }","                }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"This view has no ","type":"text"},{"type":"codeVoice","code":"ForEach"},{"text":" or conditional view structure. The color interpolation happens within a single view, so no ","type":"text"},{"type":"codeVoice","code":"DynamicContainer"},{"text":" is created and ","type":"text"},{"type":"codeVoice","code":"hostPreferenceValues"},{"text":" remains nil.","type":"text"}],"type":"paragraph"},{"text":"Debugging Tips","level":2,"anchor":"Debugging-Tips","type":"heading"},{"inlineContent":[{"type":"text","text":"To understand why async rendering is not enabled:"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Check if your view hierarchy contains ","type":"text"},{"code":"ForEach","type":"codeVoice"},{"text":" or conditional views","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Verify that animations are not using completion handlers that require main thread coordination"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the environment variable "},{"type":"codeVoice","code":"OPENSWIFTUI_PRINT_TREE=1"},{"type":"text","text":" to inspect the display list structure"}]}]}]}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncRender"},"kind":"article","variants":[{"paths":["\/documentation\/openswiftui\/asyncrender"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]}}}