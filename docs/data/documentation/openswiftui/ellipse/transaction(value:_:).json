.","type":"text"}],"type":"paragraph"}],"name":"transform"}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"return-value","text":"Return Value"},{"inlineContent":[{"type":"text","text":"A view that wraps this view and applies a transformation to"},{"type":"text","text":" "},{"type":"text","text":"all transactions used within the view whenever "},{"code":"value","type":"codeVoice"},{"type":"text","text":" changes."}],"type":"paragraph"}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to change or replace the animation used in a view."},{"type":"text","text":" "},{"type":"text","text":"Consider three identical views controlled by a"},{"type":"text","text":" "},{"type":"text","text":"button that changes all three simultaneously:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The first view animates rotating the “Rotation” "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" view by 360"},{"type":"text","text":" "},{"type":"text","text":"degrees."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The second uses the "},{"type":"codeVoice","code":"transaction(_:)"},{"type":"text","text":" modifier to change the"},{"type":"text","text":" "},{"type":"text","text":"animation by adding a delay to the start of the animation"},{"type":"text","text":" "},{"type":"text","text":"by two seconds and then increases the rotational speed of the"},{"type":"text","text":" "},{"type":"text","text":"“Rotation\\nModified” "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"type":"text","text":" view animation by a factor of 2."}]}]},{"content":[{"inlineContent":[{"text":"The third uses the ","type":"text"},{"code":"transaction(_:)","type":"codeVoice"},{"text":" modifier to disable animations","type":"text"},{"text":" ","type":"text"},{"text":"affecting the “Animation\\nReplaced” ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code implements these animations:"}]},{"type":"codeListing","code":["struct TransactionExample: View {","    @State var flag = false","","    var body: some View {","        VStack(spacing: 50) {","            HStack(spacing: 30) {","                Text(\"Rotation\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","","                Text(\"Rotation\\nModified\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","                    .transaction(value: flag) { t in","                        t.animation =","                            t.animation?.delay(2.0).speed(2)","                    }","","                Text(\"Animation\\nReplaced\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","                    .transaction(value: flag) { t in","                        t.disableAnimations = true","                    }","            }","","            Button(\"Animate\") {","                withAnimation(.easeIn(duration: 2.0)) {","                    flag.toggle()","                }","            }","        }","    }","}"],"syntax":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Ellipse"]]},"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Ellipse/transaction(value:_:)":{"role":"symbol","url":"\/documentation\/openswiftui\/ellipse\/transaction(value:_:)","type":"topic","abstract":[{"text":"Applies the given transaction mutation f