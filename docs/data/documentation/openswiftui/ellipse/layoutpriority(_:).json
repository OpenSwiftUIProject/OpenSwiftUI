     .border(Color.gray)","}"]},{"inlineContent":[{"type":"text","text":"In the example above, the first "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" element has the default"},{"type":"text","text":" "},{"type":"text","text":"priority "},{"code":"0","type":"codeVoice"},{"type":"text","text":" which causes its view to shrink dramatically due to the"},{"type":"text","text":" "},{"type":"text","text":"higher priority of the second "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" element, even though all of their"},{"type":"text","text":" "},{"type":"text","text":"other attributes (font, font size and character count) are the same."}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"A parent layout offers the child views with the highest layout priority"},{"type":"text","text":" "},{"type":"text","text":"all the space offered to the parent minus the minimum space required for"},{"type":"text","text":" "},{"type":"text","text":"all its lower-priority children."}],"type":"paragraph"}]}],"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Ellipse/layoutPriority(_:)":{"abstract":[{"text":"Sets the priority by which a parent layout should apportion space to","type":"text"},{"text":" ","type":"text"},{"text":"this child.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Ellipse\/layoutPriority(_:)","type":"topic","role":"symbol","title":"layoutPriority(_:)","kind":"symbol","url":"\/documentation\/openswiftui\/ellipse\/layoutpriority(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"layoutPriority","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Double","preciseIdentifier":"s:Sd","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"ke