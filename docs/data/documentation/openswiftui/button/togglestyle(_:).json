atform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Appearance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS, iPadOS"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]],"type":"table"},{"anchor":"Styling-toggles-in-a-hierarchy","text":"Styling toggles in a hierarchy","level":3,"type":"heading"},{"inlineContent":[{"type":"text","text":"You can set a style for all toggle instances within a view hierarchy"},{"type":"text","text":" "},{"type":"text","text":"by applying the style modifier to a container view. For example, you"},{"type":"text","text":" "},{"type":"text","text":"can apply the "},{"code":"ToggleStyle\/button","type":"codeVoice"},{"type":"text","text":" style to an "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","type":"reference"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["HStack {","    Toggle(isOn: $isFlagged) {","        Label(\"Flag\", systemImage: \"flag.fill\")","    }","    Toggle(isOn: $isMuted) {","        Label(\"Mute\", systemImage: \"speaker.slash.fill\")","    }","}",".toggleStyle(.button)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The example above has the following appearance when "},{"code":"isFlagged","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"code":"true","type":"codeVoice"},{"type":"text","text":" and "},{"code":"isMuted","type":"codeVoice"},{"type":"text","text":" is "},{"code":"false","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Platform"}]}],[{"inlineContent":[{"text":"Appearance","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iOS, iPadOS"}],"type":"paragraph"}],[{"inlineContent":[],"type":"para