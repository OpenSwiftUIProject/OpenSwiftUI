:"swift"},{"type":"paragraph","inlineContent":[{"text":"This can result in the view exceeding the parent’s bounds, which may or","type":"text"},{"text":" ","type":"text"},{"text":"may not be the effect you want.","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can think of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" as the creation of a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"counter proposal"}]},{"type":"text","text":" "},{"type":"text","text":"to the view size proposed to a view by its parent. The ideal size of a"},{"type":"text","text":" "},{"type":"text","text":"view, and the specific effects of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" depends on the"},{"type":"text","text":" "},{"type":"text","text":"particular view and how you have configured it."}]},{"type":"paragraph","inlineContent":[{"text":"To create a view that fixes the view’s size in either the horizontal or","type":"text"},{"text":" ","type":"text"},{"text":"vertical dimensions, see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)"},{"text":".","type":"text"}]}]}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button"]]},"schemaVersion":{"major":0,"minor":3,"patch":0},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Button/fixedSize()":{"type":"topic","url":"\/documentation\/openswiftui\/button\/fixedsize()","abstract":[{"text":"Fixes this view at its ideal size.","type":"text"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"fixedSize"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftU