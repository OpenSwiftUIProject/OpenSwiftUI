{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/CustomAnimation"]]},"abstract":[{"type":"text","text":"Determines whether an instance of the animation can merge with other"},{"type":"text","text":" "},{"type":"text","text":"instance of the same type."}],"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"shouldMerge"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"externalParam","text":"previous"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV","text":"Animation","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation"},{"kind":"text","text":", "},{"kind":"externalParam","text":"value"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":", "},{"kind":"externalParam","text":"time"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@NSTimeInterval","text":"TimeInterval"},{"kind":"text","text":", "},{"kind":"externalParam","text":"context"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore16AnimationContextV","text":"AnimationContext","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationContext"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":">) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore16VectorArithmeticP","text":"VectorArithmetic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VectorArithmetic"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"previous","content":[{"type":"paragraph","inlineContent":[{"text":"The previous running animation.","type":"text"}]}]},{"name":"value","content":[{"inlineContent":[{"type":"text","text":"The vector to animate towards."}],"type":"paragraph"}]},{"name":"time","content":[{"inlineContent":[{"type":"text","text":"The amount of time since the start of the previous animation."}],"type":"paragraph"}]},{"name":"context","content":[{"type":"paragraph","inlineContent":[{"text":"An instance of ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationContext","isActive":true,"type":"reference"},{"text":" that provides access","type":"text"},{"text":" ","type":"text"},{"text":"to state and the animation environment.","type":"text"}]}]}]},{"kind":"content","content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"A Boolean value of "},{"type":"codeVoice","code":"true"},{"type":"text","text":" if the animation should merge with"},{"type":"text","text":" "},{"type":"text","text":"the previous animation; otherwise, "},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}],"type":"paragraph"}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"inlineContent":[{"text":"When a view creates a new animation on an animatable value that already","type":"text"},{"text":" ","type":"text"},{"text":"has a running animation of the same animation type, the system calls","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"shouldMerge(previous:value:time:context:)","type":"codeVoice"},{"text":" method on the new","type":"text"},{"text":" ","type":"text"},{"text":"instance to determine whether it can merge the two instance. Implement","type":"text"},{"text":" ","type":"text"},{"text":"this method if the animation can merge with another instance. The","type":"text"},{"text":" ","type":"text"},{"text":"default implementation returns ","type":"text"},{"code":"false","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If "},{"type":"codeVoice","code":"shouldMerge(previous:value:time:context:)"},{"type":"text","text":" returns "},{"type":"codeVoice","code":"true"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"system merges the new animation instance with the previous animation."},{"type":"text","text":" "},{"type":"text","text":"The system provides to the new instance the state and elapsed time from"},{"type":"text","text":" "},{"type":"text","text":"the previous one. Then it removes the previous animation."}],"type":"paragraph"},{"inlineContent":[{"text":"If this method returns ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", the system doesn’t merge the animation","type":"text"},{"text":" ","type":"text"},{"text":"with the previous one. Instead, both animations run together and the","type":"text"},{"text":" ","type":"text"},{"text":"system combines their results.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If your custom animation needs to maintain state between calls to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"shouldMerge(previous:value:time:context:)"},{"type":"text","text":" method, store the state"},{"type":"text","text":" "},{"type":"text","text":"data in "},{"type":"codeVoice","code":"context"},{"type":"text","text":". This makes the data available to the method next"},{"type":"text","text":" "},{"type":"text","text":"time the system calls it. To learn more, see "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationContext","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]}],"sections":[],"metadata":{"title":"shouldMerge(previous:value:time:context:)","externalID":"s:15OpenSwiftUICore15CustomAnimationP11shouldMerge8previous5value4time7contextSbAA0E0V_qd__SdAA0E7ContextVyqd__GztAA16VectorArithmeticRd__lF","remoteSource":{"fileName":"CustomAnimation.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Animation\/Animation\/CustomAnimation.swift#L178"},"modules":[{"name":"OpenSwiftUI"}],"required":true,"roleHeading":"Instance Method","platforms":[{"beta":false,"unavailable":false,"name":"iOS","introducedAt":"13.0","deprecated":false},{"beta":false,"unavailable":false,"name":"macOS","introducedAt":"10.15","deprecated":false},{"beta":false,"unavailable":false,"name":"tvOS","introducedAt":"13.0","deprecated":false},{"beta":false,"unavailable":false,"name":"visionOS","introducedAt":"1.0","deprecated":false},{"beta":false,"unavailable":false,"name":"watchOS","introducedAt":"6.0","deprecated":false}],"role":"symbol","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"shouldMerge"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"externalParam","text":"previous"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV","text":"Animation"},{"kind":"text","text":", "},{"kind":"externalParam","text":"value"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":", "},{"kind":"externalParam","text":"time"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@NSTimeInterval","text":"TimeInterval"},{"kind":"text","text":", "},{"kind":"externalParam","text":"context"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s