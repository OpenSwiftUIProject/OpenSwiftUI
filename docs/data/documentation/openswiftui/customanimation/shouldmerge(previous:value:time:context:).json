ifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VectorArithmetic","text":"VectorArithmetic"}]}]},{"kind":"parameters","parameters":[{"name":"previous","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The previous running animation."}]}]},{"name":"value","content":[{"inlineContent":[{"text":"The vector to animate towards.","type":"text"}],"type":"paragraph"}]},{"name":"time","content":[{"inlineContent":[{"type":"text","text":"The amount of time since the start of the previous animation."}],"type":"paragraph"}]},{"name":"context","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An instance of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationContext"},{"type":"text","text":" that provides access"},{"type":"text","text":" "},{"type":"text","text":"to state and the animation environment."}]}]}]},{"kind":"content","content":[{"anchor":"return-value","text":"Return Value","level":2,"type":"heading"},{"inlineContent":[{"text":"A Boolean value of ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" if the animation should merge with","type":"text"},{"text":" ","type":"text"},{"text":"the previous animation; otherwise, ","type":"text"},{"type":"codeVoice","code":"false"},{"text":".","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"When a view creates a new animation on an animatable value that already"},{"type":"text","text":" "},{"type":"text","text":"has a running animation of the same animation type, the system calls"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"codeVoice","code":"shouldMerge(previous:value:time:context:)"},{"type":"text","text":" method on the new"},{"type":"text","text":" "},{"type":"text","text":"instance to determine whether it can merge the two instance. Implement"},{"type":"text","text":" "},{"type":"text","text":"this method if the animation can merge with another instance. The"},{"type":"text","text":" "},{"type":"text","text":"default implementation returns "},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"type":"codeVoice","code":"shouldMerge(previous:value:time:context:)"},{"text":" returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":", the","type":"text"},{"text":" ","type":"text"},{"text":"system merges the new animation instance with the previous animation.","type":"text"},{"text":" ","type":"text"},{"text":"The system provides to the new instance the state and elapsed time from","type":"text"},{"text":" ","type":"text"},{"text":"the previous one. Then it removes the previous animation.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If this method returns "},{"type":"codeVoice","code":"false"},{"type":"text","text":", the system doesn’t merge the animation"},{"type":"text","text":" "},{"type":"text","text":"with the previous one. Instead, both animations run together and the"},{"type":"text","text":" "},{"type":"text","text":"system combines their results."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If your custom animation needs to maintain state between calls to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"shouldMerge(previous:value:time:context:)"},{"type":"text","text":" method, store the state"},{"type":"text","text":" "},{"type":"text","text":"data in "},{"type":"codeVoice","code":"context"},{"type":"text","text":". This makes the data available to the method next"},{"type":"text","text":" "},{"type":"text","text":"time the system calls it. To learn more, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationContext"},{"type":"text","text":"."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfac