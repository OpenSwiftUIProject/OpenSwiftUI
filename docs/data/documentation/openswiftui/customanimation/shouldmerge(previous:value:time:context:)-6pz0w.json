{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/CustomAnimation"]]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"shouldMerge"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"externalParam","text":"previous"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore9AnimationV","text":"Animation","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation"},{"kind":"text","text":", "},{"kind":"externalParam","text":"value"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":", "},{"kind":"externalParam","text":"time"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"c:@T@NSTimeInterval","text":"TimeInterval"},{"kind":"text","text":", "},{"kind":"externalParam","text":"context"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore16AnimationContextV","text":"AnimationContext","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationContext"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":">) -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":" : "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore16VectorArithmeticP","text":"VectorArithmetic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VectorArithmetic"}],"languages":["swift"],"platforms":["macOS"]}]},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The previous running animation.","type":"text"}]}],"name":"previous"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The vector to animate towards."}]}],"name":"value"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The amount of time since the start of the previous animation.","type":"text"}]}],"name":"time"},{"content":[{"type":"paragraph","inlineContent":[{"text":"An instance of ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationContext","type":"reference","isActive":true},{"text":" that provides access","type":"text"},{"text":" ","type":"text"},{"text":"to state and the animation environment.","type":"text"}]}],"name":"context"}],"kind":"parameters"},{"content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A Boolean value of "},{"type":"codeVoice","code":"true"},{"type":"text","text":" if the animation should merge with"},{"type":"text","text":" "},{"type":"text","text":"the previous animation; otherwise, "},{"type":"codeVoice","code":"false"},{"type":"text","text":"."}]}],"kind":"content"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"When a view creates a new animation on an animatable value that already","type":"text"},{"text":" ","type":"text"},{"text":"has a running animation of the same animation type, the system calls","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"code":"shouldMerge(previous:value:time:context:)","type":"codeVoice"},{"text":" method on the new","type":"text"},{"text":" ","type":"text"},{"text":"instance to determine whether it can merge the two instance. Implement","type":"text"},{"text":" ","type":"text"},{"text":"this method if the animation can merge with another instance. The","type":"text"},{"text":" ","type":"text"},{"text":"default implementation returns ","type":"text"},{"code":"false","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If ","type":"text"},{"code":"shouldMerge(previous:value:time:context:)","type":"codeVoice"},{"type":"text","text":" returns "},{"code":"true","type":"codeVoice"},{"type":"text","text":", the"},{"type":"text","text":" "},{"type":"text","text":"system merges the new animation instance with the previous animation."},{"type":"text","text":" "},{"type":"text","text":"The system provides to the new instance the state and elapsed time from"},{"type":"text","text":" "},{"type":"text","text":"the previous one. Then it removes the previous animation."}],"type":"paragraph"},{"inlineContent":[{"text":"If this method returns ","type":"text"},{"code":"false","type":"codeVoice"},{"text":", the system doesn’t merge the animation","type":"text"},{"text":" ","type":"text"},{"text":"with the previous one. Instead, both animations run together and the","type":"text"},{"text":" ","type":"text"},{"text":"system combines their results.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If your custom animation needs to maintain state between calls to the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"shouldMerge(previous:value:time:context:)"},{"text":" method, store the state","type":"text"},{"text":" ","type":"text"},{"text":"data in ","type":"text"},{"type":"codeVoice","code":"context"},{"text":". This makes the data available to the method next","type":"text"},{"text":" ","type":"text"},{"text":"time the system calls it. To learn more, see ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationContext","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"Determines whether an instance of the animation can merge with other"},{"type":"text","text":" "},{"type":"text","text":"instance of the same type."}],"kind":"symbol","identifier":{"url":"doc:\/\/Open