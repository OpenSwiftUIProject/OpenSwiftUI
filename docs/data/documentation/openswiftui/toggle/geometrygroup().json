{"kind":"symbol","abstract":[{"text":"Isolates the geometry (e.g. position and size) of the view","type":"text"},{"text":" ","type":"text"},{"text":"from its parent view.","type":"text"}],"sections":[],"variants":[{"paths":["\/documentation\/openswiftui\/toggle\/geometrygroup()"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle\/geometryGroup()"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":"\n","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","anchor":"discussion","level":2},{"inlineContent":[{"type":"text","text":"By default OpenSwiftUI views push position and size changes down"},{"type":"text","text":" "},{"type":"text","text":"through the view hierarchy, so that only views that draw"},{"type":"text","text":" "},{"type":"text","text":"something (known as leaf views) apply the current animation to"},{"type":"text","text":" "},{"type":"text","text":"their frame rectangle. However in some cases this coalescing"},{"type":"text","text":" "},{"type":"text","text":"behavior can give undesirable results; inserting a geometry"},{"type":"text","text":" "},{"type":"text","text":"group can correct that. A group acts as a barrier between the"},{"type":"text","text":" "},{"type":"text","text":"parent view and its subviews, forcing the position and size"},{"type":"text","text":" "},{"type":"text","text":"values to be resolved and animated by the parent, before being"},{"type":"text","text":" "},{"type":"text","text":"passed down to each subview."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The example below shows one use of this function: ensuring that"},{"type":"text","text":" "},{"type":"text","text":"the member views of each row in the stack apply (and animate"},{"type":"text","text":" "},{"type":"text","text":"as) a single geometric transform from their ancestor view,"},{"type":"text","text":" "},{"type":"text","text":"rather than letting the effects of the ancestor views be"},{"type":"text","text":" "},{"type":"text","text":"applied separately to each leaf view. If the members of"},{"type":"text","text":" "},{"type":"codeVoice","code":"ItemView"},{"type":"text","text":" may be added and removed at different times the"},{"type":"text","text":" "},{"type":"text","text":"group ensures that they stay locked together as animations are"},{"type":"text","text":" "},{"type":"text","text":"applied."}],"type":"paragraph"},{"code":["VStack {","    ForEach(items) { item in","        ItemView(item: item)","            .geometryGroup()","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Returns: a new view whose geometry is isolated from that of its","type":"text"},{"text":" ","type":"text"},{"text":"parent view.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle"]]},"metadata":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}],"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"role":"symbol","externalID":"s:15OpenSwiftUICore4ViewPAAE13geometryGroupQryF::SYNTHESIZED::s:11OpenSwiftUI6ToggleV","title":"geometryGroup()","extendedModule":"OpenSwiftUICore","roleHeading":"Instance Method","platforms":[{"beta":false,"deprecated":false,"introducedAt":"13.0","unavailable":false,"name":"iOS"},{"beta":false,"deprecated":false,"introducedAt":"10.15","unavailable":false,"name":"macOS"},{"beta":false,"deprecated":false,"introducedAt":"13.0","unavailable":false,"name":"tvOS"},{"beta":false,"deprecated":false,"introducedAt":"1.0","unavailable":false,"name":"visionOS"},{"beta":false,"deprecated":false,"introducedAt":"6.0","unavailable":false,"name":"watchOS"}],"symbolKind":"method","remoteSource":{"fileName":"RendererEffect.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Render\/RendererEffect\/RendererEffect.swift#L294"}},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Toggle":{"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Toggle"}],"role":"symbol","url":"\/documentation\/openswiftui\/toggle","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Toggle"}],"title":"Toggle","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","abstract":[]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Toggle/geometryGroup()":{"url":"\/documentation\/openswiftui\/toggle\/geometrygroup()","type":"topic","kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle\/geometryGroup()","title":"geometryGroup()","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}],"abstract":[{"type":"text","text":"Isolates the geometry (e.g. position and size) of the view"},{"type":"text","text":" "},{"type":"tex