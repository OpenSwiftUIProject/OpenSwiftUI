ext"},{"text":"observed value has its new value. The old and new observed values are","type":"text"},{"text":" ","type":"text"},{"text":"passed into the closure. In the following code example, ","type":"text"},{"type":"codeVoice","code":"PlayerView"},{"text":" ","type":"text"},{"text":"passes both the old and new values to the model.","type":"text"}],"type":"paragraph"},{"code":["struct PlayerView: View {","    var episode: Episode","    @State private var playState: PlayState = .paused","","    var body: some View {","        VStack {","            Text(episode.title)","            Text(episode.showTitle)","            PlayButton(playState: $playState)","        }","        .onChange(of: playState) { oldState, newState in","            model.playStateDidChange(from: oldState, to: newState)","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"metadata":{"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Modifier\/ViewModifier\/ValueActionModifier.swift#L263","fileName":"ValueActionModifier.swift"},"title":"onChange(of:initial:_:)","roleHeading":"Instance Method","extendedModule":"OpenSwiftUICore","platforms":[{"beta":false,"introducedAt":"13.0","deprecated":false,"unavailable":false,"name":"iOS"},{"beta":false,"introducedAt":"10.15","deprecated":false,"unavailable":false,"name":"macOS"},{"beta":false,"introducedAt":"13.0","deprecated":false,"unavailable":false,"name":"tvOS"},{"beta":false,"introducedAt":"1.0","deprecated":false,"unavailable":false,"name":"visionOS"},{"beta":false,"introducedAt":"6.0","deprecated":false,"unavailable":false,"name":"watchOS"}],"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"role":"symbol","externalID":"s:15OpenSwiftUICore4ViewPAAE8onChange2of7initial_Qrqd___Sbyqd___qd__tctSQRd__lF::SYNTHESIZED::s:11OpenSwiftUI6ToggleV","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier