.description)","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The timeline view updates its content at the start date, and then"},{"type":"text","text":" "},{"type":"text","text":"again at dates separated in time by the interval amount, which is every"},{"type":"text","text":" "},{"type":"text","text":"three seconds in the example above. For a start date in the"},{"type":"text","text":" "},{"type":"text","text":"past, the view updates immediately, providing as context the date"},{"type":"text","text":" "},{"type":"text","text":"corresponding to the most recent interval boundary. The view then"},{"type":"text","text":" "},{"type":"text","text":"refreshes normally at subsequent interval boundaries. For a start date"},{"type":"text","text":" "},{"type":"text","text":"in the future, the view updates once with the current date, and then"},{"type":"text","text":" "},{"type":"text","text":"begins regular updates at the start date."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The schedule defines the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/PeriodicTimelineSchedule\/Entries"},{"type":"text","text":" "},{"type":"text","text":"structure to return the sequence of dates when the timeline view calls"},{"type":"text","text":" "},{"type":"text","text":"the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/PeriodicTimelineSchedule\/entries(from:mode:)"},{"type":"text","text":" method."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineSchedule"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"role":"symbol","platforms":[{"introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false,"name":"iOS"},{"introducedAt":"10.15","deprecated":false,"unavailable":false,"beta":fals