":"text"}]}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Initialize a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView"},{"type":"text","text":" with an explicit timeline schedule when"},{"type":"text","text":" "},{"type":"text","text":"you want to schedule view updates at particular points in time:"}]},{"syntax":"swift","code":["let dates = [","    Date(timeIntervalSinceNow: 10), \/\/ Update ten seconds from now,","    Date(timeIntervalSinceNow: 12) \/\/ and a few seconds later.","]","","struct MyView: View {","    var body: some View {","        TimelineView(.explicit(dates)) { context in","            Text(context.date.description)","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The timeline view updates its content on exactly the dates that"},{"type":"text","text":" "},{"type":"text","text":"you specify, until it runs out of dates, after which it stops changing."},{"type":"text","text":" "},{"type":"text","text":"If the dates you provide are in the past, the timeline view updates"},{"type":"text","text":" "},{"type":"text","text":"exactly once with the last entry. If you only provide dates in the"},{"type":"text","text":" "},{"type":"text","text":"future, the timeline view renders with the current date until the first"},{"type":"text","text":" "},{"type":"text","text":"date arrives. If you provide one or more dates in the past and one or"},{"type":"text","text":" "},{"type":"text","text":"more in the future, the view renders the most recent past date,"},{"type":"text","text":" "},{"type":"text","text":"refreshing normally on all subsequent dates."}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineSchedule\/explicit(_:)"},"hierarchy":{"paths":[["doc:\/\/OpenSwif