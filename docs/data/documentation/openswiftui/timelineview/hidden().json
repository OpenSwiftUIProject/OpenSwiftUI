{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView"]]},"abstract":[{"type":"text","text":"Hides this view unconditionally."}],"sections":[],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"hidden","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":"\n","kind":"text"}],"platforms":["macOS"]}]},{"content":[{"anchor":"return-value","level":2,"type":"heading","text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"A hidden view.","type":"text"}]}],"kind":"content"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Hidden views are invisible and can’t receive or respond to interactions.","type":"text"},{"text":" ","type":"text"},{"text":"However, they do remain in the view hierarchy and affect layout. Use","type":"text"},{"text":" ","type":"text"},{"text":"this modifier if you want to include a view for layout purposes, but","type":"text"},{"text":" ","type":"text"},{"text":"don’t want it to display.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["HStack {","    Image(systemName: \"a.circle.fill\")","    Image(systemName: \"b.circle.fill\")","    Image(systemName: \"c.circle.fill\")","        .hidden()","    Image(systemName: \"d.circle.fill\")","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The third circle takes up space, because it’s still present, but"},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI doesn’t draw it onscreen."}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to conditionally include a view in the view hierarchy, use"},{"type":"text","text":" "},{"type":"text","text":"an "},{"type":"codeVoice","code":"if"},{"type":"text","text":" statement instead:"}]},{"type":"codeListing","syntax":"swift","code":["VStack {","    HStack {","        Image(systemName: \"a.circle.fill\")","        Image(systemName: \"b.circle.fill\")","        if !isHidden {","            Image(systemName: \"c.circle.fill\")","        }","        Image(systemName: \"d.circle.fill\")","    }","    Toggle(\"Hide\", isOn: $isHidden)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Depending on the current value of the "},{"type":"codeVoice","code":"isHidden"},{"type":"text","text":" state variable in the"},{"type":"text","text":" "},{"type":"text","text":"example above, controlled by the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true},{"type":"text","text":" instance, OpenSwiftUI draws"},{"type":"text","text":" "},{"type":"text","text":"the circle or completely omits it from the layout."}]},{"type":"paragraph","inlineContent":[]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/timelineview\/hidden()"]}],"metadata":{"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"roleHeading":"Instance Method","role":"symbol","title":"hidden()","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"hidden"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"}],"extendedModule":"OpenSwiftUICore","externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE6hiddenQr