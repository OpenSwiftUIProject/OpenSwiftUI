,{"text":"(i.e. controls which can not style themselves using a gradient will","type":"text"},{"text":" ","type":"text"},{"text":"attempt to use the color of the gradient’s first stop).","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example shows a linear gauge tinted with a"},{"type":"text","text":" "},{"type":"text","text":"gradient from "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/blue","isActive":true},{"type":"text","text":" to "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/red","isActive":true},{"type":"text","text":"."}]},{"type":"codeListing","code":["struct ControlTint: View {","    var body: some View {","        Gauge(value: 75, in: 0...100) {","            Text(\"Temperature\")","        }","        .gaugeStyle(.linearCapacity)","        .tint(Gradient(colors: [.blue, .orange, .red]))","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Some controls adapt to the tint color differently based on their style,","type":"text"},{"text":" ","type":"text"},{"text":"the current platform, and the surrounding context. For example, in","type":"text"},{"text":" ","type":"text"},{"text":"macOS, a button with the ","type":"text"},{"code":"PrimitiveButtonStyle\/bordered","type":"codeVoice"},{"text":" style doesn’t","type":"text"},{"text":" ","type":"text"},{"text":"tint its background, but one with the","type":"text"},{"text":" ","type":"text"},{"code":"PrimitiveButtonStyle\/borderedProminent","type":"codeVoice"},{"text":" style does. In macOS, neither","type":"text"},{"text":" ","type":"text"},{"text":"of these button styles tint their label, but they do in other platforms.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/timelineview\/tint(_:)-4c5ho"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ShapeStyle/blue":{"abstract":