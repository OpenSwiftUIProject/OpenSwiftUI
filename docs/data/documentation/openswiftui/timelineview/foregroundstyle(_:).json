{"sections":[],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView\/foregroundStyle(_:)","interfaceLanguage":"swift"},"abstract":[{"text":"Sets a view’s foreground elements to use a given style.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/timelineview\/foregroundstyle(_:)"]}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"foregroundStyle"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"style"},{"text":": ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore10ShapeStyleP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","text":"ShapeStyle","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"name":"style","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The color or pattern to use when filling in the"},{"type":"text","text":" "},{"type":"text","text":"foreground elements. To indicate a specific value, use "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","isActive":true},{"type":"text","text":" or"},{"type":"text","text":" "},{"code":"ShapeStyle\/image(_:sourceRect:scale:)","type":"codeVoice"},{"type":"text","text":", or one of the gradient"},{"type":"text","text":" "},{"type":"text","text":"types, like"},{"type":"text","text":" "},{"code":"ShapeStyle\/linearGradient(colors:startPoint:endPoint:)","type":"codeVoice"},{"type":"text","text":". To set a"},{"type":"text","text":" "},{"type":"text","text":"style that’s relative to the containing view’s style, use one of the"},{"type":"text","text":" "},{"type":"text","text":"semantic styles, like "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/primary","isActive":true},{"type":"text","text":"."}]}]}],"kind":"parameters"},{"content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"A view that uses the given foreground style.","type":"text"}]}],"kind":"content"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"Use this method to style","type":"text"},{"text":" ","type":"text"},{"text":"foreground content like text, shapes, and template images","type":"text"},{"text":" ","type":"text"},{"text":"(including symbols):","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["HStack {","    Image(systemName: \"triangle.fill\")","    Text(\"Hello, world!\")","    RoundedRectangle(cornerRadius: 5)","        .frame(width: 40, height: 20)","}",".foregroundStyle(.teal)"]},{"inlineContent":[{"type":"text","text":"The example above creates a row of "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/teal"},{"type":"text","text":" foreground"},{"type":"text","text":" "},{"type":"text","text":"elements:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"You can use any style that conforms to the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle"},{"text":" protocol,","type":"text"},{"text":" ","type":"text"},{"text":"like the ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/teal"},{"text":" color in the example above, or the","type":"text"},{"text":" ","type":"text"},{"code":"ShapeStyle\/linearGradient(colors:startPoint:endPoint:)","type":"codeVoice"},{"text":" gradient","type":"text"},{"text":" ","type":"text"},{"text":"shown below:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["Text(\"Gradient Text\")","    .font(.largeTitle)","    .foregroundStyle(","        .linearGradient(","            colors: [.yellow, .blue],","            startPoint: .top,","            endPoint: .bottom","        )","    )"]},{"inlineContent":[],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"If you want to fill a single ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape","type":"reference","isActive":true},{"text":" instance with a style,","type":"text"},{"text":" ","type":"text"},{"text":"use the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape\/fill(style:)","type":"reference","isActive":true},{"text":" shape modifier instead because it’s more","type":"text"},{"text":" ","type":"text"},{"text":"efficient.","type":"text"}],"type":"paragraph"}],"style":"tip","type":"aside","name":"Tip"},{"inlineContent":[{"type":"text","text":"OpenSwiftUI creates a context-dependent render for a given style."},{"type":"text","text":" "},{"type":"text","text":"For example, a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color"},{"type":"text","text":" that you load from an asset catalog"},{"type":"text","text":" "},{"type":"text","text":"can have different light and dark appearances, while some styles"},{"type":"text","text":" "},{"type":"text","text":"also vary by platform."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Hierarchical foreground styles like "},{"code":"ShapeStyle\/secondary","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"don’t impose a style of their own, but instead modify other styles."},{"type":"text","text":" "},{"type":"text","text":"In particular, they modify the primary"},{"type":"text","text":" "},{"type":"text","text":"level of the current foreground style to the degree given by"},{"type":"text","text":" "},{"type":"text","text":"the hierarchical style’s name."},{"type":"text","text":" "},{"type":"text","text":"To find the current foreground style to modify, OpenSwiftUI looks for"},{"type":"text","text":" "},{"type":"text","text":"the innermost containing style that you apply with the"},{"type":"text","text":" "},{"code":"foregroundStyle(_:)","type":"codeVoice"},{"type":"text","text":" or the "},{"code":"View\/foregroundColor(_:)","type":"codeVoice"},{"type":"text","text":" modifier."},{"type":"text","text":" "},{"type":"text","text":"If you haven’t specified a style, OpenSwiftUI uses the default foreground"},{"type":"text","text":" "},{"type":"text","text":"style, as in the following example:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["VStack(alignment: .leading) {","    Label(\"Primary\", systemImage: \"1.square.fill\")","    Label(\"Secondary\", systemImage: \"2.square.fill\")","        .foregroundStyle(.secondary)","}"]},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"If you add a foreground style on the enclosing","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"text":", the hierarchical styling responds accordingly:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["VStack(alignment: .leading) {","    Label(\"Primary\", systemImage: \"1.square.fill\")","    Label(\"Secondary\", systemImage: \"2.square.fill\")","        .foregroundStyle(.secondary)","}",".foregroundStyle(.blue)"]},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When you apply a custom style to a view, the view disables the vibrancy"},{"type":"text","text":" "},{"type":"text","text":"effect for foreground elements in that view, or in any of its child"},{"type":"text","text":" "},{"type":"text","text":"views, that it would otherwise gain from adding a background material"},{"type":"text","text":" "},{"type":"text","text":"— for example, using the "},{"code":"View\/background(_:ignoresSafeAreaEdges:)","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"modifier. However, hierarchical styles applied to the default foreground"},{"type":"text","text":" "},{"type":"text","text":"don’t disable vibrancy."}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView"]]},"metadata":{"platforms":[{"beta":false,"introducedAt":"13.0","unavailable":false,"name":"iOS","deprecated":false},{"beta":false,"introducedAt":"10.15","unavailable":false,"name":"macOS","deprecated":false},{"beta":false,"introducedAt":"13.0","unavailable":false,"name":"tvOS","deprecated":false},{"beta":false,"introducedAt":"1.0","unavailable":false,"name":"visionOS","deprecated":false},{"beta":false,"introducedAt":"6.0","unavailable":false,"name":"watchOS","deprecated":false}],"symbolKind":"method","extendedModule":"OpenSwiftUICore","externalID":"s:15OpenSwiftUICore4ViewPAAE15foregroundStyleyQrqd__AA05ShapeF0Rd__lF::SYNTHESIZED::s:11OpenSwiftUI12TimelineViewV","role":"symbol","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"foregroundStyle","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},