"preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"extendedModule":"OpenSwiftUICore"},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"transaction"},{"kind":"text","text":"("},{"kind":"externalParam","text":"value"},{"kind":"text","text":": "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Equatable","preciseIdentifier":"s:SQ"},{"kind":"text","text":", "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"transform"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore11TransactionV","kind":"typeIdentifier","text":"Transaction","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Transaction"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"kind":"text","text":"\n"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A value to monitor for changes.","type":"text"}]}],"name":"value"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The transformation to apply to transactions","type":"text"},{"text":" ","type":"text"},{"text":"within this view.","type":"text"}]}],"name":"transform"}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"inlineContent":[{"text":"A view that wraps this view and applies a transformation to","type":"text"},{"text":" ","type":"text"},{"text":"all transactions used within the view whenever ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" changes.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier to change or replace the animation used in a view.","type":"text"},{"text":" ","type":"text"},{"text":"Consider three identical views controlled by a","type":"text"},{"text":" ","type":"text"},{"text":"button that changes all three simultaneously:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The first view animates rotating the “Rotation” "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"type":"text","text":" view by 360"},{"type":"text","text":" "},{"type":"text","text":"degrees."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The second uses the ","type":"text"},{"code":"transaction(_:)","type":"codeVoice"},{"text":" modifier to change the","type":"text"},{"text":" ","type":"text"},{"text":"animation by adding a delay to the start of the animation","type":"text"},{"text":" ","type":"text"},{"text":"by two seconds and then increases the rotational speed of the","type":"text"},{"text":" ","type":"text"},{"text":"“Rotation\\nModified” ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view animation by a factor of 2.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The third uses the "},{"type":"codeVoice","code":"transaction(_:)"},{"type":"text","text":" modifier to disable animations"},{"type":"text","text":" "},{"type":"text","text":"affecting the “Animation\\nReplaced” "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" view."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following code implements these animations:"}]},{"code":["struct TransactionExample: View {","    @State var flag = false","","    var body: some View {","        VStack(spacing: 50) {","            HStack(spacing: 30) {","                Text(\"Rotation\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","","                Text(\"Rotation\\nModified\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","                    .transaction(value: flag) { t in","                        t.animation =","                            t.animation?.delay(2.0).speed(2)","                    }","","                Text(\"Animation\\nReplaced\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","                    .transaction(value: flag) { t in","                        t.disableAnimations = true","                    }","            }","","            Button(\"Animate\") {","                withAnimation(.easeIn(duration: 2.0)) {","                    flag.toggle()","                }","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"}]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView\/transaction(value:_:)","interfaceLanguage":"swift"},"abstract":[{"text":"Applies the given transaction mutation function to all animations used","type":"text"},{"text":" ","type":"text"},{"text":"within the view.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/timelineview\/transaction(value:_:)"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Text":{"url":"\/documentation\/openswiftui\/text","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Text"}],"title":"Text","abstract":[],"role":"symbol","identifier