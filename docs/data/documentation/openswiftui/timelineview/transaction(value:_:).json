":"transform"}],"kind":"parameters"},{"content":[{"text":"Return Value","level":2,"anchor":"return-value","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that wraps this view and applies a transformation to"},{"type":"text","text":" "},{"type":"text","text":"all transactions used within the view whenever "},{"type":"codeVoice","code":"value"},{"type":"text","text":" changes."}]}],"kind":"content"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to change or replace the animation used in a view."},{"type":"text","text":" "},{"type":"text","text":"Consider three identical views controlled by a"},{"type":"text","text":" "},{"type":"text","text":"button that changes all three simultaneously:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The first view animates rotating the “Rotation” ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"text":" view by 360","type":"text"},{"text":" ","type":"text"},{"text":"degrees.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The second uses the ","type":"text"},{"code":"transaction(_:)","type":"codeVoice"},{"text":" modifier to change the","type":"text"},{"text":" ","type":"text"},{"text":"animation by adding a delay to the start of the animation","type":"text"},{"text":" ","type":"text"},{"text":"by two seconds and then increases the rotational speed of the","type":"text"},{"text":" ","type":"text"},{"text":"“Rotation\\nModified” ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view animation by a factor of 2.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The third uses the ","type":"text"},{"type":"codeVoice","code":"transaction(_:)"},{"tex