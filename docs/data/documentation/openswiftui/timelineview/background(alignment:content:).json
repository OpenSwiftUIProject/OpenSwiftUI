{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView"]]},"abstract":[{"text":"Layers the views that you specify behind this view.","type":"text"}],"metadata":{"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"extendedModule":"OpenSwiftUICore","roleHeading":"Instance Method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"background","kind":"identifier"},{"text":"<","kind":"text"},{"text":"V","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"alignment","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Alignment","preciseIdentifier":"s:15OpenSwiftUICore9AlignmentV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"content","kind":"externalParam"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"}],"externalID":"s:15OpenSwiftUICore4ViewPAAE10background9alignment7contentQrAA9AlignmentV_qd__yXEtAaBRd__lF::SYNTHESIZED::s:11OpenSwiftUI12TimelineViewV","platforms":[{"unavailable":false,"beta":false,"name":"iOS","introducedAt":"13.0","deprecated":false},{"unavailable":false,"beta":false,"name":"macOS","introducedAt":"10.15","deprecated":false},{"unavailable":false,"beta":false,"name":"tvOS","introducedAt":"13.0","deprecated":false},{"unavailable":false,"beta":false,"name":"visionOS","introducedAt":"1.0","deprecated":false},{"unavailable":false,"beta":false,"name":"watchOS","introducedAt":"6.0","deprecated":false}],"symbolKind":"method","title":"background(alignment:content:)","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Modifier\/ViewModifier\/BackgroundModifier.swift#L223","fileName":"BackgroundModifier.swift"},"role":"symbol"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"background"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"externalParam","text":"alignment"},{"kind":"text","text":": "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment","preciseIdentifier":"s:15OpenSwiftUICore9AlignmentV","kind":"typeIdentifier","text":"Alignment"},{"kind":"text","text":" = .center, "},{"kind":"attribute","text":"@"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder","preciseIdentifier":"s:15OpenSwiftUICore11ViewBuilderV","kind":"attribute","text":"ViewBuilder"},{"kind":"text","text":" "},{"kind":"externalParam","text":"content"},{"kind":"text","text":": () -> "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"},{"kind":"text","text":"\n"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"name":"alignment","content":[{"inlineContent":[{"type":"text","text":"The alignment that the modifier uses to position the"},{"type":"text","text":" "},{"type":"text","text":"implicit "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","isActive":true},{"type":"text","text":" that groups the background views. The default"},{"type":"text","text":" "},{"type":"text","text":"is "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]},{"name":"content","content":[{"type":"paragraph","inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder","isActive":true,"type":"reference"},{"text":" that you use to declare the views to draw","type":"text"},{"text":" ","type":"text"},{"text":"behind this view, stacked in a cascading order from bottom to top.","type":"text"},{"text":" ","type":"text"},{"text":"The last view that you list appears at the front of the stack.","type":"text"}]}]}]},{"content":[{"text":"Return Value","anchor":"return-value","level":2,"type":"heading"},{"inlineContent":[{"text":"A view that uses the specified content as a background.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use this modifier to place one or more views behind another view."},{"type":"text","text":" "},{"type":"text","text":"For example, you can place a collection of stars beind a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" view:"}],"type":"paragraph"},{"syntax":"swift","code":["Text(\"ABCDEF\")","    .background(alignment: .leading) { Star(color: .red) }","    .background(alignment: .center) { Star(color: .green) }","    .background(alignment: .trailing) { Star(color: .blue) }"],"type":"codeListing"},{"inlineContent":[{"text":"The example above assumes that you’ve defined a ","type":"text"},{"type":"codeVoice","code":"Star"},{"text":" view with a","type":"text"},{"text":" ","type":"text"},{"text":"parameterized color:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct Star: View {","    var color: Color","","    var body: some View {","        Image(systemName: \"star.fill\")","            .foregroundStyle(color)","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"By setting different "},{"type":"codeVoice","code":"alignment"},{"type":"text","text":" values for each modifier, you make the"},{"type":"text","text":" "},{"type":"text","text":"stars appear in different places behind the text:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you specify more than one view in the "},{"type":"codeVoice","code":"content"},{"type":"text","text":" closure, the modifier"},{"type":"text","text":" "},{"type":"text","text":"collects all of the views in the closure into an implicit "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"taking them in order from back to front. For example, you can layer a"},{"type":"text","text":" "},{"type":"text","text":"vertical bar behind a circle, with both of those behind a horizontal"},{"type":"text","text":" "},{"type":"text","text":"bar:"}],"type":"paragraph"},{"syntax":"swift","code":["Color.blue","    .frame(width: 200, height: 10) \/\/ Creates a horizontal bar.","    .background {","        Color.green","            .frame(width: 10, height: 100) \/\/ Creates a vertical bar.","        Circle()","            .frame(width: 50, height: 50)","    }"],"type":"codeListing"},{"inlineContent":[{"text":"Both the background modifier and the implicit ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"text":" composed from","type":"text"},{"text":" ","type":"text"},{"text":"the background content — the circle and the vertical bar — use a","type":"text"},{"text":" ","type":"text"},{"text":"default ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center"},{"text":" alignment. The vertical bar appears","type":"text"},{"text":" ","type":"text"},{"text":"centered behind the circle, and both appear as a composite view centered","type":"text"},{"text":" ","type":"text"},{"text":"behind the horizontal bar:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you specify an alignment for the background, it applies to the"},{"type":"text","text":" "},{"type":"text","text":"implicit stack rather than to the individual views in the closure. You"},{"type":"text","text":" "},{"type":"text","text":"can see this if you add the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/leading"},{"type":"text","text":" alignment:"}],"type":"paragraph"},{"syntax":"swift","code":["Color.blue","    .frame(width: 200, height: 10)","    .background(alignment: .leading) {","        Color.green","            .frame(width: 10, height: 100)","        Circle()","            .frame(width: 50, height: 50)","    }"],"type":"codeListing"},{"inlineContent":[{"text":"The vertical bar and the circle move as a unit to align the stack","type":"text"},{"text":" ","type":"text"},{"text":"with the leading edge of the horizontal bar, while the","type":"text"},{"text":" ","type":"text"},{"text":"vertical bar remains centered on the circle:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To control the placement of individual items inside the "},{"type":"codeVoice","code":"content"},{"type":"text","text":" "},{"type":"text","text":"closure, either use a different background modifier for each item, as"},{"type":"text","text":" "},{"type":"text","text":"the earlier example of stars under text demonstrates, or add an explicit"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","type":"reference","isActive":true},{"type":"text","text":" inside the content closure with its own alignment:"}],"type":"paragraph"},{"syntax":"swift","code":["Color.blue","    .frame(width: 200, height: 10)","    .background(alignment: .leading) {","        ZStack(alignment: .leading) {","            Color.green","                .frame(width: 10, height: 100)","            Circle()","                .frame(width: 50, height: 50)","        }","    }"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The stack alignment ensures that the circle’s leading edge aligns with"},{"type":"text","text":" "},{"type":"text","text":"the vertical bar’s, while the background modifier aligns the composite"},{"type":"text","text":" "},{"type":"text","text":"view with the horizontal bar:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"You can achieve layering without a background modifier by putting both","type":"text"},{"text":" ","type":"text"},{"text":"the modified view and the background content into a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"text":". This","type":"text"},{"text":" ","type":"text"},{"text":"produces a simpler view hierarchy, but it changes the layout priority","type":"text"},{"text":" ","type":"text"},{"text":"that OpenSwiftUI applies to the views. Use the background modifier when you","type":"text"},{"text":" ","type":"text"},{"text":"want the modified view to dominate the layout.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"If you want to specify a ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","isActive":true},{"text":" like a","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HierarchicalShapeStyle","isActive":true},{"text":" or a ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Material","isActive":true},{"text":" as the background, use","type":"text"},{"text":" ","type":"text"},{"code":"View\/background(_:ignoresSafeAreaEdges:)","type":"codeVoice"},{"text":" instead.","type":"text"},{"text":" ","type":"text"},{"text":"To specify a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape","isActive":true,"type":"reference"},{"text":" or ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/InsettableShape","isActive":true,"type":"reference"},{"text":", use","type":"text"},{"text":" ","type":"text"},{"code":"View\/background(_:in:fillStyle:)","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"To configure the background of a presentation, like a sheet, use","type":"text"},{"text":" ","type":"text"},{"code":"View\/presentationBackground(alignment:content:)","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"paths":["\/documentation\/openswiftui\/timelineview\/background(alignment:content:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView\/background(alignment:content:)"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/TimelineView":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"TimelineView","kind":"identifier"}],"url":"\/documentation\/openswiftui\/timelineview","type":"topic","navigatorTitle":[{"text":"TimelineView","kind":"identifier"}],"title":"TimelineView","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView","kind":"symbol","abstract":[{"type":"text","text":"A view that updates according to a schedule that you provide."}],"role":"symbol"},"d