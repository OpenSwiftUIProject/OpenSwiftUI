:"text","text":" for an image that you"},{"type":"text","text":" "},{"type":"text","text":"would name with the "},{"type":"codeVoice","code":"@2x"},{"type":"text","text":" suffix if stored in a file on disk."}],"type":"paragraph"}],"name":"scale"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A closure that takes the loaded image as an input, and","type":"text"},{"text":" ","type":"text"},{"text":"returns the view to show. You can return the image directly, or","type":"text"},{"text":" ","type":"text"},{"text":"modify it as needed before returning it.","type":"text"}]}],"name":"content"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A closure that returns the view to show until the","type":"text"},{"text":" ","type":"text"},{"text":"load operation completes successfully.","type":"text"}]}],"name":"placeholder"}],"kind":"parameters"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"Until the image loads, OpenSwiftUI displays the placeholder view that","type":"text"},{"text":" ","type":"text"},{"text":"you specify. When the load operation completes successfully, OpenSwiftUI","type":"text"},{"text":" ","type":"text"},{"text":"updates the view to show content that you specify, which you","type":"text"},{"text":" ","type":"text"},{"text":"create using the loaded image. For example, you can show a green","type":"text"},{"text":" ","type":"text"},{"text":"placeholder, followed by a tiled version of the loaded image:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["AsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\")) { image in","    image.resizable(resizingMode: .tile)","} placeholder: {","    Color.green","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If the load operation fails, OpenSwiftUI continues to display the"},{"type":"text","text":" "},{"type":"text","text":"placeholder. To be able to display a different view on a load error,"},{"t