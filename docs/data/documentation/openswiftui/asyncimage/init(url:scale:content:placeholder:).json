{"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"kind":"symbol","abstract":[{"type":"text","text":"Loads and displays a modifiable image from the specified URL using"},{"type":"text","text":" "},{"type":"text","text":"a custom placeholder until the image loads."}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"init"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"I"},{"kind":"text","text":", "},{"kind":"genericParameter","text":"P"},{"kind":"text","text":">("},{"kind":"externalParam","text":"url"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:10Foundation3URLV","text":"URL"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"scale"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat"},{"kind":"text","text":" = 1, "},{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:15OpenSwiftUICore11ViewBuilderV","text":"ViewBuilder","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder"},{"kind":"text","text":" "},{"kind":"externalParam","text":"content"},{"kind":"text","text":": "},{"kind":"attribute","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore5ImageV","text":"Image","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","preciseIdentifier":"s:11OpenSwiftUI10AsyncImageV3url5scale7content11placeholderACy0aB6UICore19_ConditionalContentVyqd__qd_0_GG10Foundation3URLVSg_04CoreM07CGFloatVqd__AH0E0Vcqd_0_yctcAKRszAH4ViewRd__AhVRd_0_r0_lufc1IL_qd__mfp","text":"I"},{"kind":"text","text":", "},{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:15OpenSwiftUICore11ViewB