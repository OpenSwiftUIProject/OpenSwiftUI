[{"level":2,"anchor":"discussion","type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier to change or replace the animation used in a view.","type":"text"},{"text":" ","type":"text"},{"text":"Consider three identical animations controlled by a","type":"text"},{"text":" ","type":"text"},{"text":"button that executes all three animations simultaneously:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"type":"text","text":"The first animation rotates the “Rotation” "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"type":"text","text":" view by 360"},{"type":"text","text":" "},{"type":"text","text":"degrees."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The second uses the ","type":"text"},{"code":"transaction(_:)","type":"codeVoice"},{"text":" modifier to change the","type":"text"},{"text":" ","type":"text"},{"text":"animation by adding a delay to the start of the animation","type":"text"},{"text":" ","type":"text"},{"text":"by two seconds and then increases the rotational speed of the","type":"text"},{"text":" ","type":"text"},{"text":"“Rotation\\nModified” ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"text":" view animation by a factor of 2.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The third animation uses the "},{"type":"codeVoice","code":"transaction(_:)"},{"type":"text","text":" modifier to"},{"type":"text","text":" "},{"type":"text","text":"replace the rotation animation affecting the “Animation\\nReplaced”"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"type":"text","text":" view with a spring animation."}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"The following code implements these animations:","type":"text"}]},{"type":"codeListing","code":["struct TransactionExample: View {","    @State private var flag = false","","    var body: some View {","        VStack(spacing: 50) {","            HStack(spacing: 30) {","                Text(\"Rotation\")","                    .rotationEffect(Angle(degrees:","                                            self.flag ? 360 : 0))","","                Text(\"Rotation\\nModified\")","                    .rotationEffect(Angle(degrees:","                                            self.flag ? 360 : 0))","                    .transaction { view in","                        view.animation =","                            view.animation?.delay(2.0).speed(2)","                    }","","                Text(\"Animation\\nReplaced\")","                    .rotationEffect(Angle(degrees:","                                            self.flag ? 360 : 0))","                    .transaction { view in","                        view.animation = .interactiveSpring(","                            response: 0.60,","                            dampingFraction: 0.20,","                            blendDuration: 0.25)","                    }","            }","","            Button(\"Animate\") {","                withAnimation(.easeIn(duration: 2.0)) {","                    self.flag.toggle()","                }","            }","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier on leaf views such as ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image","type":"reference"},{"text":" or ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button","type":"reference"},{"text":" rather","type":"text"},{"text":" ","type":"text"},{"text":"than container views such as ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference"},{"text":" or ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","type":"reference"},{"text":". The","type":"text"},{"text":" ","type":"text"},{"text":"transformation applies to all child views within this view; calling","type":"text"},{"text":" ","type":"text"},{"code":"transaction(_:)","type":"codeVoice"},{"text":" on a container view can lead to unbounded scope of","type":"text"},{"text":" ","type":"text"},{"text":"execution depending on the depth of the view hierarchy.","type":"text"}]}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Button":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Button","kind":"identifier"}],"navigatorTitle":[{"text":"Button","kind":"identifier"}],"abstract":[],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button","title":"Button","type":"topic","url":"\/documentation\/openswiftui\/button"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/VStack":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"topic","role":"symbol","abstract":[{"type":"text","text":"A view that arranges its subviews in a vertical line."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VStack"}],"url":"\/documentation\/openswiftui\/vstack","title":"VStack","navigatorTitle":[{"kind":"identifier","text":"VStack"}],"kind":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/AsyncImage/transaction(_:)":{"type":"topic","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage\/transaction(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"transaction","kind":"identifier"},{"text":"((","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Transaction","preciseIdentifier":"s:15OpenSwiftUICore11TransactionV","kind":"typeId