{"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"geometryGroup"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"},{"kind":"text","text":"\n"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"By default OpenSwiftUI views push position and size changes down"},{"type":"text","text":" "},{"type":"text","text":"through the view hierarchy, so that only views that draw"},{"type":"text","text":" "},{"type":"text","text":"something (known as leaf views) apply the current animation to"},{"type":"text","text":" "},{"type":"text","text":"their frame rectangle. However in some cases this coalescing"},{"type":"text","text":" "},{"type":"text","text":"behavior can give undesirable results; inserting a geometry"},{"type":"text","text":" "},{"type":"text","text":"group can correct that. A group acts as a barrier between the"},{"type":"text","text":" "},{"type":"text","text":"parent view and its subviews, forcing the position and size"},{"type":"text","text":" "},{"type":"text","text":"values to be resolved and animated by the parent, before being"},{"type":"text","text":" "},{"type":"text","text":"passed down to each subview."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example below shows one use of this function: ensuring that"},{"type":"text","text":" "},{"type":"text","text":"the member views of each row in the stack apply (and animate"},{"type":"text","text":" "},{"type":"text","text":"as) a single geometric transform from their ancestor view,"},{"type":"text","text":" "},{"type":"text","text":"rather than letting the effects of the ancestor views be"},{"type":"text","text":" "},{"type":"text","text":"applied separately to each leaf view. If the members of"},{"type":"text","text":" "},{"code":"ItemView","type":"codeVoice"},{"text":" may be added and removed at different times the","type":"text"},{"text":" ","type":"text"},{"text":"group ensures that they stay locked together as animations are","type":"text"},{"text":" ","type":"text"},{"text":"applied.","type":"text"}]},{"type":"codeListing","code":["VStack {","    ForEach(items) { item in","        ItemView(item: item)","            .geometryGroup()","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Returns: a new view whose geometry is isolated from that of its","type":"text"},{"text":" ","type":"text"},{"text":"parent view.","type":"text"}]}]}],"abstract":[{"text":"Isolates the geometry (e.g. position and size) of the view","type":"text"},{"text":" ","type":"text"},{"text":"from its parent view.","type":"text"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage\/geometryGroup()"},"metadata":{"extendedModule":"OpenSwiftUICore","platforms":[{"beta":false,"introducedAt":"13.0","deprecated":false,"name":"iOS","unavailable":false},{"beta":false,"introducedAt":"10.15","deprecated":false,"name":"macOS","unavailable":false},{"beta":false,"introducedAt":"13.0","deprecated":false,"name":"tvOS","unavailable":false},{"beta":false,"introducedAt":"1.0","deprecated":false,"name":"visionOS","unavailable":false},{"beta":false,"introducedAt":"6.0","deprecated":false,"name":"watchOS","unavailable":false}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"title":"geometryGroup()","roleHeading":"Instance Method","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"externalID":"s:15OpenSwiftUICore4ViewPAAE13geometryGroupQryF::SYNTHESIZED::s:11OpenSwiftUI10AsyncImageV","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Render\/RendererEffect\/RendererEffect.swift#L304","fileName":"RendererEffect.swift"},"role":"symbol","symbolKind":"method"},"sections":[],"schemaVersion":{"minor":3,"patch":0,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/asyncimage\/geometrygroup()"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftui\/view","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"type":"topic","title":"View","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/AsyncImage":{"url":"\/documentation\/openswiftui\/asyncimage","navigatorTitle":[{"text":"AsyncImage","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage","role":"symbol","abstract":[{"text":"A view that asynchronously loads and displays an image.","type":"text"}],"title":"AsyncImage","kind":"symbol","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AsyncImage","kind":"identifier"}]},"doc://