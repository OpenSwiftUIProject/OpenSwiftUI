es. If you set the value to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", OpenSwiftUI uses","type":"text"},{"text":" ","type":"text"},{"text":"a platform-specific default amount. The default value of this","type":"text"},{"text":" ","type":"text"},{"text":"parameter is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that’s padded by the specified amount on the"},{"type":"text","text":" "},{"type":"text","text":"specified edges."}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier to add a specified amount of padding to one or more","type":"text"},{"text":" ","type":"text"},{"text":"edges of the view. Indicate the edges to pad by naming either a single","type":"text"},{"text":" ","type":"text"},{"text":"value from ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set","type":"reference","isActive":true},{"text":", or by specifying an","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/Swift\/OptionSet","type":"reference","isActive":true},{"text":" ","type":"text"},{"text":"that contains edge values:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["VStack {","    Text(\"Text padded by 20 points on the bottom and trailing edges.\")","        .padding([.bottom, .trailing], 20)","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The order in which you apply modifiers matters. The example above"},{"type":"text","text":" "},{"type":"text","text":"applies the padding before applying the border to ensure that the"},{"type":"text","text":" "},{"type":"text","text":"border encompasses the padded region:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"You can omit either or both of the parameters. If you omit the ","type":"text"},{"type":"codeVoice","code":"length"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"OpenSwiftUI uses a default amount of padding. If you","type":"text"},{"text":" ","type":"text"},{"text":"omit the ","type":"text"},{"type":"codeVoice","code":"edges"},{"text":", OpenSwiftUI applies the padding to all edges. Omit both","type":"text"},{"text":" ","type":"text"},{"text":"to add a default padding all the way around a view. OpenSwiftUI chooses a","type":"text"},{"text":" ","type":"text"},{"text":"default amount of padding that’s appropriate for the platform and","type":"text"},{"text":" ","type":"text"},{"text":"the presentation context.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["VStack {","    Text(\"Text with default padding.\")","        .padding()","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"]},{"type":"paragraph","inlineContent":[{"text":"The example above looks like this in iOS under typical conditions:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"To control the amount of padding independently for each edge, use","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"View\/padding(_:)-6pgqq"},{"text":". To pad all outside edges of a view by a","type":"text"},{"text":" ","type":"text"},{"text":"specified amount, use ","type":"text"},{"type":"codeVoice","code":"View\/padding(_:)-68shk"},{"text":".","type":"text"}]}]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage\/padding(_:_:)","interfaceLanguage":"swift"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftu