":"text","text":"You can set a style for all toggle instances within a view hierarchy"},{"type":"text","text":" "},{"type":"text","text":"by applying the style modifier to a container view. For example, you"},{"type":"text","text":" "},{"type":"text","text":"can apply the "},{"type":"codeVoice","code":"ToggleStyle\/button"},{"type":"text","text":" style to an "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"},{"type":"text","text":":"}]},{"type":"codeListing","code":["HStack {","    Toggle(isOn: $isFlagged) {","        Label(\"Flag\", systemImage: \"flag.fill\")","    }","    Toggle(isOn: $isMuted) {","        Label(\"Mute\", systemImage: \"speaker.slash.fill\")","    }","}",".toggleStyle(.button)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example above has the following appearance when "},{"type":"codeVoice","code":"isFlagged"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"codeVoice","code":"true"},{"type":"text","text":" and "},{"type":"codeVoice","code":"isMuted"},{"type":"text","text":" is "},{"type":"codeVoice","code":"false"},{"type":"text","text":":"}]},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"text":"Platform","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Appearance"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iOS, iPadOS"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]]]},{"type":"heading","anchor":"Automatic-styling","text":"Automatic styling","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you don’t set a style, OpenSwiftUI assumes a value of"},{"type":"text","text":" "},{"type":"codeVoice","code":"ToggleStyle\/automatic"},{"type":"text","text":", which corresponds to a context-specific"},{"type":"text","text":" "},{"type":"text","text":"default. Specify the automatic style explicitly to override a"},{"type":"text","text":" "},{"type":"text","text":"container’s style and revert to the default:"}]},{"type":"codeListing","code":["HStack {","    Toggle(isOn: $isShuffling) {","        Label(\"Shuffle\", systemImage: \"shuffle\")","    }","    Toggle(isOn: $isRepeating) {","        Label(\"Repeat\", systemImage: \"repeat\")","    }","","    Divider()","","    Toggle(\"Enhance Sound\", isOn: $isEnhanced)","        .toggleStyle(.automatic) \/\/ Revert to the default style.","}",".toggleStyle(.button) \/\/ Use button style for toggles in the stack.",".labelStyle(.iconOnly) \/\/ Omit the title from any labels."],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The style that OpenSwiftUI uses as the default depends on both the platform","type":"text"},{"text":" ","type":"text"},{"text":"and the context. In macOS, the default in most contexts is a","type":"text"},{"text":" ","type":"text"},{"code":"ToggleStyle\/checkbox","type":"codeVoice"},{"text":", while in iOS, the default toggle style is a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true,"type":"reference"},{"text":":","type":"text"}]},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Appearance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"iOS, iPadOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS"}]}],[{"type":"paragraph","inlineContent":[]}]]]},{"type":"aside","name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Like toggle style does for toggles, the ","type":"text"},{"type":"codeVoice","code":"View\/labelStyle(_:)"},{"text":" ","type":"text"},{"text":"modifier sets the style for ","type":"text"},{"type":"codeVoice","code":"Label"},{"text":" instances in the hierarchy. The","type":"text"},{"text":" ","type":"text"},{"text":"example above demostrates the compact ","type":"text"},{"type":"codeVoice","code":"LabelStyle\/iconOnly"},{"text":" style,","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"which is useful for button toggles in space-constrained contexts."},{"type":"text","text":" "},{"type":"text","text":"Always include a descriptive title for better accessibility."}]}]},{"type":"paragraph","inlineContent":[{"text":"For more information about how OpenSwiftUI chooses a default toggle style,","type":"text"},{"text":" ","type":"text"},{"text":"see the ","type":"text"},{"type":"codeVoice","code":"ToggleStyle\/automatic"},{"text":" style.","type":"text"}]}]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage\/toggleStyle(_:)","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/openswiftui\/asyncimage\/togglestyle(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Sets the style for toggles in a view hierarchy."}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage"]]},"kind":"symbol","metadata":{"externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lF::SYNTHESIZED::s:11OpenSwiftUI10AsyncImageV","extendedModule":"OpenSwiftUICore","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"toggleStyle"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lFQO1Sqd__mfp","text":"S"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIden