iew that arranges its subviews in a vertical line."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VStack"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"topic","url":"\/documentation\/openswiftui\/vstack"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/HStack":{"type":"topic","navigatorTitle":[{"text":"HStack","kind":"identifier"}],"title":"HStack","url":"\/documentation\/openswiftui\/hstack","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","abstract":[{"text":"A view that arranges its subviews in a horizontal line.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"HStack","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"url":"\/documentation\/openswiftui\/view","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","role":"symbol"}}}