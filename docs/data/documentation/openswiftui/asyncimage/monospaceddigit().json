{"abstract":[{"type":"text","text":"Modifies the fonts of all child views to use fixed-width digits, if"},{"type":"text","text":" "},{"type":"text","text":"possible, while leaving other characters proportionally spaced."}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"platforms":[{"name":"iOS","introducedAt":"13.0","deprecated":false,"beta":false,"unavailable":false},{"name":"macOS","introducedAt":"10.15","deprecated":false,"beta":false,"unavailable":false},{"name":"tvOS","introducedAt":"13.0","deprecated":false,"beta":false,"unavailable":false},{"name":"visionOS","introducedAt":"1.0","deprecated":false,"beta":false,"unavailable":false},{"name":"watchOS","introducedAt":"6.0","deprecated":false,"beta":false,"unavailable":false}],"extendedModule":"OpenSwiftUICore","externalID":"s:15OpenSwiftUICore4ViewPAAE15monospacedDigitQryF::SYNTHESIZED::s:11OpenSwiftUI10AsyncImageV","symbolKind":"method","title":"monospacedDigit()","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Data\/EnvironmentKeys\/EnvironmentAdditions.swift#L329","fileName":"EnvironmentAdditions.swift"},"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"monospacedDigit","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}],"roleHeading":"Instance Method","role":"symbol"},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage\/monospacedDigit()","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"monospacedDigit"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View"},{"kind":"text","text":"\n"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"A view whose child views’ fonts use fixed-width numeric","type":"text"},{"text":" ","type":"text"},{"text":"characters, while leaving other characters proportionally spaced.","type":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Using fixed-width digits allows you to easily align numbers of the"},{"type":"text","text":" "},{"type":"text","text":"same size in a table-like arrangement. This feature is also known as"},{"type":"text","text":" "},{"type":"text","text":"“tabular figures” or “tabular numbers.”"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This modifier only affects numeric characters, and leaves all other"},{"type":"text","text":" "},{"type":"text","text":"characters unchanged."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example shows the effect of "},{"type":"codeVoice","code":"monospacedDigit()"},{"type":"text","text":" on"},{"type":"text","text":" "},{"type":"text","text":"multiple child views. The example consists of two "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":" views"},{"type":"text","text":" "},{"type":"text","text":"inside an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"},{"type":"text","text":". Each "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" contains two "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button"},{"type":"text","text":" views, with"},{"type":"text","text":" "},{"type":"text","text":"the second "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" applying the "},{"type":"codeVoice","code":"monospacedDigit()"},{"type":"text","text":" modifier to its"},{"type":"text","text":" "},{"type":"text","text":"contents. As a result, the digits in the buttons in the trailing"},{"type":"text","text":" "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" are the same width, which in turn gives the buttons equal widths."}],"type":"paragraph"},{"syntax":"swift","code":["var body: some View {","    HStack(alignment: .top) {","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        .monospacedDigit()","    }","    .padding()","    .navigationTitle(\"monospacedDigit() Child Views\")","}"],"type":"codeListing"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If a child view’s base font doesn’t support fixed-width digits, the font"},{"type":"text","text":" "},{"type":"text","text":"remains unchanged."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/openswiftui\/asyncimage\/monospaceddigit()"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interf