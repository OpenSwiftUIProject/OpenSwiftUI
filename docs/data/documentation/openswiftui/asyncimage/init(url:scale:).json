":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"text":"Until the image loads, OpenSwiftUI displays a default placeholder. When","type":"text"},{"text":" ","type":"text"},{"text":"the load operation completes successfully, OpenSwiftUI updates the","type":"text"},{"text":" ","type":"text"},{"text":"view to show the loaded image. If the operation fails, OpenSwiftUI","type":"text"},{"text":" ","type":"text"},{"text":"continues to display the placeholder. The following example loads","type":"text"},{"text":" ","type":"text"},{"text":"and displays an icon from an example server:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["AsyncImage(url: URL(string: \"https:\/\/example.com\/icon.png\"))"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"If you want to customize the placeholder or apply image-specific"},{"type":"text","text":" "},{"type":"text","text":"modifiers — like "},{"type":"codeVoice","code":"Image\/resizable(capInsets:resizingMode:)"},{"type":"text","text":" —"},{"type":"text","text":" "},{"type":"text","text":"to the loaded image, use the "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage\/init(url:scale:content:placeholder:)","type":"reference"},{"type":"text","text":" "},{"type":"text","text":"initializer instead."}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AsyncImage"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/asyncimage\/init(url:scale:)"]}],"abstract":[{"type":"text","text":"Loads and displays an image from the specified URL."}],"sections":[],"metadata":{"roleHeading":"Initializer","role":"symbol","modules":[{"name":"OpenSwiftUI"}],"symbolKind":"init","title":"init(url:scale:)","remoteSource":{"fileName":"AsyncImage.swift","url":"https:\/\/github.com\/OpenSwiftUI