UI\/documentation\/OpenSwiftUI\/HStack"},{"text":". Each ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":" contains two ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button"},{"text":" views, with","type":"text"},{"text":" ","type":"text"},{"text":"the second ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":" applying the ","type":"text"},{"type":"codeVoice","code":"monospacedDigit()"},{"text":" modifier to its","type":"text"},{"text":" ","type":"text"},{"text":"contents. As a result, the digits in the buttons in the trailing","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":" are the same width, which in turn gives the buttons equal widths.","type":"text"}]},{"type":"codeListing","code":["var body: some View {","    HStack(alignment: .top) {","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        .monospacedDigit()","    }","    .padding()","    .navigationTitle(\"monospacedDigit() Child Views\")","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"If a child view’s base font doesn’t support fixed-width digits, the font","type":"text"},{"text":" ","type":"text"},{"text":"remains unchanged.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/equatableview\/monospaceddigit()"]}],"sections":[],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/HStack":{"type":"topic","navigatorTitle":[{"text":"HStack","kind":"identifier"}],"title":"HStack","url":"\/documentation\/openswiftui\/hstack","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","abstra