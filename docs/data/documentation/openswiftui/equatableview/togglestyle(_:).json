{"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"toggleStyle","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"style","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"S","preciseIdentifier":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lFQO1Sqd__mfp","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"ToggleStyle","preciseIdentifier":"s:11OpenSwiftUI11ToggleStyleP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"style","content":[{"inlineContent":[{"text":"The toggle style to set. Use one of the built-in","type":"text"},{"text":" ","type":"text"},{"text":"values, like ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"ToggleStyle\/button"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or a custom style that you define by creating a type that conforms","type":"text"},{"text":" ","type":"text"},{"text":"to the ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle"},{"type":"text","text":" protocol."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"inlineContent":[{"text":"A view that uses the specified toggle style for itself","type":"text"},{"text":" ","type":"text"},{"text":"and its child views.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier on a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true,"type":"reference"},{"text":" instance to set a style that defines","type":"text"},{"text":" ","type":"text"},{"text":"the control’s appearance and behavior. For example, you can choose","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true,"type":"reference"},{"text":" style:","type":"text"}]},{"code":["Toggle(\"Vibrate on Ring\", isOn: $vibrateOnRing)","    .toggleStyle(.switch)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Built-in styles typically have a similar appearance across platforms,"},{"type":"text","text":" "},{"type":"text","text":"tailored to the platform’s overall style:"}]},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Appearance"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS, iPadOS"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]],"header":"row"},{"level":3,"text":"Styling toggles in a hierarchy","type":"heading","anchor":"Styling-toggles-in-a-hierarchy"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set a style for all toggle instances within a view hierarchy"},{"type":"text","text":" "},{"type":"text","text":"by applying the style modifier to a container view. For example, you"},{"type":"text","text":" "},{"type":"text","text":"can apply the "},{"type":"codeVoice","code":"ToggleStyle\/button"},{"type":"text","text":" style to an "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","type":"reference","isActive":true},{"type":"text","text":":"}]},{"code":["HStack {","    Toggle(isOn: $isFlagged) {","        Label(\"Flag\", systemImage: \"flag.fill\")","    }","    Toggle(isOn: $isMuted) {","        Label(\"Mute\", systemImage: \"speaker.slash.fill\")","    }","}",".toggleStyle(.button)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example above has the following appearance when "},{"code":"isFlagged","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"code":"true","type":"codeVoice"},{"type":"text","text":" and "},{"code":"isMuted","type":"codeVoice"},{"type":"text","text":" is "},{"code":"false","type":"codeVoice"},{"type":"text","text":":"}]},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Appearance","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"iOS, iPadOS","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"macOS","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]]],"header":"row"},{"level":3,"text":"Automatic styling","type":"heading","anchor":"Automatic-styling"},{"inlineContent":[{"type":"text","text":"If you don’t set a style, OpenSwiftUI assumes a value of"},{"type":"text","text":" "},{"type":"codeVoice","code":"ToggleStyle\/automatic"},{"type":"text","text":", which corresponds to a context-specific"},{"type":"text","text":" "},{"type":"text","text":"default. Specify the automatic style explicitly to override a"},{"type":"text","text":" "},{"type":"text","text":"container’s style and revert to the default:"}],"type":"paragraph"},{"type":"codeListing","code":["HStack {","    Toggle(isOn: $isShuffling) {","        Label(\"Shuffle\", systemImage: \"shuffle\")","    }","    Toggle(isOn: $isRepeating) {","        Label(\"Repeat\", systemImage: \"repeat\")","    }","","    Divider()","","    Toggle(\"Enhance Sound\", isOn: $isEnhanced)","        .toggleStyle(.automatic) \/\/ Revert to the default style.","}",".toggleStyle(.button) \/\/ Use button style for toggles in the stack.",".labelStyle(.iconOnly) \/\/ Omit the title from any labels."],"syntax":"swift"},{"inlineContent":[{"text":"The style that OpenSwiftUI uses as the default depends on both the platform","type":"text"},{"text":" ","type":"text"},{"text":"and the context. In macOS, the default in most contexts is a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"ToggleStyle\/checkbox"},{"text":", while in iOS, the default toggle style is a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"table","header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Appearance","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"iOS, iPadOS"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]]},{"type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"Like toggle style does for toggles, the ","type":"text"},{"type":"codeVoice","code":"View\/labelStyle(_:)"},{"text":" ","type":"text"},{"text":"modifier sets the style for ","type":"text"},{"type":"codeVoice","code":"Label"},{"text":" instances in the hierarchy. The","type":"text"},{"text":" ","type":"text"},{"text":"example above demostrates the compact ","type":"text"},{"type":"codeVoice","code":"LabelStyle\/iconOnly"},{"text":" style,","type":"text"},{"text":" ","type":"text"},{"text":"which is useful for button toggles in space-constrained contexts.","type":"text"},{"text":" ","type":"text"},{"text":"Always include a descriptive title for better accessibility.","type":"text"}]}],"style":"note"},{"inlineContent":[{"text":"For more information about how OpenSwiftUI chooses a default toggle style,","type":"text"},{"text":" ","type":"text"},{"text":"see the ","type":"text"},{"code":"ToggleStyle\/automatic","type":"codeVoice"},{"text":" style.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EquatableView\/toggleStyle(_:)"},"kind":"symbol","metadata":{"roleHeading":"Instance Method","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"title":"toggleStyle(_:)","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"toggleStyle","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"S","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lFQO1Sqd__mfp"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"extendedModule":"OpenSwiftUICore","remoteSource":{"fileName":"ToggleStyle.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/Toggle\/ToggleStyle.swift#L481"},"role":"symbol","externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggle