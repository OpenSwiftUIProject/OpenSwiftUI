{"abstract":[{"type":"text","text":"Sets the style for toggles in a view hierarchy."}],"sections":[],"kind":"symbol","primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"toggleStyle"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"style"},{"kind":"text","text":": "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lFQO1Sqd__mfp","kind":"typeIdentifier","text":"S"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:11OpenSwiftUI11ToggleStyleP","kind":"typeIdentifier","text":"ToggleStyle","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle"},{"kind":"text","text":"\n"}]}],"kind":"declarations"},{"parameters":[{"name":"style","content":[{"inlineContent":[{"type":"text","text":"The toggle style to set. Use one of the built-in"},{"type":"text","text":" "},{"type":"text","text":"values, like "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch"},{"type":"text","text":" or "},{"type":"codeVoice","code":"ToggleStyle\/button"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or a custom style that you define by creating a type that conforms"},{"type":"text","text":" "},{"type":"text","text":"to the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle"},{"type":"text","text":" protocol."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that uses the specified toggle style for itself"},{"type":"text","text":" "},{"type":"text","text":"and its child views."}]}],"kind":"content"},{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier on a ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true},{"text":" instance to set a style that defines","type":"text"},{"text":" ","type":"text"},{"text":"the control’s appearance and behavior. For example, you can choose","type":"text"},{"text":" ","type":"text"},{"text":"the ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true},{"text":" style:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["Toggle(\"Vibrate on Ring\", isOn: $vibrateOnRing)","    .toggleStyle(.switch)"]},{"type":"paragraph","inlineContent":[{"text":"Built-in styles typically have a similar appearance across platforms,","type":"text"},{"text":" ","type":"text"},{"text":"tailored to the platform’s overall style:","type":"text"}]},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Appearance"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS, iPadOS"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS"}]}],[{"type":"paragraph","inlineContent":[]}]]]},{"anchor":"Styling-toggles-in-a-hierarchy","type":"heading","level":3,"text":"Styling toggles in a hierarchy"},{"type":"paragraph","inlineContent":[{"text":"You can set a style for all toggle instances within a view hierarchy","type":"text"},{"text":" ","type":"text"},{"text":"by applying the style modifier to a container view. For example, you","type":"text"},{"text":" ","type":"text"},{"text":"can apply the ","type":"text"},{"type":"codeVoice","code":"ToggleStyle\/button"},{"text":" style to an ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","type":"reference","isActive":true},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["HStack {","    Toggle(isOn: $isFlagged) {","        Label(\"Flag\", systemImage: \"flag.fill\")","    }","    Toggle(isOn: $isMuted) {","        Label(\"Mute\", systemImage: \"speaker.slash.fill\")","    }","}",".toggleStyle(.button)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example above has the following appearance when "},{"type":"codeVoice","code":"isFlagged"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"codeVoice","code":"true"},{"type":"text","text":" and "},{"type":"codeVoice","code":"isMuted"},{"type":"text","text":" is "},{"type":"codeVoice","code":"false"},{"type":"text","text":":"}]},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Platform"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Appearance"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS, iPadOS"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]]},{"anchor":"Automatic-styling","type":"heading","level":3,"text":"Automatic styling"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you don’t set a style, OpenSwiftUI assumes a value of"},{"type":"text","text":" "},{"type":"codeVoice","code":"ToggleStyle\/automatic"},{"type":"text","text":", which corresponds to a context-specific"},{"type":"text","text":" "},{"type":"text","text":"default. Specify the automatic style explicitly to override a"},{"type":"text","text":" "},{"type":"text","text":"container’s style and revert to the default:"}]},{"syntax":"swift","type":"codeListing","code":["HStack {","    Toggle(isOn: $isShuffling) {","        Label(\"Shuffle\", systemImage: \"shuffle\")","    }","    Toggle(isOn: $isRepeating) {","        Label(\"Repeat\", systemImage: \"repeat\")","    }","","    Divider()","","    Toggle(\"Enhance Sound\", isOn: $isEnhanced)","        .toggleStyle(.automatic) \/\/ Revert to the default style.","}",".toggleStyle(.button) \/\/ Use button style for toggles in the stack.",".labelStyle(.iconOnly) \/\/ Omit the title from any labels."]},{"type":"paragraph","inlineContent":[{"text":"The style that OpenSwiftUI uses as the default depends on both the platform","type":"text"},{"text":" ","type":"text"},{"text":"and the context. In macOS, the default in most contexts is a","type":"text"},{"text":" ","type":"text"},{"code":"ToggleStyle\/checkbox","type":"codeVoice"},{"text":", while in iOS, the default toggle style is a","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","type":"reference"},{"text":":","type":"text"}]},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Platform"}]}],[{"type":"paragraph","inlineContent":[{"text":"Appearance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS, iPadOS"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS"}]}],[{"type":"paragraph","inlineContent":[]}]]]},{"type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"Like toggle style does for toggles, the ","type":"text"},{"code":"View\/labelStyle(_:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"modifier sets the style for ","type":"text"},{"code":"Label","type":"codeVoice"},{"text":" instances in the hierarchy. The","type":"text"},{"text":" ","type":"text"},{"text":"example above demostrates the compact ","type":"text"},{"code":"LabelStyle\/iconOnly","type":"codeVoice"},{"text":" style,","type":"text"},{"text":" ","type":"text"},{"text":"which is useful for button toggles in space-constrained contexts.","type":"text"},{"text":" ","type":"text"},{"text":"Always include a descriptive title for better accessibility.","type":"text"}]}],"name":"Note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more information about how OpenSwiftUI chooses a default toggle style,"},{"type":"text","text":" "},{"type":"text","text":"see the "},{"type":"codeVoice","code":"ToggleStyle\/automatic"},{"type":"text","text":" style."}]}],"kind":"content"}],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EquatableView"]]},"variants":[{"paths":["\/documentation\/openswiftui\/equatableview\/togglestyle(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EquatableView\/toggleStyle(_:)","interfaceLanguage":"swift"},"metadata":{"symbolKind":"method","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"toggleStyle","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lFQO1Sqd__mfp","text":"S","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","