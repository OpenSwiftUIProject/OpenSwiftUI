ype":"text","text":"An amount, given in points, to pad this view on the"},{"type":"text","text":" "},{"type":"text","text":"specified edges. If you set the value to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", OpenSwiftUI uses"},{"type":"text","text":" "},{"type":"text","text":"a platform-specific default amount. The default value of this"},{"type":"text","text":" "},{"type":"text","text":"parameter is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}]}],"kind":"parameters"},{"content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that’s padded by the specified amount on the"},{"type":"text","text":" "},{"type":"text","text":"specified edges."}]}],"kind":"content"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Use this modifier to add a specified amount of padding to one or more"},{"type":"text","text":" "},{"type":"text","text":"edges of the view. Indicate the edges to pad by naming either a single"},{"type":"text","text":" "},{"type":"text","text":"value from "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set"},{"type":"text","text":", or by specifying an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/Swift\/OptionSet"},{"type":"text","text":" "},{"type":"text","text":"that contains edge values:"}],"type":"paragraph"},{"syntax":"swift","code":["VStack {","    Text(\"Text padded by 20 points on the bottom and trailing edges.\")","        .padding([.bottom, .trailing], 20)","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"type":"codeListing"},{"inlineContent":[{"text":"The order in which you apply modifiers matters. The example above","type":"text"},{"text":" ","type":"text"},{"text":"applies the padding before applying the border to ensure that the","type":"text"},{"text":" ","type":"text"},{"text":"border encompasses the padded region:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can omit either or both of the parameters. If you omit the "},{"type":"codeVoice","code":"length"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI uses a default amount of padding. If you"},{"type":"text","text":" "},{"type":"text","text":"omit the "},{"type":"codeVoice","code":"edges"},{"type":"text","text":", OpenSwiftUI applies the padding to all edges. Omit both"},{"type":"text","text":" "},{"type":"text","text":"to add a default padding all the way around a view. OpenSwiftUI chooses a"},{"type":"text","text":" "},{"type":"text","text":"default amount of padding that’s appropriate for the platform and"},{"type":"text","text":" "},{"type":"text","text":"the presentation context."}],"type":"paragraph"},{"syntax":"swift","code":["VStack {","    Text(\"Text with default padding.\")","        .padding()","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"type":"codeListing"},{"inlineContent":[{"text":"The example above looks like this in iOS under typical conditions:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To control the amount of padding independently for each edge, use"},{"type":"text","text":" "},{"type":"codeVoice","code":"View\/padding(_:)-6pgqq"},{"type":"text","text":". To pad all outside edges of a view by a"},{"type":"text","text":" "},{"type":"text","text":"specified amount, use "},{"type":"codeVoice","code":"View\/padding(_:)-68shk"},{"type":"text","text":"."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation