{"abstract":[{"type":"text","text":"Sets the default font for text in this view."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"font"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"font"},{"kind":"text","text":": "},{"preciseIdentifier":"s:15OpenSwiftUICore4FontV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Font","kind":"typeIdentifier","text":"Font"},{"kind":"text","text":"?) -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","text":"View"},{"kind":"text","text":"\n"}],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"text":"The default font to use in this view.","type":"text"}],"type":"paragraph"}],"name":"font"}]},{"kind":"content","content":[{"type":"heading","anchor":"return-value","level":2,"text":"Return Value"},{"inlineContent":[{"text":"A view with the default font set to the value you supply.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":"font(_:)","type":"codeVoice"},{"type":"text","text":" to apply a specific font to all of the text in a view."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example below shows the effects of applying fonts to individual"},{"type":"text","text":" "},{"type":"text","text":"views and to view hierarchies. Font information flows down the view"},{"type":"text","text":" "},{"type":"text","text":"hierarchy as part of the environment, and remains in effect unless"},{"type":"text","text":" "},{"type":"text","text":"overridden at the level of an individual view or view container."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Here, the outermost "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference","isActive":true},{"type":"text","text":" applies a 16-point system font as a"},{"type":"text","text":" "},{"type":"text","text":"default font to views contained in that "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference","isActive":true},{"type":"text","text":". Inside that stack,"},{"type":"text","text":" "},{"type":"text","text":"the example applies a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Font\/largeTitle","type":"reference","isActive":true},{"type":"text","text":" font to just the first text"},{"type":"text","text":" "},{"type":"text","text":"view; this explicitly overrides the default. The remaining stack and the"},{"type":"text","text":" "},{"type":"text","text":"views contained with it continue to use the 16-point system font set by"},{"type":"text","text":" "},{"type":"text","text":"their containing view:"}]},{"type":"codeListing","code":["VStack {","    Text(\"Font applied to a text view.\")","        .font(.largeTitle)","","    VStack {","        Text(\"These 2 text views have the same font\")","        Text(\"applied to their parent hierarchy\")","    }","}",".font(.system(size: 16, weight: .light, design: .default))"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]}]}],"metadata":{"symbolKind":"method","remoteSource":{"fileName":"EnvironmentAdditions.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Data\/EnvironmentKeys\/EnvironmentAdditions.swift#L278"},"title":"font(_:)","role":"symbol","platforms":[{"name":"iOS","deprecated":false,"unavailable":false,"beta":false,"introducedAt":"13.0"},{"name":"macOS","deprecated