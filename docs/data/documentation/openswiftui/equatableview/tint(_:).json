{"abstract":[{"type":"text","text":"Sets the tint color within this view."}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EquatableView"]]},"kind":"symbol","schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"tint","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"tint","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Color","preciseIdentifier":"s:15OpenSwiftUICore5ColorV","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"text":"\n","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"name":"tint","content":[{"inlineContent":[{"type":"text","text":"The tint "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color"},{"type":"text","text":" to apply."}],"type":"paragraph"}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Use this method to override the default accent color for this view.","type":"text"},{"text":" ","type":"text"},{"text":"Unlike an app’s accent color, which can be overridden by user","type":"text"},{"text":" ","type":"text"},{"text":"preference, the tint color is always respected and should be used as a","type":"text"},{"text":" ","type":"text"},{"text":"way to provide additional meaning to the control.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This example shows Answer and Decline buttons with ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/green","type":"reference"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/red","type":"reference"},{"text":" tint colors, respectively.","type":"text"}]},{"code":["struct ControlTint: View {","    var body: some View {","        HStack {","            Button {","                \/\/ Answer the call","            } label: {","                Label(\"Answer\", systemImage: \"phone\")","            }","            .tint(.green)","            Button {","                \/\/ Decline the call","            } label: {","                Label(\"Decline\", systemImage: \"phone.down\")","            }","            .tint(.red)","        }","        .buttonStyle(.borderedProminent)","        .padding()","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Some controls adapt to the tint color differently based on their style,","type":"text"},{"text":" ","type":"text"},{"text":"the current platform, and the surrounding context. For example, in","type":"text"},{"text":" ","type":"text"},{"text":"macOS, a button with the ","type":"text"},{"type":"codeVoice","code":"PrimitiveButtonStyle\/bordered"},{"text":" style doesn’t","type":"text"},{"text":" ","type":"text"},{"text":"tint its background, but one with the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"PrimitiveButtonStyle\/borderedProminent"},{"text":" style does. In macOS, neither","type":"text"},{"text":" ","type":"text"},{"text":"of these button styles tint their label, but they do in other platforms.","type":"text"}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/equatableview\/tint(_