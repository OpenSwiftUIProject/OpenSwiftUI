text":" ","type":"text"},{"text":"100 frame. Because a shape always occupies the space offered to it by","type":"text"},{"text":" ","type":"text"},{"text":"the layout system, the first ellipse is 200x100 points. The second","type":"text"},{"text":" ","type":"text"},{"text":"ellipse is laid out in a frame with only a fixed height, so it occupies","type":"text"},{"text":" ","type":"text"},{"text":"that height, and whatever width the layout system offers to its parent.","type":"text"}],"type":"paragraph"},{"code":["VStack {","    Ellipse()","        .fill(Color.purple)","        .frame(width: 200, height: 100)","    Ellipse()","        .fill(Color.blue)","        .frame(height: 100)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"The alignment"},{"text":" parameter specifies this view’s alignment within the","type":"text"},{"text":" ","type":"text"},{"text":"frame.","type":"text"}],"type":"paragraph"},{"code":["Text(\"Hello world!\")","    .frame(width: 200, height: 30, alignment: .topLeading)","    .border(Color.gray)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"In the example above, the text is positioned at the top, leading corner","type":"text"},{"text":" ","type":"text"},{"text":"of the frame. If the text is taller than the frame, its bounds may","type":"text"},{"text":" ","type":"text"},{"text":"extend beyond the bottom of the frame’s bounds.","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/EquatableView":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EquatableView","navigatorTitle":[{"kind":"identifier","text":"EquatableView"}],"url":"\/documentation\/openswiftui\/equatableview","type":"topic","title":"EquatableView","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"EquatableView"}],"role":"symbol","