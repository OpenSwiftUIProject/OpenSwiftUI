{"sections":[],"metadata":{"platforms":[{"introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false,"name":"iOS"},{"introducedAt":"10.15","deprecated":false,"unavailable":false,"beta":false,"name":"macOS"},{"introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false,"name":"tvOS"},{"introducedAt":"1.0","deprecated":false,"unavailable":false,"beta":false,"name":"visionOS"},{"introducedAt":"6.0","deprecated":false,"unavailable":false,"beta":false,"name":"watchOS"}],"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"horizontalSizeClass"},{"kind":"text","text":": "},{"preciseIdentifier":"s:15OpenSwiftUICore22UserInterfaceSizeClassO","kind":"typeIdentifier","text":"UserInterfaceSizeClass"},{"kind":"text","text":"?"}],"remoteSource":{"fileName":"EnvironmentAdditions.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Data\/EnvironmentKeys\/EnvironmentAdditions.swift#L868"},"symbolKind":"property","roleHeading":"Instance Property","externalID":"s:15OpenSwiftUICore17EnvironmentValuesV19horizontalSizeClassAA013UserInterfacegH0OSgvp","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"extendedModule":"OpenSwiftUICore","title":"horizontalSizeClass","role":"symbol"},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"The horizontal size class of this environment.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/environmentvalues\/horizontalsizeclass"]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues"]]},"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"horizontalSizeClass"},{"kind":"text","text":": "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UserInterfaceSizeClass","text":"UserInterfaceSizeClass","preciseIdentifier":"s:15OpenSwiftUICore22UserInterfaceSizeClassO"},{"kind":"text","text":"? { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" "},{"kind":"keyword","text":"set"},{"kind":"text","text":" }"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"You receive a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UserInterfaceSizeClass"},{"type":"text","text":" value when you read this"},{"type":"text","text":" "},{"type":"text","text":"environment value. The value tells you about the amount of horizontal"},{"type":"text","text":" "},{"type":"text","text":"space available to the view that reads it. You can read this"},{"type":"text","text":" "},{"type":"text","text":"size class like any other of the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues"},{"type":"text","text":", by creating a"},{"type":"text","text":" "},{"type":"text","text":"property with the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Environment"},{"type":"text","text":" property wrapper:"}],"type":"paragraph"},{"code":["@Environment(\\.horizontalSizeClass) private var horizontalSizeClass"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"OpenSwiftUI sets this size class based on several factors, including:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"The current device type.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The orientation of the device.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The appearance of Slide Over and Split View on iPad."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Several built-in views change their behavior based on this size class."},{"type":"text","text":" "},{"type":"text","text":"For example, a "},{"type":"codeVoice","code":"NavigationView"},{"type":"text","text":" presents a multicolumn view when"},{"type":"text","text":" "},{"type":"text","text":"the horizontal size class is "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UserInterfaceSizeClass\/regular"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"but a single column otherwise. You can also adjust the appearance of"},{"type":"text","text":" "},{"type":"text","text":"custom views by reading the size class and conditioning your views."},{"type":"text","text":" "},{"type":"text","text":"If you do, be prepared to handle size class changes while"},{"type":"text","text":" "},{"type":"text","text":"your app runs, because factors like device orientation can change at"},{"type":"text","text":" "},{"type":"text","text":"runtime."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In watchOS, the horizontal size class is always"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UserInterfaceSizeClass\/compact"},{"type":"text","text":". In macOS, and tvOS, it’s always"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UserInterfaceSizeClass\/regular"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Writing to the horizontal size class in the environment"},{"type":"text","text":" "},{"type":"text","text":"before macOS 14.0, tvOS 17.0, and watchOS 10.0 is not supported."}],"type":"paragraph"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/horizontalSizeClass"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/EnvironmentValues/horizontalSizeClass":{"abstract":[{"text":"The horizontal size class of this environment.","type":"text"}],"title":"horizontalSizeClass","url":"\/documentation\/openswiftui\/environmentvalues\/horizontalsizeclass","role":"symbol","type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"horizontalSizeClass","kind":"identifier"},{"text":": ","kind":"text"},{"text":"UserInterfaceSizeClass","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore22UserInterfaceSizeClassO"},{"text":"?","kind":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/horizontalSizeClass","kind":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/EnvironmentValues":{"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"EnvironmentValues"}],"url":"\/documentation\/openswiftui\/environmentvalues","role":"symbol","abstract":[{"type":"text","text":"A collection of environment values propagated through a view hierarchy."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues","navigatorTitle":[{"kind":"identifier","text":"EnvironmentValues"}],"type":"topic","title":"EnvironmentValues"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/UserInterfaceSizeClass":{"abstract":[{"text":"A set of values that indicate the visual size available to the view.","type":"text"}],"title":"UserInterfaceSizeClass","url":"\/documentation\/openswiftui\/userinterfacesizeclass","role":"symbol","type":"topic","fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"UserInterfaceSizeClass","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UserInterfaceSizeClass","kind":"symbol","navigatorTitle":[{"text":"UserInterfaceSizeClass","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/UserInterfaceSizeClass/compact":{"type":"topic","title":"UserInterfaceSizeClass.compact","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UserInterfaceSizeClass\/compact","abstract":[{"type":"text","text":"The compact size class."}],"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"compact","kind":"identifier"}],"url":"\/documentation\/openswiftui\/userinterfacesizeclass\/compact","kind":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/UserInterfaceSizeClass/regular":{"abstract":[{"text":"The regular size class.","type":"text"}],"title":"UserInterfaceSizeClass.regular","url":"\/documentation\/openswiftui\/userinterfacesizeclass\/regular","role":"symbol","type":"topic","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"regular","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/UserInterfaceSizeClass\/regular","kind":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Environment":{"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"Environment"}],"url":"\/documentation\/openswiftui\/environment","type":"topic","role":"symbol","abstract":[{"type":"text","text":"A property wrapper that reads a value from a view’s environment."}],"title":"Environment","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Environment","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Environment"}]}}}