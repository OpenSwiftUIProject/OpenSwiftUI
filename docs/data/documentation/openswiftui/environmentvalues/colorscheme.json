{"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues"]]},"metadata":{"extendedModule":"OpenSwiftUICore","role":"symbol","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"symbolKind":"property","roleHeading":"Instance Property","externalID":"s:15OpenSwiftUICore17EnvironmentValuesV11colorSchemeAA05ColorG0Ovp","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"colorScheme","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore11ColorSchemeO","text":"ColorScheme","kind":"typeIdentifier"}],"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Graphic\/Color\/ColorScheme.swift#L130","fileName":"ColorScheme.swift"},"title":"colorScheme"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"colorScheme","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ColorScheme","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore11ColorSchemeO","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ColorScheme"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"text":"Discussion","type":"heading"},{"inlineContent":[{"text":"Read this environment value from within a view to find out if OpenSwiftUI","type":"text"},{"text":" ","type":"text"},{"text":"is currently displaying the view using the ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ColorScheme\/light","isActive":true},{"text":" or","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ColorScheme\/dark","isActive":true},{"text":" appearance. The value that you receive depends on","type":"text"},{"text":" ","type":"text"},{"text":"whether the user has enabled Dark Mode, possibly superseded by","type":"text"},{"text":" ","type":"text"},{"text":"the configuration of the current presentation’s view hierarchy.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["@Environment(\\.colorScheme) private var colorScheme","","var body: some View {","    Text(colorScheme == .dark ? \"Dark\" : \"Light\")","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"You can set the "},{"type":"codeVoice","code":"colorScheme"},{"type":"text","text":" environment value directly,"},{"type":"text","text":" "},{"type":"text","text":"but that usually isn’t what you want. Doing so changes the color"},{"type":"text","text":" "},{"type":"text","text":"scheme of the given view and its child views but "},{"type":"emphasis","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" the views"},{"type":"text","text":" "},{"type":"text","text":"above it in the view hierarchy. Instead, set a color scheme using the"},{"type":"text","text":" "},{"code":"View\/preferredColorScheme(_:)","type":"codeVoice"},{"type":"text","text":" modifier, which also propagates the"},{"type":"text","text":" "},{"type":"text","text":"value up through the view hierarchy to the enclosing presentation, like"},{"type":"text","text":" "},{"type":"text","text":"a sheet or a window."}],"type":"paragraph"},{"inlineContent":[{"text":"When adjusting your app’s user interface to match the color scheme,","type":"text"},{"text":" ","type":"text"},{"text":"consider also checking the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/colorSchemeContrast","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"property, which reflects a system-wide contrast setting that the user","type":"text"},{"text":" ","type":"text"},{"text":"controls. For information, see","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/accessibility#Color-and-effects","isActive":true,"type":"reference"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"in the Human Interface Guidelines.","type":"text"}],"type":"paragraph"},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"If you only need to provide different colors or"},{"type":"text","text":" "},{"type":"text","text":"images for different color scheme and contrast settings, do that in"},{"type":"text","text":" "},{"type":"text","text":"your app’s Asset Catalog. See"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/xcode\/asset-management"},{"type":"text","text":"."}],"type":"paragraph"}],"style":"note","type":"aside"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/colorScheme","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/environmentvalues\/colorscheme"]}],"sections":[],"abstract":[{"text":"The color scheme of this environment.","type":"text"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ColorScheme":{"type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ColorScheme","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"ColorScheme"}],"navigatorTitle":[{"kind":"identifier","text":"ColorScheme"}],"abstract":[{"text":"The possible color schemes, corresponding to the light and dark appearances.","type":"text"}],"kind":"symbol","url":"\/documentation\/openswiftui\/colorscheme","title":"ColorScheme"},"https://developer.apple.com/design/human-interface-guidelines/acces