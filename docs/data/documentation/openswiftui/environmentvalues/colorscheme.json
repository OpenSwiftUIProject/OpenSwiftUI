{"abstract":[{"text":"The color scheme of this environment.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/environmentvalues\/colorscheme"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"colorScheme"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore11ColorSchemeO","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ColorScheme","text":"ColorScheme"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" "},{"kind":"keyword","text":"set"},{"kind":"text","text":" }"}]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Read this environment value from within a view to find out if OpenSwiftUI","type":"text"},{"text":" ","type":"text"},{"text":"is currently displaying the view using the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ColorScheme\/light","type":"reference","isActive":true},{"text":" or","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ColorScheme\/dark","type":"reference","isActive":true},{"text":" appearance. The value that you receive depends on","type":"text"},{"text":" ","type":"text"},{"text":"whether the user has enabled Dark Mode, possibly superseded by","type":"text"},{"text":" ","type":"text"},{"text":"the configuration of the current presentation’s view hierarchy.","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["@Environment(\\.colorScheme) private var colorScheme","","var body: some View {","    Text(colorScheme == .dark ? \"Dark\" : \"Light\")","}"]},{"type":"paragraph","inlineContent":[{"text":"You can set the ","type":"text"},{"code":"colorScheme","type":"codeVoice"},{"text":" environment value directly,","type":"text"},{"text":" ","type":"text"},{"text":"but that usually isn’t what you want. Doing so changes the color","type":"text"},{"text":" ","type":"text"},{"text":"scheme of the given view and its child views but ","type":"text"},{"inlineContent":[{"type":"text","text":"not"}],"type":"emphasis"},{"text":" the views","type":"text"},{"text":" ","type":"text"},{"text":"above it in the view hierarchy. Instead, set a color scheme using the","type":"text"},{"text":" ","type":"text"},{"code":"View\/preferredColorScheme(_:)","type":"codeVoice"},{"text":" modifier, which also propagates the","type":"text"},{"text":" ","type":"text"},{"text":"value up through the view hierarchy to the enclosing presentation, like","type":"text"},{"text":" ","type":"text"},{"text":"a sheet or a window.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When adjusting your app’s user interface to match the color scheme,"},{"type":"text","text":" "},{"type":"text","text":"consider also checking the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/colorSchemeContrast","isActive":true},{"type":"text","text":" "},{"type":"text","text":"property, which reflects a system-wide contrast setting that the user"},{"type":"text","text":" "},{"type":"text","text":"controls. For information, see"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/design\/human-interface-guidelines\/accessibility#Color-and-effects","isActive":true},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"in the Human Interface Guidelines."}]},{"name":"Note","type":"aside","content":[{"inlineContent":[{"text":"If you only need to provide different colors or","type":"text"},{"text":" ","type":"text"},{"text":"images for different color scheme and contrast settings, do that in","type":"text"},{"text":" ","type":"text"},{"text":"your app’s Asset Catalog. See","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/xcode\/asset-management","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}],"style":"note"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues"]]},"kind":"symbol","sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"colorScheme","kind":"identifier"},{"text":": ","kind":"text"},{"text":"ColorScheme","preciseIdentifier":"s:15OpenSwiftUICore11ColorSchemeO","kind":"typeIdentifier"}],"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"title":"colorScheme","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Graphic\/Color\/ColorScheme.swift#L130","fileName":"ColorScheme.swift"},"extendedModule":"OpenSwiftUICore","roleHeading":"Instance Property","symbolKind":"property","role":"symbol","externalID":"s:15OpenSwiftUICore17EnvironmentValuesV11colorSchemeAA05ColorG0Ovp"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/colorScheme"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/EnvironmentValues/colorSchemeContrast":{"fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"colorSchemeContrast"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore19ColorSchemeContrastO","text":"ColorSchemeContrast"}],"abstract":[{"type":"text","text":"The contrast associated with the color scheme of this environment."}],"type":"topic","title":"colorSchemeContrast","kind":"symbol","url":"\/documentation\/openswiftui\/environmentvalues\/colorschemecontrast","identifier":"doc: