{"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"metadata":{"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isLuminanceReduced","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"}],"extendedModule":"OpenSwiftUICore","platforms":[{"unavailable":false,"name":"iOS","introducedAt":"13.0","deprecated":false,"beta":false},{"unavailable":false,"name":"macOS","introducedAt":"10.15","deprecated":false,"beta":false},{"unavailable":false,"name":"tvOS","introducedAt":"13.0","deprecated":false,"beta":false},{"unavailable":false,"name":"visionOS","introducedAt":"1.0","deprecated":false,"beta":false},{"unavailable":false,"name":"watchOS","introducedAt":"6.0","deprecated":false,"beta":false}],"symbolKind":"property","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Data\/EnvironmentKeys\/LuminanceReduced.swift#L47","fileName":"LuminanceReduced.swift"},"title":"isLuminanceReduced","role":"symbol","roleHeading":"Instance Property","externalID":"s:15OpenSwiftUICore17EnvironmentValuesV18isLuminanceReducedSbvp","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}]},"abstract":[{"type":"text","text":"A Boolean value that indicates whether the display or environment currently requires"},{"type":"text","text":" "},{"type":"text","text":"reduced luminance."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"isLuminanceReduced","kind":"identifier"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":" { ","kind":"text"},{"text":"get","kind":"keyword"},{"text":" ","kind":"text"},{"text":"set","kind":"keyword"},{"text":" }","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"type":"heading","text":"Discussion","anchor":"discussion","