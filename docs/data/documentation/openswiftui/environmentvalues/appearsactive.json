,{"content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"On macOS, views in the focused window (also referred to as the “key”"},{"type":"text","text":" "},{"type":"text","text":"window) should appear active. Some contexts also appear active in other"},{"type":"text","text":" "},{"type":"text","text":"circumstances, such as the contents of a window toolbar appearing active"},{"type":"text","text":" "},{"type":"text","text":"when the window is not focused but is the main window."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Typical adjustments made when a view does not appear active include:"}]},{"items":[{"content":[{"inlineContent":[{"text":"Uses of ","type":"text"},{"type":"codeVoice","code":"Color.accentColor"},{"text":" should generally be removed or replaced","type":"text"},{"text":" ","type":"text"},{"text":"with a desaturated style.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Text and image content in sidebars should appear dimmer.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Buttons with destructive actions should appear disabled."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"ShapeStyle.selection"},{"type":"text","text":" and selection in list and tables will"},{"type":"text","text":" "},{"type":"text","text":"automatically become a grey color"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"Custom views, styles, and shape styles can use this to adjust their","type":"text"},{"text":" ","type":"text"},{"text":"own appearance:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["struct ProminentPillButtonStyle: ButtonStyle {","    @Environment(\\.appearsActive) private var appearsActive","","    func makeBody(configuration: Configuration) -> some View {","        configuration.label","            .lineLimit(1)","            .padding(.horizontal, 8)","            .padding(.vertical, 2)","            .frame(minHeight: 20)","            .overlay(Capsule().strokeBorder(.tertiary))","            .background(appearsActive ? Color.accentColor : .clear, in: .capsule)","            .contentShape(.capsule)","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On all other platforms, this value is always "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"text":"This is bridged with ","type":"text"},{"type":"codeVoice","code":"UITraitCollection.activeAppearance"},{"text":" for UIKit","type":"text"},{"text":" ","type":"text"},{"text":"hosted content.","type":"text"}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/openswiftui\/environmentvalues\/appearsactive"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Whether views and styles in this environment should prefer an active","type":"text"},{"text":" ","type":"text"},{"text":"appearance over an inactive appearance.","type":"text"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/EnvironmentValues":{"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"EnvironmentValues"}],"url":"\/documentation\/openswiftui\/environmentvalues","role":"symbol","abstract":[{"type":"text","text":"A collection of environment values propagated through a view hierarchy."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues","navigatorTitle":[{"kind":"identifier","text":"EnvironmentValues"}],"type":"topic","title":"EnvironmentValues"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/EnvironmentValues/appearsActive":{"abstract":[{"type":"text","text":"Whether views and styles in this environment should prefer an active"},{"type":"text","text":" "},{"type":"text","text":"appearance over an inactive appearance."}],"fragments":[{