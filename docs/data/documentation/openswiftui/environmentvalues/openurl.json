{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"openURL"},{"kind":"text","text":": "},{"preciseIdentifier":"s:11OpenSwiftUI0A9URLActionV","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/OpenURLAction","text":"OpenURLAction"},{"kind":"text","text":" { "},{"kind":"keyword","text":"get"},{"kind":"text","text":" "},{"kind":"keyword","text":"set"},{"kind":"text","text":" }"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Read this environment value to get an "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/OpenURLAction","isActive":true},{"type":"text","text":" "},{"type":"text","text":"instance for a given "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Environment","isActive":true},{"type":"text","text":". Call the"},{"type":"text","text":" "},{"type":"text","text":"instance to open a URL. You call the instance directly because it"},{"type":"text","text":" "},{"type":"text","text":"defines a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/OpenURLAction\/callAsFunction(_:)","isActive":true},{"type":"text","text":" method that Swift"},{"type":"text","text":" "},{"type":"text","text":"calls when you call the instance."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, you can open a web site when the user taps a button:"}]},{"type":"codeListing","code":["struct OpenURLExample: View {","    @Environment(\\.openURL) private var openURL","","    var body: some View {","        Button {","            if let url = URL(string: \"https:\/\/www.example.com\") {","                openURL(url)","            }","        } label: {","            Label(\"Get Help\", systemImage: \"person.fill.questionmark\")","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to know whether the action succeeds, add a completion"},{"type":"text","text":" "},{"type":"text","text":"handler that takes a Boolean value. In this case, Swift implicitly"},{"type":"text","text":" "},{"type":"text","text":"calls the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/OpenURLAction\/callAsFunction(_:completion:)","isActive":true},{"type":"text","text":" method"},{"type":"text","text":" "},{"type":"text","text":"instead. That method calls your completion handler after it determines"},{"type":"text","text":" "},{"type":"text","text":"whether it can open the URL, but possibly before it finishes opening"},{"type":"text","text":" "},{"type":"text","text":"the URL. You can add a handler to the example above so that"},{"type":"text","text":" "},{"type":"text","text":"it prints the outcome to the console:"}]},{"type":"codeListing","code":["openURL(url) { accepted in","    print(accepted ? \"Success\" : \"Failure\")","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The system provides a default open URL action with behavior"},{"type":"text","text":" "},{"type":"text","text":"that depends on the contents of the URL. For example, the default"},{"type":"text","text":" "},{"type":"text","text":"action opens a Universal Link in the associated app if possible,"},{"type":"text","text":" "},{"type":"text","text":"or in the user’s default web browser if not."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can also set a custom action using the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/environment(_:_:)"},{"type":"text","text":" "},{"type":"text","text":"view modifier. Any views that read the action from the environment,"},{"type":"text","text":" "},{"type":"text","text":"including the built-in "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Link"},{"type":"text","text":" view and "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" views with markdown"},{"type":"text","text":" "},{"type":"text","text":"links, or links in attributed strings, use your action. Initialize an"},{"type":"text","text":" "},{"type":"text","text":"action by calling the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/OpenURLAction\/init(handler:)"},{"type":"text","text":" initializer with"},{"type":"text","text":" "},{"type":"text","text":"a handler that takes a URL and returns an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/OpenURLAction\/Result"},{"type":"text","text":":"}]},{"type":"codeListing","code":["Text(\"Visit [Example Company](https:\/\/www.example.com) for details.\")","    .environment(\\.openURL, OpenURLAction { url in","        handleURL(url) \/\/ Define this method to take appropriate action.","        return .handled","    })"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenSwiftUI translates the value that your custom action’s handler"},{"type":"text","text":" "},{"type":"text","text":"returns into an appropriate Boolean result for the action call."},{"type":"text","text":" "},{"type":"text","text":"For example, a view that uses the action declared above"},{"type":"text","text":" "},{"type":"text","text":"receives "},{"type":"codeVoice","code":"true"},{"type":"text","text":" when calling the action, because the"},{"type":"text","text":" "},{"type":"text","text":"handler always returns "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/OpenURLAction\/Result\/handled"},{"type":"text","text":"."}]}],"kind":"content"}],"metadata":{"title":"openURL","externalID":"s:15OpenSwiftUICore17EnvironmentValuesV0aB2UIE7openURLAD0A9URLActionVvp","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/Control\/Link\/OpenURLActionKey.swift#L125","fileName":"OpenURLActionKey.swift"},"role":"symbol","roleHeading":"Instance Property","extendedModule":"OpenSwiftUICore","symbolKind":"property","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"openURL","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:11OpenSwiftUI0A9URLActionV","text":"OpenURLAction","kind":"typeIdentifier"}]},"abstract":[{"type":"text","text":"An action that opens a URL."}],"variants":[{"paths":["\/documentation\/openswiftui\/environmentvalues\/openurl"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/openURL","interfaceLanguage":"swift"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Text":{"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Text","kind":"identifier"}],"role":"symbol","url":"\/documentation\/openswiftui\/text","type":"topic","navigatorTitle":[{"text":"Text","kind":"identifier"}],"title":"Text","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","abstract":[]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/OpenURLAction/callAsFunction(_:completion:)":{"url":"\/documentation\/openswiftui\/openurlaction\/callasfunction(_:completion:)","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/OpenURLAction\/callAsFunction(_:compl