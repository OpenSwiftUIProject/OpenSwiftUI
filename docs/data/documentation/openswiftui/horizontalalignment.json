SwiftUI/documentation/OpenSwiftUI/HorizontalAlignment/init(_:)":{"type":"topic","role":"symbol","kind":"symbol","abstract":[{"text":"Creates a custom horizontal alignment of the specified type.","type":"text"}],"url":"\/documentation\/openswiftui\/horizontalalignment\/init(_:)","title":"init(_:)","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/init(_:)","fragments":[{"text":"init","kind":"identifier"},{"text":"(any ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore11AlignmentIDP","text":"AlignmentID","kind":"typeIdentifier"},{"text":".Type)","kind":"text"}]},"doc://OpenSwiftUI/s8SendableP":{"type":"unresolvable","identifier":"doc:\/\/OpenSwiftUI\/s8SendableP","title":"Swift.Sendable"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View/environment(_:_:)":{"role":"symbol","url":"\/documentation\/openswiftui\/view\/environment(_:_:)","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/environment(_:_:)","type":"topic","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":"<","kind":"text"},{"text":"V","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"WritableKeyPath","preciseIdentifier":"s:s15WritableKeyPathC","kind":"typeIdentifier"},{"text":"<","kind":"text"},{"text":"EnvironmentValues","preciseIdentifier":"s:15OpenSwiftUICore17EnvironmentValuesV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"V","kind":"typeIdentifier"},{"text":">, ","kind":"text"},{"text":"V","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"}],"abstract":[{"text":"Sets the environment value of the specified key path to the given value.","type":"text"}],"kind":"symbol","title":"environment(_:_:)"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/EnvironmentValues/layoutDirection":{"url":"\/documentation\/openswiftui\/environmentvalues\/layoutdirection","abstract":[{"type":"text","text":"The layout direction associated with the current environment."}],"kind":"symbol","type":"topic","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"layoutDirection","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore15LayoutDirectionO","text":"LayoutDirection","kind":"typeIdentifier"}],"title":"layoutDirection","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/layoutDirection","role":"symbol"}}}