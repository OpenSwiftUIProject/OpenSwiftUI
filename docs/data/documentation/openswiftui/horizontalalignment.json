{"sections":[],"topicSections":[{"title":"Getting guides","anchor":"Getting-guides","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/leading","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/center","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/trailing"]},{"title":"Creating a custom alignment","anchor":"Creating-a-custom-alignment","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/init(_:)"]},{"title":"Instance Methods","anchor":"Instance-Methods","generated":true,"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/combineExplicit(_:)"]}],"kind":"symbol","metadata":{"title":"HorizontalAlignment","remoteSource":{"fileName":"AlignmentGuide.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Alignment\/AlignmentGuide.swift#L316"},"role":"symbol","modules":[{"name":"OpenSwiftUI"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"HorizontalAlignment","kind":"identifier"}],"navigatorTitle":[{"kind":"identifier","text":"HorizontalAlignment"}],"externalID":"s:15OpenSwiftUICore19HorizontalAlignmentV","symbolKind":"struct","roleHeading":"Structure"},"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"HorizontalAlignment","kind":"identifier"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Use horizontal alignment guides to tell OpenSwiftUI how to position views"},{"type":"text","text":" "},{"type":"text","text":"relative to one another horizontally, like when you place views vertically"},{"type":"text","text":" "},{"type":"text","text":"in an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":". The following example demonstrates common built-in"},{"type":"text","text":" "},{"type":"text","text":"horizontal alignments:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"You can generate the example above by creating a series of columns","type":"text"},{"text":" ","type":"text"},{"text":"implemented as vertical stacks, where you configure each stack with a","type":"text"},{"text":" ","type":"text"},{"text":"different alignment guide:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["private struct HorizontalAlignmentGallery: View {","    var body: some View {","        HStack(spacing: 30) {","            column(alignment: .leading, text: \"Leading\")","            column(alignment: .center, text: \"Center\")","            column(alignment: .trailing, text: \"Trailing\")","        }","        .frame(height: 150)","    }","","    private func column(alignment: HorizontalAlignment, text: String) -> some View {","        VStack(alignment: alignment, spacing: 0) {","            Color.red.frame(width: 1)","            Text(text).font(.title).border(.gray)","            Color.red.frame(width: 1)","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"During layout, OpenSwiftUI aligns the views inside each stack by bringing"},{"type":"text","text":" "},{"type":"text","text":"together the specified guides of the affected views. OpenSwiftUI calculates"},{"type":"text","text":" "},{"type":"text","text":"the position of a guide for a particular view based on the characteristics"},{"type":"text","text":" "},{"type":"text","text":"of the view. For example, the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/center","isActive":true},{"type":"text","text":" guide appears"},{"type":"text","text":" "},{"type":"text","text":"at half the width of the view. You can override the guide calculation for a"},{"type":"text","text":" "},{"type":"text","text":"particular view using the "},{"type":"codeVoice","code":"View\/alignmentGuide(_:computeValue:)"},{"type":"text","text":" "},{"type":"text","text":"view modifier."}],"type":"paragraph"},{"level":3,"text":"Layout direction","anchor":"Layout-direction","type":"heading"},{"inlineContent":[{"type":"text","text":"When a user configures their device to use a left-to-right language like"},{"type":"text","text":" "},{"type":"text","text":"English, the system places the leading alignment on the left and the"},{"type":"text","text":" "},{"type":"text","text":"trailing alignment on the right, as the example from the previous section"},{"type":"text","text":" "},{"type":"text","text":"demonstrates. However, in a right-to-left language, the system reverses"},{"type":"text","text":" "},{"type":"text","text":"these. You can see this by using the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/environment(_:_:)"},{"type":"text","text":" view"},{"type":"text","text":" "},{"type":"text","text":"modifier to explicitly override the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/layoutDirection"},{"type":"text","text":" "},{"type":"text","text":"environment value for the view defined above:"}],"type":"paragraph"},{"syntax":"swift","code":["HorizontalAlignmentGallery()","    .environment(\\.layoutDirection, .rightToLeft)"],"type":"codeListing"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"This automatic layout adjustment makes it easier to localize your app,","type":"text"},{"text":" ","type":"text"},{"text":"but it’s still important to test your app for the different locales that","type":"text"},{"text":" ","type":"text"},{"text":"you ship into. For more information about the localization process, see","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/xcode\/localization","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"level":3,"text":"Custom alignment guides","anchor":"Custom-alignment-guides","type":"heading"},{"inlineContent":[{"type":"text","text":"You can create a custom horizontal alignment by creating a type that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID","isActive":true,"type":"reference"},{"type":"text","text":" protocol, and then using that type to"},{"type":"text","text":" "},{"type":"text","text":"initalize a new static property on "},{"code":"HorizontalAlignment","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["private struct OneQuarterAlignment: AlignmentID {","    static func defaultValue(in context: ViewDimensions) -> CGFloat {","        context.width \/ 4","    }","}","","extension HorizontalAlignment {","    static let oneQuarter = HorizontalAlignment(OneQuarterAlignment.self)","}"],"type":"codeListing"},{"inlineContent":[{"text":"You implement the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID\/defaultValue(in:)","isActive":true,"type":"reference"},{"text":" method to calculate","type":"text"},{"text":" ","type":"text"},{"text":"a default value for the custom alignment guide. The method receives a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions","isActive":true,"type":"reference"},{"text":" instance that you can use to calculate an appropriate","type":"text"},{"text":" ","type":"text"},{"text":"value based on characteristics of the view. The example above places","type":"text"},{"text":" ","type":"text"},{"text":"the guide at one quarter of the width of the view, as measured from the","type":"text"},{"text":" ","type":"text"},{"text":"view’s origin.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"You can then use the custom alignment guide like any built-in guide. For","type":"text"},{"text":" ","type":"text"},{"text":"example, you can use it as the ","type":"text"},{"type":"codeVoice","code":"alignment"},{"text":" parameter to a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"or you can change it for a specific view using the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"View\/alignmentGuide(_:computeValue:)"},{"text":" view modifier.","type":"text"},{"text":" ","type":"text"},{"text":"Custom alignment guides also automatically reverse in a right-to-left","type":"text"},{"text":" ","type":"text"},{"text":"environment, just like built-in guides.","type":"text"}],"type":"paragraph"},{"level":3,"text":"Composite alignment","anchor":"Composite-alignment","type":"heading"},{"inlineContent":[{"text":"Combine a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","type":"reference"},{"text":" with a ","type":"text"},{"type":"codeVoice","code":"HorizontalAlignment"},{"text":" to create a","type":"text"},{"text":" ","type":"text"},{"text":"composite ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment","type":"reference"},{"text":" that indicates both vertical and horizontal","type":"text"},{"text":" ","type":"text"},{"text":"positioning in one value. For example, you could combine your custom","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"oneQuarter"},{"text":" horizontal alignment from the previous section with a built-in","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/center","type":"reference"},{"text":" vertical alignment to use in a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct LayeredVerticalStripes: View {","    var body: some View {","        ZStack(alignment: Alignment(horizontal: .oneQuarter, vertical: .center)) {","            verticalStripes(color: .blue)","                .frame(width: 300, height: 150)","            verticalStripes(color: .green)","                .frame(width: 180, height: 80)","        }","    }","","    private func verticalStripes(color: Color) -> some View {","        HStack(spacing: 1) {","            ForEach(0..<4) { _ in color }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The example above uses widths and heights that generate two mismatched sets"},{"type":"text","text":" "},{"type":"text","text":"of four vertical stripes. The "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","type":"reference","isActive":true},{"type":"text","text":" centers the two sets vertically and"},{"type":"text","text":" "},{"type":"text","text":"aligns them horizontally one quarter of the way from the leading edge of"},{"type":"text","text":" "},{"type":"text","text":"each set. In a left-to-right locale, this aligns the right edges of the"},{"type":"text","text":" "},{"type":"text","text":"left-most stripes of each set:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"}],"kind":"content"}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","interfaceLanguage":"swift"},"relationshipsSections":[{"title":"Conforms To","identifiers":["doc:\/\/OpenSwiftUI\/s15BitwiseCopyableP","doc:\/\/OpenSwiftUI\/SQ","doc:\/\/OpenSwiftUI\/s8SendableP"],"type":"conformsTo","kind":"relationships"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/horizontalalignment"]}],"seeAlsoSections":[{"title":"Aligning views","anchor":"Aligning-views","generated":true,"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions"]}],"abstract":[{"type":"text","text":"An alignment position along the horizontal axis."}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/HorizontalAlignment":{"abstract":[{"text":"An alignment position along the horizontal axis.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","role":"symbol","kind":"symbol","type":"topic","navigatorTitle":[{"text":"HorizontalAlignment","kind":"identifier"}],"title":"HorizontalAlignment","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"HorizontalAlignment","kind":"identifier"}],"url":"\/documentation\/openswiftui\/horizontalalignment"},"doc://OpenSwiftUI/s15BitwiseCopyableP":{"type":"unresolvable","identifier":"doc:\/\/OpenSwiftUI\/s15BitwiseCopyableP","title":"Swift.BitwiseCopyable"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View/environment(_:_:)":{"abstract":[{"text":"Sets the environment value of the specified key path to the given value.","type":"text"}],"type":"topic","role":"symbol","title":"environment(_:_:)","url":"\/documentation\/openswiftui\/view\/environment(_:_:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"environment","kind":"identifier"},{"text":"<","kind":"text"},{"text":"V","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"WritableKeyPath","kind":"typeIdentifier","preciseIdentifier":"s:s15WritableKeyPathC"},{"text":"<","kind":"text"},{"text":"Enviro