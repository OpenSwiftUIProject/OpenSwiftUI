{"relationshipsSections":[{"identifiers":["doc:\/\/OpenSwiftUI\/s15BitwiseCopyableP","doc:\/\/OpenSwiftUI\/SQ","doc:\/\/OpenSwiftUI\/s8SendableP"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/horizontalalignment"]}],"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/leading","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/center","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/trailing"],"anchor":"Getting-guides","title":"Getting guides"},{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/init(_:)"],"anchor":"Creating-a-custom-alignment","title":"Creating a custom alignment"},{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/combineExplicit(_:)"],"generated":true,"anchor":"Instance-Methods","title":"Instance Methods"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"abstract":[{"text":"An alignment position along the horizontal axis.","type":"text"}],"seeAlsoSections":[{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions"],"generated":true,"anchor":"Aligning-views","title":"Aligning views"}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"@frozen"},{"kind":"text","text":" "},{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"HorizontalAlignment"}],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Use horizontal alignment guides to tell OpenSwiftUI how to position views","type":"text"},{"text":" ","type":"text"},{"text":"relative to one another horizontally, like when you place views vertically","type":"text"},{"text":" ","type":"text"},{"text":"in an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"text":". The following example demonstrates common built-in","type":"text"},{"text":" ","type":"text"},{"text":"horizontal alignments:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can generate the example above by creating a series of columns"},{"type":"text","text":" "},{"type":"text","text":"implemented as vertical stacks, where you configure each stack with a"},{"type":"text","text":" "},{"type":"text","text":"different alignment guide:"}]},{"type":"codeListing","syntax":"swift","code":["private struct HorizontalAlignmentGallery: View {","    var body: some View {","        HStack(spacing: 30) {","            column(alignment: .leading, text: \"Leading\")","            column(alignment: .center, text: \"Center\")","            column(alignment: .trailing, text: \"Trailing\")","        }","        .frame(height: 150)","    }","","    private func column(alignment: HorizontalAlignment, text: String) -> some View {","        VStack(alignment: alignment, spacing: 0) {","            Color.red.frame(width: 1)","            Text(text).font(.title).border(.gray)","            Color.red.frame(width: 1)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"During layout, OpenSwiftUI aligns the views inside each stack by bringing","type":"text"},{"text":" ","type":"text"},{"text":"together the specified guides of the affected views. OpenSwiftUI calculates","type":"text"},{"text":" ","type":"text"},{"text":"the position of a guide for a particular view based on the characteristics","type":"text"},{"text":" ","type":"text"},{"text":"of the view. For example, the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/center","isActive":true,"type":"reference"},{"text":" guide appears","type":"text"},{"text":" ","type":"text"},{"text":"at half the width of the view. You can override the guide calculation for a","type":"text"},{"text":" ","type":"text"},{"text":"particular view using the ","type":"text"},{"code":"View\/alignmentGuide(_:computeValue:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"view modifier.","type":"text"}]},{"type":"heading","level":3,"anchor":"Layout-direction","text":"Layout direction"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When a user configures their device to use a left-to-right language like"},{"type":"text","text":" "},{"type":"text","text":"English, the system places the leading alignment on the left and the"},{"type":"text","text":" "},{"type":"text","text":"trailing alignment on the right, as the example from the previous section"},{"type":"text","text":" "},{"type":"text","text":"demonstrates. However, in a right-to-left language, the system reverses"},{"type":"text","text":" "},{"type":"text","text":"these. You can see this by using the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/environment(_:_:)"},{"type":"text","text":" view"},{"type":"text","text":" "},{"type":"text","text":"modifier to explicitly override the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/layoutDirection"},{"type":"text","text":" "},{"type":"text","text":"environment value for the view defined above:"}]},{"type":"codeListing","syntax":"swift","code":["HorizontalAlignmentGallery()","    .environment(\\.layoutDirection, .rightToLeft)"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"This automatic layout adjustment makes it easier to localize your app,","type":"text"},{"text":" ","type":"text"},{"text":"but it’s still important to test your app for the different locales that","type":"text"},{"text":" ","type":"text"},{"text":"you ship into. For more information about the localization process, see","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/xcode\/localization","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"heading","level":3,"anchor":"Custom-alignment-guides","text":"Custom alignment guides"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can create a custom horizontal alignment by creating a type that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID","type":"reference","isActive":true},{"type":"text","text":" protocol, and then using that type to"},{"type":"text","text":" "},{"type":"text","text":"initalize a new static property on "},{"code":"HorizontalAlignment","type":"codeVoice"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["private struct OneQuarterAlignment: AlignmentID {","    static func defaultValue(in context: ViewDimensions) -> CGFloat {","        context.width \/ 4","    }","}","","extension HorizontalAlignment {","    static let oneQuarter = HorizontalAlignment(OneQuarterAlignment.self)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You implement the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID\/defaultValue(in:)","type":"reference","isActive":true},{"type":"text","text":" method to calculate"},{"type":"text","text":" "},{"type":"text","text":"a default value for the custom alignment guide. The method receives a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions","isActive":true},{"type":"text","text":" instance that you can use to calculate an appropriate"},{"type":"text","text":" "},{"type":"text","text":"value based on characteristics of the view. The example above places"},{"type":"text","text":" "},{"type":"text","text":"the guide at one quarter of the width of the view, as measured from the"},{"type":"text","text":" "},{"type":"text","text":"view’s origin."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can then use the custom alignment guide like any built-in guide. For"},{"type":"text","text":" "},{"type":"text","text":"example, you can use it as the "},{"type":"codeVoice","code":"alignment"},{"type":"text","text":" parameter to a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or you can change it for a specific view using the"},{"type":"text","text":" "},{"type":"codeVoice","code":"View\/alignmentGuide(_:computeValue:)"},{"type":"text","text":" view modifier."},{"type":"text","text":" "},{"type":"text","text":"Custom alignment guides also automatically reverse in a right-to-left"},{"type":"text","text":" "},{"type":"text","text":"environment, just like built-in guides."}]},{"level":3,"text":"Composite alignment","anchor":"Composite-alignment","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Combine a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment"},{"type":"text","text":" with a "},{"type":"codeVoice","code":"HorizontalAlignment"},{"type":"text","text":" to create a"},{"type":"text","text":" "},{"type":"text","text":"composite "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment"},{"type":"text","text":" that indicates both vertical and horizontal"},{"type":"text","text":" "},{"type":"text","text":"positioning in one value. For example, you could combine your custom"},{"type":"text","text":" "},{"type":"codeVoice","code":"oneQuarter"},{"type":"text","text":" horizontal alignment from the previous section with a built-in"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VerticalAlignment\/center"},{"type":"text","text":" vertical alignment to use in a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["struct LayeredVerticalStripes: View {","    var body: some View {","        ZStack(alignment: Alignment(horizontal: .oneQuarter, vertical: .center)) {","            verticalStripes(color: .blue)","                .frame(width: 300, height: 150)","            verticalStripes(color: .green)","                .frame(width: 180, height: 80)","        }","    }","","    private func verticalStripes(color: Color) -> some View {","        HStack(spacing: 1) {","            ForEach(0..<4) { _ in color }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example above uses widths and heights that generate two mismatched sets"},{"type":"text","text":" "},{"type":"text","text":"of four vertical stripes. The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack"},{"type":"text","text":" centers the two sets vertically and"},{"type":"text","text":" "},{"type":"text","text":"aligns them horizontally one quarter of the way from the leading edge of"},{"type":"text","text":" "},{"type":"text","text":"each set. In a left-to-right locale, this aligns the right edges of the"},{"type":"text","text":" "},{"type":"text","text":"left-most stripes of each set:"}]},{"type":"paragraph","inlineContent":[]}],"kind":"content"}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment","interfaceLanguage":"swift"},"metadata":{"navigatorTitle":[{"text":"HorizontalAlignment","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"HorizontalAlignment","kind":"identifier"}],"modules":[{"name":"OpenSwiftUI"}],"symbolKind":"struct","externalID":"s:15OpenSwiftUICore19HorizontalAlignmentV","title":"HorizontalAlignment","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Alignment\/AlignmentGuide.swift#L316","fileName":"AlignmentGuide.swift"},"role":"symbol","roleHeading":"Structure"},"schemaVersion":{"minor":3,"major":0,"patch":0},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/HorizontalAlignment/combineExplicit(_:)":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"combineExplicit","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"url":"\/documentation\/openswiftui\/horizontalalignment\/combineexplicit(_:)","type":"topic","abstract":[{"text":"Merges a sequence of explicit alignment values produced by","type":"text"},{"text":" ","type":"text"},{"text":"this instance.","type":"text"}],"title":"combineExplicit(_:)","kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/combineExplicit(_:)","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/HorizontalAlignment/center":{"fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"let","kind":"keyword"},{"text":" ","kind":"text"},{"text":"center","kind":"identifier"},{"text":": ","kind":"text"},{"text":"HorizontalAlignment","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore19HorizontalAlignmentV"}],"kind":"symbol","abstract":[{"type":"text","text":"A guide that marks the horizontal center of the view."}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HorizontalAlignment\/center","role":"symbol","type":"topic","title":"center","url":"\/documentation\/openswiftui\/horizontalalignment\/center"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/AlignmentID/defaultValue(in:)":{"kind":"symbol","type":"topic","abstract":[{"type":"text","text":"Calculates a default value for the corresponding guide in the specified"},{"type":"text","text":" "},{"type":"text","text":"context."}],"title":"defaultValue(in:)","role":"symbol","url":"\/documentation\/openswiftui\/alignmentid\/defaultvalue(in:)","fragments":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"defaultValue","kind":"identifier"},{"text":"(","kind":"text"},{"text":"in","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ViewDimensions","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore14ViewDimensionsV"},{"text":") -> ","kind":"text"},{"text":"CGFloat","kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV"}],"required":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AlignmentID\/defaultValue(in:)"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ViewDimensions":{"url":"\/documentation\/openswiftui\/viewdimensions","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewDimensions","title":"ViewDimensions","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewDimensions","kind":"identifier"}],"abstract":[{"type":"text","text":"A view’s size and alignment guides in its own c