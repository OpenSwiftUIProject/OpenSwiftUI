{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/makeCache(subviews:)"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout"]]},"abstract":[{"text":"Creates and initializes a cache for a layout instance.","type":"text"}],"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"makeCache"},{"kind":"text","text":"("},{"kind":"externalParam","text":"subviews"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"AnyLayout","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Subviews","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"AnyLayout","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Cache","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV5CacheV"}],"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/AnyLayout.swift#L131","fileName":"AnyLayout.swift"},"modules":[{"name":"OpenSwiftUI"}],"title":"makeCache(subviews:)","roleHeading":"Instance Method","symbolKind":"method","externalID":"s:15OpenSwiftUICore9AnyLayoutV9makeCache8subviewsAC0G0VAA0E8SubviewsV_tF"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/anylayout\/makecache(subviews:)"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"makeCache","kind":"identifier"},{"text":"(","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"AnyLayout","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout"},{"text":".","kind":"text"},{"text":"Subviews","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews"},{"text":") -> ","kind":"text"},{"text":"AnyLayout","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout"},{"text":".","kind":"text"},{"text":"Cache","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV5CacheV","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/Cache"}],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A collection of proxy instances that represent the","type":"text"},{"text":" ","type":"text"},{"text":"views that the container arranges. You can use the proxies in the","type":"text"},{"text":" ","type":"text"},{"text":"collection to get information about the subviews as you","type":"text"},{"text":" ","type":"text"},{"text":"calculate values to store in the cache.","type":"text"}]}],"name":"subviews"}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"inlineContent":[{"text":"Storage for calculated data that you share among","type":"text"},{"text":" ","type":"text"},{"text":"the methods of your custom layout container.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"You can optionally use a cache to preserve calculated values across"},{"type":"text","text":" "},{"type":"text","text":"calls to a layout container’s methods. Many layout types don’t need"},{"type":"text","text":" "},{"type":"text","text":"a cache, because OpenSwiftUI automatically reuses both the results of"},{"type":"text","text":" "},{"type":"text","text":"calls into the layout and the values that the layout reads from its"},{"type":"text","text":" "},{"type":"text","text":"subviews. Rely on the protocol’s default implementation of this method"},{"type":"text","text":" "},{"type":"text","text":"if you don’t need a cache."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"However you might find a cache useful when:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"The layout container repeats complex, intermediate calculations","type":"text"},{"text":" ","type":"text"},{"text":"across calls like ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/sizeThatFits(proposal:subviews:cache:)"},{"text":",","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/placeSubviews(in:proposal:subviews:cache:)"},{"text":", and","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"explicitAlignment(of:in:proposal:subviews:cache:)"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"You might be able to improve performance by calculating values","type":"text"},{"text":" ","type":"text"},{"text":"once and storing them in a cache.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The layout container reads many "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutValueKey","isActive":true,"type":"reference"},{"type":"text","text":" values from"},{"type":"text","text":" "},{"type":"text","text":"subviews. It might be more efficient to do that once and store the"},{"type":"text","text":" "},{"type":"text","text":"results in the cache, rather than rereading the subviews’ values before"},{"type":"text","text":" "},{"type":"text","text":"each layout call."}]}]},{"content":[{"inlineContent":[{"text":"You want to maintain working storage, like temporary Swift arrays,","type":"text"},{"text":" ","type":"text"},{"text":"across calls into the layout, to minimize the number of allocation","type":"text"},{"text":" ","type":"text"},{"text":"events.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"Only implement a cache if profiling shows that it improves performance."}],"type":"paragraph"},{"text":"Initialize a cache","anchor":"Initialize-a-cache","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"Implement the "},{"type":"codeVoice","code":"makeCache(subviews:)"},{"type":"text","text":" method to create a cache."},{"type":"text","text":" "},{"type":"text","text":"You can add computed values to the cache right away, using information"},{"type":"text","text":" "},{"type":"text","text":"from the "},{"type":"codeVoice","code":"subviews"},{"type":"text","text":" input parameter, or you can do that later. The"},{"type":"text","text":" "},{"type":"text","text":"methods of the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout"},{"type":"text","text":" protocol that can access the cache"},{"type":"text","text":" "},{"type":"text","text":"take the cache as an in-out parameter, which enables you to modify"},{"type":"text","text":" "},{"type":"text","text":"the cache anywhere that you can read it."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can use any storage type that makes sense for your layout"},{"type":"text","text":" "},{"type":"text","text":"algorithm, but be sure that you only store data that you derive"},{"type":"text","text":" "},{"type":"text","text":"from the layout and its subviews (lazily, if possible). For this to"},{"type":"text","text":" "},{"type":"text","text":"work correctly, OpenSwiftUI needs to be able to call this method to"},{"type":"text","text":" "},{"type":"text","text":"recreate the cache without changing the layout result."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When you return a cache from this method, you implicitly define a type"},{"type":"text","text":" "},{"type":"text","text":"for your cache. Be sure to either make the type of the "},{"type":"codeVoice","code":"cache"},{"type":"text","text":" "},{"type":"text","text":"parameters on your other "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout"},{"type":"text","text":" protocol methods match, or use"},{"type":"text","text":" "},{"type":"text","text":"a type alias to define the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/Cache"},{"type":"text","text":" associated type."}],"type":"paragraph"},{"text":"Update the cache","anchor":"Update-the-cache","type":"heading","level":3},{"inlineContent":[{"type":"text","text":"If the layout container or any of its subviews change, OpenSwiftUI"},{"type":"text","text":" "},{"type":"text","text":"calls the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/updateCache(_:subviews:)","isActive":true},{"type":"text","text":" method so you can"},{"type":"text","text":" "},{"type":"text","text":"modify or invalidate the contents of the"},{"type":"text","text":" "},{"type":"text","text":"cache. The default implementation of that method calls the"},{"type":"text","text":" "},{"code":"makeCache(subviews:)","type":"codeVoice"},{"type":"text","text":" method to recreate the cache, but you can"},{"type":"text","text":" "},{"type":"text","text":"provide your own implementation of the update method to take an"},{"type":"text","text":" "},{"type":"text","text":"incremental approach, if appropriate."}],"type":"paragraph"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/LayoutValueKey":{"ide