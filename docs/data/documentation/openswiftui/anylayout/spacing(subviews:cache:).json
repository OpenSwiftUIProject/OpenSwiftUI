{"abstract":[{"text":"Returns the preferred spacing values of the composite view.","type":"text"}],"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"spacing","kind":"identifier"},{"text":"(","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout","text":"AnyLayout","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews","text":"Subviews","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cache","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout","text":"AnyLayout","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV5CacheV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/Cache","text":"Cache","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","text":"ViewSpacing","kind":"typeIdentifier"}]}]},{"kind":"parameters","parameters":[{"name":"subviews","content":[{"inlineContent":[{"text":"A collection of proxy instances that represent the","type":"text"},{"text":" ","type":"text"},{"text":"views that the container arranges. You can use the proxies in the","type":"text"},{"text":" ","type":"text"},{"text":"collection to get information about the subviews as you determine","type":"text"},{"text":" ","type":"text"},{"text":"how much spacing the container prefers around it.","type":"text"}],"type":"paragraph"}]},{"name":"cache","content":[{"type":"paragraph","inlineContent":[{"text":"Optional storage for calculated data that you can share among","type":"text"},{"text":" ","type":"text"},{"text":"the methods of your custom layout container. See","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/makeCache(subviews:)","isActive":true},{"text":" for details.","type":"text"}]}]}]},{"kind":"content","content":[{"anchor":"return-value","level":2,"type":"heading","text":"Return Value"},{"inlineContent":[{"type":"text","text":"A "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing"},{"type":"text","text":" instance that describes the preferred"},{"type":"text","text":" "},{"type":"text","text":"spacing around the container view."}],"type":"paragraph"}]},{"kind":"content","content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement this method to provide custom spacing preferences"},{"type":"text","text":" "},{"type":"text","text":"for a layout container. The value you return affects"},{"type":"text","text":" "},{"type":"text","text":"the spacing around the container, but it doesn’t affect how the"},{"type":"text","text":" "},{"type":"text","text":"container arranges subviews relative to one another inside the"},{"type":"text","text":" "},{"type":"text","text":"container."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Create a custom "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","isActive":true},{"type":"text","text":" instance for your container by"},{"type":"text","text":" "},{"type":"text","text":"initializing one with default values, and then merging that with"},{"type":"text","text":" "},{"type":"text","text":"spacing instances of certain subviews. For example, if you define"},{"type":"text","text":" "},{"type":"text","text":"a basic vertical stack that places subviews in a column, you could"},{"type":"text","text":" "},{"type":"text","text":"use the spacing preferences of the subview edges that make"},{"type":"text","text":" "},{"type":"text","text":"contact with the container’s edges:"}]},{"type":"codeListing","syntax":"swift","code":["extension BasicVStack {","    func spacing(subviews: Subviews, cache: inout ()) -> ViewSpacing {","        var spacing = ViewSpacing()","","        for index in subviews.indices {","            var edges: Edge.Set = [.leading, .trailing]","            if index == 0 { edges.formUnion(.top) }","            if index == subviews.count - 1 { edges.formUnion(.bottom) }","            spacing.formUnion(subviews[index].spacing, edges: edges)","        }","","        return spacing","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"In the above example, the first and last subviews contribute to the"},{"type":"text","text":" "},{"type":"text","text":"spacing above and below the container, respectively, while all subviews"},{"type":"text","text":" "},{"type":"text","text":"affect the spacing on the leading and trailing edges."}]},{"type":"paragraph","inlineContent":[{"text":"If you don’t implement this method, the protocol provides a default","type":"text"},{"text":" ","type":"text"},{"text":"implementation that merges the spacing preferences across all subviews on all edges.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/openswiftui\/anylayout\/spacing(subviews:cache:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout"]]},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/spacing(subviews:cache:)","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"metadata":{"roleHeading":"Instance Method","title":"spacing(subviews:cache:)","modules":[{"name":"OpenSwiftUI"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"spacing"},{"kind":"text","text":"("},{"kind":"externalParam","text":"subviews"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"AnyLayout","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Subviews","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa"},{"kind":"text","text":", "},{"kind":"externalParam","text":"cache"},{"kind":"text","text":": "},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"AnyLayout","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"Cache","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV5CacheV"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"ViewSpacing","preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV"}],"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/AnyLayout.swift#L205","fileName":"AnyLayout.swift"},"externalID":"s:15OpenSwiftUICore9AnyLayoutV7spacing8subviews5cacheAA11ViewSpacingVAA0E8SubviewsV_AC5CacheVztF","symbolKind":"method","role":"symbol"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ViewSpacing":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewSpacing","kind":"identifier"}],"title":"ViewSpacing","url"