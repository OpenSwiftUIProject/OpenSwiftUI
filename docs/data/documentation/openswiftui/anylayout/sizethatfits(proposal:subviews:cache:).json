{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout"]]},"sections":[],"variants":[{"paths":["\/documentation\/openswiftui\/anylayout\/sizethatfits(proposal:subviews:cache:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"modules":[{"name":"OpenSwiftUI"}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizeThatFits","kind":"identifier"},{"text":"(","kind":"text"},{"text":"proposal","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore16ProposedViewSizeV","text":"ProposedViewSize","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV","text":"AnyLayout","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","text":"Subviews","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cache","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV","text":"AnyLayout","kind":"typeIdentifier"},{"text":".","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV5CacheV","text":"Cache","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"preciseIdentifier":"c:@S@CGSize","text":"CGSize","kind":"typeIdentifier"}],"externalID":"s:15OpenSwiftUICore9AnyLayoutV12sizeThatFits8proposal8subviews5cacheSo6CGSizeVAA16ProposedViewSizeV_AA0E8SubviewsVAC5CacheVztF","remoteSource":{"fileName":"AnyLayout.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/AnyLayout.swift#L277"},"roleHeading":"Instance Method","symbolKind":"method","title":"sizeThatFits(proposal:subviews:cache:)","role":"symbol"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/sizeThatFits(proposal:subviews:cache:)"},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Returns the size of the composite view, given a proposed size"},{"type":"text","text":" "},{"type":"text","text":"and the view’s subviews."}],"kind":"symbol","primaryContentSections":[{"declarations":[{"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"sizeThatFits","kind":"identifier"},{"text":"(","kind":"text"},{"text":"proposal","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ProposedViewSize","preciseIdentifier":"s:15OpenSwiftUICore16ProposedViewSizeV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"AnyLayout","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Subviews","preciseIdentifier":"s:15OpenSwiftUICore6LayoutP8Subviewsa","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout\/Subviews","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"cache","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"AnyLayout","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Cache","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV5CacheV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/Cache","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"CGSize","preciseIdentifier":"c:@S@CGSize","kind":"typeIdentifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"text":"A size proposal for the container. The container’s parent","type":"text"},{"text":" ","type":"text"},{"text":"view that calls this method might call the method more than once","type":"text"},{"text":" ","type":"text"},{"text":"with different proposals to learn more about the container’s","type":"text"},{"text":" ","type":"text"},{"text":"flexibility before deciding which proposal to use for placement.","type":"text"}],"type":"paragraph"}],"name":"proposal"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A collection of proxies that represent the"},{"type":"text","text":" "},{"type":"text","text":"views that the container arranges. You can use the proxies in the"},{"type":"text","text":" "},{"type":"text","text":"collection to get information about the subviews as you determine"},{"type":"text","text":" "},{"type":"text","text":"how much space the container needs to display them."}]}],"name":"subviews"},{"content":[{"type":"paragraph","inlineContent":[{"text":"Optional storage for calculated data that you can share among","type":"text"},{"text":" ","type":"text"},{"text":"the methods of your custom layout container. See","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/makeCache(subviews:)","isActive":true,"type":"reference"},{"text":" for details.","type":"text"}]}],"name":"cache"}],"kind":"parameters"},{"content":[{"text":"Return Value","type":"heading","anchor":"return-value","level":2},{"type":"paragraph","inlineContent":[{"text":"A size that indicates how much space the container","type":"text"},{"text":" ","type":"text"},{"text":"needs to arrange its subviews.","type":"text"}]}],"kind":"content"},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement this method to tell your custom layout container’s parent"},{"type":"text","text":" "},{"type":"text","text":"view how much space the container needs for a set of subviews, given"},{"type":"text","text":" "},{"type":"text","text":"a size proposal. The parent might call this method more than once"},{"type":"text","text":" "},{"type":"text","text":"during a layout pass with different proposed sizes to test the"},{"type":"text","text":" "},{"type":"text","text":"flexibility of the container, using proposals like:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/zero","isActive":true,"type":"reference"},{"type":"text","text":" proposal; respond with the"},{"type":"text","text":" "},{"type":"text","text":"layout’s minimum size."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/infinity","isActive":true,"type":"reference"},{"text":" proposal; respond with the","type":"text"},{"text":" ","type":"text"},{"text":"layout’s maximum size.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/unspecified"},{"type":"text","text":" proposal; respond with the"},{"type":"text","text":" "},{"type":"text","text":"layout’s ideal size."}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The parent might also choose to test flexibility in one dimension at a"},{"type":"text","text":" "},{"type":"text","text":"time. For example, a horizontal stack might propose a fixed height and"},{"type":"text","text":" "},{"type":"text","text":"an infinite width, and then the same height with a zero width."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example calculates the size for a basic vertical stack"},{"type":"text","text":" "},{"type":"text","text":"that places views in a column, with no spacing between the views:"}]},{"code":["private struct BasicVStack: Layout {","    func sizeThatFits(","        proposal: ProposedViewSize,","        subviews: Subviews,","        cache: inout ()","    ) -> CGSize {","        subviews.reduce(CGSize.zero) { result, subview in","            let size = subview.sizeThatFits(.unspecified)","            return CGSize(","                width: max(result.width, size.width),","                height: result.height + size.height)","        }","    }","","    \/\/ This layout also needs a placeSubviews() implementation.","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The implementation asks each subview for its ideal size by calling the"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutSubview\/sizeThatFits(_:)","type":"reference","isActive":true},{"type":"text","text":" method with an"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ProposedViewSize\/unspecified","type":"reference","isActive":true},{"type":"text","text":" proposed size."},{"type":"text","text":" "},{"type":"text","text":"It then reduces these values into a single size that represents"},{"type":"text","text":" "},{"type":"text","text":"the maximum subview width and the sum of subview heights."},{"type":"text","text":" "},{"type":"text","text":"Because this example isn’t flexible, it ignores its size proposal"},{"type":"text","text":" "},{"type":"text","text":"input and always returns the same value for a given set of subviews."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenSwiftUI views choose their own size, so the layout engine always"},{"type":"text","text":" "},{"type":"text","text":"uses a value that you return from this method as the actual size of the"},{"type":"text","text":" "},{"type":"text","text":"composite view. That size factors into the construction of the "},{"type":"codeVoice","code":"bounds"},{"type":"text","text":" "},{"type":"text","text":"input to the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/placeSubviews(in:proposal:subviews:cache:)","isActive":true},{"type":"text","text":" method."}]}],"kind":"content"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/AnyLayout":{"type":"topic","abstract":[{"text":"A type-erased instance of the layout protocol.","type":"text"}],"url":"\/documentation\/openswiftui\/anylayout","title":"AnyLayout","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout","role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"AnyLayout"}],"kind":"symbol","navigatorTitle":[{"kind":"identifier","text":"AnyLayout"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/AnyLayout/placeSubviews(in:proposal:subviews:cache:)":{"abstract":[{"text":"Assigns positions to each of the layout’s subviews.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout\/placeSubviews(in:proposal:subviews:cache:)","url":"\/documentation\/openswiftui\/anylayout\/placesubviews(in:proposal:subviews:cache:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"placeSubviews","kind":"identifier"},{"text":"(","kind":"text"},{"text":"in","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"CGRect","preciseIdentifier":"c:@S@CGRect","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"proposal","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ProposedViewSize","preciseIdentifier":"s:15OpenSwiftUICore16ProposedViewSizeV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"subviews","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"AnyLayout","preciseIdentifier":"s:15OpenSwiftUICore9AnyLayoutV","kind":"typeIdentifier"},{"text":".","kind":"te