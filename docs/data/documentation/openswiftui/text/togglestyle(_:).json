{"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"]]},"abstract":[{"type":"text","text":"Sets the style for toggles in a view hierarchy."}],"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"toggleStyle","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"style","kind":"internalParam"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"S","preciseIdentifier":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lFQO1Sqd__mfp"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:11OpenSwiftUI11ToggleStyleP","kind":"typeIdentifier","text":"ToggleStyle","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle"},{"kind":"text","text":"\n"}]}],"kind":"declarations"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The toggle style to set. Use one of the built-in"},{"type":"text","text":" "},{"type":"text","text":"values, like "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","type":"reference"},{"type":"text","text":" or "},{"code":"ToggleStyle\/button","type":"codeVoice"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"or a custom style that you define by creating a type that conforms"},{"type":"text","text":" "},{"type":"text","text":"to the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle","isActive":true},{"text":" protocol.","type":"text"}]}],"name":"style"}],"kind":"parameters"},{"content":[{"text":"Return Value","anchor":"return-value","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that uses the specified toggle style for itself"},{"type":"text","text":" "},{"type":"text","text":"and its child views."}]}],"kind":"content"},{"content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use this modifier on a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference","isActive":true},{"type":"text","text":" instance to set a style that defines"},{"type":"text","text":" "},{"type":"text","text":"the control’s appearance and behavior. For example, you can choose"},{"type":"text","text":" "},{"type":"text","text":"the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","type":"reference","isActive":true},{"type":"text","text":" style:"}],"type":"paragraph"},{"code":["Toggle(\"Vibrate on Ring\", isOn: $vibrateOnRing)","    .toggleStyle(.switch)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Built-in styles typically have a similar appearance across platforms,","type":"text"},{"text":" ","type":"text"},{"text":"tailored to the platform’s overall style:","type":"text"}],"type":"paragraph"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"inlineContent":[{"text":"Appearance","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"iOS, iPadOS","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]],[[{"inlineContent":[{"text":"macOS","type":"text"}],"type":"paragraph"}],[{"inlineContent":[],"type":"paragraph"}]]],"type":"table"},{"text":"Styling toggles in a hierarchy","anchor":"Styling-toggles-in-a-hierarchy","level":3,"type":"heading"},{"inlineContent":[{"text":"You can set a style for all toggle instances within a view hierarchy","type":"text"},{"text":" ","type":"text"},{"text":"by applying the style modifier to a container view. For example, you","type":"text"},{"text":" ","type":"text"},{"text":"can apply the ","type":"text"},{"type":"codeVoice","code":"ToggleStyle\/button"},{"text":" style to an ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","isActive":true,"type":"reference"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["HStack {","    Toggle(isOn: $isFlagged) {","        Label(\"Flag\", systemImage: \"flag.fill\")","    }","    Toggle(isOn: $isMuted) {","        Label(\"Mute\", systemImage: \"speaker.slash.fill\")","    }","}",".toggleStyle(.button)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The example above has the following appearance when "},{"type":"codeVoice","code":"isFlagged"},{"type":"text","text":" is"},{"type":"text","text":" "},{"type":"codeVoice","code":"true"},{"type":"text","text":" and "},{"type":"codeVoice","code":"isMuted"},{"type":"text","text":" is "},{"type":"codeVoice","code":"false"},{"type":"text","text":":"}],"type":"paragraph"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Appearance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS, iPadOS"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"text":"macOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]]],"type":"table"},{"text":"Automatic styling","anchor":"Automatic-styling","level":3,"type":"heading"},{"inlineContent":[{"text":"If you don’t set a style, OpenSwiftUI assumes a value of","type":"text"},{"text":" ","type":"text"},{"code":"ToggleStyle\/automatic","type":"codeVoice"},{"text":", which corresponds to a context-specific","type":"text"},{"text":" ","type":"text"},{"text":"default. Specify the automatic style explicitly to override a","type":"text"},{"text":" ","type":"text"},{"text":"container’s style and revert to the default:","type":"text"}],"type":"paragraph"},{"code":["HStack {","    Toggle(isOn: $isShuffling) {","        Label(\"Shuffle\", systemImage: \"shuffle\")","    }","    Toggle(isOn: $isRepeating) {","        Label(\"Repeat\", systemImage: \"repeat\")","    }","","    Divider()","","    Toggle(\"Enhance Sound\", isOn: $isEnhanced)","        .toggleStyle(.automatic) \/\/ Revert to the default style.","}",".toggleStyle(.button) \/\/ Use button style for toggles in the stack.",".labelStyle(.iconOnly) \/\/ Omit the title from any labels."],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The style that OpenSwiftUI uses as the default depends on both the platform","type":"text"},{"text":" ","type":"text"},{"text":"and the context. In macOS, the default in most contexts is a","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"ToggleStyle\/checkbox"},{"text":", while in iOS, the default toggle style is a","type":"text"},{"text":" ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch"},{"text":":","type":"text"}],"type":"paragraph"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Appearance"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"iOS, iPadOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS"}]}],[{"type":"paragraph","inlineContent":[]}]]],"type":"table"},{"content":[{"inlineContent":[{"type":"text","text":"Like toggle style does for toggles, the "},{"type":"codeVoice","code":"View\/labelStyle(_:)"},{"type":"text","text":" "},{"type":"text","text":"modifier sets the style for "},{"type":"codeVoice","code":"Label"},{"type":"text","text":" instances in the hierarchy. The"},{"type":"text","text":" "},{"type":"text","text":"example above demostrates the compact "},{"type":"codeVoice","code":"LabelStyle\/iconOnly"},{"type":"text","text":" style,"},{"type":"text","text":" "},{"type":"text","text":"which is useful for button toggles in space-constrained contexts."},{"type":"text","text":" "},{"type":"text","text":"Always include a descriptive title for better accessibility."}],"type":"paragraph"}],"name":"Note","style":"note","type":"aside"},{"inlineContent":[{"text":"For more information about how OpenSwiftUI chooses a default toggle style,","type":"text"},{"text":" ","type":"text"},{"text":"see the ","type":"text"},{"code":"ToggleStyle\/automatic","type":"codeVoice"},{"text":" style.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/openswiftui\/text\/togglestyle(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"metadata":{"remoteSource":{"fileName":"ToggleStyle.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/Toggle\/ToggleStyle.swift#L460"},"extendedModule":"OpenSwiftUICore","roleHeading":"Instance Method","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lF::SYNTHESIZED::s:15OpenSwiftUICore4TextV","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"toggleStyle","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP0aB2UIE11toggleStyleyQrqd__AD06ToggleG0Rd__lF