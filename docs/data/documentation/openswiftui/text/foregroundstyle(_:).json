{"abstract":[{"text":"Sets a view’s foreground elements to use a given style.","type":"text"}],"primaryContentSections":[{"declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"foregroundStyle"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"style"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":" : "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","preciseIdentifier":"s:15OpenSwiftUICore10ShapeStyleP","kind":"typeIdentifier","text":"ShapeStyle"},{"kind":"text","text":"\n"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"name":"style","content":[{"inlineContent":[{"type":"text","text":"The color or pattern to use when filling in the"},{"type":"text","text":" "},{"type":"text","text":"foreground elements. To indicate a specific value, use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color"},{"type":"text","text":" or"},{"type":"text","text":" "},{"type":"codeVoice","code":"ShapeStyle\/image(_:sourceRect:scale:)"},{"type":"text","text":", or one of the gradient"},{"type":"text","text":" "},{"type":"text","text":"types, like"},{"type":"text","text":" "},{"type":"codeVoice","code":"ShapeStyle\/linearGradient(colors:startPoint:endPoint:)"},{"type":"text","text":". To set a"},{"type":"text","text":" "},{"type":"text","text":"style that’s relative to the containing view’s style, use one of the"},{"type":"text","text":" "},{"type":"text","text":"semantic styles, like "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/primary"},{"type":"text","text":"."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"text":"Return Value","anchor":"return-value","level":2,"type":"heading"},{"inlineContent":[{"text":"A view that uses the given foreground style.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this method to style","type":"text"},{"text":" ","type":"text"},{"text":"foreground content like text, shapes, and template images","type":"text"},{"text":" ","type":"text"},{"text":"(including symbols):","type":"text"}]},{"type":"codeListing","code":["HStack {","    Image(systemName: \"triangle.fill\")","    Text(\"Hello, world!\")","    RoundedRectangle(cornerRadius: 5)","        .frame(width: 40, height: 20)","}",".foregroundStyle(.teal)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The example above creates a row of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/teal","type":"reference"},{"text":" foreground","type":"text"},{"text":" ","type":"text"},{"text":"elements:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use any style that conforms to the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","type":"reference","isActive":true},{"type":"text","text":" protocol,"},{"type":"text","text":" "},{"type":"text","text":"like the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/teal","type":"reference","isActive":true},{"type":"text","text":" color in the example above, or the"},{"type":"text","text":" "},{"type":"codeVoice","code":"ShapeStyle\/linearGradient(colors:startPoint:endPoint:)"},{"type":"text","text":" gradient"},{"type":"text","text":" "},{"type":"text","text":"shown below:"}]},{"type":"codeListing","code":["Text(\"Gradient Text\")","    .font(.largeTitle)","    .foregroundStyle(","        .linearGradient(","            colors: [.yellow, .blue],","            startPoint: .top,","            endPoint: .bottom","        )","    )"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"style":"tip","type":"aside","content":[{"inlineContent":[{"type":"text","text":"If you want to fill a single "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape","type":"reference","isActive":true},{"type":"text","text":" instance with a style,"},{"type":"text","text":" "},{"type":"text","text":"use the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape\/fill(style:)","type":"reference","isActive":true},{"type":"text","text":" shape modifier instead because it’s more"},{"type":"text","text":" "},{"type":"text","text":"efficient."}],"type":"paragraph"}],"name":"Tip"},{"type":"paragraph","inlineContent":[{"text":"OpenSwiftUI creates a context-dependent render for a given style.","type":"text"},{"text":" ","type":"text"},{"text":"For example, a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","type":"reference"},{"text":" that you load from an asset catalog","type":"text"},{"text":" ","type":"text"},{"text":"can have different light and dark appearances, while some styles","type":"text"},{"text":" ","type":"text"},{"text":"also vary by platform.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Hierarchical foreground styles like ","type":"text"},{"code":"ShapeStyle\/secondary","type":"codeVoice"},{"text":" ","type":"text"},{"text":"don’t impose a style of their own, but instead modify other styles.","type":"text"},{"text":" ","type":"text"},{"text":"In particular, they modify the primary","type":"text"},{"text":" ","type":"text"},{"text":"level of the current foreground style to the degree given by","type":"text"},{"text":" ","type":"text"},{"text":"the hierarchical style’s name.","type":"text"},{"text":" ","type":"text"},{"text":"To find the current foreground style to modify, OpenSwiftUI looks for","type":"text"},{"text":" ","type":"text"},{"text":"the innermost containing style that you apply with the","type":"text"},{"text":" ","type":"text"},{"code":"foregroundStyle(_:)","type":"codeVoice"},{"text":" or the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/foregroundColor(_:)","type":"reference","isActive":true},{"text":" modifier.","type":"text"},{"text":" ","type":"text"},{"text":"If you haven’t specified a style, OpenSwiftUI uses the default foreground","type":"text"},{"text":" ","type":"text"},{"text":"style, as in the following example:","type":"text"}]},{"type":"codeListing","code":["VStack(alignment: .leading) {","    Label(\"Primary\", systemImage: \"1.square.fill\")","    Label(\"Secondary\", systemImage: \"2.square.fill\")","        .foregroundStyle(.secondary)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you add a foreground style on the enclosing"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":", the hierarchical styling responds accordingly:"}]},{"type":"codeListing","code":["VStack(alignment: .leading) {","    Label(\"Primary\", systemImage: \"1.square.fill\")","    Label(\"Secondary\", systemImage: \"2.square.fill\")","        .foregroundStyle(.secondary)","}",".foregroundStyle(.blue)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When you apply a custom style to a view, the view disables the vibrancy"},{"type":"text","text":" "},{"type":"text","text":"effect for foreground elements in that view, or in any of its child"},{"type":"text","text":" "},{"type":"text","text":"views, that it would otherwise gain from adding a background material"},{"type":"text","text":" "},{"type":"text","text":"— for example, using the "},{"type":"codeVoice","code":"View\/background(_:ignoresSafeAreaEdges:)"},{"type":"text","text":" "},{"type":"text","text":"modifier. However, hierarchical styles applied to the default foreground"},{"type":"text","text":" "},{"type":"text","text":"don’t disable vibrancy."}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/foregroundStyle(_:)","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/text\/foregroundstyle(_:)"]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"]]},"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"symbolKind":"method","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"externalID":"s:15OpenSwiftUICore4ViewPAAE15foregroundStyleyQrqd__AA05ShapeF0Rd__lF::SYNTHESIZED::s:15OpenSwiftUICore4TextV","role":"symbol","platforms":[{"introducedAt":"13.0","unavailable":false,"name":"iOS","deprecated":false,"beta":false},{"introducedAt":"10.15","unavailable":false,"name":"macOS","deprecated":false,"beta":false},{"introducedAt":"13.0","unavailable":false,"name":"tvOS","deprecated":false,"beta":false},{"introducedAt":"1.0","unavailable":false,"name":"visionOS","deprecated":false,"beta":false},{"introducedAt":"6.0","unavailable":false,"name":"watchOS","deprecated":false,"beta":false}],"title":"foregroundStyle(_:)","remoteSource":{"fileName":"ForegroundStyleModifier.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main