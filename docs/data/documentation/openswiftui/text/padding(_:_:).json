{"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/padding(_:_:)","interfaceLanguage":"swift"},"primaryContentSections":[{"declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"padding","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"edges","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"Edge","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge","preciseIdentifier":"s:15OpenSwiftUICore4EdgeO","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Set","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set","preciseIdentifier":"s:15OpenSwiftUICore4EdgeO3SetV","kind":"typeIdentifier"},{"text":" = .all, ","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"length","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier"},{"text":"? = nil) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"content":[{"inlineContent":[{"text":"The set of edges to pad for this view. The default","type":"text"},{"text":" ","type":"text"},{"text":"is ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set\/all","isActive":true,"type":"reference"},{"text":".","type":"text"}],"type":"paragraph"}],"name":"edges"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"An amount, given in points, to pad this view on the"},{"type":"text","text":" "},{"type":"text","text":"specified edges. If you set the value to "},{"type":"codeVoice","code":"nil"},{"type":"text","text":", OpenSwiftUI uses"},{"type":"text","text":" "},{"type":"text","text":"a platform-specific default amount. The default value of this"},{"type":"text","text":" "},{"type":"text","text":"parameter is "},{"type":"codeVoice","code":"nil"},{"type":"text","text":"."}]}],"name":"length"}],"kind":"parameters"},{"content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"type":"text","text":"A view that’s padded by the specified amount on the"},{"type":"text","text":" "},{"type":"text","text":"specified edges."}],"type":"paragraph"}],"kind":"content"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to add a specified amount of padding to one or more"},{"type":"text","text":" "},{"type":"text","text":"edges of the view. Indicate the edges to pad by naming either a single"},{"type":"text","text":" "},{"type":"text","text":"value from "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set","isActive":true},{"type":"text","text":", or by specifying an"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/Swift\/OptionSet","isActive":true},{"type":"text","text":" "},{"type":"text","text":"that contains edge values:"}]},{"syntax":"swift","code":["VStack {","    Text(\"Text padded by 20 points on the bottom and trailing edges.\")","        .padding([.bottom, .trailing], 20)","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The order in which you apply modifiers matters. The example above"},{"type":"text","text":" "},{"type":"text","text":"applies the padding before applying the border to ensure that the"},{"type":"text","text":" "},{"type":"text","text":"border encompasses the padded region:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can omit either or both of the parameters. If you omit the "},{"type":"codeVoice","code":"length"},{"type":"text","text":","},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI uses a default amount of padding. If you"},{"type":"text","text":" "},{"type":"text","text":"omit the "},{"type":"codeVoice","code":"edges"},{"type":"text","text":", OpenSwiftUI applies the padding to all edges. Omit both"},{"type":"text","text":" "},{"type":"text","text":"to add a default padding all the way around a view. OpenSwiftUI chooses a"},{"type":"text","text":" "},{"type":"text","text":"default amount of padding that’s appropriate for the platform and"},{"type":"text","text":" "},{"type":"text","text":"the presentation context."}]},{"syntax":"swift","code":["VStack {","    Text(\"Text with default padding.\")","        .padding()","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example above looks like this in iOS under typical conditions:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"To control the amount of padding independently for each edge, use","type":"text"},{"text":" ","type":"text"},{"code":"View\/padding(_:)-6pgqq","type":"codeVoice"},{"text":". To pad all outside edges of a view by a","type":"text"},{"text":" ","type":"text"},{"text":"specified amount, use ","type":"text"},{"code":"View\/padding(_:)-68shk","type":"codeVoice"},{"text":".","type":"text"}]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"]]},"variants":[{"paths":["\/documentation\/openswiftui\/text\/padding(_:_:)"],"trai