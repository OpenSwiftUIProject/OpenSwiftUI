e":"watchOS","introducedAt":"6.0"}],"title":"transaction(value:_:)"},"abstract":[{"type":"text","text":"Applies the given transaction mutation function to all animations used"},{"type":"text","text":" "},{"type":"text","text":"within the view."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/text\/transaction(value:_:)"]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"transaction","kind":"identifier"},{"text":"(","kind":"text"},{"text":"value","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Equatable","kind":"typeIdentifier","preciseIdentifier":"s:SQ"},{"text":", ","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"transform","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Transaction","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Transaction","preciseIdentifier":"s:15OpenSwiftUICore11TransactionV"},{"text":") -> ","kind":"text"},{"text":"Void","kind":"typeIdentifier","preciseIdentifier":"s:s4Voida"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":"\n","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A value to monitor for changes.","type":"text"}]}],"name":"value"},{"content":[{"inlineContent":[{"type":"text","text":"The transformation to apply to transactions"},{"type":"text","text":" "},{"type":"text","text":"within this view."}],"type":"paragraph"}],"name":"transform"}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"inlineContent":[{"type":"text","text":"A view that wraps this view and applies a transformation to"},{"type":"text","text":" "},{"type":"text","text":"all transactions used within the view whenever "},{"type":"codeVoice","code":"value"},{"type":"text","text":" changes."}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use this modifier to change or replace the animation used in a view."},{"type":"text","text":" "},{"type":"text","text":"Consider three identical views controlled by a"},{"type":"text","text":" "},{"type":"text","text":"button that changes all three simultaneously:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"The first view animates rotating the “Rotation” ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view by 360","type":"text"},{"text":" ","type":"text"},{"text":"degrees.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The second uses the "},{"code":"transaction(_:)","type":"codeVoice"},{"type":"text","text":" modifier to change the"},{"type":"text","text":" "},{"type":"text","text":"animation by adding a delay to the start of the animation"},{"type":"text","text":" "},{"type":"text","text":"by two seconds and then increases the rotational speed of the"},{"type":"text","text":" "},{"type":"text","text":"“Rotation\\nModified” "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"type":"text","text":" view animation by a factor of 2."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The third uses the "},{"code":"transaction(_:)","type":"codeVoice"},{"type":"text","text":" modifier to disable animations"},{"type":"text","text":" "},{"type":"text","text":"affecting the “Animation\\nReplaced” "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference"},{"type":"text","text":" view."}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The following code implements these animations:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct TransactionExample: View {","    @State var flag = false","","    var body: some View {","        VStack(spacing: 50) {","            HStack(spacing: 30) {","                Text(\"Rotation\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","","                Text(\"Rotation\\nModified\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","                    .transaction(value: flag) { t in","                        t.animation =","                            t.animation?.delay(2.0).speed(2)","                    }","","                Text(\"Animation\\nReplaced\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","                    .transaction(value: flag) { t in","                        t.disableAnimations = true","                    }","            }","","            Button(\"Animate\") {","                withAnimation(.easeIn(duration: 2.0)) {","                    flag.toggle()","                }","            }","        }","    }","}"],"type":"codeListing"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View