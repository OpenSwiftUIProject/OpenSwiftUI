{"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/tag(_:includeOptional:)","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"]]},"kind":"symbol","metadata":{"roleHeading":"Instance Method","platforms":[{"introducedAt":"13.0","beta":false,"name":"iOS","deprecated":false,"unavailable":false},{"introducedAt":"10.15","beta":false,"name":"macOS","deprecated":false,"unavailable":false},{"introducedAt":"13.0","beta":false,"name":"tvOS","deprecated":false,"unavailable":false},{"introducedAt":"1.0","beta":false,"name":"visionOS","deprecated":false,"unavailable":false},{"introducedAt":"6.0","beta":false,"name":"watchOS","deprecated":false,"unavailable":false}],"externalID":"s:15OpenSwiftUICore4ViewPAAE3tag_15includeOptionalQrqd___SbtSHRd__lF::SYNTHESIZED::s:15OpenSwiftUICore4TextV","title":"tag(_:includeOptional:)","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"tag","kind":"identifier"},{"text":"<","kind":"text"},{"text":"V","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"V","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"includeOptional","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Bool","kind":"typeIdentifier","preciseIdentifier":"s:Sb"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"remoteSource":{"fileName":"Tag.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/View\/Tag.swift#L71"},"role":"symbol","extendedModule":"OpenSwiftUICore"},"abstract":[{"text":"Sets the unique tag value of this view.","type":"text"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"tag"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"tag"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":", "},{"kind":"externalParam","text":"includeOptional"},{"kind":"text","text":": "},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":" = true) -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View"},{"kind":"text","text":" "},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":" : "},{"preciseIdentifier":"s:SH","kind":"typeIdentifier","text":"Hashable"},{"kind":"text","text":"\n"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"tag","content":[{"inlineContent":[{"text":"A ","type":"text"},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/hashable"},{"text":" ","type":"text"},{"text":"value to use as the view’s tag.","type":"text"}],"type":"paragraph"}]},{"name":"includeOptional","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"If the tag value for "},{"type":"codeVoice","code":"Optional<V>"},{"type":"text","text":" should"},{"type":"text","text":" "},{"type":"text","text":"also be set."}]}]}],"kind":"parameters"},{"kind":"content","content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view with the specified tag set."}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"text":"Use this modifier to differentiate among certain selectable views,","type":"text"},{"text":" ","type":"text"},{"text":"like the possible values of a ","type":"text"},{"type":"codeVoice","code":"Picker"},{"text":" or the tabs of a ","type":"text"},{"type":"codeVoice","code":"TabView"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Tag values can be of any type that conforms to the","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/hashable","type":"reference","isActive":true},{"text":" protocol.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This modifier will write the tag value for the type ","type":"text"},{"code":"V","type":"codeVoice"},{"text":", as well as","type":"text"},{"text":" ","type":"text"},{"code":"Optional<V>","type":"codeVoice"},{"text":" if ","type":"text"},{"code":"includeOptional","type":"codeVoice"},{"text":" is enabled. Containers checking for","type":"text"},{"text":" ","type":"text"},{"text":"tags of either type will see the value as set.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"In the example below, the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach","isActive":true},{"type":"text","text":" loop in the "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":" view"},{"type":"text","text":" "},{"type":"text","text":"builder iterates over the "},{"type":"codeVoice","code":"Flavor"},{"type":"text","text":" enumeration. It extracts the string"},{"type":"text","text":" "},{"type":"text","text":"value of each enumeration element for use in constructing the row"},{"type":"text","text":" "},{"type":"text","text":"label, and uses the enumeration value as input to the "},{"type":"codeVoice","code":"tag(_:)"},{"type":"text","text":" "},{"type":"text","text":"modifier."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct FlavorPicker: View {","    enum Flavor: String, CaseIterable, Identifiable {","        case chocolate, vanilla, strawberry","        var id: Self { self }","    }","","    @State private var selectedFlavor: Flavor? = nil","","    var body: some View {","        Picker(\"Flavor\", selection: $selectedFlavor) {","            ForEach(Flavor.allCases) { flavor in","                Text(flavor.rawValue)","                    .tag(flavor)","            }","        }","    }","}"]},{"inlineContent":[{"text":"The selection type of the ","type":"text"},{"code":"Picker","type":"codeVoice"},{"text":" is an ","type":"text"},{"code":"Optional<Flavor>","type":"codeVoice"},{"text":" and so it","type":"text"},{"text":" ","type":"text"},{"text":"will look for tags on its contents of ","type":"text"},{"code":"Optional<Flavor>","type":"codeVoice"},{"text":"type. Since the","type":"text"},{"text":" ","type":"text"},{"text":"tag modifier defaults to having ","type":"text"},{"code":"includeOptional","type":"codeVoice"},{"text":" enabled, even though","type":"text"},{"text":" ","type":"text"},{"text":"the tag for each option is a non-optional ","type":"text"},{"code":"Flavor","type":"codeVoice"},{"text":", the tag modifier","type":"text"},{"text":" ","type":"text"},{"text":"writes values for both the non-optional, and optional versions of the","type":"text"},{"text":" ","type":"text"},{"text":"value, allowing the contents to be selectable by the ","type":"text"},{"code":"Picker","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach"},{"text":" automatically applies a default tag to each enumerated","type":"text"},{"text":" ","type":"text"},{"text":"view using the ","type":"text"},{"type":"codeVoice","code":"id"},{"text":" parameter of the corresponding element. If","type":"text"},{"text":" ","type":"text"},{"text":"the element’s ","type":"text"},{"type":"codeVoice","code":"id"},{"text":" parameter and the picker’s ","type":"text"},{"type":"codeVoice","code":"selection"},{"text":" input","type":"text"},{"text":" ","type":"text"},{"text":"have exactly the same type, or the same type but optional, you can omit","type":"text"},{"text":" ","type":"text"},{"text":"the explicit tag modifier.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To see examples that don’t require an explicit tag, see "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":"."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/text\/tag(_:includeoptional:)"]}],"references":{"https://developer.apple.com/documentation/swift/hashable":{"type":"link","url":"https:\/\/developer.apple.com\/documentation\/swift\/hashable","identifier":"https:\/\/developer.apple.com\/documentation\/swift\/hashable","titleInlineContent":[{"type":"text","text":"Hashable"}],"title":"Hashable"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Text":{"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Text","kind":"identifier"}],"role":"symbol","url":"\/documentation\/openswiftui\/text","type":"topic","navigatorTitle":[{"text":"Text","kind":"identifier"}],"title":"Text","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","abstract":[]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ForEach":{"abstract":[{"text":"A structure that computes views on demand from an underlying collection of","type":"text"},{"text":" ","type":"text"},{"text":"identified data.","type":"text"}],"type":"topic","role":"symbol","kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ForEach","kind":"identifier"}],"navigatorTitle":[{"text":"ForEach","kind":"identifier"}],"title":"ForEach","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach","url":"\/documentation\/openswiftui\/foreach"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"url":"\/documentation\/openswiftui\/view","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Text/tag(_:includeOptional:)":{"role":"symbol","kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"tag"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"V"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":", "},{"kind":"externalParam","text":"includeOptional"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:Sb","text":"Bool"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"}],"title":"tag(_:includeOptional:)","abstract":[{"type":"text","text":"Sets the unique tag value of this view."}],"url":"\/documentation\/openswiftui\/text\/tag(_:includeoptional:)","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/tag(_:includeOptional:)","type":"topic"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Decla