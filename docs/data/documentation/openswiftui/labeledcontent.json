{"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent","interfaceLanguage":"swift"},"abstract":[{"text":"A container for attaching a label to a value-bearing view.","type":"text"}],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent\/init(content:label:)"],"generated":true,"title":"Initializers"},{"anchor":"Default-Implementations","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent\/View-Implementations"],"generated":true,"title":"Default Implementations"}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/OpenSwiftUI\/s8CopyableP","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"],"type":"conformsTo","title":"Conforms To"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LabeledContent","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Label","kind":"genericParameter"},{"text":", ","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":">","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"text":"The instance’s content represents a read-only or read-write value, and its","type":"text"},{"text":" ","type":"text"},{"text":"label identifies or describes the purpose of that value.","type":"text"},{"text":" ","type":"text"},{"text":"The resulting element has a layout that’s consistent with other framework","type":"text"},{"text":" ","type":"text"},{"text":"controls and automatically adapts to its container, like a form or toolbar.","type":"text"},{"text":" ","type":"text"},{"text":"Some styles of labeled content also apply styling or behaviors to the value","type":"text"},{"text":" ","type":"text"},{"text":"content, like making ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"text":" views selectable.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The following example associates a label with a custom view and has"},{"type":"text","text":" "},{"type":"text","text":"a layout that matches the label of the "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["Form {","    LabeledContent(\"Custom Value\") {","        MyCustomView(value: $value)","    }","    Picker(\"Selected Value\", selection: $selection) {","        Text(\"Option 1\").tag(1)","        Text(\"Option 2\").tag(2)","    }","}"]},{"type":"heading","text":"Custom view labels","level":3,"anchor":"Custom-view-labels"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can assemble labeled content with an explicit view for its label"},{"type":"text","text":" "},{"type":"text","text":"using the "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent\/init(content:label:)","type":"reference","isActive":true},{"type":"text","text":" initializer. For example, you can"},{"type":"text","text":" "},{"type":"text","text":"rewrite the previous labeled content example using a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference","isActive":true},{"type":"text","text":" view:"}]},{"type":"codeListing","syntax":"swift","code":["LabeledContent {","    MyCustomView(value: $value)","} label: {","    Text(\"Custom Value\")","}"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"label","type":"codeVoice"},{"text":" view builder accepts any kind of view, like a ","type":"text"},{"code":"Label","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["LabeledContent {","    MyCustomView(value: $value)","} label: {","    Label(\"Custom Value\", systemImage: \"hammer\")","}"]},{"type":"paragraph","inlineContent":[{"text":"For cases where adding a subtitle to the label is desired, use a view","type":"text"},{"text":" ","type":"text"},{"text":"builder that creates multiple ","type":"text"},{"code":"Text","type":"codeVoice"},{"text":" views where the first text represents","type":"text"},{"text":" ","type":"text"},{"text":"the title and the second text represents the subtitle:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["LabeledContent {","    MyCustomView(value: $value)","} label: {","    Text(\"Custom Value\")","    Text(\"Custom Subtitle Value\")","}"]},{"type":"heading","text":"Textual labeled content","level":3,"anchor":"Textual-labeled-content"},{"type":"paragraph","inlineContent":[{"text":"You can construct labeled content with string values or formatted values","type":"text"},{"text":" ","type":"text"},{"text":"to create read-only displays of textual values:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Form {","    Section(\"Information\") {","        LabeledContent(\"Name\", value: person.name)","        LabeledContent(\"Age\", value: person.age, format: .number)","        LabeledContent(\"Height\", value: person.height,","            format: .measurement(width: .abbreviated))","    }","    if !person.pets.isEmpty {","        Section(\"Pets\") {","            ForEach(pet) { pet in","                LabeledContent(pet.species, value: pet.name)","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Wherever possible, OpenSwiftUI makes this text selectable."}]},{"type":"heading","text":"Compositional elements","level":3,"anchor":"Compositional-elements"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use labeled content as the label for other elements. For example,"},{"type":"text","text":" "},{"type":"text","text":"a "},{"type":"codeVoice","code":"NavigationLink"},{"type":"text","text":" can present a summary value for the destination it"},{"type":"text","text":" "},{"type":"text","text":"links to:"}]},{"type":"codeListing","syntax":"swift","code":["Form {","    NavigationLink(value: Settings.wifiDetail) {","        LabeledContent(\"Wi-Fi\", value: ssidName)","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"In some cases, the styling of views used as the value content is","type":"text"},{"text":" ","type":"text"},{"text":"specialized as well. For example, while a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle"},{"text":" in an inset group","type":"text"},{"text":" ","type":"text"},{"text":"form on macOS is styled as a switch by default, it’s styled as a checkbox","type":"text"},{"text":" ","type":"text"},{"text":"when used as a value element within a surrounding ","type":"text"},{"type":"codeVoice","code":"LabeledContent"},{"text":" ","type":"text"},{"text":"instance:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Form {","    LabeledContent(\"Source Control\") {","        Toggle(\"Refresh local status automatically\",","            isOn: $refreshLocalStatus)","        Toggle(\"Fetch and refresh server status automatically\",","            isOn: $refreshServerStatus)","        Toggle(\"Add and remove files automatically\",","            isOn: $addAndRemoveFiles)","        Toggle(\"Select files to commit automatically\",","            isOn: $selectFiles)","    }","}"]},{"type":"heading","text":"Controlling label visibility","level":3,"anchor":"Controlling-label-visibility"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A label communicates the identity or purpose of the value, which is"},{"type":"text","text":" "},{"type":"text","text":"important for accessibility. However, you might want to hide the label"},{"type":"text","text":" "},{"type":"text","text":"in the display, and some controls or contexts may visually hide their label"},{"type":"text","text":" "},{"type":"text","text":"by default. The "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/labelsHidden()","isActive":true},{"type":"text","text":" modifier allows controlling that"},{"type":"text","text":" "},{"type":"text","text":"visibility. The following example hides both labels, producing only a"},{"type":"text","text":" "},{"type":"text","text":"group of the two value views:"}]},{"type":"codeListing","syntax":"swift","code":["Group {","    LabeledContent(\"Custom Value\") {","        MyCustomView(value: $value)","    }","    Picker(\"Selected Value\", selection: $selection) {","        Text(\"Option 1\").tag(1)","        Text(\"Option 2\").tag(2)","    }","}",".labelsHidden()"]},{"type":"heading","text":"Styling labeled content","level":3,"anchor":"Styling-labeled-content"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can set label styles using the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/labeledContentStyle(_:)","isActive":true},{"type":"text","text":" "},{"type":"text","text":"modifier. You can also build custom styles using "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContentStyle","isActive":true},{"type":"text","text":"."}]}]}],"metadata":{"title":"LabeledContent","role":"symbol","platforms":[{"name":"iOS","introducedAt":"13.0","deprecated":false,"beta":false,"unavailable":false},{"name":"macOS","introducedAt":"10.15","deprecated":false,"beta":false,"unavailable":false},{"name":"tvOS","introducedAt":"13.0","deprecated":false,"beta":false,"unavailable":false},{"name":"visionOS","introducedAt":"1.0","deprecated":false,"beta":false,"unavailable":false},{"name":"watchOS","introducedAt":"6.0","deprecated":false,"beta":false,"unavailable":false}],"navigat