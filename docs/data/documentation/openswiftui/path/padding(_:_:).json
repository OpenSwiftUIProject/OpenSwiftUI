{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Path\/padding(_:_:)"},"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"padding","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"edges","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4EdgeO","text":"Edge","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge","kind":"typeIdentifier"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4EdgeO3SetV","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set","text":"Set"},{"kind":"text","text":" = .all, "},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"length"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat"},{"kind":"text","text":"? = nil) -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"},{"kind":"text","text":"\n"}]}],"kind":"declarations"},{"parameters":[{"name":"edges","content":[{"inlineContent":[{"type":"text","text":"The set of edges to pad for this view. The default"},{"type":"text","text":" "},{"type":"text","text":"is "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set\/all","type":"reference","isActive":true},{"type":"text","text":"."}],"type":"paragraph"}]},{"name":"length","content":[{"type":"paragraph","inlineContent":[{"text":"An amount, given in points, to pad this view on the","type":"text"},{"text":" ","type":"text"},{"text":"specified edges. If you set the value to ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":", OpenSwiftUI uses","type":"text"},{"text":" ","type":"text"},{"text":"a platform-specific default amount. The default value of this","type":"text"},{"text":" ","type":"text"},{"text":"parameter is ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}]}]}],"kind":"parameters"},{"content":[{"anchor":"return-value","type":"heading","level":2,"text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that’s padded by the specified amount on the"},{"type":"text","text":" "},{"type":"text","text":"specified edges."}]}],"kind":"content"},{"content":[{"level":2,"type":"heading","anchor":"discussion","text":"Discussion"},{"inlineContent":[{"type":"text","text":"Use this modifier to add a specified amount of padding to one or more"},{"type":"text","text":" "},{"type":"text","text":"edges of the view. Indicate the edges to pad by naming either a single"},{"type":"text","text":" "},{"type":"text","text":"value from "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Edge\/Set"},{"type":"text","text":", or by specifying an"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/Swift\/OptionSet"},{"type":"text","text":" "},{"type":"text","text":"that contains edge values:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["VStack {","    Text(\"Text padded by 20 points on the bottom and trailing edges.\")","        .padding([.bottom, .trailing], 20)","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"]},{"inlineContent":[{"text":"The order in which you apply modifiers matters. The example above","type":"text"},{"type":"text","text":" "},{"type":"text","text":"applies the padding before applying the border to ensure that the"},{"type":"text","text":" "},{"type":"text","text":"border encompasses the padded region:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"You can omit either or both of the parameters. If you omit the ","type":"text"},{"code":"length","type":"codeVoice"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"OpenSwiftUI uses a default amount of padding. If you","type":"text"},{"text":" ","type":"text"},{"text":"omit the ","type":"text"},{"code":"edges","type":"codeVoice"},{"text":", OpenSwiftUI applies the padding to all edges. Omit both","type":"text"},{"text":" ","type":"text"},{"text":"to add a default padding all the way around a view. OpenSwiftUI chooses a","type":"text"},{"text":" ","type":"text"},{"text":"default amount of padding that’s appropriate for the platform and","type":"text"},{"text":" ","type":"text"},{"text":"the presentation context.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["VStack {","    Text(\"Text with default padding.\")","        .padding()","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"]},{"inlineContent":[{"text":"The example above looks like this in iOS under typical conditions:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"To control the amount of padding independently for each edge, use","type":"text"},{"text":" ","type":"text"},{"code":"View\/padding(_:)-6pgqq","type":"codeVoice"},{"text":". To pad all outside edges of a view by a","type":"text"},{"text":" ","type":"text"},{"text":"specified amount, use ","type":"text"},{"code":"View\/padding(_:)-68shk","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Path"]]},"schemaVersion":{"minor":3,"patch":0,"major":0},"kind":"symbol","variants":[{"pa