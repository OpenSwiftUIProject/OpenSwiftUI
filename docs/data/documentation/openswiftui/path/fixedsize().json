00, height: 200)","    .border(Color.gray)"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"This can result in the view exceeding the parent’s bounds, which may or","type":"text"},{"text":" ","type":"text"},{"text":"may not be the effect you want.","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can think of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" as the creation of a "},{"type":"emphasis","inlineContent":[{"text":"counter proposal","type":"text"}]},{"type":"text","text":" "},{"type":"text","text":"to the view size proposed to a view by its parent. The ideal size of a"},{"type":"text","text":" "},{"type":"text","text":"view, and the specific effects of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" depends on the"},{"type":"text","text":" "},{"type":"text","text":"particular view and how you have configured it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a view that fixes the view’s size in either the horizontal or"},{"type":"text","text":" "},{"text":"vertical dimensions, see ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)","type":"reference"},{"text":".","type":"text"}]}]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Path\/fixedSize()","interfaceLanguage":"swift"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Path/fixedSize()":{"title":"fixedSize()","url":"\/documentation\/openswiftui\/path\/fixedsize()","role":"symbol","type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Path\/fixedSize()","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"fixedSize","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier