xt","text":" "},{"kind":"identifier","text":"fixedSize"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}]}]},{"kind":"content","content":[{"anchor":"return-value","level":2,"type":"heading","text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"A view that fixes this view at its ideal size.","type":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"text":"During the layout of the view hierarchy, each view proposes a size to","type":"text"},{"text":" ","type":"text"},{"text":"each child view it contains. If the child view doesn’t need a fixed size","type":"text"},{"text":" ","type":"text"},{"text":"it can accept and conform to the size offered by the parent.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For example, a "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"type":"text","text":" view placed in an explicitly sized frame wraps"},{"type":"text","text":" "},{"type":"text","text":"and truncates its string to remain within its parent’s bounds:"}],"type":"paragraph"},{"code":["Text(\"A single line of text, too long to fit in a box.\")","    .frame(width: 200, height: 200)","    .border(Color.gray)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" modifier can be used to create a view that maintains"},{"type":"text","text":" "},{"type":"text","text":"the "},{"type":"emphasis","inlineContent":[{"text":"ideal size","type":"text"}]},{"type":"text","text":" of its children both dimensions:"}],"type":"paragraph"},{"code":["Text(\"A single line of text, too long to fit in a box.\")","    .fixedSize()","    .frame(width: 200, height: 200)","    .border(Color.gray)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This can result in the view exceeding the parent’s bounds, which may or"},{"type":"text","text":" "},{"type":"text","text":"may not be the effect you want."}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"You can think of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" as the creation of a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"counter proposal"}]},{"type":"text","text":" "},{"type":"text","text":"to the view size proposed to a view by its parent. The ideal size of a"},{"type":"text","text":" "},{"type":"text","text":"view, and the specific effects of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" depends on the"},{"type":"text","text":" "},{"type":"text","text":"particular view and how you have configured it."}],"type":"paragraph"},{"inlineContent":[{"text":"To create a view that fixes the view’s size in either the horizontal or","type":"text"},{"text":" ","type":"text"},{"text":"vertical dimensions, see ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)","isActive":true},{"text":".","type":"text"}],"type":"paragraph"}]}],"sections":[],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Path":{"abstract":[{"text":"The outline of a 2D shape.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Path","role":"symbol","kind":"symbol","type":"topic","navigatorTitle":[{"text":"Path","kind":"identifier"}],"title":"Path","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Path","kind":"identifier"}],"url":"\/documentation\/openswiftui\/path"},"doc://OpenSwiftUI/documentation/Open