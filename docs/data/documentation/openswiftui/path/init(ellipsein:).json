{"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Path"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"ellipseIn"},{"kind":"text","text":" "},{"kind":"internalParam","text":"rect"},{"kind":"text","text":": "},{"preciseIdentifier":"c:@S@CGRect","kind":"typeIdentifier","text":"CGRect"},{"kind":"text","text":")"}],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The rectangle that bounds the ellipse.","type":"text"}]}],"name":"rect"}]},{"content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"This is a convenience function that creates a path of an","type":"text"},{"text":" ","type":"text"},{"text":"ellipse. Using this convenience function is more efficient than","type":"text"},{"text":" ","type":"text"},{"text":"creating a path and adding an ellipse to it.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The ellipse is approximated by a sequence of Bézier","type":"text"},{"text":" ","type":"text"},{"text":"curves. Its center is the midpoint of the rectangle defined by","type":"text"},{"text":" ","type":"text"},{"text":"the rect parameter. If the rectangle is square, then the","type":"text"},{"text":" ","type":"text"},{"text":"ellipse is circular with a radius equal to one-half the width","type":"text"},{"text":" ","type":"text"},{"text":"(or height) of the rectangle. If the rect parameter specifies a","type":"text"},{"text":" ","type":"text"},{"text":"rectangular shape, then the major and minor axes of the ellipse","type":"text"},{"text":" ","type":"text"},{"text":"are defined by the width and height of the rectangle.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The ellipse forms a complete subpath of the path—that"},{"type":"text","text":" "},{"type":"text","text":"is, the ellipse drawing starts with a move-to operation and"},{"type":"text","text":" "},{"type":"text","text":"ends with a close-subpath operation, with all moves oriented in"},{"type":"text","text":" "},{"type":"text","text":"the clockwise direction. If you supply an affine transform,"},{"type":"text","text":" "},{"type":"text","text":"then the constructed Bézier curves that define the"},{"type":"text","text":" "},{"type":"text","text":"ellipse are transformed before they are added to the path."}],"type":"paragraph"}],"kind":"content"}],"sections":[],"variants":[{"paths":["\/documentation\/openswiftui\/path\/init(ellipsein:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Path\/init(ellipseIn:)","interfaceLanguage":"swift"},"metadata":{"symbolKind":"init","remoteSource":{"fileName":"Path.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Shape\/Path.swift#L352"},"fragments":[{"kind":"identifier","text":"init"},{"kind":"text","text":"("},{"kind":"externalParam","text":"ellipseIn"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"CGRect","preciseIdentifier":"c:@S@CGRect"},{"kind":"text","text":")"}],"roleHeading":"Initializer","role":"symbol","modules":[{"name":"OpenSwiftUI"}],"externalID":"s:15OpenSwiftUICore4PathV9ellipseInACSo6CGRectV_tcfc","title":"init(ellipseIn:)","platforms":[{"unavailable":false,"introducedAt":"13.0","beta":false,"name":"iOS","deprecated":false},{"unavailable":false,"introducedAt":"10.15","beta":false,"name":"macOS","deprecated":false},{"unavailable":false,"introducedAt":"13.0","beta":false,"name":"tvOS","deprecated":false},{"unavailable":false,"introducedAt":"1.0","beta":false,"name":"visionOS","deprecated":false},{"unavailable":false,"introducedAt":"6.0","beta":false,"name":"watchOS","deprecated":false}]},"abstract":[{"type":"text","text":"Creates a path as an ellipse within the given rectangle."}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Path/init(ellipseIn:)":{"kind":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"ellipseIn","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"c:@S@CGRect","text":"CGRect","kind":"typeIdentifier"},{"text":")","kind":"text"}],"url":"\/documentation\/openswiftui\/path\/init(ellipsein:)","role":"symbol","abstract":[{"text":"Creates a path as an ellipse within the given rectangle.","type":"text"}],"title":"init(ellipseIn:)","type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Path\/init(ellipseIn:)"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Path":{"abstract":[{"text":"The outline of a 2D shape.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Path","role":"symbol","kind":"symbol","type":"topic","navigatorTitle":[{"text":"Path","kind":"identifier"}],"title":"Path","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Path","kind":"identifier"}],"url":"\/documentation\/openswiftui\/path"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]}}}