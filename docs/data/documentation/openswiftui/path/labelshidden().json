content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier when you want to omit a label from one or more"},{"type":"text","text":" "},{"type":"text","text":"controls in your user interface. For example, the first "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference"},{"type":"text","text":" in"},{"type":"text","text":" "},{"type":"text","text":"the following example hides its label:"}]},{"code":["VStack {","    Toggle(isOn: $toggle1) {","        Text(\"Toggle 1\")","    }","    .labelsHidden()","","    Toggle(isOn: $toggle2) {","        Text(\"Toggle 2\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference","isActive":true},{"type":"text","text":" in the example above centers the first toggle’s control"},{"type":"text","text":" "},{"type":"text","text":"element in the available space, while it centers the second toggle’s"},{"type":"text","text":" "},{"type":"text","text":"combined label and control element:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"Always provide a label for controls, even when you hide the label,","type":"text"},{"text":" ","type":"text"},{"text":"because SwiftUI uses labels for other purposes, including accessibility.","type":"text"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This modifier doesn’t work for all labels. It applies to"},{"type":"text","text":" "},{"type":"text","text":"labels that are separate from the rest of the control’s interface,"},{"type":"text","text":" "},{"type":"text","text":"like they are for "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true},{"type":"text","text":", but not to