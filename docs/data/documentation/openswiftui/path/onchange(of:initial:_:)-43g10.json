xt":"\n","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"parameters":[{"name":"value","content":[{"inlineContent":[{"text":"The value to check against when determining whether","type":"text"},{"text":" ","type":"text"},{"text":"to run the closure.","type":"text"}],"type":"paragraph"}]},{"name":"initial","content":[{"inlineContent":[{"type":"text","text":"Whether the action should be run when this view initially"},{"type":"text","text":" "},{"type":"text","text":"appears."}],"type":"paragraph"}]},{"name":"action","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"A closure to run when the value changes."}]}]},{"name":"oldValue","content":[{"inlineContent":[{"type":"text","text":"The old value that failed the comparison check (or the"},{"type":"text","text":" "},{"type":"text","text":"initial value when requested)."}],"type":"paragraph"}]},{"name":"newValue","content":[{"type":"paragraph","inlineContent":[{"text":"The new value that failed the comparison check.","type":"text"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"text":"Return Value","anchor":"return-value","type":"heading"},{"inlineContent":[{"text":"A view that fires an action when the specified value changes.","type":"text"}],"type":"paragraph"}]},{"kind":"content","content":[{"level":2,"text":"Discussion","type":"heading","anchor":"discussion"},{"inlineContent":[{"text":"You can use ","type":"text"},{"type":"codeVoice","code":"onChange"},{"text":" to trigger a side effect as the result of a","type":"text"},{"text":" ","type":"text"},{"text":"value changing, such as an ","type":"text"},{"type":"codeVoice","code":"Environment"},{"text":" key or a ","type":"text"},{"type":"codeVoice","code":"Binding"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The system may call the action closure on the main actor, so avoid","type":"text"},{"text":" ","type":"text"},{"text":"long-running tasks in the closure. If you need to perform such tasks,","type":"text"},{"text":" ","type":"text"},{"text":"detach an asynchronous background task.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When the value changes, the new version of the closure will be called,","type":"text"},{"text":" ","type":"text"},{"text":"so any captured values will have their values from the time that the","type":"text"},{"text":" ","type":"text"},{"text":"observed value has its new value. The old and new observed values are","type":"text"},{"text":" ","type":"text"},{"text":"passed into the closure. In the following code example, ","type":"text"},{"code":"PlayerView","type":"codeVoice"},{"text":" ","type":"text"},{"text":"passes both the old and new values to the model.","type":"text"}],"type":"paragraph"},{"code":["struct PlayerView: View {","    var episode: Episode","    @State private var playState: PlayState = .paused","","    var body: some View {","        VStack {","            Text(episode.title)","            Text(episode.showTitle)","            PlayButton(playState: $playState)","        }","        .onChange(of: playState) { oldState, newState in","            model.playStateDidChange(from: oldState, to: newState)","        }","    }","}"],"type":"codeListing","syntax":"swift"}]}],"abstract":[{"text":"Adds a modifier for this view that fires an action when a specific","type":"text"},{"text":" ","type":"text"},{"text":"value changes.","type":"text"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftui\/view","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"type":"topic","title":"View","abstr