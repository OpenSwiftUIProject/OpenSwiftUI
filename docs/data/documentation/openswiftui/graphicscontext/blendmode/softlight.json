{"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/GraphicsContext\/BlendMode\/softLight","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/GraphicsContext","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/GraphicsContext\/BlendMode"]]},"abstract":[{"type":"text","text":"A mode that either darkens or lightens colors, depending on the"},{"type":"text","text":" "},{"type":"text","text":"source image sample color."}],"metadata":{"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Graphic\/GraphicsContext.swift#L249","fileName":"GraphicsContext.swift"},"role":"symbol","title":"softLight","roleHeading":"Type Property","modules":[{"name":"OpenSwiftUI"}],"externalID":"s:15OpenSwiftUICore15GraphicsContextV9BlendModeV9softLightAEvpZ","symbolKind":"property","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"softLight"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore15GraphicsContextV","text":"GraphicsContext"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore15GraphicsContextV9BlendModeV","text":"BlendMode"}]},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"static","kind":"keyword"},{"text":" ","kind":"text"},{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"softLight","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore15GraphicsContextV","text":"GraphicsContext","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/GraphicsContext"},{"text":".","kind":"text"},{"preciseId