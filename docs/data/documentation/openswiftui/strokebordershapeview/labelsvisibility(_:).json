{"abstract":[{"type":"text","text":"Controls the visibility of labels of any controls contained within this"},{"type":"text","text":" "},{"type":"text","text":"view."}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"labelsVisibility"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"visibility"},{"kind":"text","text":": "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Visibility","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore10VisibilityO","text":"Visibility"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"},{"kind":"text","text":"\n"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Use this modifier when you want to omit a label from one or more","type":"text"},{"text":" ","type":"text"},{"text":"labeled content in your user interface. For example, the first ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"in the following example hides its label:","type":"text"}]},{"type":"codeListing","code":["VStack {","    Toggle(isOn: $toggle1) {","        Text(\"Toggle 1\")","    }","    .labelsVisibility(.hidden)","","    Toggle(isOn: $toggle2) {","        Text(\"Toggle 2\")","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference","isActive":true},{"text":" in the example above centers the first toggle’s control","type":"text"},{"text":" ","type":"text"},{"text":"element in the available space, while it centers the second toggle’s","type":"text"},{"text":" ","type":"text"},{"text":"combined label and control element:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always provide a label for controls, even when you hide the label,"},{"type":"text","text":" "},{"type":"text","text":"because OpenSwiftUI uses labels for other purposes, including accessibility."}]},{"type":"paragraph","inlineContent":[{"text":"On iOS, a ","type":"text"},{"type":"codeVoice","code":"Picker"},{"text":" within a ","type":"text"},{"type":"codeVoice","code":"Menu"},{"text":" hides its label by default. You can use","type":"text"},{"text":" ","type":"text"},{"text":"this modifier to explicitly show the label in that context:","type":"text"}]},{"type":"codeListing","code":["Menu {","    Picker(\"Flavor\", selection: $selectedFlavor) {","        Text(\"Chocolate\").tag(Flavor.chocolate)","        Text(\"Vanilla\").tag(Flavor.vanilla)","        Text(\"Strawberry\").tag(Flavor.strawberry)","    }","    .labelsVisibility(.visible)","}"],"syntax":"swift"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"This modifier doesn’t work for all labels. It applies to","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent","type":"reference","isActive":true},{"text":" elements, including controls like ","type":"text"},{"type":"codeVoice","code":"Picker"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference","isActive":true},{"text":", but not to controls like a bordered button where the label","type":"text"},{"text":" ","type":"text"},{"text":"is inside the button’s border.","type":"text"}]}],"style":"note","name":"Note"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StrokeBorderShapeView"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"sections":[],"variants":[{"paths":["\/documentation\/openswiftui\/strokebordershapeview\/labelsvisibility(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"kind":"symbol","metadata":{"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"platforms":[{"introducedAt":"13.0","name":"iOS","deprecated":false,"beta":false,"unavailable":false},{"introducedAt":"10.15","name":"macOS","deprecated":false,"beta":false,"unavailable":false},{"introducedAt":"13.0","name":"tvOS","deprecated":false,"beta":false,"unavailable":false},{"introducedAt":"1.0","name":"visionOS","deprecated":false,"beta":false,"unavailable":false},{"introducedAt":"6.0","name":"watchOS","deprecated":false,"beta":false,"unavailable":false}],"symbolKind":"method","remoteSource":{"fileName":"LabelVisibility.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/LabelContent\/LabelVisibility.swift#L60"},"roleHeading":"Instance Method","externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE16labelsVisibilityyQrAA0G0OF::SYNTHESIZED::s:15OpenSwiftUICore21StrokeBorderShapeViewV","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"labelsVisibility","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore10VisibilityO","text":"Visibility","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"}],"role":"symbol","extendedModule":"OpenSwiftUICore","title":"labelsVisibility(_:)"},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StrokeBorderShapeView\/labelsVisibility(_:)",