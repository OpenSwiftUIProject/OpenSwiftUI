{"abstract":[{"type":"text","text":"Isolates the geometry (e.g. position and size) of the view"},{"type":"text","text":" "},{"type":"text","text":"from its parent view."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"title":"geometryGroup()","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"roleHeading":"Instance Method","role":"symbol","platforms":[{"name":"iOS","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"name":"macOS","introducedAt":"10.15","deprecated":false,"unavailable":false,"beta":false},{"name":"tvOS","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"name":"visionOS","introducedAt":"1.0","deprecated":false,"unavailable":false,"beta":false},{"name":"watchOS","introducedAt":"6.0","deprecated":false,"unavailable":false,"beta":false}],"extendedModule":"OpenSwiftUICore","externalID":"s:15OpenSwiftUICore4ViewPAAE13geometryGroupQryF::SYNTHESIZED::s:15OpenSwiftUICore21StrokeBorderShapeViewV","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"geometryGroup"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Render\/RendererEffect\/RendererEffect.swift#L304","fileName":"RendererEffect.swift"}},"sections":[],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StrokeBorderShapeView\/geometryGroup()","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StrokeBorderShapeView"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/strokebordershapeview\/geometrygroup()"]}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"geometryGroup"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},{"kind":"text","text":"\n"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"By default OpenSwiftUI views push position and size changes down"},{"type":"text","text":" "},{"type":"text","text":"through the view hierarchy, so that only views that draw"},{"type":"text","text":" "},{"type":"text","text":"something (known as leaf views) apply the current animation to"},{"type":"text","text":" "},{"type":"text","text":"their frame rectangle. However in some cases this coalescing"},{"type":"text","text":" "},{"type":"text","text":"behavior can give undesirable results; inserting a geometry"},{"type":"text","text":" "},{"type":"text","text":"group can correct that. A group acts as a barrier between the"},{"type":"text","text":" "},{"type":"text","text":"parent view and its subviews, forcing the position and size"},{"type":"text","text":" "},{"type":"text","text":"values to be resolved and animated by the parent, before being"},{"type":"text","text":" "},{"type":"text","text":"passed down to each subview."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The example below shows one use of this function: ensuring that"},{"type":"text","text":" "},{"type":"text","text":"the member views of each row in the stack apply (and animate"},{"type":"text","text":" "},{"type":"text","text":"as) a single geometric transform from their ancestor view,"},{"type":"text","text":" "},{"type":"text","text":"rather than letting the effects of the ancestor views be"},{"type":"text","text":" "},{"type":"text","text":"applied separately to each leaf view. If the members of"},{"type":"text","text":" "},{"type":"codeVoice","code":"ItemView"},{"text":" may be added and removed at different times the","type":"text"},{"text":" ","type":"text"},{"text":"group ensures that they stay locked together as animations are","type":"text"},{"text":" ","type":"text"},{"text":"applied.","type":"text"}],"type":"paragraph"},{"code":["VStack {","    ForEach(items) { item in","        ItemView(item: item)","            .geometryGroup()","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Returns: a new view whose geometry is isolated from that of its"},{"type":"text","text":" "},{"type":"text","text":"parent view."}],"type":"paragraph"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftui\/view","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"type":"topic","title":"View","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/StrokeBorderShapeView":{"abstract":[{"type":"text","text":"A shape provider that strokes the border of its shape."}],"role":"symbol","url":"\/documentation\/openswiftui\/strokebordershapeview","type":"topic","title":"StrokeBorderShapeView","kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StrokeBorderShapeView","navigatorTitle":[{"text":"StrokeBorderShapeView","kind":"identifier"}],"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"StrokeBorderShapeView","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/StrokeBorderShapeView/geometryGroup()":{"title":"geometryGroup()","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/StrokeBorderShapeView\/geometryGroup()","url":"\/documentation\/openswiftui\/strokebordershapeview\/geometrygroup()","type":"topic","abstract":[{"text":"Isolates the geometry (e.g. position and size) of the view","type":"text"},{"text":" ","type":"text"},{"text":"from its parent view.","type":"text"}],"role":"symbol","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}]}}}