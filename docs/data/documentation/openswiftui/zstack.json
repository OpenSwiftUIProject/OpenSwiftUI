{"schemaVersion":{"minor":3,"major":0,"patch":0},"abstract":[{"text":"A view that overlays its subviews, aligning them in both axes.","type":"text"}],"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack","interfaceLanguage":"swift"},"metadata":{"remoteSource":{"fileName":"ZStack.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Stack\/ZStack.swift#L70"},"navigatorTitle":[{"text":"ZStack","kind":"identifier"}],"modules":[{"name":"OpenSwiftUI"}],"role":"symbol","externalID":"s:15OpenSwiftUICore6ZStackV","roleHeading":"Structure","platforms":[{"unavailable":false,"beta":false,"name":"iOS","introducedAt":"13.0","deprecated":false},{"unavailable":false,"beta":false,"name":"macOS","introducedAt":"10.15","deprecated":false},{"unavailable":false,"beta":false,"name":"tvOS","introducedAt":"13.0","deprecated":false},{"unavailable":false,"beta":false,"name":"visionOS","introducedAt":"1.0","deprecated":false},{"unavailable":false,"beta":false,"name":"watchOS","introducedAt":"6.0","deprecated":false}],"symbolKind":"struct","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ZStack","kind":"identifier"}],"title":"ZStack"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"sections":[],"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack\/init(alignment:content:)"],"generated":true,"title":"Initializers"},{"anchor":"Type-Aliases","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack\/Body"],"generated":true,"title":"Type Aliases"},{"anchor":"Default-Implementations","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack\/View-Implementations"],"generated":true,"title":"Default Implementations"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ZStack","kind":"identifier"},{"text":"<","kind":"text"},{"text":"Content","kind":"genericParameter"},{"text":"> ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Content","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"ZStack"},{"type":"text","text":" assigns each successive subview a higher z-axis value than"},{"type":"text","text":" "},{"type":"text","text":"the one before it, meaning later subviews appear “on top” of earlier ones."}]},{"type":"paragraph","inlineContent":[{"text":"The following example creates a ","type":"text"},{"type":"codeVoice","code":"ZStack"},{"text":" of 100 x 100 point ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Rectangle"},{"text":" ","type":"text"},{"text":"views filled with one of six colors, offsetting each successive subview","type":"text"},{"text":" ","type":"text"},{"text":"by 10 points so they don’t completely overlap:","type":"text"}]},{"type":"codeListing","code":["let colors: [Color] =","    [.red, .orange, .yellow, .green, .blue, .purple]","","var body: some View {","    ZStack {","        ForEach(0..<colors.count) {","            Rectangle()","                .fill(colors[$0])","                .frame(width: 100, height: 100)","                .offset(x: CGFloat($0) * 10.0,","                        y: CGFloat($0) * 10.0)","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"ZStack"},{"type":"text","text":" uses an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment"},{"type":"text","text":" to set the x- and y-axis coordinates of"},{"type":"text","text":" "},{"type":"text","text":"each subview, defaulting to a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/center"},{"type":"text","text":" alignment. In the following"},{"type":"text","text":" "},{"type":"text","text":"example, the "},{"type":"codeVoice","code":"ZStack"},{"type":"text","text":" uses a "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Alignment\/bottomLeading"},{"type":"text","text":" alignment to lay"},{"type":"text","text":" "},{"type":"text","text":"out two subviews, a red 100 x 50 point rectangle below, and a blue 50 x 100"},{"type":"text","text":" "},{"type":"text","text":"point rectangle on top. Because of the alignment value, both rectangles"},{"type":"text","text":" "},{"type":"text","text":"share a bottom-left corner with the "},{"type":"codeVoice","code":"ZStack"},{"type":"text","text":" (in locales where left is the"},{"type":"text","text":" "},{"type":"text","text":"leading side)."}]},{"type":"codeListing","code":["var body: some View {","    ZStack(alignment: .bottomLeading) {","        Rectangle()","            .fill(Color.red)","            .frame(width: 100, height: 50)","        Rectangle()","            .fill(Color.blue)","            .frame(width:50, height: 100)","    }","    .border(Color.green, width: 1)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"If you need a version of this stack that conforms to the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"protocol, like when you want to create a conditional layout using","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyLayout","isActive":true,"type":"reference"},{"text":", use ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStackLayout","isActive":true,"type":"reference"},{"text":" instead.","type":"text"}]}],"style":"note","name":"Note"}]}],"variants":[{"paths":["\/documentation\/openswiftui\/zstack"],"traits":[{"interfaceLanguage":"swift"}]}],"relationshipsSections":[{"type":"conformsTo","kind":"relationships","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"],"title":"Conforms To"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ZStack/Body":{"url":"\/documentation\/openswiftui\/zstack\/body","abstract":[{"type":"text","text":"The type of view representing the body of this view."}],"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ZStack\/Body","navigatorTitle":[{"text":"Body","kind":"identifier"}],"role":"symbol","type":"topic","fragments":[{"text":"typealias","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Body","kind":"identifier"}],"title":"ZStack.Body"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Alignment":{"url":"\/documentation\/openswiftui\/alignment","abstract":[{"type":"text","text":"An alignment in both axes."}],"navigatorTitle":[{"text":"Alignment","kind":"identifier"}],"kind":"symbol","fragments":[{"text":"struct",