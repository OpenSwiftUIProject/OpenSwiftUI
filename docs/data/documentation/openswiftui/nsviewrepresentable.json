{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"abstract":[{"text":"A wrapper that you use to integrate an AppKit view into your SwiftUI view","type":"text"},{"text":" ","type":"text"},{"text":"hierarchy.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/nsviewrepresentable"]}],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"],"type":"inheritsFrom"}],"topicSections":[{"anchor":"Associated-Types","generated":true,"title":"Associated Types","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewRepresentable\/Coordinator","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewRepresentable\/NSViewType"]},{"anchor":"Instance-Methods","generated":true,"title":"Instance Methods","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewRepresentable\/makeCoordinator()","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewRepresentable\/makeNSView(context:)","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewRepresentable\/sizeThatFits(_:nsView:context:)","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewRepresentable\/updateNSView(_:context:)"]},{"anchor":"Type-Aliases","generated":true,"title":"Type Aliases","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewRepresentable\/Context","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewRepresentable\/LayoutOptions"]},{"anchor":"Type-Methods","generated":true,"title":"Type Methods","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewRepresentable\/dismantleNSView(_:coordinator:)"]}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewRepresentable"},"schemaVersion":{"minor":3,"patch":0,"major":0},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@preconcurrency","kind":"attribute"},{"text":" ","kind":"text"},{"text":"@","kind":"attribute"},{"text":"MainActor","preciseIdentifier":"s:ScM","kind":"attribute"},{"text":" ","kind":"text"},{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NSViewRepresentable","kind":"identifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"kind":"keyword","text":"where"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP4BodyQa","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/Body-swift.associatedtype","text":"Body"},{"kind":"text","text":" == "},{"kind":"typeIdentifier","preciseIdentifier":"s:s5NeverO","text":"Never"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Use an "},{"code":"NSViewRepresentable","type":"codeVoice"},{"type":"text","text":" instance to create and manage an"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/appkit\/nsview","isActive":true},{"type":"text","text":" object in your OpenSwiftUI"},{"type":"text","text":" "},{"type":"text","text":"interface. Adopt this protocol in one of your app’s custom instances, and"},{"type":"text","text":" "},{"type":"text","text":"use its methods to create, update, and tear down your view. The creation and"},{"type":"text","text":" "},{"text":"update processes parallel the behavior of OpenSwiftUI views, and you use them to","type":"text"},{"text":" ","type":"text"},{"text":"configure your view with your app’s current state information. Use the","type":"text"},{"text":" ","type":"text"},{"text":"teardown process to remove your view cleanly from your OpenSwiftUI. For example,","type":"text"},{"text":" ","type":"text"},{"text":"you might use the teardown process to notify other objects that the view is","type":"text"},{"text":" ","type":"text"},{"text":"disappearing.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To add your view into your OpenSwiftUI interface, create your"},{"type":"text","text":" "},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewRepresentable","type":"reference"},{"type":"text","text":" instance and add it to your OpenSwiftUI interface. The"},{"type":"text","text":" "},{"type":"text","text":"system calls the methods of your representable instance at appropriate times"},{"type":"text","text":" "},{"type":"text","text":"to create and update the view. The following example shows the inclusion of"},{"type":"text","text":" "},{"type":"text","text":"a custom "},{"code":"MyRepresentedCustomView","type":"codeVoice"},{"text":" struct in the view hierarchy.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["struct ContentView: View {","   var body: some View {","      VStack {","         Text(\"Global Sales\")","         MyRepresentedCustomView()","      }","   }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The system doesn’t automatically communicate changes occurring within your"},{"type":"text","text":" "},{"type":"text","text":"view controller to other parts of your OpenSwiftUI interface. When you want your"},{"type":"text","text":" "},{"type":"text","text":"view controller to coordinate with other OpenSwiftUI views, you must provide a"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewControllerRepresentable\/Coordinator","isActive":true},{"type":"text","text":" object to facilitate those"},{"type":"text","text":" "},{"type":"text","text":"interactions. For example, you use a coordinator to forward target-action"},{"type":"text","text":" "},{"type":"text","text":"and delegate messages from your view controller to any OpenSwiftUI views."}],"type":"paragraph"},{"name":"Warning","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"OpenSwiftUI fully controls the layout of the AppKit view using the view’s"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/appkit\/nsview\/1483713-frame","isActive":true},{"type":"text","text":" and"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/appkit\/nsview\/1483817-bounds","isActive":true},{"type":"text","text":" "},{"type":"text","text":"properties. Don’t directly set these layout-related properties on the view"},{"type":"text","text":" "},{"type":"text","text":"managed by an "},{"type":"codeVoice","code":"NSViewRepresentable"},{"text":" instance from your own","type":"text"},{"text":" ","type":"text"},{"text":"code because that conflicts with OpenSwiftUI and results in undefined behavior.","type":"text"}]}],"style":"warning","type":"aside"}]}],"metadata":{"role":"symbol","remoteSource":{"fileName":"NSViewRepresentable.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/Integration\/Representable\/AppKit\/NSViewRepresentable.swift#L65"},"roleHeading":"Protocol","platforms":[{"deprecated":false,"beta":false,"unavailable":false,"name":"macOS","introducedAt":"10.15"}],"symbolKind":"protocol","modules":[{"name":"OpenSwiftUI"}],"externalID":"s:11OpenSwiftUI19NSViewRepresentableP","title":"NSViewRepresentable","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"NSViewRepresentable"}],"navigatorTitle":[{"kind":"identifier","text":"NSViewRepresentable"}]},"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/NSViewRepresentable":{"url":"\/documentation\/openswiftui\/nsviewrepre