macOS"],"languages":["swift"],"tokens":[{"text":"@preconcurrency","kind":"attribute"},{"text":" ","kind":"text"},{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NSViewRepresentable","kind":"identifier"},{"text":" : ","kind":"text"},{"text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Self","kind":"typeIdentifier"},{"text":".","kind":"text"},{"text":"Body","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/Body-swift.associatedtype","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP4BodyQa"},{"text":" == ","kind":"text"},{"text":"Never","kind":"typeIdentifier","preciseIdentifier":"s:s5NeverO"}]}]},{"content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Use an "},{"type":"codeVoice","code":"NSViewRepresentable"},{"type":"text","text":" instance to create and manage an"},{"type":"text","text":" "},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/appkit\/nsview","isActive":true},{"type":"text","text":" object in your OpenSwiftUI"},{"type":"text","text":" "},{"type":"text","text":"interface. Adopt this protocol in one of your app’s custom instances, and"},{"type":"text","text":" "},{"type":"text","text":"use its methods to create, update, and tear down your view. The creation and"},{"type":"text","text":" "},{"type":"text","text":"update processes parallel the behavior of OpenSwiftUI views, and you use them to"},{"type":"text","text":" "},{"type":"text","text":"configure your view with your app’s current state information. Use the"},{"type":"text","text":" "},{"type":"text","text":"teardown process to remove your view cleanly from your OpenSwiftUI. For example,"},{"type":"text","text":" "},{"type":"text","text":"you might use the teardown process to notify other objects that the view is"},{"type":"text","text":" "},{"type":"text","text":"disappearing."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To add your view into your OpenSwiftUI interface, create your"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewRepresentable","isActive":true,"type":"reference"},{"type":"text","text":" instance and add it to your OpenSwiftUI interface. The"},{"type":"text","text":" "},{"type":"text","text":"system calls the methods of your representable instance at appropriate times"},{"type":"text","text":" "},{"type":"text","text":"to create and update the view. The following example shows the inclusion of"},{"type":"text","text":" "},{"type":"text","text":"a custom "},{"code":"MyRepresentedCustomView","type":"codeVoice"},{"type":"text","text":" struct in the view hierarchy."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct ContentView: View {","   var body: some View {","      VStack {","         Text(\"Global Sales\")","         MyRepresentedCustomView()","      }","   }","}"]},{"inlineContent":[{"text":"The system doesn’t automatically communicate changes occurring within your","type":"text"},{"text":" ","type":"text"},{"text":"view controller to other parts of your OpenSwiftUI interface. When you want your","type":"text"},{"text":" ","type":"text"},{"text":"view controller to coordinate with other OpenSwiftUI views, you must provide a","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/NSViewControllerRepresentable\/Coordinator","type":"reference"},{"text":" object to facilitate those","type":"text"},{"text":" ","type":"text"},{"text":"interactions. For example, you use a coordinator to forward target-action","type":"text"},{"text":" ","type":"text"},{"text":"and delegate messages from your view controller to any OpenSwiftUI views.","type":"text"}],"type":"paragraph"},{"name":"Warning","content":[{"type":"paragraph","inlineContent":[{"text":"OpenSwiftUI fully controls the layout of the AppKit view using the view’s","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/appkit\/nsview\/1483713-frame","isActive":true,"type":"reference"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/appkit\/nsview\/1483817-bounds","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"properties. Don’t directly set these layout-related properties on the view","type":"text"},{"text":" ","type":"text"},{"text":"managed by an ","type":"text"},{"type":"codeVoice","code":"NSViewRepresentable"},{"text":" instance from your own","type":"text"},{"text":" ","type":"text"},{"text":"code because that conflicts with OpenSwiftUI and results in undefined behavior.","type":"text"}]}],"type":"aside","style":"warning"}],"kind":"content"}],"metadata":{"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/Integration\/Representable\/AppKit\/NSViewRepresentable.swift#L65","fileName":"NSViewRepresentable.swift"},"role":"symbol","platforms":[{"unavailable":false,"introducedAt":"10.15","deprecated":false,"beta":false,"name":"macOS"}],"roleHeading":"Protocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"NSViewRepresentable","kind":"identifier"}],"externalID":"s:11OpenSwiftUI19NSViewRepresentableP","modules":[{"name":"OpenSwiftUI"}],"title":"NSViewRepresentable","navigatorTitle":[{"text":"NSViewRepresentable","kind":"identifier"}],"symbolKind":"protocol"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/NSViewRepresentable/makeNSView(context:)":{"identifier":"doc:\/\/OpenS