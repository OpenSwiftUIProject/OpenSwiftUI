iew container.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Here, the outermost ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true,"type":"reference"},{"text":" applies a 16-point system font as a","type":"text"},{"text":" ","type":"text"},{"text":"default font to views contained in that ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true,"type":"reference"},{"text":". Inside that stack,","type":"text"},{"text":" ","type":"text"},{"text":"the example applies a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Font\/largeTitle","isActive":true,"type":"reference"},{"text":" font to just the first text","type":"text"},{"text":" ","type":"text"},{"text":"view; this explicitly overrides the default. The remaining stack and the","type":"text"},{"text":" ","type":"text"},{"text":"views contained with it continue to use the 16-point system font set by","type":"text"},{"text":" ","type":"text"},{"text":"their containing view:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["VStack {","    Text(\"Font applied to a text view.\")","        .font(.largeTitle)","","    VStack {","        Text(\"These 2 text views have the same font\")","        Text(\"applied to their parent hierarchy\")","    }","}",".font(.system(size: 16, weight: .light, design: .default))"]},{"inlineContent":[],"type":"paragraph"}],"kind":"content"}],"metadata":{"title":"font(_:)","role":"symbol","externalID":"s:15OpenSwiftUICore4ViewPAAE4fontyQrAA4FontVSgF::SYNTHESIZED::s:11OpenSwiftUI12ViewThatFitsV","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"font","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Font","preciseIdentifier":"s:15OpenSwiftUICore4FontV","kind":"typeIdentifier"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text"