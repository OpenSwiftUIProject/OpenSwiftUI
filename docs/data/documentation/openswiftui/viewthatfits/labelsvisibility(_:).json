ggle2) {","        Text(\"Toggle 2\")","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true},{"type":"text","text":" in the example above centers the first toggle’s control"},{"type":"text","text":" "},{"type":"text","text":"element in the available space, while it centers the second toggle’s"},{"type":"text","text":" "},{"type":"text","text":"combined label and control element:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always provide a label for controls, even when you hide the label,"},{"type":"text","text":" "},{"type":"text","text":"because OpenSwiftUI uses labels for other purposes, including accessibility."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On iOS, a "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":" within a "},{"type":"codeVoice","code":"Menu"},{"type":"text","text":" hides its label by default. You can use"},{"type":"text","text":" "},{"type":"text","text":"this modifier to explicitly show the label in that context:"}]},{"type":"codeListing","syntax":"swift","code":["Menu {","    Picker(\"Flavor\", selection: $selectedFlavor) {","        Text(\"Chocolate\").tag(Flavor.chocolate)","        Text(\"Vanilla\").tag(Flavor.vanilla)","        Text(\"Strawberry\").tag(Flavor.strawberry)","    }","    .labelsVisibility(.visible)","}"]},{"type":"aside","content":[{"inlineContent":[{"text":"This modifier doesn’t work for all labels. It applies to","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent","type":"reference","isActive":true},{"text":" elements, including controls like ","type":"text"},{"code":"Picker","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference","isActive":true},{"text":", but not to controls like a bordered button where the label","type":"text"},{"text":" ","type":"text"},{"text":"is inside the button’s border.","type":"text"}],"type":"paragraph"}],"name":"Note","style":"note"}]}],"abstract":[{"text":"Controls the visibility of labels of any controls contained within this","type":"text"},{"text":" ","type":"text"},{"text":"view.","type":"text"}],"metadata":{"roleHeading":"Instance Method","platforms":[{"unavailable":false,"beta":false,"name":"iOS","introducedAt":"13.0","deprecated":false},{"unavailable":false,"beta":false,"name":"macOS","introducedAt":"10.15","deprecated":false},{"unavailable":false,"beta":false,"name":"tvOS","introducedAt":"13.0","deprecated":false},{"unavailable":false,"beta":false,"name":"visionOS","introducedAt":"1.0","deprecated":false},{"unavailable":false,"beta":false,"name":"watchOS","introducedAt":"6.0","deprecated":false}],"role":"symbol","extendedModule":"OpenSwiftUICore","externalID":"s:15OpenSwiftUICore4ViewP0aB2UIE16labelsVisibilityyQrAA0G0OF::SYNTHESIZED::s:11OpenSwiftUI12ViewThatFitsV","symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"labelsVisibility","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Visibility","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore10VisibilityO"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/LabelContent\/LabelVisibility.swift#L60","fileName":"LabelVisibility.swift"},"title":"labelsVisibility(_:)","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}]},"variants":[{"paths":["\/documentation\/openswiftui\/viewthatfits\/labelsvisibility(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references