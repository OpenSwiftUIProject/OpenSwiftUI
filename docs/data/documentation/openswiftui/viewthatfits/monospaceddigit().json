{"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewThatFits\/monospacedDigit()","interfaceLanguage":"swift"},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewThatFits"]]},"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"abstract":[{"text":"Modifies the fonts of all child views to use fixed-width digits, if","type":"text"},{"text":" ","type":"text"},{"text":"possible, while leaving other characters proportionally spaced.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"monospacedDigit","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view whose child views’ fonts use fixed-width numeric"},{"type":"text","text":" "},{"type":"text","text":"characters, while leaving other characters proportionally spaced."}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Using fixed-width digits allows you to easily align numbers of the"},{"type":"text","text":" "},{"type":"text","text":"same size in a table-like arrangement. This feature is also known as"},{"type":"text","text":" "},{"type":"text","text":"“tabular figures” or “tabular numbers.”"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This modifier only affects numeric characters, and leaves all other"},{"type":"text","text":" "},{"type":"text","text":"characters unchanged."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example shows the effect of "},{"type":"codeVoice","code":"monospacedDigit()"},{"type":"text","text":" on"},{"type":"text","text":" "},{"type":"text","text":"multiple child views. The example consists of two "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true},{"type":"text","text":" views"},{"type":"text","text":" "},{"type":"text","text":"inside an "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","isActive":true},{"type":"text","text":". Each "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" contains two "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button","isActive":true},{"type":"text","text":" views, with"},{"type":"text","text":" "},{"type":"text","text":"the second "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" applying the "},{"type":"codeVoice","code":"monospacedDigit()"},{"type":"text","text":" modifier to its"},{"type":"text","text":" "},{"type":"text","text":"contents. As a result, the digits in the buttons in the trailing"},{"type":"text","text":" "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" are the same width, which in turn gives the buttons equal widths."}],"type":"paragraph"},{"code":["var body: some View {","    HStack(alignment: .top) {","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        .monospacedDigit()","    }","    .padding()","    .navigationTitle(\"monospacedDigit() Child Views\")","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"If a child view’s base font doesn’t support fixed-width digits, the font","type":"text"},{"text":" ","type":"text"},{"text":"remains unchanged.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/viewthatfits\/monospaceddigit()"]}],"metadata":{"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"monospacedDigit"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","text":"View"}],"roleHeading":"Instance Method","role":"symbol","extendedModule":"OpenSwiftUICore","symbolKind":"method","platforms":[{"unavailable":false,"name":"iOS","beta":false,"introducedAt":"13.0","deprecated":false},{"unavailable":false,"name":"macOS","beta":false,"introducedAt":"10.15","deprecated":false},{"unavailable":false,"name":"tvOS","beta":false,"introducedAt":"13.0","deprecated":false},{"unavailable":false,"name":"visionOS","beta":false,"introducedAt":"1.0","deprecated":false},{"unavailable":false,"name":"watchOS","beta":false,"introducedAt":"6.0","deprecated":false}],"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Data\/EnvironmentKeys\/EnvironmentAdditions.swift#L329","fileName":"EnvironmentAdditions.swift"},"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"title":"monospacedDigit()","externalID":"s:15OpenSwiftUICore4ViewPAAE15monospacedDigitQryF::SYNTHESIZED::s:11OpenSwiftUI12ViewThatFitsV"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Button":{"type":"topic","navigatorTitle":[{"text":"Button","kind":"identifier"}],"title":"Button","url":"\/documentation\/openswiftui\/button","abstract":[],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Butto