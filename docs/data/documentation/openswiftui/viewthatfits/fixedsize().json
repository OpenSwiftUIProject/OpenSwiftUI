en both dimensions:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Text(\"A single line of text, too long to fit in a box.\")","    .fixedSize()","    .frame(width: 200, height: 200)","    .border(Color.gray)"]},{"type":"paragraph","inlineContent":[{"text":"This can result in the view exceeding the parent’s bounds, which may or","type":"text"},{"text":" ","type":"text"},{"text":"may not be the effect you want.","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can think of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" as the creation of a "},{"inlineContent":[{"text":"counter proposal","type":"text"}],"type":"emphasis"},{"type":"text","text":" "},{"type":"text","text":"to the view size proposed to a view by its parent. The ideal size of a"},{"type":"text","text":" "},{"type":"text","text":"view, and the specific effects of "},{"type":"codeVoice","code":"fixedSize()"},{"type":"text","text":" depends on the"},{"type":"text","text":" "},{"type":"text","text":"particular view and how you have configured it."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"To create a view that fixes the view’s size in either the horizontal or"},{"type":"text","text":" "},{"type":"text","text":"vertical dimensions, see "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/fixedSize(horizontal:vertical:)","type":"reference","isActive":true},{"type":"text","text":"."}]}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ViewThatFits":{"type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ViewThatFits"}],"url":"\/documentation\/openswiftui\/viewthatfits","title":"ViewThatFits","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewThatFits","navigatorTitle":[{"kind":"identifier","text":"ViewThatFits"}],"kind":"symbol","role":"symbol","abstract":[{"text":"A vie