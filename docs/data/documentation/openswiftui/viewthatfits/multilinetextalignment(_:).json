{"sections":[],"metadata":{"role":"symbol","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"title":"multilineTextAlignment(_:)","roleHeading":"Instance Method","extendedModule":"OpenSwiftUICore","symbolKind":"method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"multilineTextAlignment"},{"kind":"text","text":"("},{"kind":"typeIdentifier","text":"TextAlignment","preciseIdentifier":"s:15OpenSwiftUICore13TextAlignmentO"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"remoteSource":{"fileName":"EnvironmentParagraphStyle.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/View\/Text\/Util\/EnvironmentParagraphStyle.swift#L383"},"externalID":"s:15OpenSwiftUICore4ViewPAAE22multilineTextAlignmentyQrAA0fG0OF::SYNTHESIZED::s:11OpenSwiftUI12ViewThatFitsV","platforms":[{"unavailable":false,"beta":false,"name":"iOS","deprecated":false,"introducedAt":"13.0"},{"unavailable":false,"beta":false,"name":"macOS","deprecated":false,"introducedAt":"10.15"},{"unavailable":false,"beta":false,"name":"tvOS","deprecated":false,"introducedAt":"13.0"},{"unavailable":false,"beta":false,"name":"visionOS","deprecated":false,"introducedAt":"1.0"},{"unavailable":false,"beta":false,"name":"watchOS","deprecated":false,"introducedAt":"6.0"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"text":"Sets the alignment of a text view that contains multiple lines of text.","type":"text"}],"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewThatFits\/multilineTextAlignment(_:)"},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewThatFits"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/viewthatfits\/multilinetextalignment(_:)"]}],"primaryContentSections":[{"declarations":[{"platforms":["macOS"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"multilineTextAlignment","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"alignment","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"TextAlignment","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TextAlignment","preciseIdentifier":"s:15OpenSwiftUICore13TextAlignmentO"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":"\n","kind":"text"}],"languages":["swift"]}],"kind":"declarations"},{"parameters":[{"name":"alignment","content":[{"inlineContent":[{"type":"text","text":"A value that you use to align multiple lines of"},{"type":"text","text":" "},{"type":"text","text":"text within a view."}],"type":"paragraph"}]}],"kind":"parameters"},{"content":[{"text":"Return Value","anchor":"return-value","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"A view that aligns the lines of multiline "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"type":"text","text":" instances"},{"type":"text","text":" "},{"type":"text","text":"it contains."}],"type":"paragraph"}],"kind":"content"},{"content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to set an alignment for a multiline block of text."},{"type":"text","text":" "},{"type":"text","text":"For example, the modifier centers the contents of the following"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" view:"}]},{"syntax":"swift","code":["Text(\"This is a block of text that shows up in a text element as multiple lines.\\(\"\\n\") Here we have chosen to center this text.\")","    .frame(width: 200)","    .multilineTextAlignment(.center)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The text in the above example spans more than one line because:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The newline character introduces a line break.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The frame modifier limits the space available to the text view, and"},{"type":"text","text":" "},{"type":"text","text":"by default a text view wraps lines that don’t fit in the available"},{"type":"text","text":" "},{"type":"text","text":"width. As a result, the text before the explicit line break wraps to"},{"type":"text","text":" "},{"type":"text","text":"three lines, and the text after uses two lines."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier applies the alignment to the all the lines of text in"},{"type":"text","text":" "},{"type":"text","text":"the view, regardless of why wrapping occurs:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"The modifier has no effect on a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view that contains only one","type":"text"},{"text":" ","type":"text"},{"text":"line of text, because a text view has a width that exactly matches the","type":"text"},{"text":" ","type":"text"},{"text":"width of its widest line. If you want to align an entire text view","type":"text"},{"text":" ","type":"text"},{"text":"rather than its contents, set the aligment of its container, like a","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true,"type":"reference"},{"text":" or a frame that you create with the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/frame(minWidth:idealWidth:maxWidth:minHeight:idealHeight:maxHeight:alignment:)","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"modifier.","type":"text"}]},{"style":"note","type":"aside","name":"Note","content":[{"type":"paragraph","inlineContent":[{"text":"You can use this modifier to control the alignment of a ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"text":" ","type":"text"},{"text":"view that you create with the ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/init(_:style:)","isActive":true},{"text":" initializer","type":"text"},{"text":" ","type":"text"},{"text":"to display localized dates and times, including when the view uses","type":"text"},{"text":" ","type":"text"},{"text":"only a single line, but only when that view appears in a widget.","type":"text"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier also affects the content alignment of other text container"},{"type":"text","text":" "},{"type":"text","text":"types, like "},{"type":"codeVoice","code":"TextEditor"},{"type":"text","text":" and "},{"type":"codeVoice","code":"TextField"},{"type":"text","text":". In those cases, the"},{"type":"text","text":" "},{"type":"text","text":"modifier sets the alignment even when the view contains only a single"},{"type":"text","text":" "},{"type":"text","text":"line because view’s width isn’t dictated by the width of the text it"},{"type":"text","text":" "},{"type":"text","text":"contains."}]},{"type":"paragraph","inlineContent":[{"text":"The modifier operates by setting the","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/multilineTextAlignment","type":"reference","isActive":true},{"text":" value in the environment,","type":"text"},{"text":" ","type":"text"},{"text":"so it affects all the text containers in the modified view hierarchy.","type":"text"},{"text":" ","type":"text"},{"text":"For example, you can apply the modifier to a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference","isActive":true},{"text":" to","type":"text"},{"text":" ","type":"text"},{"text":"configure all the text views inside the stack.","type":"text"}]}],"kind":"content"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/VStack":{"title":"VStack","navigatorTitle":[{"kind":"identifier","text":"VStack"}],"abstract":[{"type":"text","text":"A view that arranges its subviews in a vertical line."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VStack"}],"kind":"symbol","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"topic","url":"\/documentation\/openswiftui\/vstack"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Text/init(_:style:)":{"url":"\/documentation\/openswiftui\/text\/init(_:style:)","abstract":[],"fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Date","kind":"typeIdentifier","preciseIdentifier":"s:10Foundation4DateV"},{"text":", ","kind":"text"},{"text":"style","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Text","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4TextV"},{"text":".","kind":"text"},{"text":"DateStyle","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4TextV9DateStyleV"},{"text":")","kind":"text"}],"kind":"symbol","role":"symbol","identifier