},{"text":"that height, and whatever width the layout system offers to its parent.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["VStack {","    Ellipse()","        .fill(Color.purple)","        .frame(width: 200, height: 100)","    Ellipse()","        .fill(Color.blue)","        .frame(height: 100)","}"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"code":"The alignment","type":"codeVoice"},{"text":" parameter specifies this view’s alignment within the","type":"text"},{"text":" ","type":"text"},{"text":"frame.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Text(\"Hello world!\")","    .frame(width: 200, height: 30, alignment: .topLeading)","    .border(Color.gray)"]},{"type":"paragraph","inlineContent":[{"text":"In the example above, the text is positioned at the top, leading corner","type":"text"},{"text":" ","type":"text"},{"text":"of the frame. If the text is taller than the frame, its bounds may","type":"text"},{"text":" ","type":"text"},{"text":"extend beyond the bottom of the frame’s bounds.","type":"text"}]},{"type":"paragraph","inlineContent":[]}]}],"sections":[],"abstract":[{"type":"text","text":"Positions this view within an invisible frame with the specified size."}],"metadata":{"role":"symbol","extendedModule":"OpenSwiftUICore","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Modifier\/FrameLayout.swift#L167","fileName":"FrameLayout.swift"},"externalID":"s:15OpenSwiftUICore4ViewPAAE5frame5width6height9alignmentQr14CoreFoundation7CGFloatVSg_AkA9AlignmentVtF::SYNTHESIZED::s:15OpenSwiftUICore7AnyViewV","symbolKind":"method","title":"frame(width:height:alignment:)","modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"frame"},{"kind":"text","text":"("},{"kind":"externalParam","text":"width"},{"k