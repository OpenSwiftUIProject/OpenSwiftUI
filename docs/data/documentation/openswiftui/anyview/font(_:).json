idual view or view container."}],"type":"paragraph"},{"inlineContent":[{"text":"Here, the outermost ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference"},{"text":" applies a 16-point system font as a","type":"text"},{"text":" ","type":"text"},{"text":"default font to views contained in that ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference"},{"text":". Inside that stack,","type":"text"},{"text":" ","type":"text"},{"text":"the example applies a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Font\/largeTitle","type":"reference"},{"text":" font to just the first text","type":"text"},{"text":" ","type":"text"},{"text":"view; this explicitly overrides the default. The remaining stack and the","type":"text"},{"text":" ","type":"text"},{"text":"views contained with it continue to use the 16-point system font set by","type":"text"},{"text":" ","type":"text"},{"text":"their containing view:","type":"text"}],"type":"paragraph"},{"code":["VStack {","    Text(\"Font applied to a text view.\")","        .font(.largeTitle)","","    VStack {","        Text(\"These 2 text views have the same font\")","        Text(\"applied to their parent hierarchy\")","    }","}",".font(.system(size: 16, weight: .light, design: .default))"],"syntax":"swift","type":"codeListing"},{"inlineContent":[],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/openswiftui\/anyview\/font(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyView"]]},"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnyView\/font(_:)","interfaceLanguage":"swift"},"sections":[],"metadata":{"role":"symbol","roleHeading":"Instance Method","externalID":"s:15OpenSwiftUICore4V