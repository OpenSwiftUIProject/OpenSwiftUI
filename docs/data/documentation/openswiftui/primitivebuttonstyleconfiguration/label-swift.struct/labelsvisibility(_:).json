":false,"unavailable":false},{"beta":false,"name":"watchOS","introducedAt":"6.0","deprecated":false,"unavailable":false}],"role":"symbol"},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"labelsVisibility"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"visibility"},{"kind":"text","text":": "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Visibility","preciseIdentifier":"s:15OpenSwiftUICore10VisibilityO","kind":"typeIdentifier","text":"Visibility"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"},{"kind":"text","text":"\n"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier when you want to omit a label from one or more"},{"type":"text","text":" "},{"type":"text","text":"labeled content in your user interface. For example, the first "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","isActive":true},{"type":"text","text":" "},{"type":"text","text":"in the following example hides its label:"}]},{"type":"codeListing","syntax":"swift","code":["VStack {","    Toggle(isOn: $toggle1) {","        Text(\"Toggle 1\")","    }","    .labelsVisibility(.hidden)","","    Toggle(isOn: $toggle2) {","        Text(\"Toggle 2\")","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true},{"text":" in the example above centers the first toggle’s control","type":"text"},{"text":" ","type":"text"},{"text":"element in the available space, while it centers the second toggle’s","type":"text"},{"text":" ","type":"text"},{"text":"combined label and control element:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always provide a label for controls, even when you hide the label,"},{"type":"text","text":" "},{"type":"text","text":"because OpenSwiftUI uses labels for other purposes, including accessibility."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On iOS, a "},{"type":"codeVoice","code":"Picker"},{"type":"text","text":" within a "},{"type":"codeVoice","code":"Menu"},{"type":"text","text":" hides its label by default. You can use"},{"type":"text","text":" "},{"type":"text","text":"this modifier to explicitly show the label in that context:"}]},{"type":"codeListing","syntax":"swift","code":["Menu {","    Picker(\"Flavor\", selection: $selectedFlavor) {","        Text(\"Chocolate\").tag(Flavor.chocolate)","        Text(\"Vanilla\").tag(Flavor.vanilla)","        Text(\"Strawberry\").tag(Flavor.strawberry)","    }","    .labelsVisibility(.visible)","}"]},{"type":"aside","content":[{"inlineContent":[{"text":"This modifier doesn’t work for all labels. It applies to","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent","type":"reference"},{"text":" elements, including controls like ","type":"text"},{"code":"Picker","type":"codeVoice"},{"text":" and","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference"},{"text":", but not to controls like a bordered button where the label","type":"text"},{"text":" ","type":"text"},{"text":"is inside the button’s border.","type":"text"}],"ty