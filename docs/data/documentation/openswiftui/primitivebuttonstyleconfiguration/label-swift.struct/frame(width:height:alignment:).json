t","text":"\n"}],"languages":["swift"]}],"kind":"declarations"},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"A fixed width for the resulting view. If ","type":"text"},{"type":"codeVoice","code":"width"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"the resulting view assumes this view’s sizing behavior.","type":"text"}]}],"name":"width"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A fixed height for the resulting view. If ","type":"text"},{"type":"codeVoice","code":"height"},{"text":" is ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"the resulting view assumes this view’s sizing behavior.","type":"text"}]}],"name":"height"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The alignment of this view inside the resulting frame.","type":"text"},{"text":" ","type":"text"},{"text":"Note that most alignment values have no apparent effect when the","type":"text"},{"text":" ","type":"text"},{"text":"size of the frame happens to match that of this view.","type":"text"}]}],"name":"alignment"}]},{"content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"A view with fixed dimensions of ","type":"text"},{"code":"width","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"height","type":"codeVoice"},{"text":", for the","type":"text"},{"text":" ","type":"text"},{"text":"parameters that are non-","type":"text"},{"code":"nil","type":"codeVoice"},{"text":".","type":"text"}]}],"kind":"content"},{"content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Use this method to specify a fixed size for a view’s width, height, or"},{"type":"text","text":" "},{"type":"text","text":"both. If you only specify one of the dimensions, the r