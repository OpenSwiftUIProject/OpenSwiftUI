],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/primitivebuttonstyleconfiguration\/label-swift.struct\/monospaceddigit()"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"monospacedDigit","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":"\n","kind":"text"}]}]},{"kind":"content","content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"A view whose child views’ fonts use fixed-width numeric"},{"type":"text","text":" "},{"type":"text","text":"characters, while leaving other characters proportionally spaced."}],"type":"paragraph"}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"Using fixed-width digits allows you to easily align numbers of the","type":"text"},{"text":" ","type":"text"},{"text":"same size in a table-like arrangement. This feature is also known as","type":"text"},{"text":" ","type":"text"},{"text":"“tabular figures” or “tabular numbers.”","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This modifier only affects numeric characters, and leaves all other"},{"type":"text","text":" "},{"type":"text","text":"characters unchanged."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The following example shows the effect of "},{"type":"codeVoice","code":"monospacedDigit()"},{"type":"text","text":" on"},{"type":"text","text":" "},{"type":"text","text":"multiple child views. The example consists of two "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":" views"},{"type":"text","text":" "},{"type":"text","text":"inside an "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"},{"type":"text","text":". Each "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" contains two "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button"},{"type":"text","text":" views, with"},{"type":"text","text":" "},{"type":"text","text":"the second "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" applying the "},{"type":"codeVoice","code":"monospacedDigit()"},{"type":"text","text":" modifier to its"},{"type":"text","text":" "},{"type":"text","text":"contents. As a result, the digits in the buttons in the trailing"},{"type":"text","text":" "},{"type":"codeVoice","code":"VStack"},{"type":"text","text":" are the same width, which in turn gives the buttons equal widths."}],"type":"paragraph"},{"code":["var body: some View {","    HStack(alignment: .top) {","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        .monospacedDigit()","    }","    .padding()","    .navigationTitle(\"monospacedDigit() Child Views\")","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"If a child view’s base font doesn’t support fixed-width digits, the font","type":"text"},{"text":" ","type":"text"},{"text":"remains unchanged.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/O