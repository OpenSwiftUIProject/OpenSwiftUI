{"abstract":[{"type":"text","text":"The properties of a toggle instance."}],"schemaVersion":{"minor":3,"patch":0,"major":0},"metadata":{"role":"symbol","remoteSource":{"fileName":"ToggleStyle.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/Toggle\/ToggleStyle.swift#L213"},"externalID":"s:11OpenSwiftUI24ToggleStyleConfigurationV","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ToggleStyleConfiguration"}],"roleHeading":"Structure","modules":[{"name":"OpenSwiftUI"}],"navigatorTitle":[{"kind":"identifier","text":"ToggleStyleConfiguration"}],"title":"ToggleStyleConfiguration","symbolKind":"struct"},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration","interfaceLanguage":"swift"},"topicSections":[{"generated":true,"title":"Structures","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/Label-swift.struct"],"anchor":"Structures"},{"generated":true,"title":"Instance Properties","identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/isMixed","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/isOn","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/label-swift.property"],"anchor":"Instance-Properties"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"ToggleStyleConfiguration"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Overview","anchor":"overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"When you define a custom toggle style by creating a type that conforms to"},{"type":"text","text":" "},{"type":"text","text":"the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle"},{"type":"text","text":" protocol, you implement the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/makeBody(configuration:)"},{"type":"text","text":" method. That method takes a"},{"type":"text","text":" "},{"code":"ToggleStyleConfiguration","type":"codeVoice"},{"type":"text","text":" input that has the information you need"},{"type":"text","text":" "},{"type":"text","text":"to define the behavior and appearance of a "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The configuration structure’s "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/label-swift.property","isActive":true},{"type":"text","text":" reflects the"},{"type":"text","text":" "},{"type":"text","text":"toggle’s content, which might be the value that you supply to the"},{"type":"text","text":" "},{"type":"codeVoice","code":"label"},{"type":"text","text":" parameter of the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle\/init(isOn:label:)","isActive":true},{"type":"text","text":" initializer."},{"type":"text","text":" "},{"type":"text","text":"Alternatively, it could be another view that OpenSwiftUI builds from an"},{"type":"text","text":" "},{"type":"text","text":"initializer that takes a string input, like "},{"type":"codeVoice","code":"Toggle\/init(_:isOn:)"},{"type":"text","text":"."},{"type":"text","text":" "},{"type":"text","text":"In either case, incorporate the label into the toggle’s view to help"},{"type":"text","text":" "},{"type":"text","text":"the user understand what the toggle does. For example, the built-in"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true},{"type":"text","text":" style horizontally stacks the label with the"},{"type":"text","text":" "},{"type":"text","text":"control element."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The structure’s "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration\/isOn","isActive":true},{"type":"text","text":" property provides a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Binding","isActive":true},{"type":"text","text":" to the state"},{"type":"text","text":" "},{"type":"text","text":"of the toggle. Adjust the appearance of the toggle based on this value."},{"type":"text","text":" "},{"type":"text","text":"For example, the built-in "},{"type":"codeVoice","code":"ToggleStyle\/button"},{"type":"text","text":" style fills the button’s"},{"type":"text","text":" "},{"type":"text","text":"background when the property is "},{"type":"codeVoice","code":"true"},{"type":"text","text":", but leaves the background empty"},{"type":"text","text":" "},{"type":"text","text":"when the property is "},{"type":"codeVoice","code":"false"},{"type":"text","text":". Change the value when the user performs"},{"type":"text","text":" "},{"type":"text","text":"an action that’s meant to change the toggle, like the button does when"},{"type":"text","text":" "},{"type":"text","text":"tapped or clicked by the user."}],"type":"paragraph"}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"sections":[],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/togglestyleconfiguration"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ToggleStyle":{"kind":"symbol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ToggleStyle","kind":"identifier"}],"title":"ToggleStyle","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/To