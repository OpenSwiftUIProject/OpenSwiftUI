d and should be used as a","type":"text"},{"text":" ","type":"text"},{"text":"way to provide additional meaning to the control.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This example shows Answer and Decline buttons with "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/green","isActive":true,"type":"reference"},{"type":"text","text":" "},{"type":"text","text":"and "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/red","isActive":true,"type":"reference"},{"type":"text","text":" tint colors, respectively."}]},{"syntax":"swift","type":"codeListing","code":["struct ControlTint: View {","    var body: some View {","        HStack {","            Button {","                \/\/ Answer the call","            } label: {","                Label(\"Answer\", systemImage: \"phone\")","            }","            .tint(.green)","            Button {","                \/\/ Decline the call","            } label: {","                Label(\"Decline\", systemImage: \"phone.down\")","            }","            .tint(.red)","        }","        .buttonStyle(.borderedProminent)","        .padding()","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Some controls adapt to the tint color differently based on their style,","type":"text"},{"text":" ","type":"text"},{"text":"the current platform, and the surrounding context. For example, in","type":"text"},{"text":" ","type":"text"},{"text":"macOS, a button with the ","type":"text"},{"type":"codeVoice","code":"PrimitiveButtonStyle\/bordered"},{"text":" style doesn’t","type":"text"},{"text":" ","type":"text"},{"text":"tint its background, but one with the","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"PrimitiveButtonStyle\/borderedProminent"},{"text":" style does. In macOS, neither","type":"text"},{"text":" ","type":"text"},{"text":"of these button styles tint their label, but they do in other platforms.","type":"text"}]}]}],"metadata":{"platforms":[{"name":"iOS","introducedAt":"13.0","deprecated":false,"beta":false,"unavailable":false},{"name":"macOS","introducedAt":"10.15","deprecated":false,"beta":false,"unavailable":false},{"name":"tvOS","introducedAt":"13.0","deprecated":false,"beta":false,"unavailable":false},{"name":"visionOS","introducedAt":"1.0","deprecated":false,"beta":false,"unavailable":false},{"name":"watchOS","introducedAt":"6.0","deprecated":false,"beta":false,"unavailable":false}],"title":"tint(_:)","extendedModule":"OpenSwiftUICore","roleHeading":"Instance Method","externalID":"s:15OpenSwiftUICore4ViewPAAE4tintyQrAA5ColorVSgF::SYNTHESIZED::s:15OpenSwiftUICore5GroupV","role":"symbol","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Shape\/Tint.swift#L134","fileName":"Tint.swift"},"symbolKind":"method","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"tint","kind":"identifier"},{"text":"(","kind":"text"},{"text":"Color","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore5ColorV"},{"text":"?) -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/group\/tint(_:)-6rfq2"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Color":{"type":"topic","role":"symbol","title":"Color","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Color","kind":"identifier"}],"navigatorTitle":[{"text":"Color","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","url":"\/documentation\/openswiftui\/color","abstract":[{"type":"text","text":"A representation of a color that adapts to a given context."}],"kind":"symbol"}