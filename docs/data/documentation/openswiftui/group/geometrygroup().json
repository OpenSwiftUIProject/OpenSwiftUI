{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Group"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":"\n","kind":"text"}],"languages":["swift"],"platforms":["macOS"]}]},{"content":[{"type":"heading","anchor":"discussion","text":"Discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"By default OpenSwiftUI views push position and size changes down","type":"text"},{"text":" ","type":"text"},{"text":"through the view hierarchy, so that only views that draw","type":"text"},{"text":" ","type":"text"},{"text":"something (known as leaf views) apply the current animation to","type":"text"},{"text":" ","type":"text"},{"text":"their frame rectangle. However in some cases this coalescing","type":"text"},{"text":" ","type":"text"},{"text":"behavior can give undesirable results; inserting a geometry","type":"text"},{"text":" ","type":"text"},{"text":"group can correct that. A group acts as a barrier between the","type":"text"},{"text":" ","type":"text"},{"text":"parent view and its subviews, forcing the position and size","type":"text"},{"text":" ","type":"text"},{"text":"values to be resolved and animated by the parent, before being","type":"text"},{"text":" ","type":"text"},{"text":"passed down to each subview.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The example below shows one use of this function: ensuring that","type":"text"},{"text":" ","type":"text"},{"text":"the member views of each row in the stack apply (and animate","type":"text"},{"text":" ","type":"text"},{"text":"as) a single geometric transform from their ancestor view,","type":"text"},{"text":" ","type":"text"},{"text":"rather than letting the effects of the ancestor views be","type":"text"},{"text":" ","type":"text"},{"text":"applied separately to each leaf view. If the members of","type":"text"},{"text":" ","type":"text"},{"code":"ItemView","type":"codeVoice"},{"text":" may be added and removed at different times the","type":"text"},{"text":" ","type":"text"},{"text":"group ensures that they stay locked together as animations are","type":"text"},{"text":" ","type":"text"},{"text":"applied.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["VStack {","    ForEach(items) { item in","        ItemView(item: item)","            .geometryGroup()","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Returns: a new view whose geometry is isolated from that of its","type":"text"},{"text":" ","type":"text"},{"text":"parent view.","type":"text"}]}],"kind":"content"}],"abstract":[{"text":"Isolates the geometry (e.g. position and size) of the view","type":"text"},{"text":" ","type":"text"},{"text":"from its parent view.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Group\/geometryGroup()"},"metadata":{"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"remoteSource":{"fileName":"RendererEffect.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Render\/RendererEffect\/RendererEffect.swift#L294"},"externalID":"s:15OpenSwiftUICore4ViewPAAE13geometryGroupQryF::SYNTHESIZED::s:15OpenSwiftUICore5GroupV","role":"symbol","extendedModule":"OpenSwiftUICore","roleHeading":"Instance Method","symbolKind":"method","title":"geometryGroup()","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"geometryGroup"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"}],"platforms":[{"introducedAt":"13.0","deprecated":false,"unavailable":false,"name":"iOS","beta":false},{"introducedAt":"10.15","deprecated":false,"unavailable":false,"name":"macOS","beta":false},{"introducedAt":"13.0","deprecated":false,"unavailable":false,"name":"tvOS","beta":false},{"introducedAt":"1.0","deprecated":false,"unavailable":false,"name":"visionOS","beta":false},{"introducedAt":"6.0","deprecated":false,"unavailable":false,"name":"watchOS","beta":false}]},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"sections":[],"variants":[{"paths":["\/documentation\/openswiftui\/group\/geometrygroup()"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Group":{"abstract":[{"text":"A type that collects multiple instances of a content type — like views,","type":"text"},{"text":" ","type":"text"},{"text":"scenes, or commands — into a single unit.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Group","role":"symbol","kind":"symbol","type":"topic","navigatorTitle":[{"text":"Group","kind":"identifier"}],"title":"Group","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Group","kind":"identifier"}],"url":"\/documentation\/openswiftui\/group"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Group/geometryGroup()":{"abstract":[{"text":"Isolates the geometry (e.g. position and size) of the view","type":"text"},{"text":" ","type":"text"},{"text":"from its parent view.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Group\/geometryGroup()","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"kind":"symbol","title":"geometryGroup()","type":"topic","url":"\/documentation\/openswiftui\/group\/geometrygroup()"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"url":"\/documentation\/openswiftui\/view","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]}}}