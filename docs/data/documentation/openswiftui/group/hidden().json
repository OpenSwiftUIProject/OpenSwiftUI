"A hidden view.","type":"text"}]}],"kind":"content"},{"content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"inlineContent":[{"text":"Hidden views are invisible and can’t receive or respond to interactions.","type":"text"},{"text":" ","type":"text"},{"text":"However, they do remain in the view hierarchy and affect layout. Use","type":"text"},{"text":" ","type":"text"},{"text":"this modifier if you want to include a view for layout purposes, but","type":"text"},{"text":" ","type":"text"},{"text":"don’t want it to display.","type":"text"}],"type":"paragraph"},{"code":["HStack {","    Image(systemName: \"a.circle.fill\")","    Image(systemName: \"b.circle.fill\")","    Image(systemName: \"c.circle.fill\")","        .hidden()","    Image(systemName: \"d.circle.fill\")","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The third circle takes up space, because it’s still present, but"},{"type":"text","text":" "},{"type":"text","text":"OpenSwiftUI doesn’t draw it onscreen."}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"If you want to conditionally include a view in the view hierarchy, use"},{"type":"text","text":" "},{"type":"text","text":"an "},{"type":"codeVoice","code":"if"},{"type":"text","text":" statement instead:"}],"type":"paragraph"},{"code":["VStack {","    HStack {","        Image(systemName: \"a.circle.fill\")","        Image(systemName: \"b.circle.fill\")","        if !isHidden {","            Image(systemName: \"c.circle.fill\")","        }","        Image(systemName: \"d.circle.fill\")","    }","    Toggle(\"Hide\", isOn: $isHidden)","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Depending on the current value of the "},{"type":"codeVoice","code":"isHidden"},{"type":"text","text":" state variable in the"},{"type":"text","text":" "},{"type":"text","text":"example above, controlled by the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle"},{"type":"text","text":" instance, OpenSwiftUI draws"},{"type":"text","text":" "},{"type":"text","text":"the circle or completely omits it from the layout."}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"}],"kind":"content"}],"abstract":[{"text":"Hides this view unconditionally.","type":"text"}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Group\/hidden()","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/group\/hidden()"]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Group"]]},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Group/hidden()":{"role":"symbol","url":"\/documentation\/openswiftui\/group\/hidden()","kind":"symbol","abstract":[{"text":"Hides this view unconditionally.","type":"text"}],"type":"topic","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"hidden"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"title":"hidden()","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Group\/hidden()"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"url":"\/documentation\/openswiftui\/view","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Toggle":{"kind":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Toggle"}],"role":"symbol","url":"\/documentation\/openswiftui\/toggle","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Toggle"}],"title":"Toggle","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","abstract":[]},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Group":{"abstract":[{"text":"A type that collects multiple instances of a content type — like views,","type":"text"},{"text":" ","type":"text"},{"text":"scenes, or commands — into a single unit.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Group","role":"symbol","kind":"symbol","type":"topic","navigatorTitle":[{"text":"Group","kind":"identifier"}],"title":"Group","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Group","kind":"identifier"}],"url":"\/documentation\/openswiftui\/group"}}}