nd":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"monospacedDigit","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"platforms":["macOS"]}],"kind":"declarations"},{"content":[{"anchor":"return-value","type":"heading","level":2,"text":"Return Value"},{"inlineContent":[{"type":"text","text":"A view whose child views’ fonts use fixed-width numeric"},{"type":"text","text":" "},{"type":"text","text":"characters, while leaving other characters proportionally spaced."}],"type":"paragraph"}],"kind":"content"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Using fixed-width digits allows you to easily align numbers of the"},{"type":"text","text":" "},{"type":"text","text":"same size in a table-like arrangement. This feature is also known as"},{"type":"text","text":" "},{"type":"text","text":"“tabular figures” or “tabular numbers.”"}]},{"type":"paragraph","inlineContent":[{"text":"This modifier only affects numeric characters, and leaves all other","type":"text"},{"text":" ","type":"text"},{"text":"characters unchanged.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The following example shows the effect of ","type":"text"},{"type":"codeVoice","code":"monospacedDigit()"},{"text":" on","type":"text"},{"text":" ","type":"text"},{"text":"multiple child views. The example consists of two ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"text":" views","type":"text"},{"text":" ","type":"text"},{"text":"inside an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"},{"text":". Each ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":" contains two ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button"},{"text":" views, with","type":"text"},{"text":" ","type":"text"},{"text":"the second ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":" applying the ","type":"text"},{"type":"codeVoice","code":"monospacedDigit()"},{"text":" modifier to its","type":"text"},{"text":" ","type":"text"},{"text":"contents. As a result, the digits in the buttons in the trailing","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"VStack"},{"text":" are the same width, which in turn gives the buttons equal widths.","type":"text"}]},{"code":["var body: some View {","    HStack(alignment: .top) {","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        .monospacedDigit()","    }","    .padding()","    .navigationTitle(\"monospacedDigit() Child Views\")","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If a child view’s base font doesn’t support fixed-width digits, the font"},{"type":"text","text":" "},{"type":"text","text":"remains unchanged."}]}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/group\/monospaceddigit()"]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Group/monospacedDigit()":{"type":"topic","abstract":[{"text":"Modifies the fonts of all child views to use fixed-width digits, if","type":"text"},{"text":" ","type":"text"},{"text":"possible, while leaving other characters proportionally spaced.","ty