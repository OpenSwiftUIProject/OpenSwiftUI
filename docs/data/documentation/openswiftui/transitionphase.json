, transitions should generally not make any visual","type":"text"},{"text":" ","type":"text"},{"text":"change to the view they are applied to, since the transition’s view","type":"text"},{"text":" ","type":"text"},{"text":"modifications in the ","type":"text"},{"code":"identity","type":"codeVoice"},{"text":" phase will be applied to the view as long as","type":"text"},{"text":" ","type":"text"},{"text":"it is visible. In the ","type":"text"},{"code":"willAppear","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"didDisappear","type":"codeVoice"},{"text":" phases, transitions","type":"text"},{"text":" ","type":"text"},{"text":"should apply a change that will be animated to create the transition. If no","type":"text"},{"text":" ","type":"text"},{"text":"animatable change is applied, then the transition will be a no-op.","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"See Also: "},{"type":"codeVoice","code":"Transition"}]}]},{"content":[{"inlineContent":[{"text":"See Also: ","type":"text"},{"code":"AnyTransition","type":"codeVoice"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/TransitionPhase/didDisappear":{"type":"topic","kind":"symbol","abstract":[{"text":"The transition is being applied to a view that has been requested to be","type":"text"},{"text":" ","type":"text"},{"text":"removed from the view hierarchy.","type":"text"}],"role":"symbol","title":"TransitionPhase.didDisappear","url":"\/documentation\/openswiftui\/transitionphase\/diddisappear","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"didDisappear"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TransitionPhase\/didDisappear"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/TransitionPhase/willAppear":{"type":"topic","url":"\/documentation\/openswiftui\/transitionphase\/willappear","abstract":[{"type":"text","text":"T