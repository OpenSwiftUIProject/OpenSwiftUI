{"abstract":[{"type":"text","text":"Gets the preferred spacing distance along the specified axis to the view"},{"type":"text","text":" "},{"type":"text","text":"that returns a specified spacing preference."}],"metadata":{"symbolKind":"method","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Layout.swift#L1125","fileName":"Layout.swift"},"modules":[{"name":"OpenSwiftUI"}],"roleHeading":"Instance Method","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"distance","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ViewSpacing","preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"along","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Axis","preciseIdentifier":"s:15OpenSwiftUICore4AxisO","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier"}],"externalID":"s:15OpenSwiftUICore11ViewSpacingV8distance2to5along14CoreFoundation7CGFloatVAC_AA4AxisOtF","title":"distance(to:along:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/viewspacing\/distance(to:along:)"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing\/distance(to:along:)"},"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"distance","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"next","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV","text":"ViewSpacing","kind":"typeIdentifier","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing"},{"text":", ","kind":"text"},{"text":"along","kind":"externalParam"},{"kind":"text","text":" "},{"kind":"internalParam","text":"axis"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Axis","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Axis","preciseIdentifier":"s:15OpenSwiftUICore4AxisO"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV"}]}]},{"kind":"parameters","parameters":[{"name":"next","content":[{"inlineContent":[{"type":"text","text":"The spacing preferences instance of the adjacent view."}],"type":"paragraph"}]},{"name":"axis","content":[{"type":"paragraph","inlineContent":[{"text":"The axis that the two views align on.","type":"text"}]}]}]},{"content":[{"level":2,"anchor":"return-value","type":"heading","text":"Return Value"},{"type":"paragraph","inlineContent":[{"text":"A floating point value that represents the smallest distance","type":"text"},{"text":" ","type":"text"},{"text":"in points between two views that satisfies the spacing preferences","type":"text"},{"text":" ","type":"text"},{"text":"of both this view and the adjacent views on their shared edge.","type":"text"}]}],"kind":"content"},{"content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"inlineContent":[{"text":"Call this method from your implementation of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout","type":"reference"},{"text":" protocol","type":"text"},{"text":" ","type":"text"},{"text":"methods if you need to measure the default spacing between two","type":"text"},{"text":" ","type":"text"},{"text":"views in a custom layout. Call the method on the first view’s","type":"text"},{"text":" ","type":"text"},{"text":"preferences instance, and provide the second view’s preferences","type":"text"},{"text":" ","type":"text"},{"text":"instance as input.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For example, consider two views that appear in a custom horizontal","type":"text"},{"text":" ","type":"text"},{"text":"stack. The following distance call gets the preferred spacing between","type":"text"},{"text":" ","type":"text"},{"text":"these views, where ","type":"text"},{"type":"codeVoice","code":"spacing1"},{"text":" contains the preferences of a first","type":"text"},{"text":" ","type":"text"},{"text":"view, and ","type":"text"},{"type":"codeVoice","code":"spacing2"},{"text":" contains the preferences of a second view:","type":"text"}],"type":"paragraph"},{"code":["let distance = spacing1.distance(to: spacing2, axis: .horizontal)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The method first determines, based on the axis and the ordering, that"},{"type":"text","text":" "},{"type":"text","text":"the views abut on the trailing edge of the first view and the leading"},{"type":"text","text":" "},{"type":"text","text":"edge of the second. It then gets the spacing preferences for the"},{"type":"text","text":" "},{"type":"text","text":"corresponding edges of each view, and returns the greater of the two"},{"type":"text","text":" "},{"type":"text","text":"values. This results in the smallest value that provides enough space"},{"type":"text","text":" "},{"type":"text","text":"to satisfy the preferences of both views."}],"type":"paragraph"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"This method returns the default spacing between views, but a"},{"type":"text","text":" "},{"type":"text","text":"layout can choose to ignore the value and use custom spacing instead."}]}],"name":"Note","style":"note"}],"kind":"content"}],"kind":"symbol","schemaVersion":{"minor":3,"patch":0,"major":0},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ViewSpacing":{"fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ViewSpacing","kind":"identifier"}],"title":"ViewSpacing","url":"\/documentation\/openswiftui\/viewspacing","kind":"symbol","type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing","abstract":[{"text":"A collection of the geometric spacing preferences of a view.","type":"text"}],"role":"symbol","navigatorTitle":[{"text":"ViewSpacing","kind":"identifier"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ViewSpacing/distance(to:along:)":{"title":"distance(to:along:)","type":"topic","url":"\/documentation\/openswiftui\/viewspacing\/distance(to:along:)","kind":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"distance","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"ViewSpacing","preciseIdentifier":"s:15OpenSwiftUICore11ViewSpacingV","kind":"typeIdentifier"},{"text":", ","kind":"text"},{"text":"along","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"Axis","preciseIdentifier":"s:15OpenSwiftUICore4AxisO","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"CGFloat","preciseIdentifier":"s:14CoreFoundation7CGFloatV","kind":"typeIdentifier"}],"abstract":[{"text":"Gets the preferred spacing distance along the specified axis to the view","type":"text"},{"text":" ","type":"text"},{"text":"that returns a specified spacing preference.","type":"text"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewSpacing\/distance(to:along:)","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Axis":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Axis","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"Axis"}],"title":"Axis","navigatorTitle":[{"kind":"identifier","