{"abstract":[{"text":"A key for accessing a layout value of a layout container’s subviews.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/layoutvaluekey"]}],"sections":[],"topicSections":[{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutValueKey\/Value"],"generated":true,"anchor":"Associated-Types","title":"Associated Types"},{"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutValueKey\/defaultValue"],"generated":true,"anchor":"Type-Properties","title":"Type Properties"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LayoutValueKey"},"metadata":{"remoteSource":{"fileName":"Layout.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Layout.swift#L1880"},"externalID":"s:15OpenSwiftUICore14LayoutValueKeyP","symbolKind":"protocol","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"LayoutValueKey","kind":"identifier"}],"roleHeading":"Protocol","title":"LayoutValueKey","modules":[{"name":"OpenSwiftUI"}],"role":"symbol","navigatorTitle":[{"kind":"identifier","text":"LayoutValueKey"}]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"LayoutValueKey"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"text":"Overview","type":"heading","anchor":"overview","level":2},{"inlineContent":[{"type":"text","text":"If you create a custom layout by defining a type that conforms to the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Layout","isActive":true},{"type":"text","text":" protocol, you can also create custom layout values"},{"type":"text","text":" "},{"type":"text","text":"that you set on