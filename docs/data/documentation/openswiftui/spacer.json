{"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"symbol","topicSections":[{"generated":true,"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Spacer\/init(minLength:)"],"anchor":"Initializers","title":"Initializers"},{"generated":true,"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Spacer\/minLength"],"anchor":"Instance-Properties","title":"Instance Properties"},{"generated":true,"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Spacer\/View-Implementations"],"anchor":"Default-Implementations","title":"Default Implementations"}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Spacer"},"metadata":{"role":"symbol","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Spacer"}],"roleHeading":"Structure","externalID":"s:15OpenSwiftUICore6SpacerV","symbolKind":"struct","navigatorTitle":[{"kind":"identifier","text":"Spacer"}],"remoteSource":{"fileName":"Spacer.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Layout\/Separator\/Spacer.swift#L116"},"modules":[{"name":"OpenSwiftUI"}],"title":"Spacer","platforms":[{"introducedAt":"13.0","name":"iOS","deprecated":false,"beta":false,"unavailable":false},{"introducedAt":"10.15","name":"macOS","deprecated":false,"beta":false,"unavailable":false},{"introducedAt":"13.0","name":"tvOS","deprecated":false,"beta":false,"unavailable":false},{"introducedAt":"1.0","name":"visionOS","deprecated":false,"beta":false,"unavailable":false},{"introducedAt":"6.0","name":"watchOS","deprecated":false,"beta":false,"unavailable":false}]},"abstract":[{"type":"text","text":"A flexible space that expands along the major axis of its containing stack"},{"type":"text","text":" "},{"type":"text","text":"layout, or on both axes if not contained in a stack."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/spacer"]}],"relationshipsSections":[{"identifiers":["doc:\/\/OpenSwiftUI\/s15BitwiseCopyableP","doc:\/\/OpenSwiftUI\/s8SendableP","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"],"type":"conformsTo","title":"Conforms To","kind":"relationships"}],"primaryContentSections":[{"declarations":[{"tokens":[{"text":"@","kind":"attribute"},{"text":"MainActor","kind":"attribute","preciseIdentifier":"s:ScM"},{"text":" ","kind":"text"},{"text":"@frozen","kind":"attribute"},{"text":" ","kind":"text"},{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Spacer","kind":"identifier"}],"platforms":["macOS"],"languages":["swift"]}],"kind":"declarations"},{"content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"A spacer creates an adaptive view with no content that expands as much as","type":"text"},{"text":" ","type":"text"},{"text":"it can. For example, when placed within an ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"},{"text":", a spacer expands","type":"text"},{"text":" ","type":"text"},{"text":"horizontally as much as the stack allows, moving sibling views out of the","type":"text"},{"text":" ","type":"text"},{"text":"way, within the limits of the stack’s size.","type":"text"},{"text":" ","type":"text"},{"text":"OpenSwiftUI sizes a stack that doesn’t contain a spacer up to the combined","type":"text"},{"text":" ","type":"text"},{"text":"ideal widths of the content of the stack’s child views.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The following example provides a simple checklist row to illustrate how you","type":"text"},{"text":" ","type":"text"},{"text":"can use a spacer:","type":"text"}]},{"code":["struct ChecklistRow: View {","    let name: String","","    var body: some View {","        HStack {","            Image(systemName: \"checkmark\")","            Text(name)","        }","        .border(Color.blue)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Adding a spacer before the image creates an adaptive view with no content"},{"type":"text","text":" "},{"type":"text","text":"that expands to push the image and text to the right side of the stack."},{"type":"text","text":" "},{"type":"text","text":"The stack also now expands to take as much space as the parent view allows,"},{"type":"text","text":" "},{"type":"text","text":"shown by the blue border that indicates the boundary of the stack:"}]},{"code":["struct ChecklistRow: View {","    let name: String","","    var body: some View {","        HStack {","            Spacer()","            Image(systemName: \"checkmark\")","            Text(name)","        }","        .border(Color.blue)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"Moving the spacer between the image and the name pushes those elements to","type":"text"},{"text":" ","type":"text"},{"text":"the left and right sides of the ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","type":"reference","isActive":true},{"text":", respectively. Because the stack","type":"text"},{"text":" ","type":"text"},{"text":"contains the spacer, it expands to take as much horizontal space as the","type":"text"},{"text":" ","type":"text"},{"text":"parent view allows; the blue border indicates its size:","type":"text"}]},{"code":["struct ChecklistRow: View {","    let name: String","","    var body: some View {","        HStack {","            Image(systemName: \"checkmark\")","            Spacer()","            Text(name)","        }","        .border(Color.blue)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"Adding two spacer views on the outside of the stack leaves the image and","type":"text"},{"text":" ","type":"text"},{"text":"text together, while the stack expands to take as much horizontal space","type":"text"},{"text":" ","type":"text"},{"text":"as the parent view allows:","type":"text"}]},{"code":["struct ChecklistRow: View {","    let name: String","","    var body: some View {","        HStack {","            Spacer()","            Image(systemName: \"checkmark\")","            Text(name)","            Spacer()","        }","        .border(Color.blue)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[]}],"kind":"content"}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"seeAlsoSections":[{"generated":true,"identifiers":["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Divider"],"anchor":"Separators","title":"Separators"}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Spacer/minLength":{"role":"symbol","fragments":[{"text":"var","kind":"keyword"},{"text":" ","kind":"text"},{"text":"minLength","kind":"identifier"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat","kind":"typeIdentifier"},{"text":"?","kind":"text"}],"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Spacer\/minLength","abstract":[{"text":"The minimum length this spacer can be shrunk to, along the axis or axes","type":"text"},{"text":" ","type":"text"},{"text":"of expansion.","type":"text"}],"url":"\/documentation\/openswiftui\/spacer\/minlength","type":"topic","title":"minLength"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Spacer/init(minLength:)":{"role":"symbol","fragments":[{"text":"init","kind":"identifier"},{"text":"(","kind":"text"},{"text":"minLength","kind":"externalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:14CoreFoundation7CGFloatV","text":"CGFloat","kind":"typeIdentifier"},{"text":"?)","kind":"text"}],"kind":"symbol