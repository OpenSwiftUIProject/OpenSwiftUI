{"abstract":[{"text":"Isolates the geometry (e.g. position and size) of the view","type":"text"},{"text":" ","type":"text"},{"text":"from its parent view.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/RoundedRectangle"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"text":"\n","kind":"text"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"By default OpenSwiftUI views push position and size changes down"},{"type":"text","text":" "},{"type":"text","text":"through the view hierarchy, so that only views that draw"},{"type":"text","text":" "},{"type":"text","text":"something (known as leaf views) apply the current animation to"},{"type":"text","text":" "},{"type":"text","text":"their frame rectangle. However in some cases this coalescing"},{"type":"text","text":" "},{"type":"text","text":"behavior can give undesirable results; inserting a geometry"},{"type":"text","text":" "},{"type":"text","text":"group can correct that. A group acts as a barrier between the"},{"type":"text","text":" "},{"type":"text","text":"parent view and its subviews, forcing the position and size"},{"type":"text","text":" "},{"type":"text","text":"values to be resolved and animated by the parent, before being"},{"type":"text","text":" "},{"type":"text","text":"passed down to each subview."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The example below shows one use of this function: ensuring that"},{"type":"text","text":" "},{"type":"text","text":"the member views of each row in the stack apply (and animate"},{"type":"text","text":" "},{"type":"text","text":"as) a single geometric transform from their ancestor view,"},{"type":"text","text":" "},{"type":"text","text":"rather than letting the effects of the ancestor views be"},{"type":"text","text":" "},{"type":"text","text":"applied separately to each leaf view. If the members of"},{"type":"text","text":" "},{"code":"ItemView","type":"codeVoice"},{"type":"text","text":" may be added and removed at different times the"},{"type":"text","text":" "},{"type":"text","text":"group ensures that they stay locked together as animations are"},{"type":"text","text":" "},{"type":"text","text":"applied."}],"type":"paragraph"},{"code":["VStack {","    ForEach(items) { item in","        ItemView(item: item)","            .geometryGroup()","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Returns: a new view whose geometry is isolated from that of its"},{"type":"text","text":" "},{"type":"text","text":"parent view."}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/RoundedRectangle\/geometryGroup()"},"metadata":{"modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"extendedModule":"OpenSwiftUICore","symbolKind":"method","platforms":[{"name":"iOS","unavailable":false,"introducedAt":"13.0","deprecated":false,"beta":false},{"name":"macOS","unavailable":false,"introducedAt":"10.15","deprecated":false,"beta":false},{"name":"tvOS","unavailable":false,"introducedAt":"13.0","deprecated":false,"beta":false},{"name":"visionOS","unavailable":false,"introducedAt":"1.0","deprecated":false,"beta":false},{"name":"watchOS","unavailable":false,"introducedAt":"6.0","deprecated":false,"beta":false}],"externalID":"s:15OpenSwiftUICore4ViewPAAE13geometryGroupQryF::SYNTHESIZED::s:15OpenSwiftUICore16RoundedRectangleV","roleHeading":"Instance Method","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"geometryGroup"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"}],"remoteSource":{"fileName":"RendererEffect.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Render\/RendererEffect\/RendererEffect.swift#L294"},"title":"geometryGroup()","role":"symbol"},"kind":"symbol","schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"paths":["\/documentation\/openswiftui\/roundedrectangle\/geometrygroup()"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"url":"\/documentation\/openswiftui\/view","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/RoundedRectangle/geometryGroup()":{"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"geometryGroup","kind":"identifier"},{"text":"() -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"}],"type":"topic","kind":"symbol","role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/RoundedRectangle\/geometryGroup()","abstract":[{"type":"text","text":"Isolates the geometry (e.g. position and size) of the view"},{"type":"text","text":" "},{"type":"text","text":"from its parent view."}],"title":"geometryGroup()","url":"\/documentation\/openswiftui\/roundedrectangle\/geometrygroup()"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/RoundedRectangle":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/RoundedRectangle","title":"RoundedRectangle","url":"\/documentation\/openswiftui\/roundedrectangle","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RoundedRectangle","kind":"identifier"}],"abstract":[{"text":"A rectangular shape with rounded corners, aligned inside the frame of the","type":"text"},{"text":" ","type":"text"},{"text":"view containing it.","type":"text"}],"kind":"symbol","role":"symbol","navigatorTitle":[{"text":"RoundedRectangle","kind":"identifier"}],"type":"topic"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}]}}}