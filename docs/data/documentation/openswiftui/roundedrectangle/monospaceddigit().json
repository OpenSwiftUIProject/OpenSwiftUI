aracters proportionally spaced."}],"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["macOS"],"languages":["swift"],"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"monospacedDigit"},{"kind":"text","text":"() -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"},{"kind":"text","text":"\n"}]}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"A view whose child views’ fonts use fixed-width numeric","type":"text"},{"text":" ","type":"text"},{"text":"characters, while leaving other characters proportionally spaced.","type":"text"}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Using fixed-width digits allows you to easily align numbers of the"},{"type":"text","text":" "},{"type":"text","text":"same size in a table-like arrangement. This feature is also known as"},{"type":"text","text":" "},{"type":"text","text":"“tabular figures” or “tabular numbers.”"}],"type":"paragraph"},{"inlineContent":[{"text":"This modifier only affects numeric characters, and leaves all other","type":"text"},{"text":" ","type":"text"},{"text":"characters unchanged.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The following example shows the effect of ","type":"text"},{"code":"monospacedDigit()","type":"codeVoice"},{"text":" on","type":"text"},{"text":" ","type":"text"},{"text":"multiple child views. The example consists of two ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true},{"text":" views","type":"text"},{"text":" ","type":"text"},{"text":"inside an ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","isActive":true},{"text":". Each ","type":"text"},{"code":"VStack","type":"codeVoice"},{"text":" contains two ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button","isActive":true},{"text":" views, with","type":"text"},{"text":" ","type":"text"},{"text":"the second ","type":"text"},{"code":"VStack","type":"codeVoice"},{"text":" applying the ","type":"text"},{"code":"monospacedDigit()","type":"codeVoice"},{"text":" modifier to its","type":"text"},{"text":" ","type":"text"},{"text":"contents. As a result, the digits in the buttons in the trailing","type":"text"},{"text":" ","type":"text"},{"code":"VStack","type":"codeVoice"},{"text":" are the same width, which in turn gives the buttons equal widths.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["var body: some View {","    HStack(alignment: .top) {","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        VStack(alignment: .leading) {","            Button(\"Delete 111 messages\") {}","            Button(\"Delete 222 messages\") {}","        }","        .monospacedDigit()","    }","    .padding()","    .navigationTitle(\"monospacedDigit() Child Views\")","}"],"type":"codeListing"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"If a child view’s base font doesn’t support fixed-width digits, the font","type":"text"},{"text":" ","type":"text"},{"text":"remains unchanged.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View