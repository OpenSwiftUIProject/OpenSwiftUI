enSwiftUI\/RoundedRectangle"]]},"sections":[],"abstract":[{"text":"Applies the given transaction mutation function to all animations used","type":"text"},{"text":" ","type":"text"},{"text":"within the view.","type":"text"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"transaction"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"transform"},{"kind":"text","text":": "},{"kind":"keyword","text":"@escaping"},{"kind":"text","text":" ("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Transaction","kind":"typeIdentifier","text":"Transaction","preciseIdentifier":"s:15OpenSwiftUICore11TransactionV"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","kind":"typeIdentifier","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"transform","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The transformation to apply to transactions"},{"type":"text","text":" "},{"type":"text","text":"within this view."}]}]}]},{"kind":"content","content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that wraps this view and applies a transformation to"},{"type":"text","text":" "},{"type":"text","text":"all transactions used within the view."}]}]},{"kind":"content","content":[{"type":"heading","level":2,"text":"Discussion","anchor":"discussion"},{"inlineContent":[{"type":"text","text":"Use this modifier to change or replace the animation used in a view."},{"type":"text","text":" "},{"type":"text","text":"Consider three identical animations controlled by a"},{"type":"text","text":" "},{"type":"text","text":"button that executes all three animations simultaneously:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"The first animation rotates the “Rotation” ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view by 360","type":"text"},{"text":" ","type":"text"},{"text":"degrees.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The second uses the "},{"type":"codeVoice","code":"transaction(_:)"},{"type":"text","text":" modifier to change the"},{"type":"text","text":" "},{"type":"text","text":"animation by adding a delay to the start of the animation"},{"type":"text","text":" "},{"type":"text","text":"by two seconds and then increases the rotational speed of the"},{"type":"text","text":" "},{"type":"text","text":"“Rotation\\nModified” "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" view animation by a factor of 2."}]}]},{"content":[{"inlineContent":[{"text":"The third animation uses the ","type":"text"},{"type":"codeVoice","code":"transaction(_:)"},{"type":"text","text":" modifier to"},{"type":"text","text":" "},{"type":"text","text":"replace the rotation animation affecting the “Animation\\nReplaced”"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" view with a spring animation."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The following code implements these animations:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct TransactionExample: View {","    @State private var flag = false","","    var body: some View {","        VStack(spacing: 50) {","            HStack(spacing: 30) {","                Text(\"Rotation\")","                    .rotationEffect(Angle(degrees:","                                            self.flag ? 360 : 0))","","                Text(\"Rotation\\nModified\")","                    .rotationEffect(Angle(degrees:","                                            self.flag ? 360 : 0))","                    .transaction { view in","                        view.animation =","                            view.animation?.delay(2.0).speed(2)","                    }","","                Text(\"Animation\\nReplaced\")","                    .rotationEffect(Angle(degrees:","                                            self.flag ? 360 : 0))","                    .transaction { view in","                        view.animation = .interactiveSpring(","                            response: 0.60,","                            dampingFraction: 0.20,","                            blendDuration: 0.25)","                    }","            }","","            Button(\"Animate\") {","                withAnimation(.easeIn(duration: 2.0)) {","                    self.flag.toggle()","                }","            }","        }","    }","}"]},{"inlineContent":[{"text":"Use this modifier on leaf views such as ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image","type":"reference"},{"text":" or ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button","type":"reference"},{"text":" rather","type":"text"},{"text":" ","type":"text"},{"text":"than container views such as ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"reference"},{"text":" or ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack","type":"reference"},{"text":". The","type":"text"},{"text":" ","type":"text"},{"text":"transformation applies to all child views within this view; calling","type":"text"},{"text":" ","type":"text"},{"code":"transaction(_:)","type":"codeVoice"},{"text":" on a container view can lead to unbounded scope of","type":"text"},{"text":" ","type":"text"},{"text":"execution depending on the depth of the view hierarchy.","type":"text"}],"type":"paragraph"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","abstract":[{"type":"text","text":"Declare the user interface and behavior for your app on every platform."}],"url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","role":"collection"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"url":"\/documentation\/openswiftui\/view","kind":"symbol","role":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"type":"topic","title":"View","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/RoundedRectangle/transaction(_:)":{"url":"\/documentation\/openswiftui\/roundedrectangle\/transaction(_:)","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"transaction"},{"kind":"text","text":"(("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"kind":"typeIdentifier","preciseIdentifier":"s:15OpenSwiftUICore11TransactionV","text":"Transact