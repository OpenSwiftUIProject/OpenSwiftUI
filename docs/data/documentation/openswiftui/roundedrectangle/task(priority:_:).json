ext"},{"text":"the view appears.","type":"text"}]}]},{"kind":"content","content":[{"level":2,"anchor":"discussion","text":"Discussion","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier to perform an asynchronous task with a lifetime that"},{"type":"text","text":" "},{"type":"text","text":"matches that of the modified view. If the task doesn’t finish"},{"type":"text","text":" "},{"type":"text","text":"before OpenSwiftUI removes the view or the view changes identity, OpenSwiftUI"},{"type":"text","text":" "},{"type":"text","text":"cancels the task."}]},{"type":"paragraph","inlineContent":[{"text":"Use the ","type":"text"},{"code":"await","type":"codeVoice"},{"text":" keyword inside the task to","type":"text"},{"text":" ","type":"text"},{"text":"wait for an asynchronous call to complete, or to wait on the values of","type":"text"},{"text":" ","type":"text"},{"text":"an ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/asyncsequence","isActive":true,"type":"reference"},{"text":" ","type":"text"},{"text":"instance. For example, you can modify a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view to start a task","type":"text"},{"text":" ","type":"text"},{"text":"that loads content from a remote resource:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["let url = URL(string: \"https:\/\/example.com\")!","@State private var message = \"Loading...\"","","var body: some View {","    Text(message)","        .task {","            do {","                var receivedLines = [String]()","                for try await line in url.lines {","                    receivedLines.append(line)","                    message = \"Received \\(receivedLines.count) lines\"","                }","            } catch {","                message = \"Failed to load\"","            }","        }","}"]},{"type":"paragraph","inlineContent":[{"text":"This example uses the","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url\/3767315-lines","type":"reference"},{"text":" ","type":"text"},{"text":"method to get the content stored at the specified","type":"text"},{"text":" ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url","type":"reference"},{"text":" as an","type":"text"},{"text":" ","type":"text"},{"text":"asynchronous sequence of strings. When each new line arrives, the body","type":"text"},{"text":" ","type":"text"},{"text":"of the ","type":"text"},{"code":"for","type":"codeVoice"},{"text":"-","type":"text"},{"code":"await","type":"codeVoice"},{"text":"-","type":"text"},{"code":"in","type":"codeVoice"},{"text":" loop stores the line in an array of strings","type":"text"},{"text":" ","type":"text"},{"text":"and updates the content of the text view to report the latest line","type":"text"},{"text":" ","type":"text"},{"text":"count.","type":"text"}]}]}],"abstract":[{"type":"text","text":"Adds an asynchronous task to perform before this view appears."}],"kind":"symbol","identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/RoundedRectangle\/task(priority:_:)","interfaceLanguage":"swift"},"sections":[],"schemaVersion":{"patch":0,"minor":3,"major":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/RoundedRectangle"]]},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/RoundedRectangle":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/RoundedRectangle","title":"RoundedRectangle","url":"\/documentation\/openswiftui\/roundedrectangle","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"RoundedRectangle","kind":"identifier"}],"abstract":[{"text":"A rectangular shape with rounded corners, aligned inside the fram