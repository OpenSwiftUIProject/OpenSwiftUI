n the"},{"type":"text","text":" "},{"type":"text","text":"group is shrunk and stretch sooner when the group is stretched."}]},{"type":"codeListing","syntax":"swift","code":["HStack {","    Text(\"This is a moderately long string.\")","        .font(.largeTitle)","        .border(Color.gray)","","    Spacer()","","    Text(\"This is a higher priority string.\")","        .font(.largeTitle)","        .layoutPriority(1)","        .border(Color.gray)","}"]},{"type":"paragraph","inlineContent":[{"text":"In the example above, the first ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" element has the default","type":"text"},{"text":" ","type":"text"},{"text":"priority ","type":"text"},{"code":"0","type":"codeVoice"},{"text":" which causes its view to shrink dramatically due to the","type":"text"},{"text":" ","type":"text"},{"text":"higher priority of the second ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" element, even though all of their","type":"text"},{"text":" ","type":"text"},{"text":"other attributes (font, font size and character count) are the same.","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A parent layout offers the child views with the highest layout priority"},{"type":"text","text":" "},{"type":"text","text":"all the space offered to the parent minus the minimum space required for"},{"type":"text","text":" "},{"type":"text","text":"all its lower-priority children."}]}],"kind":"content"}],"metadata":{"title":"layoutPriority(_:)","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"role":"symbol","externalID":"s:15OpenSwiftUICore4ViewPAAE14layoutPriorityyQrSdF::SYNTHESIZED::s:15OpenSwiftUICore16RoundedRectangleV","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"layoutP