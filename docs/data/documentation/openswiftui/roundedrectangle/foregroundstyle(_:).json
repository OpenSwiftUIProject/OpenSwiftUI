{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/RoundedRectangle"]]},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"foregroundStyle","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"style","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"},{"text":" ","kind":"text"},{"text":"where","kind":"keyword"},{"text":" ","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":" : ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle","text":"ShapeStyle","preciseIdentifier":"s:15OpenSwiftUICore10ShapeStyleP","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The color or pattern to use when filling in the","type":"text"},{"text":" ","type":"text"},{"text":"foreground elements. To indicate a specific value, use ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","isActive":true,"type":"reference"},{"text":" or","type":"text"},{"text":" ","type":"text"},{"code":"ShapeStyle\/image(_:sourceRect:scale:)","type":"codeVoice"},{"text":", or one of the gradient","type":"text"},{"text":" ","type":"text"},{"text":"types, like","type":"text"},{"text":" ","type":"text"},{"code":"ShapeStyle\/linearGradient(colors:startPoint:endPoint:)","type":"codeVoice"},{"text":". To set a","type":"text"},{"text":" ","type":"text"},{"text":"style that’s relative to the containing view’s style, use one of the","type":"text"},{"text":" ","type":"text"},{"text":"semantic styles, like ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/primary","isActive":true,"type":"reference"},{"text":".","type":"text"}]}],"name":"style"}]},{"kind":"content","content":[{"level":2,"anchor":"return-value","type":"heading","text":"Return Value"},{"inlineContent":[{"type":"text","text":"A view that uses the given foreground style."}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this method to style"},{"type":"text","text":" "},{"type":"text","text":"foreground content like text, shapes, and template images"},{"type":"text","text":" "},{"type":"text","text":"(including symbols):"}]},{"syntax":"swift","type":"codeListing","code":["HStack {","    Image(systemName: \"triangle.fill\")","    Text(\"Hello, world!\")","    RoundedRectangle(cornerRadius: 5)","        .frame(width: 40, height: 20)","}",".foregroundStyle(.teal)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example above creates a row of "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/teal","type":"reference","isActive":true},{"type":"text","text":" foreground"},{"type":"text","text":" "},{"type":"text","text":"elements:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can use any style that conforms to the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle"},{"type":"text","text":" protocol,"},{"type":"text","text":" "},{"type":"text","text":"like the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/teal"},{"type":"text","text":" color in the example above, or the"},{"type":"text","text":" "},{"code":"ShapeStyle\/linearGradient(colors:startPoint:endPoint:)","type":"codeVoice"},{"type":"text","text":" gradient"},{"type":"text","text":" "},{"type":"text","text":"shown below:"}]},{"syntax":"swift","type":"codeListing","code":["Text(\"Gradient Text\")","    .font(.largeTitle)","    .foregroundStyle(","        .linearGradient(","            colors: [.yellow, .blue],","            startPoint: .top,","            endPoint: .bottom","        )","    )"]},{"type":"paragraph","inlineContent":[]},{"name":"Tip","type":"aside","style":"tip","content":[{"inlineContent":[{"text":"If you want to fill a single ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape","type":"reference"},{"text":" instance with a style,","type":"text"},{"text":" ","type":"text"},{"text":"use the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Shape\/fill(style:)","type":"reference"},{"text":" shape modifier instead because it’s more","type":"text"},{"text":" ","type":"text"},{"text":"efficient.","type":"text"}],"type":"paragraph"}]},{"type":"paragraph","inlineContent":[{"text":"OpenSwiftUI creates a context-dependent render for a given style.","type":"text"},{"text":" ","type":"text"},{"text":"For example, a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","isActive":true,"type":"reference"},{"text":" that you load from an asset catalog","type":"text"},{"text":" ","type":"text"},{"text":"can have different light and dark appearances, while some styles","type":"text"},{"text":" ","type":"text"},{"text":"also vary by platform.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Hierarchical foreground styles like "},{"type":"codeVoice","code":"ShapeStyle\/secondary"},{"type":"text","text":" "},{"type":"text","text":"don’t impose a style of their own, but instead modify other styles."},{"type":"text","text":" "},{"type":"text","text":"In particular, they modify the primary"},{"type":"text","text":" "},{"type":"text","text":"level of the current foreground style to the degree given by"},{"type":"text","text":" "},{"type":"text","text":"the hierarchical style’s name."},{"type":"text","text":" "},{"type":"text","text":"To find the current foreground style to modify, OpenSwiftUI looks for"},{"type":"text","text":" "},{"type":"text","text":"the innermost containing style that you apply with the"},{"type":"text","text":" "},{"type":"codeVoice","code":"foregroundStyle(_:)"},{"type":"text","text":" or the "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/foregroundColor(_:)"},{"type":"text","text":" modifier."},{"type":"text","text":" "},{"type":"text","text":"If you haven’t specified a style, OpenSwiftUI uses the default foreground"},{"type":"text","text":" "},{"type":"text","text":"style, as in the following example:"}]},{"syntax":"swift","type":"codeListing","code":["VStack(alignment: .leading) {","    Label(\"Primary\", systemImage: \"1.square.fill\")","    Label(\"Secondary\", systemImage: \"2.square.fill\")","        .foregroundStyle(.secondary)","}"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you add a foreground style on the enclosing"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true,"type":"reference"},{"type":"text","text":", the hierarchical styling responds accordingly:"}]},{"syntax":"swift","type":"codeListing","code":["VStack(alignment: .leading) {","    Label(\"Primary\", systemImage: \"1.square.fill\")","    Label(\"Secondary\", systemImage: \"2.square.fill\")","        .foregroundStyle(.secondary)","}",".foregroundStyle(.blue)"]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"text":"When you apply a custom style to a view, the view disables the vibrancy","type":"text"},{"text":" ","type":"text"},{"text":"effect for foreground elements in that view, or in any of its child","type":"text"},{"text":" ","type":"text"},{"text":"views, that it would otherwise gain from adding a background material","type":"text"},{"text":" ","type":"text"},{"text":"— for example, using the ","type":"text"},{"code":"View\/background(_:ignoresSafeAreaEdges:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"modifier. However, hierarchical styles applied to the default foreground","type":"text"},{"text":" ","type":"text"},{"text":"don’t disable vibrancy.","type":"text"}]}]}],"metadata":{"extendedModule":"OpenSwiftUICore","role":"symbol","title":"foregroundStyle(_:)","roleHeading":"Instance Method","platforms":[{"unavailable":false,"name":"iOS","introducedAt":"13.0","deprecated":false,"beta":false},{"unavailable":false,"name":"macOS","introducedAt":"10.15","deprecated":false,"beta":false},{"unavailable":false,"name":"tvOS","introducedAt":"13.0","deprecated":false,"beta":false},{"unavailable":false,"name":"visionOS","introducedAt":"1.0","deprecated":false,"beta":false},{"unavailable":false,"name":"watchOS","introducedAt":"6.0","deprecated":false,"beta":false}],"externalID":"s:15OpenSwiftUICore4ViewPAAE15foregroundStyleyQrqd__AA05ShapeF0Rd__lF::SYNTHESIZED::s:15OpenSwiftUICore16RoundedRectangleV","modules":[{"name":"OpenSwiftUI","relatedModules":["OpenSwiftUICore"]}],"fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"foregroundStyle","kind":"identifier"},{"text":"<","kind":"text"},{"text":"S","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"S","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"typeIdentifier","precise