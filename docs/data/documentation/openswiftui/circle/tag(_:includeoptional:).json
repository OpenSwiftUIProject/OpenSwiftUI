content"},{"content":[{"type":"heading","text":"Discussion","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Use this modifier to differentiate among certain selectable views,","type":"text"},{"text":" ","type":"text"},{"text":"like the possible values of a ","type":"text"},{"type":"codeVoice","code":"Picker"},{"text":" or the tabs of a ","type":"text"},{"type":"codeVoice","code":"TabView"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Tag values can be of any type that conforms to the","type":"text"},{"text":" ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/hashable","isActive":true,"type":"reference"},{"text":" protocol.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This modifier will write the tag value for the type "},{"type":"codeVoice","code":"V"},{"type":"text","text":", as well as"},{"type":"text","text":" "},{"type":"codeVoice","code":"Optional<V>"},{"type":"text","text":" if "},{"type":"codeVoice","code":"includeOptional"},{"type":"text","text":" is enabled. Containers checking for"},{"type":"text","text":" "},{"type":"text","text":"tags of either type will see the value as set."}],"type":"paragraph"},{"inlineContent":[{"text":"In the example below, the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach","type":"reference"},{"text":" loop in the ","type":"text"},{"code":"Picker","type":"codeVoice"},{"text":" view","type":"text"},{"text":" ","type":"text"},{"text":"builder iterates over the ","type":"text"},{"code":"Flavor","type":"codeVoice"},{"text":" enumeration. It extracts the string","type":"text"},{"text":" ","type":"text"},{"text":"value of each enumeration element for use in constructing the row","type":"text"},{"text":" ","type":"text"},{"text":"label, and uses the enumeration value as input to the ","type":"text"},{"code":"tag(_:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"modifier.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["struct FlavorPicker: View {","    enum Flavor: String, CaseIterable, Identifiable {","        case chocolate, vanilla, strawberry","        var id: Self { self }","    }","","    @State private var selectedFlavor: Flavor? = nil","","    var body: some View {","        Picker(\"Flavor\", selection: $selectedFlavor) {","            ForEach(Flavor.allCases) { flavor in","                Text(flavor.rawValue)","                    .tag(flavor)","            }","        }","    }","}"]},{"inlineContent":[{"text":"The selection type of the ","type":"text"},{"code":"Picker","type":"codeVoice"},{"text":" is an ","type":"text"},{"code":"Optional<Flavor>","type":"codeVoice"},{"text":" and so it","type":"text"},{"text":" ","type":"text"},{"text":"will look for tags on its contents of ","type":"text"},{"code":"Optional<Flavor>","type":"codeVoice"},{"text":"type. Since the","type":"text"},{"text":" ","type":"text"},{"text":"tag modifier defaults to having ","type":"text"},{"code":"includeOptional","type":"codeVoice"},{"text":" enabled, even though","type":"text"},{"text":" ","type":"text"},{"text":"the tag for each option is a non-optional ","type":"text"},{"code":"Flavor","type":"codeVoice"},{"text":", the tag modifier","type":"text"},{"text":" ","type":"text"},{"text":"writes values for both the non-optional, and optional versions of the","type":"text"},{"text":" ","type":"text"},{"text":"value, allowing the contents to be selectable by the ","type":"text"},{"code":"Picker","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"A ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ForEach","type":"reference","isActive":true},{"text":" automatically applies a default tag to each enumerated","type":"text"},{"text":" ","type":"text"},{"text":"view using the ","type":"text"},{"code":"id","type":"codeVoice"},{"text":" parameter of 