:true,"type":"reference"},{"text":":","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["HStack {","    Toggle(isOn: $isFlagged) {","        Label(\"Flag\", systemImage: \"flag.fill\")","    }","    Toggle(isOn: $isMuted) {","        Label(\"Mute\", systemImage: \"speaker.slash.fill\")","    }","}",".toggleStyle(.button)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The example above has the following appearance when "},{"code":"isFlagged","type":"codeVoice"},{"type":"text","text":" is"},{"type":"text","text":" "},{"code":"true","type":"codeVoice"},{"type":"text","text":" and "},{"code":"isMuted","type":"codeVoice"},{"type":"text","text":" is "},{"code":"false","type":"codeVoice"},{"type":"text","text":":"}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Appearance","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"iOS, iPadOS","type":"text"}]}],[{"type":"paragraph","inlineContent":[]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"macOS"}]}],[{"type":"paragraph","inlineContent":[]}]]],"header":"row","type":"table"},{"text":"Automatic styling","anchor":"Automatic-styling","level":3,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"If you don’t set a style, OpenSwiftUI assumes a value of","type":"text"},{"text":" ","type":"text"},{"type":"codeVoice","code":"ToggleStyle\/automatic"},{"text":", which corresponds to a context-specific","type":"text"},{"text":" ","type":"text"},{"text":"default. Specify the automatic style explicitly to override a","type":"text"},{"text":" ","type":"text"},{"text":"container’s style and revert to the default:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["HStack {","    Toggle(isOn: $isShuffling) {","        Label(\"Shuffle\", systemImage: \"shuffle\")","    }","    Toggle(isOn: $isRepeating) {","        Label(\"Repeat\", systemImage: \"repeat\")","    }","