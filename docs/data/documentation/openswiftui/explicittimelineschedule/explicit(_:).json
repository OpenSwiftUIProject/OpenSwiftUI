ns"},{"parameters":[{"content":[{"type":"paragraph","inlineContent":[{"text":"The sequence of dates at which a timeline view","type":"text"},{"text":" ","type":"text"},{"text":"updates. Use a monotonically increasing sequence of dates,","type":"text"},{"text":" ","type":"text"},{"text":"and ensure that at least one is in the future.","type":"text"}]}],"name":"dates"}],"kind":"parameters"},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Initialize a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView","type":"reference"},{"text":" with an explicit timeline schedule when","type":"text"},{"text":" ","type":"text"},{"text":"you want to schedule view updates at particular points in time:","type":"text"}]},{"syntax":"swift","code":["let dates = [","    Date(timeIntervalSinceNow: 10), \/\/ Update ten seconds from now,","    Date(timeIntervalSinceNow: 12) \/\/ and a few seconds later.","]","","struct MyView: View {","    var body: some View {","        TimelineView(.explicit(dates)) { context in","            Text(context.date.description)","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The timeline view updates its content on exactly the dates that"},{"type":"text","text":" "},{"type":"text","text":"you specify, until it runs out of dates, after which it stops changing."},{"type":"text","text":" "},{"type":"text","text":"If the dates you provide are in the past, the timeline view updates"},{"type":"text","text":" "},{"type":"text","text":"exactly once with the last entry. If you only provide dates in the"},{"type":"text","text":" "},{"type":"text","text":"future, the timeline view renders with the current date until the first"},{"type":"text","text":" "},{"type":"text","text":"date arrives. If you provide one or more dates in the past and one or"},{"type":"text","text":" "},{"type":"text","text":"more in the future, the view renders the most recent past date,"},{"type":"text","text":" "},{"type":"text","text":"refreshing normally on all subsequent dates."}]}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/ExplicitTimelineSchedule/explicit(_:)":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ExplicitTimelineSchedule\/explicit(_:)","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"explicit"},{"kind":"text","text":"<"},{"kind":"genericParameter","text":"S"},{"kind":"text","text":">("},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:15OpenSwiftUICore24ExplicitTimelineScheduleV","kind":"typeIdentifier","text":"ExplicitTimelineSchedule"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"S"},{"kind":"text","text":">"}],"title":"explicit(_:)","kind":"symbol","url":"\/documentation\/openswiftui\/explicittimelineschedule\/explicit(_:)","abstract":[{"text":"A schedule for updating a timeline view at explicit points in time.","type":"text"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/ExplicitTimelineSchedule":{"title":"ExplicitTimelineSchedule","type":"topic","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ExplicitTimelineSchedule","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ExplicitTimelineSchedule","kind":"identifier"}],"abstract":[{"text":"A schedule for updating a timeline view at explicit points in time.","type":"text"}],"role":"symbol","navigatorTitle":[{"text":"ExplicitTimelineSchedule","kind":"identifier"}],"url":"\/documentation\/openswiftui\/explicittimelineschedule","kind":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","role":"collection","url":"\/documentation\/openswiftui","type":"topic","title":"OpenSwiftUI","ide