t"}]}],"name":"dates"}]},{"kind":"content","content":[{"text":"Discussion","type":"heading","anchor":"discussion","level":2},{"type":"paragraph","inlineContent":[{"text":"Initialize a ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/TimelineView"},{"text":" with an explicit timeline schedule when","type":"text"},{"text":" ","type":"text"},{"text":"you want to schedule view updates at particular points in time:","type":"text"}]},{"syntax":"swift","code":["let dates = [","    Date(timeIntervalSinceNow: 10), \/\/ Update ten seconds from now,","    Date(timeIntervalSinceNow: 12) \/\/ and a few seconds later.","]","","struct MyView: View {","    var body: some View {","        TimelineView(.explicit(dates)) { context in","            Text(context.date.description)","        }","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The timeline view updates its content on exactly the dates that"},{"type":"text","text":" "},{"type":"text","text":"you specify, until it runs out of dates, after which it stops changing."},{"type":"text","text":" "},{"type":"text","text":"If the dates you provide are in the past, the timeline view updates"},{"type":"text","text":" "},{"type":"text","text":"exactly once with the last entry. If you only provide dates in the"},{"type":"text","text":" "},{"type":"text","text":"future, the timeline view renders with the current date until the first"},{"type":"text","text":" "},{"type":"text","text":"date arrives. If you provide one or more dates in the past and one or"},{"type":"text","text":" "},{"type":"text","text":"more in the future, the view renders the most recent past date,"},{"type":"text","text":" "},{"type":"text","text":"refreshing normally on all subsequent dates."}]}]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"variants":[{"paths":["\/documentation\/openswiftui\/explicittimelineschedule\/explicit(_:)"],"traits":[{"interfac