the view whenever ","type":"text"},{"code":"value","type":"codeVoice"},{"text":" changes.","type":"text"}],"type":"paragraph"}],"kind":"content"},{"content":[{"type":"heading","anchor":"discussion","level":2,"text":"Discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this modifier to change or replace the animation used in a view.","type":"text"},{"text":" ","type":"text"},{"text":"Consider three identical views controlled by a","type":"text"},{"text":" ","type":"text"},{"text":"button that changes all three simultaneously:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"The first view animates rotating the “Rotation” ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference"},{"text":" view by 360","type":"text"},{"text":" ","type":"text"},{"text":"degrees.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The second uses the ","type":"text"},{"type":"codeVoice","code":"transaction(_:)"},{"text":" modifier to change the","type":"text"},{"text":" ","type":"text"},{"text":"animation by adding a delay to the start of the animation","type":"text"},{"text":" ","type":"text"},{"text":"by two seconds and then increases the rotational speed of the","type":"text"},{"text":" ","type":"text"},{"text":"“Rotation\\nModified” ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"text":" view animation by a factor of 2.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"The third uses the ","type":"text"},{"code":"transaction(_:)","type":"codeVoice"},{"text":" modifier to disable animations","type":"text"},{"text":" ","type":"text"},{"text":"affecting the “Animation\\nReplaced” ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"text":"The following code implements these animations:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct TransactionExample: View {","    @State var flag = false","","    var body: some View {","        VStack(spacing: 50) {","            HStack(spacing: 30) {","                Text(\"Rotation\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","","                Text(\"Rotation\\nModified\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","                    .transaction(value: flag) { t in","                        t.animation =","                            t.animation?.delay(2.0).speed(2)","                    }","","                Text(\"Animation\\nReplaced\")","                    .rotationEffect(Angle(degrees: flag ? 360 : 0))","                    .transaction(value: flag) { t in","                        t.disableAnimations = true","                    }","            }","","            Button(\"Animate\") {","                withAnimation(.easeIn(duration: 2.0)) {","                    flag.toggle()","                }","            }","        }","    }","}"]}],"kind":"content"}],"abstract":[{"text":"Applies the given transaction mutation function to all animations used","type":"text"},{"text":" ","type":"text"},{"text":"within the view.","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/labeledcontent\/transaction(value:_:)"]}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent\/transaction(value:_:)","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent"]]},"sections":[],"kind":"symbol","metadata":{"role":"symbol","extendedModule":"OpenSwiftUICore","platforms":[{"beta":false,"unava