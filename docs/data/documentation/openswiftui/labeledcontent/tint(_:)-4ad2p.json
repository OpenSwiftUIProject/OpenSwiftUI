inlineContent":[{"text":"This example shows a linear gauge tinted with a","type":"text"},{"text":" ","type":"text"},{"text":"gradient from ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/blue","type":"reference"},{"text":" to ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/red","type":"reference"},{"text":".","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct ControlTint: View {","    var body: some View {","        Gauge(value: 75, in: 0...100) {","            Text(\"Temperature\")","        }","        .gaugeStyle(.linearCapacity)","        .tint(Gradient(colors: [.blue, .orange, .red]))","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some controls adapt to the tint color differently based on their style,"},{"type":"text","text":" "},{"type":"text","text":"the current platform, and the surrounding context. For example, in"},{"type":"text","text":" "},{"type":"text","text":"macOS, a button with the "},{"type":"codeVoice","code":"PrimitiveButtonStyle\/bordered"},{"type":"text","text":" style doesn’t"},{"type":"text","text":" "},{"type":"text","text":"tint its background, but one with the"},{"type":"text","text":" "},{"type":"codeVoice","code":"PrimitiveButtonStyle\/borderedProminent"},{"type":"text","text":" style does. In macOS, neither"},{"type":"text","text":" "},{"type":"text","text":"of these button styles tint their label, but they do in other platforms."}]}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/labeledcontent\/tint(_:)-4ad2p"]}],"kind":"symbol","sections":[],"abstract":[{"text":"Sets the tint within this view.","type":"text"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent\/tint(_:)-4ad2p"},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/LabeledContent":{"url