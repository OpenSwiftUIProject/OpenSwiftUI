":"text","text":"The example below shows the effects of applying fonts to individual"},{"type":"text","text":" "},{"type":"text","text":"views and to view hierarchies. Font information flows down the view"},{"type":"text","text":" "},{"type":"text","text":"hierarchy as part of the environment, and remains in effect unless"},{"type":"text","text":" "},{"type":"text","text":"overridden at the level of an individual view or view container."}],"type":"paragraph"},{"inlineContent":[{"text":"Here, the outermost ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true,"type":"reference"},{"text":" applies a 16-point system font as a","type":"text"},{"text":" ","type":"text"},{"text":"default font to views contained in that ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","isActive":true,"type":"reference"},{"text":". Inside that stack,","type":"text"},{"text":" ","type":"text"},{"text":"the example applies a ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Font\/largeTitle","isActive":true,"type":"reference"},{"text":" font to just the first text","type":"text"},{"text":" ","type":"text"},{"text":"view; this explicitly overrides the default. The remaining stack and the","type":"text"},{"text":" ","type":"text"},{"text":"views contained with it continue to use the 16-point system font set by","type":"text"},{"text":" ","type":"text"},{"text":"their containing view:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["VStack {","    Text(\"Font applied to a text view.\")","        .font(.largeTitle)","","    VStack {","        Text(\"These 2 text views have the same font\")","        Text(\"applied to their parent hierarchy\")","    }","}",".font(.system(size: 16, weight: .light, design: .default))"]},{"inlineContent":[],"type":"paragraph"}],"kind":"content"}],"metadata":{"remoteSource":{"fileName":"EnvironmentAdditions.swift