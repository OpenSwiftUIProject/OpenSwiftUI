{"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Link\/transaction(_:)","interfaceLanguage":"swift"},"kind":"symbol","metadata":{"externalID":"s:15OpenSwiftUICore4ViewPAAE11transactionyQryAA11TransactionVzcF::SYNTHESIZED::s:11OpenSwiftUI4LinkV","extendedModule":"OpenSwiftUICore","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"transaction"},{"kind":"text","text":"(("},{"kind":"keyword","text":"inout"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore11TransactionV","kind":"typeIdentifier","text":"Transaction"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:s4Voida","kind":"typeIdentifier","text":"Void"},{"kind":"text","text":") -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier","text":"View"}],"role":"symbol","remoteSource":{"fileName":"TransactionModifier.swift","url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUICore\/Animation\/Transaction\/TransactionModifier.swift#L84"},"modules":[{"relatedModules":["OpenSwiftUICore"],"name":"OpenSwiftUI"}],"title":"transaction(_:)","platforms":[{"deprecated":false,"name":"iOS","introducedAt":"13.0","beta":false,"unavailable":false},{"deprecated":false,"name":"macOS","introducedAt":"10.15","beta":false,"unavailable":false},{"deprecated":false,"name":"tvOS","introducedAt":"13.0","beta":false,"unavailable":false},{"deprecated":false,"name":"visionOS","introducedAt":"1.0","beta":false,"unavailable":false},{"deprecated":false,"name":"watchOS","introducedAt":"6.0","beta":false,"unavailable":false}],"symbolKind":"method","roleHeading":"Instance Method"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"transaction","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"transform","kind":"internalParam"},{"text":": ","kind":"text"},{"text":"@escaping","kind":"keyword"},{"text":" (","kind":"text"},{"text":"inout","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Transaction","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Transaction","preciseIdentifier":"s:15OpenSwiftUICore11TransactionV","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Void","preciseIdentifier":"s:s4Voida","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"},{"text":"\n","kind":"text"}]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"The transformation to apply to transactions"},{"type":"text","text":" "},{"type":"text","text":"within this view."}],"type":"paragraph"}],"name":"transform"}]},{"kind":"content","content":[{"level":2,"type":"heading","anchor":"return-value","text":"Return Value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that wraps this view and applies a transformation to"},{"type":"text","text":" "},{"type":"text","text":"all transactions used within the view."}]}]},{"kind":"content","content":[{"anchor":"discussion","type":"heading","level":2,"text":"Discussion"},{"inlineContent":[{"type":"text","text":"Use this modifier to change or replace the animation used in a view."},{"type":"text","text":" "},{"type":"text","text":"Consider three identical animations controlled by a"},{"type":"text","text":" "},{"type":"text","text":"button that executes all three animations simultaneously:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The first animation rotates the “Rotation” "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" view by 360"},{"type":"text","text":" "},{"type":"text","text":"degrees."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"The second uses the "},{"type":"codeVoice","code":"transaction(_:)"},{"type":"text","text":" modifier to change the"},{"type":"text","text":" "},{"type":"text","text":"animation by adding a delay to the start of the animation"},{"type":"text","text":" "},{"type":"text","text":"by two seconds and then increases the rotational speed of the"},{"type":"text","text":" "},{"type":"text","text":"“Rotation\\nModified” "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text"},{"type":"text","text":" view animation by a factor of 2."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"The third animation uses the ","type":"text"},{"code":"transaction(_:)","type":"codeVoice"},{"text":" modifier to","type":"text"},{"text":" ","type":"text"},{"text":"replace the rotation animation affecting the “Animation\\nReplaced”","type":"text"},{"text":" ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true,"type":"reference"},{"text":" view with a spring animation.","type":"text"}]}]}]},{"inlineContent":[{"type":"text","text":"The following code implements these animations:"}],"type":"paragraph"},{"type":"codeListing","code":["struct TransactionExample: View {","    @State private var flag = false","","    var body: some View {","        VStack(spacing: 50) {","            HStack(spacing: 30) {","                Text(\"Rotation\")","                    .rotationEffect(Angle(degrees:","                                            self.flag ? 360 : 0))","","                Text(\"Rotation\\nModified\")","                    .rotationEffect(Angle(degrees:","                                            self.flag ? 360 : 0))","                    .transaction { view in","                        view.animation =","                            view.animation?.delay(2.0).speed(2)","                    }","","                Text(\"Animation\\nReplaced\")","                    .rotationEffect(Angle(degrees:","                                            self.flag ? 360 : 0))","                    .transaction { view in","                        view.animation = .interactiveSpring(","                            response: 0.60,","                            dampingFraction: 0.20,","                            blendDuration: 0.25)","                    }","            }","","            Button(\"Animate\") {","                withAnimation(.easeIn(duration: 2.0)) {","                    self.flag.toggle()","                }","            }","        }","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Use this modifier on leaf views such as "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Image"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button"},{"type":"text","text":" rather"},{"type":"text","text":" "},{"type":"text","text":"than container views such as "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"type":"text","text":" or "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/HStack"},{"type":"text","text":". The"},{"type":"text","text":" "},{"type":"text","text":"transformation applies to all child views within this view; calling"},{"type":"text","text":" "},{"code":"transaction(_:)","type":"codeVoice"},{"type":"text","text":" on a container view can lead to unbounded scope of"},{"type":"text","text":" "},{"type":"text","text":"execution depending on the depth of the view hierarchy."}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/link\/transaction(_:)"]}],"abstract":[{"type":"text","text":"Applies the given transaction mutation function to all animations used"},{"type":"text","text":" "},{"type":"text","text":"within the view."}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Link"]]},"sections":[],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/VStack":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack","type":"topic","role":"symbol","abstract":[{"type":"text","text":"A view that arranges its subviews in a vertical line."}],"fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"VStack"}],"url":"\/documentation\/openswiftui\/vstack","title":"VStack","navigatorTitle":[{"kind":"identifier","text":"VStack"}],"kind":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Link":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Link","role":"symbol","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Link","kind":"identifier"}],"url":"\/documentation\/openswiftui\/link","title":"Link","navigatorTitle":[{"text":"Link","kind":"identifier"}],"abstract":[{"type":"text","text":"A control for navigating to a URL."}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Text":{"url":"\/documentation\/openswiftui\/text","type":"topic","navigatorTitle":[{"kind":"identifier","text":"Text"}],"title":"Text","abstract":[],"role":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"Text"}],"kind":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI":{"kind":"symbol","