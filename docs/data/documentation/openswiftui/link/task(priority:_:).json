ntent":[{"text":"Return Value","type":"heading","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A view that runs the specified action asynchronously before"},{"type":"text","text":" "},{"type":"text","text":"the view appears."}]}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Use this modifier to perform an asynchronous task with a lifetime that"},{"type":"text","text":" "},{"type":"text","text":"matches that of the modified view. If the task doesn’t finish"},{"type":"text","text":" "},{"type":"text","text":"before OpenSwiftUI removes the view or the view changes identity, OpenSwiftUI"},{"type":"text","text":" "},{"type":"text","text":"cancels the task."}],"type":"paragraph"},{"inlineContent":[{"text":"Use the ","type":"text"},{"code":"await","type":"codeVoice"},{"text":" keyword inside the task to","type":"text"},{"text":" ","type":"text"},{"text":"wait for an asynchronous call to complete, or to wait on the values of","type":"text"},{"text":" ","type":"text"},{"text":"an ","type":"text"},{"isActive":true,"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/asyncsequence","type":"reference"},{"text":" ","type":"text"},{"text":"instance. For example, you can modify a ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","type":"reference"},{"text":" view to start a task","type":"text"},{"text":" ","type":"text"},{"text":"that loads content from a remote resource:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["let url = URL(string: \"https:\/\/example.com\")!","@State private var message = \"Loading...\"","","var body: some View {","    Text(message)","        .task {","            do {","                var receivedLines = [String]()","                for try await line in url.lines {","                    receivedLines.append(line)","                    message = \"Received \\(receivedLines.count) lines\"","                }","            } catch {","                message = \"Failed to load\"","            }","        }","}"]},{"inlineContent":[{"text":"This example uses the","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url\/3767315-lines","isActive":true},{"text":" ","type":"text"},{"text":"method to get the content stored at the specified","type":"text"},{"text":" ","type":"text"},{"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/foundation\/url","isActive":true},{"text":" as an","type":"text"},{"text":" ","type":"text"},{"text":"asynchronous sequence of strings. When each new line arrives, the body","type":"text"},{"text":" ","type":"text"},{"text":"of the ","type":"text"},{"type":"codeVoice","code":"for"},{"text":"-","type":"text"},{"type":"codeVoice","code":"await"},{"text":"-","type":"text"},{"type":"codeVoice","code":"in"},{"text":" loop stores the line in an array of strings","type":"text"},{"text":" ","type":"text"},{"text":"and updates the content of the text view to report the latest line","type":"text"},{"text":" ","type":"text"},{"text":"count.","type":"text"}],"type":"paragraph"}]}],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Link"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Link":{"kind":"symbol","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Link","role":"symbol","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Link","kind":"identifier"}],"url":"\/documentation\/openswiftui\/link","title":"Link","navigatorTitle":[{"text":"Link","kind":"identifier"}],"abstract":[{"type":"text","text":"A control for navigating to a URL."}]},"doc://OpenSwiftUI/docu