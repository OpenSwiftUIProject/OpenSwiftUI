s. The example above","type":"text"},{"text":" ","type":"text"},{"text":"applies the padding before applying the border to ensure that the","type":"text"},{"text":" ","type":"text"},{"text":"border encompasses the padded region:","type":"text"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"text":"You can omit either or both of the parameters. If you omit the ","type":"text"},{"type":"codeVoice","code":"length"},{"text":",","type":"text"},{"text":" ","type":"text"},{"text":"OpenSwiftUI uses a default amount of padding. If you","type":"text"},{"text":" ","type":"text"},{"text":"omit the ","type":"text"},{"type":"codeVoice","code":"edges"},{"text":", OpenSwiftUI applies the padding to all edges. Omit both","type":"text"},{"text":" ","type":"text"},{"text":"to add a default padding all the way around a view. OpenSwiftUI chooses a","type":"text"},{"text":" ","type":"text"},{"text":"default amount of padding that’s appropriate for the platform and","type":"text"},{"text":" ","type":"text"},{"text":"the presentation context.","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["VStack {","    Text(\"Text with default padding.\")","        .padding()","        .border(.gray)","    Text(\"Unpadded text for comparison.\")","        .border(.yellow)","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The example above looks like this in iOS under typical conditions:"}],"type":"paragraph"},{"inlineContent":[],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"To control the amount of padding independently for each edge, use"},{"type":"text","text":" "},{"type":"codeVoice","code":"View\/padding(_:)-6pgqq"},{"type":"text","text":". To pad all outside edges of a view by a"},{"type":"text","text":" "},{"type":"text","text":"specified amount, use "},{"type":"codeVoice","code":"View\/padding(_:)-68shk"},{"type":"text","text":"."}],"type":"paragraph"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{