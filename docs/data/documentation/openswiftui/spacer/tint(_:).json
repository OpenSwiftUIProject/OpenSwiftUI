{"abstract":[{"type":"text","text":"Sets the tint color within this view."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Spacer\/tint(_:)"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/spacer\/tint(_:)"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"kind":"symbol","primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"nonisolated"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"tint"},{"kind":"text","text":"("},{"kind":"externalParam","text":"_"},{"kind":"text","text":" "},{"kind":"internalParam","text":"tint"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Color","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","preciseIdentifier":"s:15OpenSwiftUICore5ColorV"},{"kind":"text","text":"?) -> "},{"kind":"keyword","text":"some"},{"kind":"text","text":" "},{"kind":"typeIdentifier","text":"View","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP"},{"kind":"text","text":"\n"}],"platforms":["macOS"],"languages":["swift"]}]},{"parameters":[{"name":"tint","content":[{"type":"paragraph","inlineContent":[{"text":"The tint ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Color","type":"reference"},{"text":" to apply.","type":"text"}]}]}],"kind":"parameters"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"text":"Use this method to override the default accent color for this view.","type":"text"},{"text":" ","type":"text"},{"text":"Unlike an app’s accent color, which can be overridden by user","type":"text"},{"text":" ","type":"text"},{"text":"preference, the tint color is always respected and should be used as a","type":"text"},{"text":" ","type":"text"},{"text":"way to provide additional meaning to the control.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"This example shows Answer and Decline buttons with ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/green","type":"reference"},{"text":" ","type":"text"},{"text":"and ","type":"text"},{"isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ShapeStyle\/red","type":"reference"},{"text":" tint colors, respectively.","type":"text"}]},{"type":"codeListing","code":["struct ControlTint: View {","    var body: some View {","        HStack {","            Button {","                \/\/ Answer the call","            } label: {","                Label(\"Answer\", systemImage: \"phone\")","            }","            .tint(.green)","            Button {","                \/\/ Decline the call","            } label: {","                Label(\"Decline\", systemImage: \"phone.down\")","            }","            .tint(.red)","        }","        .buttonStyle(.borderedProminent)","        .padding()","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Some controls adapt to the tint color differently based on their style,"},{"type":"text","text":" "},{"type":"text","text":"the current platform, and the surrounding context. For example, in"},{"type":"text","text":" "},{"type":"text","text":"macOS, a button with the "},{"code":"PrimitiveButtonStyle\/bordered","type":"codeVoice"},{"type":"text","text":" style doesn’t"},{"type":"text","text":" "},{"type":"text","text":"tint its background, but one with the"},{"type":"text","text":" "},{"code":"PrimitiveButtonStyle\/borderedProminent","type":"codeVoice"},{"type":"text","text":" style does. In macOS, neither"},{"type":"text","text":" "},{"type":"text","text":"of these button styles tint their label, but they do in other platforms."}]}]}],"sections":[],"hierarchy