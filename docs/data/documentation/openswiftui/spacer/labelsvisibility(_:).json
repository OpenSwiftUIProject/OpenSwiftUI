{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"nonisolated","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"labelsVisibility","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"visibility","kind":"internalParam"},{"text":": ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Visibility","text":"Visibility","preciseIdentifier":"s:15OpenSwiftUICore10VisibilityO","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"some","kind":"keyword"},{"text":" ","kind":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","text":"View","preciseIdentifier":"s:15OpenSwiftUICore4ViewP","kind":"typeIdentifier"},{"text":"\n","kind":"text"}],"platforms":["macOS"],"languages":["swift"]}]},{"content":[{"text":"Discussion","level":2,"type":"heading","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this modifier when you want to omit a label from one or more"},{"type":"text","text":" "},{"type":"text","text":"labeled content in your user interface. For example, the first "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference","isActive":true},{"type":"text","text":" "},{"type":"text","text":"in the following example hides its label:"}]},{"type":"codeListing","code":["VStack {","    Toggle(isOn: $toggle1) {","        Text(\"Toggle 1\")","    }","    .labelsVisibility(.hidden)","","    Toggle(isOn: $toggle2) {","        Text(\"Toggle 2\")","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/VStack"},{"text":" in the example above centers the first toggle’s control","type":"text"},{"text":" ","type":"text"},{"text":"element in the available space, while it centers the second toggle’s","type":"text"},{"text":" ","type":"text"},{"text":"combined label and control element:","type":"text"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Always provide a label for controls, even when you hide the label,"},{"type":"text","text":" "},{"type":"text","text":"because OpenSwiftUI uses labels for other purposes, including accessibility."}]},{"type":"paragraph","inlineContent":[{"text":"On iOS, a ","type":"text"},{"code":"Picker","type":"codeVoice"},{"text":" within a ","type":"text"},{"code":"Menu","type":"codeVoice"},{"text":" hides its label by default. You can use","type":"text"},{"text":" ","type":"text"},{"text":"this modifier to explicitly show the label in that context:","type":"text"}]},{"type":"codeListing","code":["Menu {","    Picker(\"Flavor\", selection: $selectedFlavor) {","        Text(\"Chocolate\").tag(Flavor.chocolate)","        Text(\"Vanilla\").tag(Flavor.vanilla)","        Text(\"Strawberry\").tag(Flavor.strawberry)","    }","    .labelsVisibility(.visible)","}"],"syntax":"swift"},{"type":"aside","style":"note","name":"Note","content":[{"inlineContent":[{"type":"text","text":"This modifier doesn’t work for all labels. It applies to"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/LabeledContent","type":"reference","isActive":true},{"type":"text","text":" elements, including controls like "},{"code":"Picker","type":"codeVoice"},{"type":"text","text":" and"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle","type":"reference","isActive":true},{"type":"text","text":", but not to controls like a bordered button where the label"},{"type":"text","text":" "},{"type":"text","text":"is inside the button’s border."}],"type":"paragraph"}]}],"kind":"content"}],"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Spacer\/labelsVisibility(_:)","