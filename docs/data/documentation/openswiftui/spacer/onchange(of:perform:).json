 value changes."}],"schemaVersion":{"patch":0,"major":0,"minor":3},"deprecationSummary":[{"type":"paragraph","inlineContent":[{"text":"Use `onChange` with a two or zero parameter action closure instead.","type":"text"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/openswiftui\/spacer\/onchange(of:perform:)"]}],"kind":"symbol","references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Binding":{"url":"\/documentation\/openswiftui\/binding","navigatorTitle":[{"text":"Binding","kind":"identifier"}],"role":"symbol","abstract":[{"text":"A property wrapper type that can read and write a value owned by a source of","type":"text"},{"text":" ","type":"text"},{"text":"truth.","type":"text"}],"title":"Binding","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Binding","type":"topic","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Binding","kind":"identifier"}],"kind":"symbol"},"https://developer.apple.com/documentation/swift/equatable":{"identifier":"https:\/\/developer.apple.com\/documentation\/swift\/equatable","title":"Equatable","titleInlineContent":[{"text":"Equatable","type":"text"}],"type":"link","url":"https:\/\/developer.apple.com\/documentation\/swift\/equatable"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/View":{"fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"View","kind":"identifier"}],"kind":"symbol","navigatorTitle":[{"text":"View","kind":"identifier"}],"title":"View","type":"topic","abstract":[{"type":"text","text":"A type that represents part of your app’s user interface and provides"},{"type":"text","text":" "},{"type":"text","text":"modifiers that you use to configure views."}],"url":"\/documentation\/openswiftui\/view","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Spacer/onChange(of:perform:)":{"deprecated":true,"fragments":[{"text":"func","kind":"ke