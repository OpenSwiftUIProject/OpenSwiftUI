ht:maxHeight:alignment:)"},{"text":" ","type":"text"},{"text":"modifier.","type":"text"}]},{"style":"note","content":[{"inlineContent":[{"text":"You can use this modifier to control the alignment of a ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text","isActive":true},{"text":" ","type":"text"},{"text":"view that you create with the ","type":"text"},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Text\/init(_:style:)","isActive":true},{"text":" initializer","type":"text"},{"text":" ","type":"text"},{"text":"to display localized dates and times, including when the view uses","type":"text"},{"text":" ","type":"text"},{"text":"only a single line, but only when that view appears in a widget.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Note"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier also affects the content alignment of other text container"},{"type":"text","text":" "},{"type":"text","text":"types, like "},{"type":"codeVoice","code":"TextEditor"},{"type":"text","text":" and "},{"type":"codeVoice","code":"TextField"},{"type":"text","text":". In those cases, the"},{"type":"text","text":" "},{"type":"text","text":"modifier sets the alignment even when the view contains only a single"},{"type":"text","text":" "},{"type":"text","text":"line because view’s width isn’t dictated by the width of the text it"},{"type":"text","text":" "},{"type":"text","text":"contains."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier operates by setting the"},{"type":"text","text":" "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues\/multilineTextAlignment","isActive":true},{"type":"text","text":" value in the environment,"},{"type":"text","text":" "},{"type":"text","text":"so it affects all the text containers in the modified view hierarchy."},{"type":"text","text":" "},{"type":"t