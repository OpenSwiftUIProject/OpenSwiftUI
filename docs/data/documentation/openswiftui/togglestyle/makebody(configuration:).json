{"abstract":[{"type":"text","text":"Creates a view that represents the body of a toggle."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI","doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle"]]},"identifier":{"url":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/makeBody(configuration:)","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:15OpenSwiftUICore11ViewBuilderV","text":"ViewBuilder","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ViewBuilder"},{"kind":"text","text":" "},{"kind":"attribute","text":"@"},{"kind":"attribute","preciseIdentifier":"s:ScM","text":"MainActor"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"makeBody"},{"kind":"text","text":"("},{"kind":"externalParam","text":"configuration"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:11OpenSwiftUI11ToggleStyleP13Configurationa","text":"Configuration","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/Configuration"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:11OpenSwiftUI11ToggleStyleP4BodyQa","text":"Body","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/Body"}],"languages":["swift"],"platforms":["macOS"]}]},{"kind":"parameters","parameters":[{"name":"configuration","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The properties of the toggle, including a"},{"type":"text","text":" "},{"type":"text","text":"label and a binding to the toggle’s state."}]}]}]},{"kind":"content","content":[{"type":"heading","text":"Return Value","level":2,"anchor":"return-value"},{"type":"paragraph","inlineContent":[{"text":"A view that has behavior and appearance that enables it","type":"text"},{"text":" ","type":"text"},{"text":"to function as a ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle"},{"text":".","type":"text"}]}]},{"kind":"content","content":[{"anchor":"discussion","level":2,"type":"heading","text":"Discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Implement this method when you define a custom toggle style that"},{"type":"text","text":" "},{"type":"text","text":"conforms to the "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle","isActive":true},{"type":"text","text":" protocol. Use the "},{"type":"codeVoice","code":"configuration"},{"type":"text","text":" "},{"type":"text","text":"input — a "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyleConfiguration","isActive":true},{"type":"text","text":" instance — to access the"},{"type":"text","text":" "},{"type":"text","text":"toggle’s label and state. Return a view that has the appearance and"},{"type":"text","text":" "},{"type":"text","text":"behavior of a toggle. For example you can create a toggle that displays"},{"type":"text","text":" "},{"type":"text","text":"a label and a circle that’s either empty or filled with a checkmark:"}]},{"syntax":"swift","code":["struct ChecklistToggleStyle: ToggleStyle {","    func makeBody(configuration: Configuration) -> some View {","        Button {","            configuration.isOn.toggle()","        } label: {","            HStack {","                Image(systemName: configuration.isOn","                        ? \"checkmark.circle.fill\"","                        : \"circle\")","                configuration.label","            }","        }","        .tint(.primary)","        .buttonStyle(.borderless)","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"code":"ChecklistToggleStyle","type":"codeVoice"},{"text":" toggle style provides a way to both observe","type":"text"},{"text":" ","type":"text"},{"text":"and modify the toggle state: the circle fills for the on state, and","type":"text"},{"text":" ","type":"text"},{"text":"users can tap or click the toggle to change the state. By using a","type":"text"},{"text":" ","type":"text"},{"text":"customized ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Button","isActive":true,"type":"reference"},{"text":" to compose the toggle’s body, OpenSwiftUI","type":"text"},{"text":" ","type":"text"},{"text":"automatically provides the behaviors that users expect from a","type":"text"},{"text":" ","type":"text"},{"text":"control that has button-like characteristics.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can present a collection of toggles that use this style in a stack:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When updating a view hierarchy, the system calls your implementation"},{"type":"text","text":" "},{"type":"text","text":"of the "},{"type":"codeVoice","code":"makeBody(configuration:)"},{"type":"text","text":" method for each "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Toggle"},{"type":"text","text":" instance"},{"type":"text","text":" "},{"type":"text","text":"that uses the associated style."}]},{"anchor":"Modify-the-current-style","level":3,"type":"heading","text":"Modify the current style"},{"type":"paragraph","inlineContent":[{"text":"Rather than create an entirely new style, you can alternatively","type":"text"},{"text":" ","type":"text"},{"text":"modify a toggle’s current style. Use the ","type":"text"},{"code":"Toggle\/init(_:)","type":"codeVoice"},{"text":" ","type":"text"},{"text":"initializer inside the ","type":"text"},{"code":"makeBody(configuration:)","type":"codeVoice"},{"text":" method to create","type":"text"},{"text":" ","type":"text"},{"text":"and modify a toggle based on a ","type":"text"},{"code":"configuration","type":"codeVoice"},{"text":" value. For example,","type":"text"},{"text":" ","type":"text"},{"text":"you can create a style that adds padding and a red border to the","type":"text"},{"text":" ","type":"text"},{"text":"current style:","type":"text"}]},{"syntax":"swift","code":["struct RedBorderToggleStyle: ToggleStyle {","    func makeBody(configuration: Configuration) -> some View {","        Toggle(configuration)","            .padding()","            .border(.red)","    }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you create a "},{"type":"codeVoice","code":"redBorder"},{"type":"text","text":" static variable from this style,"},{"type":"text","text":" "},{"type":"text","text":"you can apply the style to toggles that already use another style, like"},{"type":"text","text":" "},{"type":"text","text":"the built-in "},{"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/ToggleStyle\/switch","isActive":true},{"type":"text","text":" and "},{"type":"codeVoice","code":"ToggleStyle\/button"},{"type":"text","text":" styles:"}]},{"syntax":"swift","code":["Toggle(\"Switch\", isOn: $isSwitchOn)","    .toggleStyle(.redBorder)","    .toggleStyle(.switch)","","Toggle(\"Button\", isOn: $isButtonOn)","    .toggleStyle(.redBorder)","    .toggleStyle(.button)"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both toggles appear with the usual styling, each with a red border:"}]},{"type":"paragraph","inlineContent":[]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Apply the custom style closer to the toggle than the"},{"type":"text","text":" "},{"type":"text","text":"modified style because OpenSwiftUI evaluates style view modifiers in order"},{"type":"text","text":" "},{"type":"text","text":"from outermost to innermost. If you apply the styles in the other"},{"type":"text","text":" "},{"type":"text","text":"order, the red border style doesn’t have an effect, because the"},{"type":"text","text":" "},{"type":"text","text":"built-in styles override it completely."}]}]}],"metadata":{"title":"makeBody(configuration:)","roleHeading":"Instance Method","platforms":[{"name":"iOS","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"name":"macOS","introducedAt":"10.15","deprecated":false,"unavailable":false,"beta":false},{"name":"tvOS","introducedAt":"13.0","deprecated":false,"unavailable":false,"beta":false},{"name":"visionOS","introducedAt":"1.0","deprecated":false,"unavailable":false,"beta":false},{"name":"watchOS","introducedAt":"6.0","deprecated":false,"unavailable":false,"beta":false}],"externalID":"s:11OpenSwiftUI11ToggleStyleP8makeBody13configuration0G0QzAA0dE13ConfigurationV_tF","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"makeBody"},{"kind":"text","text":"("},{"kind":"externalParam","text":"configuration"},{"kind":"text","text":": "},{"kind":"typeIdentifier","preciseIdentifier":"s:11OpenSwiftUI11ToggleStyleP13Configurationa","text":"Configuration"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"},{"kind":"text","text":"."},{"kind":"typeIdentifier","preciseIdentifier":"s:11OpenSwiftUI11ToggleStyleP4BodyQa","text":"Body"}],"modules":[{"name":"OpenSwiftUI"}],"role":"symbol","symbolKind":"method","remoteSource":{"url":"https:\/\/github.com\/OpenSwiftUIProject\/OpenSwiftUI\/blob\/main\/Sources\/OpenSwiftUI\/View\/Toggle\/ToggleStyle.swift#L175","fileName":"ToggleStyle.swift"},"required":true},"kind":"symbol","schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/openswiftui\/togglestyle\/makebody(configuration:)"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://OpenSwiftUI/documentation/OpenSwiftUI/Button":{"type":"topic","navigatorTitle