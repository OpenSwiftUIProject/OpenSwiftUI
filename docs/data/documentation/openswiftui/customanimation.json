iftUICore16AnimationContextV","text":"AnimationContext"},{"kind":"text","text":"<"},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":">) -> "},{"kind":"typeIdentifier","text":"V"},{"kind":"text","text":"?"}],"abstract":[{"text":"Calculates the velocity of the animation at a specified time.","type":"text"}]},"doc://OpenSwiftUI/documentation/OpenSwiftUI/AnimationContext/environment":{"role":"symbol","type":"topic","kind":"symbol","fragments":[{"kind":"keyword","text":"var"},{"kind":"text","text":" "},{"kind":"identifier","text":"environment"},{"kind":"text","text":": "},{"preciseIdentifier":"s:15OpenSwiftUICore17EnvironmentValuesV","kind":"typeIdentifier","text":"EnvironmentValues"}],"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/AnimationContext\/environment","title":"environment","abstract":[{"type":"text","text":"The current environment of the view that created the custom animation."}],"url":"\/documentation\/openswiftui\/animationcontext\/environment"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/Animation/init(_:)":{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Animation\/init(_:)","title":"init(_:)","abstract":[{"text":"Create an ","type":"text"},{"type":"codeVoice","code":"Animation"},{"text":" that contains the specified custom animation.","type":"text"}],"type":"topic","fragments":[{"text":"init","kind":"identifier"},{"text":"<","kind":"text"},{"text":"A","kind":"genericParameter"},{"text":">(","kind":"text"},{"text":"A","kind":"typeIdentifier"},{"text":")","kind":"text"}],"url":"\/documentation\/openswiftui\/animation\/init(_:)","kind":"symbol","role":"symbol"},"doc://OpenSwiftUI/documentation/OpenSwiftUI/CustomAnimation/shouldMerge(previous:value:time:context:)":{"defaultImplementations":1,"url":"\/documentation\/openswiftui\/customanimation\/shouldmerge(previous:value:time:context:)","kind":"symbol","required":true,"title":"shouldMerge(previous:value:time:context:)","fragments":[{"text":"func","kind":"keyword"},{"