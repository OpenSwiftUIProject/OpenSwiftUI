{"hierarchy":{"paths":[["doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI"]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"A key for accessing values in the environment.","type":"text"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":" "},{"kind":"identifier","text":"EnvironmentKey"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"You can create custom environment values by extending the"},{"type":"text","text":" "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentValues","type":"reference","isActive":true},{"type":"text","text":" structure with new properties."},{"type":"text","text":" "},{"type":"text","text":"First declare a new environment key type and specify a value for the"},{"type":"text","text":" "},{"type":"text","text":"required "},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentKey\/defaultValue","type":"reference","isActive":true},{"type":"text","text":" property:"}]},{"code":["private struct MyEnvironmentKey: EnvironmentKey {","    static let defaultValue: String = \"Default value\"","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The Swift compiler automatically infers the associated ","type":"text"},{"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/EnvironmentKey\/Value","type":"reference","isActive":true},{"text":" type as the","type":"text"},{"text":" ","type":"text"},{"text":"type you specify for the default value. Then use the key to define a new","type":"text"},{"text":" ","type":"text"},{"text":"environment value property:","type":"text"}]},{"code":["extension EnvironmentValues {","    var myCustomValue: String {","        get { self[MyEnvironmentKey.self] }","        set { self[MyEnvironmentKey.self] = newValue }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Clients of your environment value never use the key directly."},{"type":"text","text":" "},{"type":"text","text":"Instead, they use the key path of your custom environment value property."},{"type":"text","text":" "},{"type":"text","text":"To set the environment value for a view and all its subviews, add the"},{"type":"text","text":" "},{"isActive":true,"type":"reference","identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/View\/environment(_:_:)"},{"type":"text","text":" view modifier to that view:"}]},{"code":["MyView()","    .environment(\\.myCustomValue, \"Another string\")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"As a convenience, you can also define a dedicated view modifier to"},{"type":"text","text":" "},{"type":"text","text":"apply this environment value:"}]},{"code":["extension View {","    func myCustomValue(_ myCustomValue: String) -> some View {","        environment(\\.myCustomValue, myCustomValue)","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This improves clarity at the call site:"}]},{"code":["MyView()","    .myCustomValue(\"Another string\")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To read the value from inside "},{"type":"codeVoice","code":"MyView"},{"type":"text","text":" or one of its descendants, use the"},{"type":"text","text":" "},{"type":"reference","isActive":true,"identifier":"doc:\/\/OpenSwiftUI\/documentation\/OpenSwiftUI\/Environment"},{"type":"text","text":" property wrapper:"}]},{"code":["struct MyView: View {","    @Environment(\\.myCustomValue) var customValue: String","","    var body: some View {","        Text(customValue) \/\/ Displays \"Another string\".","    }","}"],"type":"codeLis