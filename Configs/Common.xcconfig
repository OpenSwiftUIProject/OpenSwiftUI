// Common.xcconfig
// Shared build settings for OpenSwiftUI

// MARK: - Deployment Targets

MACOSX_DEPLOYMENT_TARGET = 15.0
IPHONEOS_DEPLOYMENT_TARGET = 18.0
TVOS_DEPLOYMENT_TARGET = 18.0
WATCHOS_DEPLOYMENT_TARGET = 10.0
XROS_DEPLOYMENT_TARGET = 2.0

// MARK: - Platform

SUPPORTED_PLATFORMS = iphoneos iphonesimulator macosx xros xrsimulator
ALLOW_TARGET_PLATFORM_SPECIALIZATION = YES
TARGETED_DEVICE_FAMILY = 1,2,7
SDKROOT = auto

// MARK: - C/C++ Language

GCC_C_LANGUAGE_STANDARD = gnu17
CLANG_CXX_LANGUAGE_STANDARD = gnu++20
CLANG_ENABLE_MODULES = YES

// MARK: - C/C++ Preprocessor

// These must mirror the Swift conditions in SWIFT_ACTIVE_COMPILATION_CONDITIONS
// that are also used in C/ObjC headers via #if preprocessor guards.
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) OPENSWIFTUI=1 OPENSWIFTUI_RENDERBOX=1 OPENSWIFTUI_CF_CGTYPES=1 OPENRENDERBOX_CF_CGTYPES=1 OPENSWIFTUI_LINK_COREUI=1 OPENSWIFTUI_LINK_SFSYMBOLS=1
GCC_PREPROCESSOR_DEFINITIONS[config=Debug] = $(inherited) OPENSWIFTUI=1 OPENSWIFTUI_RENDERBOX=1 OPENSWIFTUI_CF_CGTYPES=1 OPENRENDERBOX_CF_CGTYPES=1 OPENSWIFTUI_LINK_COREUI=1 OPENSWIFTUI_LINK_SFSYMBOLS=1 DEBUG=1

// MARK: - Swift

SWIFT_VERSION = 5.0
OTHER_SWIFT_FLAGS = $(inherited) -package-name OpenSwiftUI -enable-library-evolution -no-verify-emitted-module-interface -Xfrontend -experimental-spi-only-imports -enable-private-imports -unavailable-decl-optimization=stub -enable-upcoming-feature BareSlashRegexLiterals -enable-upcoming-feature InternalImportsByDefault -enable-upcoming-feature InferSendableFromCaptures -enable-experimental-feature Extern

SWIFT_ACTIVE_COMPILATION_CONDITIONS = $(inherited) OPENSWIFTUI OPENSWIFTUI_CF_CGTYPES OPENRENDERBOX_CF_CGTYPES OPENSWIFTUI_LINK_COREUI OPENSWIFTUI_LINK_SFSYMBOLS _OPENSWIFTUI_SWIFTUI_RENDER OPENSWIFTUI_ENABLE_PRIVATE_IMPORTS OPENSWIFTUI_RELEASE_2024 OPENSWIFTUI_SUPPORT_2021_API OPENSWIFTUI_SUPPORT_2022_API OPENSWIFTUI_SUPPORT_2023_API OPENSWIFTUI_SUPPORT_2024_API
SWIFT_ACTIVE_COMPILATION_CONDITIONS[config=Debug] = $(inherited) DEBUG OPENSWIFTUI OPENSWIFTUI_CF_CGTYPES OPENRENDERBOX_CF_CGTYPES OPENSWIFTUI_LINK_COREUI OPENSWIFTUI_LINK_SFSYMBOLS _OPENSWIFTUI_SWIFTUI_RENDER OPENSWIFTUI_ENABLE_PRIVATE_IMPORTS OPENSWIFTUI_RELEASE_2024 OPENSWIFTUI_SUPPORT_2021_API OPENSWIFTUI_SUPPORT_2022_API OPENSWIFTUI_SUPPORT_2023_API OPENSWIFTUI_SUPPORT_2024_API
